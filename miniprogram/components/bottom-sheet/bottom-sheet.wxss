.sheet-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 900;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(15, 23, 42, 0.46);
  animation: sheetMaskIn 0.18s ease;
}

.sheet-panel {
  width: 100%;
  box-sizing: border-box;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 18rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -18rpx 52rpx rgba(15, 23, 42, 0.18);
  animation: sheetUp 0.24s ease;
  transition: transform 0.16s ease;
}

.sheet-drag-area {
  padding-bottom: 20rpx;
}

.sheet-grabber {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 24rpx;
  border-radius: 999rpx;
  background: #d8dee6;
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: center;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 400;
  color: #111827;
}

.sheet-body {
  max-height: calc(80vh - 120rpx);
  overflow-y: auto;
}

@keyframes sheetMaskIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes sheetUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
