/* ============================================
   空状态组件 - 城市服务清爽可信风格
   ============================================ */

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

/* 卡片模式 */
.empty-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(22, 119, 210, 0.1);
  border: 2rpx solid rgba(22, 119, 210, 0.08);
  margin: 32rpx;
}

/* 图标区域 */
.empty-icon-wrapper {
  margin-bottom: 36rpx;
}

.empty-circle {
  width: 180rpx;
  height: 180rpx;
  background: linear-gradient(135deg, #E6F3FF 0%, #EEF7FD 50%, #C4E5F5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(22, 119, 210, 0.15);
  animation: float 4s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
}

/* 标题 */
.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 16rpx;
  text-align: center;
}

/* 描述 */
.empty-desc {
  font-size: 26rpx;
  color: #7B8794;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

/* 操作按钮 */
.empty-actions {
  display: flex;
  gap: 20rpx;
}

.empty-btn {
  padding: 24rpx 56rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  border: none;
  line-height: 1;
}

.empty-btn::after {
  border: none;
}

.empty-btn.primary {
  background: linear-gradient(135deg, #1677D2 0%, #2B8AD8 100%);
  color: white;
  box-shadow: 0 8rpx 32rpx rgba(22, 119, 210, 0.35);
}

.empty-btn.secondary {
  background: rgba(22, 119, 210, 0.1);
  color: #1677D2;
  border: 2rpx solid rgba(22, 119, 210, 0.2);
}

.btn-hover {
  transform: scale(0.96);
  opacity: 0.9;
}

.empty-btn.primary.btn-hover {
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 210, 0.25);
}
/* ============================================
   城市服务风格视觉覆盖：公共状态组件
   ============================================ */
.loading-container,
.empty-container,
.error-container,
.loading-card,
.empty-card,
.error-card {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.loading-icon,
.empty-icon-wrapper,
.error-icon-wrapper,
.empty-circle,
.error-circle {
  background: #eef7fd;
  box-shadow: none;
  animation: none;
}

.loading-dot,
.empty-btn.primary,
.error-btn.primary {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.empty-btn.secondary,
.error-btn.secondary {
  background: #ffffff;
  color: var(--sky-deep);
  border: 1rpx solid var(--border-color);
  box-shadow: none;
}