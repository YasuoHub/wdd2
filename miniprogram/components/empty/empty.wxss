/* ============================================
   空状态组件 - 天蓝色青春活力风格
   ============================================ */

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

/* 卡片模式 */
.empty-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
  margin: 32rpx;
}

/* 图标区域 */
.empty-icon-wrapper {
  margin-bottom: 36rpx;
}

.empty-circle {
  width: 180rpx;
  height: 180rpx;
  background: linear-gradient(135deg, #E6F3FF 0%, #D4EDF7 50%, #C4E5F5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(93, 184, 230, 0.15);
  animation: float 4s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.empty-emoji {
  font-size: 88rpx;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
}

/* 标题 */
.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 16rpx;
  text-align: center;
}

/* 描述 */
.empty-desc {
  font-size: 26rpx;
  color: #6B8BA4;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

/* 操作按钮 */
.empty-actions {
  display: flex;
  gap: 20rpx;
}

.empty-btn {
  padding: 24rpx 56rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  border: none;
  line-height: 1;
}

.empty-btn::after {
  border: none;
}

.empty-btn.primary {
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  color: white;
  box-shadow: 0 8rpx 32rpx rgba(93, 184, 230, 0.35);
}

.empty-btn.secondary {
  background: rgba(93, 184, 230, 0.1);
  color: #5DB8E6;
  border: 2rpx solid rgba(93, 184, 230, 0.2);
}

.btn-hover {
  transform: scale(0.96);
  opacity: 0.9;
}

.empty-btn.primary.btn-hover {
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.25);
}
