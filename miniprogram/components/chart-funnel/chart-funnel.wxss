.funnel {
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.funnel-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: width 0.5s ease;
}
.funnel-block {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 28rpx;
  background: linear-gradient(90deg, #5DB8E6, #3a8fd4);
  border-radius: 10rpx;
  box-sizing: border-box;
}
.funnel-label {
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
}
.funnel-value {
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}
.funnel-rate {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #999;
}
.funnel-rate text {
  color: #666;
}
.empty-tip {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}
