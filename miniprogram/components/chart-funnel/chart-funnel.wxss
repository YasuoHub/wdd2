.funnel {
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.funnel-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: width 0.5s ease;
}
.funnel-block {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 28rpx;
  background: linear-gradient(90deg, var(--brand-primary), #3a8fd4);
  border-radius: 10rpx;
  box-sizing: border-box;
}
.funnel-label {
  color: #fff;
  font-size: 26rpx;
  font-weight: 400;
}
.funnel-value {
  color: #fff;
  font-size: 30rpx;
  font-weight: 400;
}
.funnel-rate {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #999;
}
.funnel-rate text {
  color: #666;
}
.empty-tip {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}
/* ============================================
   城市服务风格视觉覆盖：公共状态组件
   ============================================ */
.loading-container,
.empty-container,
.error-container,
.loading-card,
.empty-card,
.error-card {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.loading-icon,
.empty-icon-wrapper,
.error-icon-wrapper,
.empty-circle,
.error-circle {
  background: #eef7fd;
  box-shadow: none;
  animation: none;
}

.loading-dot,
.empty-btn.primary,
.error-btn.primary {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.empty-btn.secondary,
.error-btn.secondary {
  background: #ffffff;
  color: var(--sky-deep);
  border: 1rpx solid var(--border-color);
  box-shadow: none;
}