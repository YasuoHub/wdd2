/* ============================================
   加载状态组件 - 天蓝色青春活力风格
   ============================================ */

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-full {
  min-height: 400rpx;
  padding: 80rpx 40rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  margin: 32rpx;
}

/* 转圈加载 */
.loading-spinner {
  border: 4rpx solid rgba(93, 184, 230, 0.2);
  border-top-color: #5DB8E6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 点状加载 */
.loading-dots {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
.dot:nth-child(3) { animation-delay: 0s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* 加载文字 */
.loading-text {
  color: #6B8BA4;
  margin-top: 24rpx;
  font-weight: 500;
}

/* 骨架屏 */
.skeleton-wrapper {
  width: 100%;
  padding: 20rpx 0;
}

.skeleton-row {
  padding: 16rpx 0;
}

.skeleton-item {
  height: 40rpx;
  background: linear-gradient(90deg, #E8F4F8 25%, #D4EDF7 50%, #E8F4F8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 12rpx;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
