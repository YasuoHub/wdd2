.chart-line-wrap {
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
}

.chart-canvas {
  width: 100%;
  height: 100%;
}
.chart-tooltip {
  position: absolute;
  background: rgba(0, 0, 0, 0.8);
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  z-index: 20;
  pointer-events: none;
}
.tooltip-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #fff;
  line-height: 1.6;
}
.tooltip-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
/* ============================================
   城市服务风格视觉覆盖：公共状态组件
   ============================================ */
.loading-container,
.empty-container,
.error-container,
.loading-card,
.empty-card,
.error-card {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.loading-icon,
.empty-icon-wrapper,
.error-icon-wrapper,
.empty-circle,
.error-circle {
  background: #eef7fd;
  box-shadow: none;
  animation: none;
}

.loading-dot,
.empty-btn.primary,
.error-btn.primary {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.empty-btn.secondary,
.error-btn.secondary {
  background: #ffffff;
  color: var(--sky-deep);
  border: 1rpx solid var(--border-color);
  box-shadow: none;
}