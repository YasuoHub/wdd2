@font-face {
  font-family: 'WddLucide';
  src: url('data:font/woff;base64,') format('woff');
  font-style: normal;
  font-weight: normal;
}

.wdd-icon-frame {
  display: inline-flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  line-height: 0;
}

.wdd-icon-font {
  display: block;
  font-family: 'WddLucide';
  font-style: normal;
  font-weight: normal;
  line-height: 1;
  text-rendering: auto;
  transform: translateY(0.08em);
}
/* ============================================
   城市服务风格视觉覆盖：公共状态组件
   ============================================ */
.loading-container,
.empty-container,
.error-container,
.loading-card,
.empty-card,
.error-card {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.loading-icon,
.empty-icon-wrapper,
.error-icon-wrapper,
.empty-circle,
.error-circle {
  background: #eef7fd;
  box-shadow: none;
  animation: none;
}

.loading-dot,
.empty-btn.primary,
.error-btn.primary {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.empty-btn.secondary,
.error-btn.secondary {
  background: #ffffff;
  color: var(--sky-deep);
  border: 1rpx solid var(--border-color);
  box-shadow: none;
}