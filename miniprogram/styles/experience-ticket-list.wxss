.admin-ticket-page {
  padding: 0 0 32rpx;
  background: var(--bg-secondary);
}

.admin-ticket-page .tab-bar {
  display: flex;
  position: relative;
  height: 76rpx;
  margin: 18rpx 24rpx 6rpx;
  padding: 6rpx;
  border: 1rpx solid var(--border-light);
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: var(--shadow-card-ios);
  box-sizing: border-box;
}

.admin-ticket-page .tab-item {
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
  line-height: 1;
}

.admin-ticket-page .tab-item.active {
  color: var(--sky-deep);
  background: var(--brand-primary-08);
}

.admin-ticket-page .ticket-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 22rpx 24rpx 32rpx;
}

.admin-ticket-page .ticket-card {
  display: flex;
  overflow: hidden;
  border: 1rpx solid rgba(217, 226, 236, 0.92);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.055);
}

.admin-ticket-page .ticket-card:active {
  background: #fafafa;
}

.admin-ticket-page .ticket-card.resolved {
  background: #fbfcfd;
}

.admin-ticket-page .card-left {
  flex-shrink: 0;
  width: 6rpx;
  opacity: 0.82;
}

.admin-ticket-page .left-report,
.admin-ticket-page .left-down {
  background: #d64545;
}

.admin-ticket-page .left-published {
  background: var(--brand-primary);
}

.admin-ticket-page .card-body {
  flex: 1;
  min-width: 0;
  padding: 26rpx 26rpx 22rpx;
}

.admin-ticket-page .card-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.admin-ticket-page .card-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #111827;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.admin-ticket-page .status-tag {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  line-height: 1.5;
}

.admin-ticket-page .status-pending {
  color: #e67e22;
  background: rgba(230, 126, 34, 0.08);
}

.admin-ticket-page .status-published {
  color: var(--sky-deep);
  background: var(--brand-primary-08);
}

.admin-ticket-page .status-resolved,
.admin-ticket-page .status-down {
  color: var(--text-tertiary);
  background: rgba(0, 0, 0, 0.04);
}

.admin-ticket-page .card-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.admin-ticket-page .info-label {
  flex-shrink: 0;
  width: 150rpx;
  color: var(--text-tertiary);
}

.admin-ticket-page .info-value {
  min-width: 0;
  overflow: hidden;
  color: var(--text-primary);
  text-overflow: ellipsis;
  white-space: nowrap;
}

.admin-ticket-page .card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 12rpx;
}

.admin-ticket-page .footer-time {
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
  color: var(--text-light);
  font-size: 24rpx;
}

.admin-ticket-page .footer-time text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.admin-ticket-page .supplement-tag,
.admin-ticket-page .ticket-action {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border: 1rpx solid var(--brand-primary-16);
  border-radius: 20rpx;
  color: var(--sky-deep);
  background: var(--brand-primary-08);
  font-size: 22rpx;
  line-height: 1.5;
}

.admin-ticket-page .ticket-action.danger {
  color: #d64545;
  border-color: #efb4b4;
  background: rgba(214, 69, 69, 0.08);
}
