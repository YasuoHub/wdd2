@import "./wdd-polish.wxss";

page {
  min-height: 100%;
  background: #f5f7fa;
}

.experience-page {
  min-height: 100vh;
  padding: 24rpx 28rpx 150rpx;
  box-sizing: border-box;
}

.experience-card,
.form-section,
.detail-section {
  margin-bottom: 22rpx;
  padding: 28rpx;
  border: 1rpx solid #e1e8f0;
  border-radius: 12rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.experience-card:active {
  opacity: 0.88;
}

.experience-title {
  display: block;
  color: #111827;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 600;
}

.experience-location,
.experience-meta,
.muted-text {
  margin-top: 14rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.5;
}

.experience-result {
  display: -webkit-box;
  margin-top: 18rpx;
  overflow: hidden;
  color: #344054;
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.search-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 22rpx;
  border: 1rpx solid #d8e1eb;
  border-radius: 10rpx;
  background: #ffffff;
  font-size: 28rpx;
  box-sizing: border-box;
}

.small-button,
.primary-button,
.secondary-button,
.danger-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  margin: 0;
  padding: 0 26rpx;
  border-radius: 10rpx;
  font-size: 29rpx;
  line-height: 76rpx;
  box-sizing: border-box;
}

.small-button::after,
.primary-button::after,
.secondary-button::after,
.danger-button::after {
  border: 0;
}

.small-button,
.primary-button {
  color: #ffffff;
  background: var(--brand-primary);
}

.secondary-button {
  color: var(--brand-primary);
  border: 1rpx solid var(--brand-primary);
  background: #ffffff;
}

.danger-button {
  color: #d64545;
  border: 1rpx solid #efb4b4;
  background: #ffffff;
}

.field-label,
.section-title {
  display: block;
  margin-bottom: 14rpx;
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 600;
}

.field-input,
.field-textarea {
  width: 100%;
  padding: 18rpx 20rpx;
  border: 1rpx solid #d8e1eb;
  border-radius: 8rpx;
  background: #ffffff;
  color: #111827;
  font-size: 28rpx;
  box-sizing: border-box;
}

.field-input {
  height: 76rpx;
}

.field-textarea {
  min-height: 150rpx;
  line-height: 1.55;
}

.field-group {
  margin-bottom: 28rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.selectable-image {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  border: 4rpx solid transparent;
  border-radius: 10rpx;
  background: #eef2f6;
  box-sizing: border-box;
}

.selectable-image.selected {
  border-color: var(--brand-primary);
}

.selectable-image image,
.detail-image {
  width: 100%;
  height: 100%;
}

.select-mark {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  color: #ffffff;
  background: var(--brand-primary);
  font-size: 24rpx;
}

.fixed-actions {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 18rpx;
  padding: 18rpx 28rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e1e8f0;
  background: rgba(255, 255, 255, 0.98);
  box-sizing: border-box;
}

.fixed-actions button {
  flex: 1;
}

.status-note {
  margin-bottom: 22rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid #d8e9fb;
  border-radius: 10rpx;
  color: #135fa7;
  background: #f3f8ff;
  font-size: 25rpx;
  line-height: 1.5;
}

.detail-value {
  display: block;
  color: #344054;
  font-size: 29rpx;
  line-height: 1.72;
  white-space: pre-wrap;
}

.detail-image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.detail-image-wrap {
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 10rpx;
  background: #eef2f6;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 22rpx;
}

.inline-action {
  padding: 12rpx 18rpx;
  color: var(--brand-primary);
  font-size: 26rpx;
}

.inline-action.danger {
  color: #d64545;
}

.empty-state {
  padding: 120rpx 30rpx;
  color: #8a96a3;
  font-size: 28rpx;
  text-align: center;
}
.report-mask {
  position: fixed;
  z-index: 50;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
}

.report-dialog {
  position: fixed;
  z-index: 51;
  left: 42rpx;
  right: 42rpx;
  top: 50%;
  max-height: 82vh;
  padding: 30rpx;
  overflow-y: auto;
  border-radius: 12rpx;
  background: #ffffff;
  transform: translateY(-50%);
  box-sizing: border-box;
}

.report-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.report-actions button {
  flex: 1;
}

.preview-block {
  margin-top: 22rpx;
}

.experience-error {
  display: flex;
  align-items: center;
  flex-direction: column;
  margin-top: 84rpx;
  padding: 48rpx 34rpx;
  border: 1rpx solid #e1e8f0;
  border-radius: 12rpx;
  background: #ffffff;
  text-align: center;
  box-sizing: border-box;
}

.experience-error-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: var(--brand-primary-08);
}

.experience-error-title {
  margin-top: 22rpx;
  color: #111827;
  font-size: 31rpx;
  line-height: 1.35;
  font-weight: 600;
}

.experience-error-desc {
  margin-top: 12rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.55;
}

.experience-retry {
  margin-top: 28rpx;
}
