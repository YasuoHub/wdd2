/* ============================================
   问当地共享视觉层：iOS 式信息卡片 / 低饱和标签 / 稳重交易信息
   只负责视觉统一，不承载业务逻辑。
   ============================================ */

.container,
.chat-container {
  background: #f5f7fa;
}

.header,
.footer,
.input-area,
.popup-content,
.modal-content,
.rules-modal-content {
  background: #ffffff;
  border-color: var(--border-light);
  box-shadow: var(--shadow-card);
}

.section-card,
.task-card,
.need-card,
.user-card,
.menu-list,
.quick-panel,
.need-feed,
.login-tip-card,
.balance-section,
.record-card,
.ticket-card,
.report-card,
.appeal-card,
.profile-card,
.rating-card,
.info-card,
.form-card,
.stat-card,
.section,
.target-card,
.rating-section,
.tags-section,
.comment-section,
.card {
  background: var(--surface-ios, #ffffff);
  border: 1rpx solid rgba(217, 226, 236, 0.9);
  border-radius: 24rpx;
  box-shadow: var(--shadow-card-ios, 0 10rpx 30rpx rgba(15, 23, 42, 0.06));
}

.task-card:active,
.need-card:active,
.ticket-card:active,
.card:active,
.section:active {
  transform: scale(0.992);
  box-shadow: var(--shadow-press-ios, 0 6rpx 18rpx rgba(15, 23, 42, 0.05));
}

.task-card::before,
.need-card::before,
.status-card::before {
  display: none;
}

.type-strip,
.card-left,
.card-accent,
.message-card.unread::before,
.system-card.unread::before {
  display: none;
}

.card-footer {
  border-bottom: none !important;
}

.location-bar,
.filter-item,
.sort-section,
.distance-section,
.type-badge,
.type-tag,
.card-location,
.location-info,
.distance-tag,
.quick-tag,
.type-item,
.time-option,
.quick-point,
.quick-amount,
.payment-option,
.amount-detail,
.rules-tip,
.points-tip-wrapper,
.input-wrapper,
.toolbar-toggle-btn,
.more-btn,
.system-message-text,
.time-divider text,
.task-type,
.comment-box,
.user-tag {
  background: var(--surface-subtle, #f8fafc);
  border: 1rpx solid var(--border-light);
  box-shadow: none;
}

.filter-item.active,
.tab.active,
.type-item.active,
.quick-tag.active,
.time-option.active,
.payment-option.active {
  background: var(--surface-tag-blue, rgba(22, 119, 210, 0.08));
  border-color: rgba(22, 119, 210, 0.34);
  color: var(--sky-deep);
  box-shadow: none;
}

.filter-item.active .filter-name,
.quick-tag.active,
.time-option.active,
.payment-option.active .payment-name {
  color: var(--sky-deep);
  font-weight: 400;
}

.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon,
.action-btn.primary,
.submit-btn.active {
  background: var(--sky-primary);
  color: #ffffff;
  box-shadow: var(--shadow-sky);
}

.action-btn.success {
  background: var(--fresh-mint);
  color: #ffffff;
  box-shadow: var(--shadow-green);
}

.action-btn.danger,
.btn-vitality {
  background: #ffffff;
  color: var(--danger-color);
  border: 1rpx solid rgba(214, 69, 69, 0.22);
  box-shadow: none;
}

.amount-badge,
.points-tag,
.task-points-mini,
.quick-amount.active,
.quick-point.active,
.time-recommend {
  background: var(--surface-tag-orange, rgba(217, 106, 34, 0.1));
  border: 1rpx solid rgba(217, 106, 34, 0.2);
  color: var(--vitality-orange);
  box-shadow: none;
  font-variant-numeric: tabular-nums;
}

.amount-badge .amount-value,
.amount-value,
.amount-symbol,
.points-tag,
.need-amount,
.task-points,
.info-value.reward {
  color: var(--vitality-orange);
  -webkit-text-fill-color: currentColor;
  background: none;
  font-variant-numeric: tabular-nums;
}

.amount-badge wdd-icon {
  opacity: 0.78;
}

.status-badge,
.status-tag,
.task-status-pill,
.supplement-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid transparent;
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1.25;
  white-space: nowrap;
  box-shadow: none;
}

.status-badge.pending,
.status-tag.status-pending,
.task-status-pill.status-pending {
  background: var(--surface-tag-yellow, rgba(233, 185, 73, 0.16));
  border-color: rgba(148, 107, 0, 0.16);
  color: #946b00;
}

.status-badge.ongoing,
.task-status-pill.status-ongoing {
  background: var(--surface-tag-blue, rgba(22, 119, 210, 0.08));
  border-color: rgba(22, 119, 210, 0.18);
  color: var(--sky-deep);
}

.status-badge.completed,
.status-tip.success,
.task-status-pill.status-completed {
  background: var(--surface-tag-green, rgba(31, 143, 122, 0.1));
  border-color: rgba(31, 143, 122, 0.18);
  color: var(--fresh-mint);
}

.status-badge.breaking,
.status-tip.warning,
.task-status-pill.status-breaking {
  background: #fff8e6;
  border-color: rgba(233, 185, 73, 0.26);
  color: #946b00;
}

.status-badge.cancelled,
.status-badge.resolved,
.status-tag.status-resolved,
.task-status-pill.status-cancelled,
.task-status-pill.status-expired {
  background: #eef2f6;
  border-color: #d9e2ec;
  color: var(--text-secondary);
}

.status-card .status-icon,
.state-icon,
.type-icon,
.quick-type-icon,
.need-type-icon,
.hero-login-icon {
  border-radius: 20rpx;
  background: rgba(22, 119, 210, 0.08);
  border: 1rpx solid rgba(22, 119, 210, 0.1);
  box-shadow: none;
}

.message-status .status-icon {
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.12);
}

.helper-profile-tip,
.balance-insufficient,
.task-ended-bar.breaking-bar,
.waiting-tip,
.tips-section {
  background: #fff8e6;
  border-color: rgba(233, 185, 73, 0.3);
}

.balance-value.points,
.balance-value.available,
.points-number,
.publish-points,
.publish-amount {
  color: var(--text-primary);
  background: none;
  -webkit-text-fill-color: currentColor;
}

.wdd-amount,
.need-amount,
.amount-current,
.amount-symbol,
.detail-value.fee,
.warning-text,
.balance-value.insufficient,
.task-points-mini {
  color: var(--vitality-orange);
}

.detail-value.income,
.tag-mint,
.status-success,
.success-text {
  color: var(--fresh-mint);
}

.message-item.other .message-bubble.text {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-sm);
}

.message-item.self .message-bubble.text {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.popup-overlay,
.modal-mask,
.rules-modal {
  background: rgba(15, 23, 42, 0.46);
}

image,
button,
view {
  letter-spacing: 0;
}

.publish-btn.disabled,
.send-btn[disabled],
.disabled {
  color: var(--text-muted);
}
