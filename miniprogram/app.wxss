/* ============================================
   问当地小程序 - 全局样式
   风格：微信城市服务 / 清爽可信 / 地点感强 / 交易清楚
   ============================================ */

/* 页面基础样式 - 白底浅灰的城市服务工具风格 */
page {
  font-family:
    -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
    "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  color: #1f2933;
  background: #f5f7fa;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
  width: 100%;

  /* CSS 变量 - 微信城市服务感设计令牌 */
  /* 主色调 - 克制蓝绿 */
  --sky-primary: #1677d2;
  --sky-light: #2b8ad8;
  --sky-soft: #d9ecfb;
  --sky-pale: #eef7fd;
  --sky-dark: #0f66bd;
  --sky-deep: #135fa7;

  /* 品牌色令牌 - 后续换品牌系列优先改这里 */
  --brand-primary: var(--sky-primary);
  --brand-primary-light: var(--sky-light);
  --brand-primary-soft: var(--sky-soft);
  --brand-primary-pale: var(--sky-pale);
  --brand-primary-dark: var(--sky-dark);
  --brand-primary-deep: var(--sky-deep);
  --brand-primary-05: rgba(22, 119, 210, 0.05);
  --brand-primary-08: rgba(22, 119, 210, 0.08);
  --brand-primary-10: rgba(22, 119, 210, 0.1);
  --brand-primary-12: rgba(22, 119, 210, 0.12);
  --brand-primary-16: rgba(22, 119, 210, 0.16);
  --brand-primary-18: rgba(22, 119, 210, 0.18);
  --brand-primary-20: rgba(22, 119, 210, 0.2);
  --brand-primary-30: rgba(22, 119, 210, 0.3);
  --brand-primary-34: rgba(22, 119, 210, 0.34);
  --brand-primary-35: rgba(22, 119, 210, 0.35);
  --brand-primary-50: rgba(22, 119, 210, 0.5);

  /* 辅助色 - 只用于明确状态和交易信息 */
  --vitality-orange: #d96a22;
  --vitality-coral: #e9823a;
  --vitality-yellow: #e9b949;
  --money-gold: #c9941e;
  --fresh-mint: #1f8f7a;
  --fresh-green: #34a98f;
  --lavender: #8b96a8;
  --pink-soft: #d65f76;
  --vitality-orange-05: rgba(217, 106, 34, 0.05);
  --vitality-orange-08: rgba(217, 106, 34, 0.08);
  --vitality-orange-10: rgba(217, 106, 34, 0.1);
  --vitality-orange-12: rgba(217, 106, 34, 0.12);
  --vitality-orange-14: rgba(217, 106, 34, 0.14);
  --vitality-orange-15: rgba(217, 106, 34, 0.15);
  --vitality-orange-18: rgba(217, 106, 34, 0.18);
  --vitality-orange-20: rgba(217, 106, 34, 0.2);
  --vitality-orange-24: rgba(217, 106, 34, 0.24);
  --vitality-orange-30: rgba(217, 106, 34, 0.3);
  --vitality-orange-35: rgba(217, 106, 34, 0.35);
  --vitality-orange-50: rgba(217, 106, 34, 0.5);
  --fresh-mint-08: rgba(31, 143, 122, 0.08);
  --fresh-mint-10: rgba(31, 143, 122, 0.1);
  --fresh-mint-12: rgba(31, 143, 122, 0.12);
  --fresh-mint-14: rgba(31, 143, 122, 0.14);
  --fresh-mint-15: rgba(31, 143, 122, 0.15);
  --fresh-mint-18: rgba(31, 143, 122, 0.18);
  --fresh-mint-20: rgba(31, 143, 122, 0.2);
  --fresh-mint-30: rgba(31, 143, 122, 0.3);
  --vitality-yellow-14: rgba(233, 185, 73, 0.14);
  --vitality-yellow-16: rgba(233, 185, 73, 0.16);
  --vitality-yellow-26: rgba(233, 185, 73, 0.26);
  --vitality-yellow-28: rgba(233, 185, 73, 0.28);
  --vitality-yellow-30: rgba(233, 185, 73, 0.3);

  /* 任务类型色令牌 */
  --type-weather-color: var(--brand-primary);
  --type-weather-light: var(--brand-primary-light);
  --type-weather-bg: var(--brand-primary-12);
  --type-shop-color: var(--brand-primary);
  --type-shop-light: var(--brand-primary-soft);
  --type-shop-bg: var(--brand-primary-10);
  --type-traffic-color: var(--brand-primary);
  --type-traffic-light: var(--brand-primary-light);
  --type-traffic-bg: var(--brand-primary-10);
  --type-parking-color: var(--brand-primary);
  --type-parking-light: var(--brand-primary-light);
  --type-parking-bg: var(--brand-primary-10);
  --type-queue-color: var(--brand-primary);
  --type-queue-light: var(--brand-primary-light);
  --type-queue-bg: var(--brand-primary-10);
  --type-other-color: var(--brand-primary);
  --type-other-light: var(--brand-primary-light);
  --type-other-bg: var(--brand-primary-08);

  /* 背景色 */
  --bg-primary: #f5f7fa;
  --bg-secondary: #eef2f6;
  --bg-tertiary: #fafbfc;
  --bg-card: #ffffff;
  --bg-glass: #ffffff;

  /* 文字色 - 确保对比度 */
  --text-primary: #1f2933;
  --text-secondary: #52616f;
  --text-tertiary: #7b8794;
  --text-light: #9aa5b1;
  --text-muted: #b8c2cc;
  --text-white: #ffffff;

  /* 边框色 */
  --border-color: #d9e2ec;
  --border-light: #e6edf3;

  /* 功能色 */
  --danger-color: #d64545;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(15, 23, 42, 0.04);
  --shadow-md: 0 6rpx 18rpx rgba(15, 23, 42, 0.06);
  --shadow-lg: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
  --shadow-sky: 0 4rpx 14rpx var(--brand-primary-18);
  --shadow-orange: 0 4rpx 14rpx var(--vitality-orange-18);
  --shadow-green: 0 4rpx 14rpx var(--fresh-mint-18);
  --shadow-card: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
  --shadow-float: 0 12rpx 34rpx rgba(15, 23, 42, 0.12);
  --shadow-card-ios: 0 10rpx 30rpx rgba(15, 23, 42, 0.06), 0 1rpx 0 rgba(255, 255, 255, 0.82) inset;
  --shadow-press-ios: 0 6rpx 18rpx rgba(15, 23, 42, 0.05);
  --surface-ios: rgba(255, 255, 255, 0.96);
  --surface-subtle: #f8fafc;
  --surface-tag-blue: var(--brand-primary-08);
  --surface-tag-orange: var(--vitality-orange-10);
  --surface-tag-green: var(--fresh-mint-10);
  --surface-tag-yellow: var(--vitality-yellow-16);

  /* 圆角 - 克制、真实小程序质感 */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-xxl: 40rpx;
  --radius-full: 9999rpx;

  /* 间距 - 自适应 */
  --space-xs: 12rpx;
  --space-sm: 20rpx;
  --space-md: 32rpx;
  --space-lg: 40rpx;
  --space-xl: 56rpx;
  --space-xxl: 80rpx;
}

/* ============================================
   全站视觉基准：专业信息流 + 克制地点感
   ============================================ */
.wdd-page {
  min-height: 100vh;
  position: relative;
  background:
    linear-gradient(180deg, #f5f7fa 0%, #fafbfc 46%, #f3f6f9 100%);
  box-sizing: border-box;
}

.wdd-page-bg {
  position: absolute;
  z-index: 0;
  top: 0;
  left: 0;
  right: 0;
  height: 760rpx;
  pointer-events: none;
  overflow: hidden;
}

.wdd-page-bg::before {
  content: "";
  position: absolute;
  top: -86rpx;
  right: -172rpx;
  width: 620rpx;
  height: 520rpx;
  opacity: 0.72;
  background:
    radial-gradient(circle at 68% 36%, var(--brand-primary-12) 0, var(--brand-primary-12) 116rpx, transparent 118rpx),
    radial-gradient(circle at 30% 72%, var(--fresh-mint-08) 0, var(--fresh-mint-08) 96rpx, transparent 98rpx),
    linear-gradient(90deg, transparent 0, transparent 31%, rgba(82, 97, 111, 0.12) 31%, rgba(82, 97, 111, 0.12) 31.6%, transparent 31.6%, transparent 100%),
    linear-gradient(0deg, transparent 0, transparent 42%, rgba(82, 97, 111, 0.1) 42%, rgba(82, 97, 111, 0.1) 42.6%, transparent 42.6%, transparent 100%),
    linear-gradient(135deg, transparent 0, transparent 54%, var(--brand-primary-16) 54%, var(--brand-primary-16) 55%, transparent 55%, transparent 100%),
    linear-gradient(24deg, transparent 0, transparent 62%, var(--fresh-mint-10) 62%, var(--fresh-mint-10) 63%, transparent 63%, transparent 100%);
}

.wdd-page-bg::after {
  content: "";
  position: absolute;
  left: -120rpx;
  top: 254rpx;
  width: 520rpx;
  height: 360rpx;
  opacity: 0.56;
  background:
    radial-gradient(circle at 26% 46%, var(--fresh-mint-08) 0, var(--fresh-mint-08) 118rpx, transparent 120rpx),
    radial-gradient(circle at 74% 56%, var(--vitality-orange-05) 0, var(--vitality-orange-05) 76rpx, transparent 78rpx),
    linear-gradient(112deg, transparent 0, transparent 48%, var(--brand-primary-10) 48%, var(--brand-primary-10) 49%, transparent 49%, transparent 100%),
    linear-gradient(8deg, transparent 0, transparent 56%, rgba(82, 97, 111, 0.08) 56%, rgba(82, 97, 111, 0.08) 56.7%, transparent 56.7%, transparent 100%);
}

.wdd-page > view:not(.wdd-page-bg):not(.action-bar):not(.footer):not(.back-to-top):not(.menu-mask):not(.modal-mask):not(.popup-mask):not(.overlay-mask),
.wdd-page > scroll-view,
.wdd-page > swiper,
.wdd-page > form,
.wdd-page > button {
  position: relative;
  z-index: 1;
}

.wdd-map-surface {
  position: relative;
  overflow: hidden;
}

.wdd-map-surface::before {
  content: "";
  position: absolute;
  inset: 0;
  opacity: 0.14;
  pointer-events: none;
  background:
    linear-gradient(135deg, transparent 0 45%, var(--brand-primary-16) 45% 46%, transparent 46% 100%),
    linear-gradient(28deg, transparent 0 58%, var(--fresh-mint-10) 58% 59%, transparent 59% 100%);
}

.wdd-card {
  background: var(--surface-ios);
  border: 1rpx solid rgba(217, 226, 236, 0.88);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card-ios);
  box-sizing: border-box;
}

.wdd-section-title {
  color: var(--text-primary);
  font-size: 34rpx;
  font-weight: 400;
  letter-spacing: 0;
}

.wdd-section-subtitle {
  color: var(--text-tertiary);
  font-size: 24rpx;
}

.wdd-icon {
  width: 32rpx;
  height: 32rpx;
  display: inline-block;
  flex-shrink: 0;
}

.wdd-icon-sm {
  width: 28rpx;
  height: 28rpx;
}

.wdd-icon-lg {
  width: 44rpx;
  height: 44rpx;
}

.wdd-icon-xl {
  width: 64rpx;
  height: 64rpx;
}

.wdd-icon-chip {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: var(--surface-tag-blue);
  border: 1rpx solid var(--brand-primary-10);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.wdd-icon-chip image {
  width: 34rpx;
  height: 34rpx;
}

.wdd-btn-primary {
  background: var(--brand-primary);
  color: #fff;
  box-shadow: var(--shadow-sky);
  border-radius: var(--radius-full);
}

.wdd-btn-secondary {
  background: #ffffff;
  color: var(--sky-deep);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-full);
}

.wdd-amount {
  color: var(--vitality-orange);
  font-weight: 400;
  letter-spacing: 0;
  font-variant-numeric: tabular-nums;
}

.money-prefix,
.money-text {
  display: inline-block;
  color: var(--money-gold) !important;
  font: inherit;
  font-size: 1.12em;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  -webkit-text-fill-color: var(--money-gold) !important;
}

.money-prefix {
  margin-right: 2rpx;
}

.money-text {
  margin-left: 7rpx;
}

.balance-amount .amount-number,
.amount-input-wrapper .amount-input {
  color: var(--money-gold) !important;
  -webkit-text-fill-color: var(--money-gold) !important;
}

.menu-desc-money,
.payment-balance-money,
.balance-insufficient-text,
.record-balance-money,
.apply-balance-money,
.approval-copy,
.rule-desc-money,
.rule-text-money,
.approve-label-money,
.task-reward-inline {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
}

.wdd-divider {
  height: 1rpx;
  background: var(--border-light);
}

/* 重置默认样式 */
view,
text,
image,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: none;
  border: none;
  font-size: inherit;
  line-height: inherit;
  color: inherit;
}

button::after {
  border: none;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* ============================================
   动画效果
   ============================================ */

/* 淡入上移动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 弹跳动画 */
@keyframes bounce {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

/* 脉冲动画 */
@keyframes pulse {
  0%,
  100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

/* 闪烁动画 */
@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}

/* 旋转动画 */
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* 浮动动画 */
@keyframes float {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}

/* 呼吸光晕 */
@keyframes breathe {
  0%,
  100% {
    box-shadow: 0 0 20rpx var(--brand-primary-30);
  }
  50% {
    box-shadow: 0 0 40rpx var(--brand-primary-35);
  }
}

/* ============================================
   工具类
   ============================================ */

/* 弹性布局 */
.flex {
  display: flex;
}
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.flex-column {
  display: flex;
  flex-direction: column;
}
.flex-wrap {
  display: flex;
  flex-wrap: wrap;
}
.flex-1 {
  flex: 1;
}

/* 文字对齐 */
.text-center {
  text-align: center;
}
.text-left {
  text-align: left;
}
.text-right {
  text-align: right;
}

/* 文字截断 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* ============================================
   阴影样式
   ============================================ */
.shadow-sm {
  box-shadow: var(--shadow-sm);
}
.shadow-md {
  box-shadow: var(--shadow-md);
}
.shadow-lg {
  box-shadow: var(--shadow-lg);
}
.shadow-sky {
  box-shadow: var(--shadow-sky);
}
.shadow-orange {
  box-shadow: var(--shadow-orange);
}

/* ============================================
   毛玻璃效果
   ============================================ */
.glass {
  background: var(--bg-glass);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
}

/* ============================================
   按钮样式 - 克制主色
   ============================================ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 400;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  letter-spacing: 0.02em;
  border: none;
}

.btn:active {
  transform: scale(0.96);
}

/* 主按钮 */
.btn-primary {
  background: var(--sky-primary);
  color: var(--text-white);
  box-shadow: var(--shadow-sky);
}

.btn-primary:active {
  box-shadow: 0 2rpx 12rpx var(--brand-primary-20);
}

/* 次要按钮 */
.btn-secondary {
  background: #ffffff;
  color: var(--sky-deep);
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
}

/* 交易按钮 */
.btn-vitality {
  background: var(--vitality-orange);
  color: var(--text-white);
  box-shadow: var(--shadow-orange);
}

/* 成功按钮 */
.btn-fresh {
  background: var(--fresh-mint);
  color: var(--text-white);
  box-shadow: var(--shadow-green);
}

/* ============================================
   卡片样式 - 清爽可信
   ============================================ */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
}

/* ============================================
   标签样式 - 明确状态
   ============================================ */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 400;
}

.tag-sky {
  background: var(--brand-primary-08);
  color: var(--sky-deep);
}

.tag-orange {
  background: var(--vitality-orange-10);
  color: var(--vitality-orange);
}

.tag-mint {
  background: var(--fresh-mint-10);
  color: var(--fresh-mint);
}

.tag-yellow {
  background: var(--vitality-yellow-14);
  color: #946b00;
}

/* ============================================
   背景渐变
   ============================================ */
.bg-sky-gradient {
  background: var(--sky-primary);
}

.bg-sky-light {
  background: var(--bg-primary);
}

.bg-vitality {
  background: var(--vitality-orange);
}

.bg-fresh {
  background: var(--fresh-mint);
}

/* ============================================
   轻阴影效果
   ============================================ */
.glow-sky {
  box-shadow: var(--shadow-sky);
}

.glow-orange {
  box-shadow: var(--shadow-orange);
}

.glow-mint {
  box-shadow: var(--shadow-green);
}

/* ============================================
   页面切换动画
   ============================================ */
.page-enter {
  animation: fadeInUp 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ============================================
   加载状态
   ============================================ */
.skeleton {
  background: linear-gradient(90deg, #eef2f6 25%, #eef7fd 50%, #eef2f6 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-sm);
}

/* ============================================
   自适应设计 - 适配不同屏幕
   ============================================ */

/* 小屏幕适配 */
@media screen and (max-width: 320px) {
  page {
    font-size: 26rpx;
  }
  page {
    --space-md: 24rpx;
    --space-lg: 32rpx;
  }
}

/* 大屏幕适配 */
@media screen and (min-width: 414px) {
  page {
    font-size: 30rpx;
  }
  :root {
    --space-md: 36rpx;
    --space-lg: 48rpx;
  }
}

/* iPad 适配 */
@media screen and (min-width: 768px) {
  .container {
    max-width: 750rpx;
    margin: 0 auto;
  }
}

/* ============================================
   TabBar 样式微调
   ============================================ */
.tab-bar-item {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-bar-item-active {
  transform: scale(1.15);
}

/* ============================================
   安全区域适配
   ============================================ */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ============================================
   按压效果
   ============================================ */
.pressable {
  transition: transform 0.15s ease;
}
.pressable:active {
  transform: scale(0.96);
}

/* ============================================
   禁用状态
   ============================================ */
.disabled {
  opacity: 0.5;
  pointer-events: none;
}
