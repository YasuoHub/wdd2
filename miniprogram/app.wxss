/* ============================================
   问当地小程序 - 全局样式
   风格：青春活力 / 天蓝色主调 / 亲和力
   ============================================ */

/* 页面基础样式 - 天蓝青春风格 */
page {
  font-family:
    -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
    "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  color: #2c3e50;
  background: linear-gradient(180deg, #f0f8ff 0%, #e6f3ff 50%, #edf7ff 100%);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
  width: 100%;

  /* CSS变量 - 天蓝色系设计令牌 */
  /* 主色调 - 天蓝色系 */
  --sky-primary: #5db8e6;
  --sky-light: #7ec8e8;
  --sky-soft: #a8d8f0;
  --sky-pale: #d4edf7;
  --sky-dark: #3a9ad2;
  --sky-deep: #2a7db3;

  /* 辅助色 - 活力点缀 */
  --vitality-orange: #ff8c69;
  --vitality-coral: #ff9a8b;
  --vitality-yellow: #ffd166;
  --fresh-mint: #6dd5b0;
  --fresh-green: #88d8a3;
  --lavender: #b8b8e8;
  --pink-soft: #ffb6c1;

  /* 背景色 */
  --bg-primary: #f0f8ff;
  --bg-secondary: #e6f3ff;
  --bg-tertiary: #edf7ff;
  --bg-card: rgba(255, 255, 255, 0.95);
  --bg-glass: rgba(255, 255, 255, 0.85);

  /* 文字色 - 确保对比度 */
  --text-primary: #2c3e50;
  --text-secondary: #4a6572;
  --text-tertiary: #6b8ba4;
  --text-light: #8fa8b8;
  --text-muted: #a8c4d4;
  --text-white: #ffffff;

  /* 边框色 */
  --border-color: rgba(93, 184, 230, 0.2);
  --border-light: rgba(93, 184, 230, 0.12);

  /* 功能色 */
  --danger-color: #ff6b6b;

  /* 阴影 */
  --shadow-sm: 0 2rpx 12rpx rgba(93, 184, 230, 0.08);
  --shadow-md: 0 4rpx 24rpx rgba(93, 184, 230, 0.12);
  --shadow-lg: 0 8rpx 40rpx rgba(93, 184, 230, 0.16);
  --shadow-sky: 0 4rpx 20rpx rgba(93, 184, 230, 0.25);
  --shadow-orange: 0 4rpx 16rpx rgba(255, 140, 105, 0.3);
  --shadow-green: 0 4rpx 16rpx rgba(109, 213, 176, 0.35);

  /* 圆角 - 亲和力 */
  --radius-xs: 12rpx;
  --radius-sm: 20rpx;
  --radius-md: 28rpx;
  --radius-lg: 40rpx;
  --radius-xl: 56rpx;
  --radius-xxl: 80rpx;
  --radius-full: 9999rpx;

  /* 间距 - 自适应 */
  --space-xs: 12rpx;
  --space-sm: 20rpx;
  --space-md: 32rpx;
  --space-lg: 40rpx;
  --space-xl: 56rpx;
  --space-xxl: 80rpx;
}

/* 重置默认样式 */
view,
text,
image,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: none;
  border: none;
  font-size: inherit;
  line-height: inherit;
  color: inherit;
}

button::after {
  border: none;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* ============================================
   动画效果
   ============================================ */

/* 淡入上移动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 弹跳动画 */
@keyframes bounce {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

/* 脉冲动画 */
@keyframes pulse {
  0%,
  100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

/* 闪烁动画 */
@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}

/* 旋转动画 */
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* 浮动动画 */
@keyframes float {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}

/* 呼吸光晕 */
@keyframes breathe {
  0%,
  100% {
    box-shadow: 0 0 20rpx rgba(93, 184, 230, 0.3);
  }
  50% {
    box-shadow: 0 0 40rpx rgba(93, 184, 230, 0.5);
  }
}

/* ============================================
   工具类
   ============================================ */

/* 弹性布局 */
.flex {
  display: flex;
}
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.flex-column {
  display: flex;
  flex-direction: column;
}
.flex-wrap {
  display: flex;
  flex-wrap: wrap;
}
.flex-1 {
  flex: 1;
}

/* 文字对齐 */
.text-center {
  text-align: center;
}
.text-left {
  text-align: left;
}
.text-right {
  text-align: right;
}

/* 文字截断 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* ============================================
   阴影样式
   ============================================ */
.shadow-sm {
  box-shadow: var(--shadow-sm);
}
.shadow-md {
  box-shadow: var(--shadow-md);
}
.shadow-lg {
  box-shadow: var(--shadow-lg);
}
.shadow-sky {
  box-shadow: var(--shadow-sky);
}
.shadow-orange {
  box-shadow: var(--shadow-orange);
}

/* ============================================
   毛玻璃效果
   ============================================ */
.glass {
  background: var(--bg-glass);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
}

/* ============================================
   按钮样式 - 天蓝色主调
   ============================================ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  letter-spacing: 0.02em;
  border: none;
}

.btn:active {
  transform: scale(0.96);
}

/* 主按钮 - 天蓝色渐变 */
.btn-primary {
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 50%,
    var(--sky-soft) 100%
  );
  color: var(--text-white);
  box-shadow: var(--shadow-sky);
}

.btn-primary:active {
  box-shadow: 0 2rpx 12rpx rgba(93, 184, 230, 0.2);
}

/* 次要按钮 - 白色玻璃 */
.btn-secondary {
  background: var(--bg-glass);
  color: var(--sky-deep);
  border: 2rpx solid rgba(93, 184, 230, 0.3);
  box-shadow: var(--shadow-sm);
}

/* 活力橙按钮 */
.btn-vitality {
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  color: var(--text-white);
  box-shadow: var(--shadow-orange);
}

/* 薄荷绿按钮 */
.btn-fresh {
  background: linear-gradient(
    135deg,
    var(--fresh-mint) 0%,
    var(--fresh-green) 100%
  );
  color: var(--text-white);
  box-shadow: 0 4rpx 20rpx rgba(109, 213, 176, 0.3);
}

/* ============================================
   卡片样式 - 圆润亲和
   ============================================ */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid rgba(93, 184, 230, 0.1);
}

/* ============================================
   标签样式 - 青春活泼
   ============================================ */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
}

.tag-sky {
  background: linear-gradient(
    135deg,
    rgba(93, 184, 230, 0.2) 0%,
    rgba(168, 216, 240, 0.15) 100%
  );
  color: var(--sky-deep);
}

.tag-orange {
  background: linear-gradient(
    135deg,
    rgba(255, 140, 105, 0.2) 0%,
    rgba(255, 154, 139, 0.15) 100%
  );
  color: #e86a4a;
}

.tag-mint {
  background: linear-gradient(
    135deg,
    rgba(109, 213, 176, 0.2) 0%,
    rgba(136, 216, 163, 0.15) 100%
  );
  color: #3ba882;
}

.tag-yellow {
  background: linear-gradient(
    135deg,
    rgba(255, 209, 102, 0.25) 0%,
    rgba(255, 220, 130, 0.2) 100%
  );
  color: #c9941e;
}

/* ============================================
   背景渐变
   ============================================ */
.bg-sky-gradient {
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 50%,
    var(--sky-soft) 100%
  );
}

.bg-sky-light {
  background: linear-gradient(
    180deg,
    var(--bg-primary) 0%,
    var(--bg-secondary) 100%
  );
}

.bg-vitality {
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
}

.bg-fresh {
  background: linear-gradient(
    135deg,
    var(--fresh-mint) 0%,
    var(--fresh-green) 100%
  );
}

/* ============================================
   发光效果
   ============================================ */
.glow-sky {
  box-shadow: 0 0 40rpx rgba(93, 184, 230, 0.4);
}

.glow-orange {
  box-shadow: 0 0 40rpx rgba(255, 140, 105, 0.4);
}

.glow-mint {
  box-shadow: 0 0 40rpx rgba(109, 213, 176, 0.4);
}

/* ============================================
   页面切换动画
   ============================================ */
.page-enter {
  animation: fadeInUp 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ============================================
   加载状态
   ============================================ */
.skeleton {
  background: linear-gradient(90deg, #e8f4f8 25%, #d4edf7 50%, #e8f4f8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-sm);
}

/* ============================================
   自适应设计 - 适配不同屏幕
   ============================================ */

/* 小屏幕适配 */
@media screen and (max-width: 320px) {
  page {
    font-size: 26rpx;
  }
  :root {
    --space-md: 24rpx;
    --space-lg: 32rpx;
  }
}

/* 大屏幕适配 */
@media screen and (min-width: 414px) {
  page {
    font-size: 30rpx;
  }
  :root {
    --space-md: 36rpx;
    --space-lg: 48rpx;
  }
}

/* iPad 适配 */
@media screen and (min-width: 768px) {
  .container {
    max-width: 750rpx;
    margin: 0 auto;
  }
}

/* ============================================
   TabBar 样式微调
   ============================================ */
.tab-bar-item {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-bar-item-active {
  transform: scale(1.15);
}

/* ============================================
   安全区域适配
   ============================================ */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ============================================
   按压效果
   ============================================ */
.pressable {
  transition: transform 0.15s ease;
}
.pressable:active {
  transform: scale(0.96);
}

/* ============================================
   禁用状态
   ============================================ */
.disabled {
  opacity: 0.5;
  pointer-events: none;
}
