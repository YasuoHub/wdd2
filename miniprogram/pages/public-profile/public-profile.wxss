page { background: var(--bg-secondary); }
.container { padding: 30rpx; }
.loading { text-align: center; padding: 60rpx; color: var(--text-tertiary); }
.profile-card { background: #fff; border-radius: 24rpx; padding: 40rpx; text-align: center; margin-bottom: 24rpx; }
.avatar-wrap { margin-bottom: 20rpx; }
.avatar { width: 140rpx; height: 140rpx; border-radius: 50%; }
.avatar-default { width: 140rpx; height: 140rpx; border-radius: 50%; background: var(--primary-color); color: #fff; font-size: 48rpx; display: flex; align-items: center; justify-content: center; margin: 0 auto; }
.nickname { font-size: 36rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 12rpx; }
.rating-wrap { display: flex; align-items: center; justify-content: center; gap: 12rpx; }
.stars { display: flex; align-items: center; gap: 4rpx; }
.rating-num { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.rating-count { font-size: 24rpx; color: var(--text-tertiary); }
.section { background: #fff; border-radius: 24rpx; padding: 28rpx; margin-bottom: 24rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 20rpx; }
.tag-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tag { padding: 10rpx 24rpx; background: rgba(116,185,255,0.15); color: #74b9ff; border-radius: 28rpx; font-size: 26rpx; }
.tag.location { background: rgba(168,230,207,0.3); color: #2ecc71; }
.location-list { display: flex; flex-direction: column; gap: 16rpx; }
.location-item { display: flex; align-items: center; padding: 20rpx; background: var(--bg-secondary); border-radius: 16rpx; }
.location-item.clickable { position: relative; }
.location-item.clickable:active { opacity: 0.7; }
.location-item.clickable::after { display: none; }
.location-info { display: flex; align-items: center; gap: 12rpx; flex: 1; padding-right: 40rpx; }
.location-icon { font-size: 28rpx; }
.location-name { font-size: 28rpx; color: var(--text-primary); }
.rating-list { display: flex; flex-direction: column; gap: 20rpx; }
.rating-item { padding: 20rpx; background: var(--bg-secondary); border-radius: 16rpx; }
.rating-stars { display: flex; align-items: center; gap: 3rpx; margin-bottom: 8rpx; }
.rating-comment { font-size: 28rpx; color: var(--text-secondary); line-height: 1.5; }
.rating-comment.empty { color: var(--text-tertiary); font-style: italic; }
.empty { text-align: center; padding: 40rpx; color: var(--text-tertiary); font-size: 28rpx; }
/* ============================================
   城市服务风格视觉覆盖：清爽可信、交易清楚、低装饰
   ============================================ */
.container,
.chat-container {
  background: #f5f7fa;
}

.header,
.footer,
.input-area,
.popup-content,
.modal-content,
.rules-modal-content {
  background: #ffffff;
  border-color: var(--border-light);
  box-shadow: var(--shadow-card);
}

.section-card,
.task-card,
.user-card,
.menu-list,
.quick-panel,
.need-feed,
.login-tip-card,
.balance-section,
.record-card,
.ticket-card,
.report-card,
.appeal-card,
.profile-card,
.rating-card,
.info-card,
.form-card,
.stat-card,
.card {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.location-bar,
.filter-item,
.sort-section,
.distance-section,
.type-badge,
.card-location,
.distance-tag,
.quick-tag,
.type-item,
.time-option,
.quick-point,
.quick-amount,
.payment-option,
.amount-detail,
.rules-tip,
.points-tip-wrapper,
.input-wrapper,
.toolbar-toggle-btn,
.more-btn,
.system-message-text,
.time-divider text {
  background: #f8fafc;
  border-color: var(--border-light);
  box-shadow: none;
}

.filter-item.active,
.type-item.active,
.quick-tag.active,
.time-option.active,
.payment-option.active {
  background: rgba(22, 119, 210, 0.08);
  border-color: rgba(22, 119, 210, 0.34);
  box-shadow: none;
}

.filter-item.active .filter-name,
.quick-tag.active,
.time-option.active,
.payment-option.active .payment-name {
  color: var(--sky-deep);
  font-weight: 600;
}

.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.amount-badge,
.quick-amount.active,
.quick-point.active,
.time-recommend,
.btn-vitality {
  background: var(--vitality-orange);
  box-shadow: var(--shadow-orange);
}

.balance-value.points,
.balance-value.available,
.points-number,
.publish-points,
.publish-amount {
  color: var(--text-primary);
  background: none;
  -webkit-text-fill-color: currentColor;
}

.wdd-amount,
.need-amount,
.amount-current,
.amount-symbol,
.detail-value.fee,
.warning-text,
.balance-value.insufficient,
.task-points-mini {
  color: var(--vitality-orange);
}

.detail-value.income,
.tag-mint,
.status-success,
.success-text {
  color: var(--fresh-mint);
}

.message-item.other .message-bubble.text {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-sm);
}

.message-item.self .message-bubble.text {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.popup-overlay,
.modal-mask,
.rules-modal {
  background: rgba(15, 23, 42, 0.46);
}

.helper-profile-tip,
.balance-insufficient,
.task-ended-bar.breaking-bar {
  background: #fff8e6;
  border-color: rgba(233, 185, 73, 0.34);
}

image,
button,
view {
  letter-spacing: 0;
}
/* 城市服务按钮对比修正 */
.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  color: #ffffff;
}

.publish-btn.disabled,
.send-btn[disabled],
.disabled {
  color: var(--text-muted);
}