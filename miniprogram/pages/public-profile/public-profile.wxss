@import "../../styles/wdd-polish.wxss";

page {
  background: #f5f7fa;
}

.container {
  min-height: 100vh;
  padding: 30rpx;
  background: linear-gradient(180deg, #f5f7fa 0%, #fbfcfd 48%, #f3f6f9 100%);
  box-sizing: border-box;
}

.loading {
  padding: 72rpx 0;
  color: var(--text-tertiary);
  font-size: 27rpx;
  text-align: center;
}

.profile-card,
.section {
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid #e1e8f0;
  border-radius: 14rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.045);
  box-sizing: border-box;
}

.profile-card {
  display: grid;
  grid-template-columns: 126rpx minmax(0, 1fr);
  column-gap: 26rpx;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 32rpx 34rpx;
  text-align: left;
}

.avatar-wrap {
  grid-row: 1 / 3;
  width: 112rpx;
  height: 112rpx;
}

.avatar,
.avatar-default {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
}

.avatar-default {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 42rpx;
  background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-primary-deep) 100%);
}

.nickname {
  min-width: 0;
  margin-bottom: 12rpx;
  color: var(--text-primary);
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rating-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 10rpx;
  min-width: 0;
}

.stars {
  display: flex;
  align-items: center;
  gap: 3rpx;
  flex-shrink: 0;
}

.star-glyph {
  font-size: 25rpx;
  line-height: 1;
}

.rating-num {
  color: var(--text-secondary);
  font-size: 25rpx;
  font-weight: 500;
}

.rating-count {
  min-width: 0;
  color: var(--text-tertiary);
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section {
  margin-bottom: 24rpx;
  padding: 30rpx 32rpx;
}

.section-title {
  margin-bottom: 22rpx;
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.25;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  min-height: 42rpx;
  padding: 7rpx 18rpx;
  border: 1rpx solid #d9ecfb;
  border-radius: 8rpx;
  color: var(--sky-deep);
  background: var(--brand-primary-08);
  font-size: 24rpx;
  line-height: 1.25;
  box-sizing: border-box;
}

.tag.location {
  border-color: var(--fresh-mint-18);
  color: var(--fresh-mint);
  background: var(--fresh-mint-08);
}

.location-list,
.rating-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.location-item {
  display: flex;
  align-items: center;
  min-height: 72rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid var(--border-light);
  border-radius: 10rpx;
  background: #f8fafc;
}

.location-item.clickable {
  position: relative;
}

.location-item.clickable:active {
  background: var(--brand-primary-05);
  opacity: 0.9;
}

.location-item.clickable::after {
  display: none;
}

.location-info {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 12rpx;
  min-width: 0;
}

.location-name {
  min-width: 0;
  color: var(--text-secondary);
  font-size: 27rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rating-item {
  padding: 20rpx 22rpx;
  border: 1rpx solid var(--border-light);
  border-radius: 10rpx;
  background: #f8fafc;
}

.rating-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.rating-stars {
  display: flex;
  align-items: center;
  gap: 3rpx;
  flex-shrink: 0;
}

.rating-star-glyph {
  color: #c9941e;
  font-size: 23rpx;
  line-height: 1;
}

.rating-type {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  max-width: 260rpx;
  min-height: 36rpx;
  padding: 5rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 1.2;
}

.rating-type text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rating-comment {
  display: block;
  color: var(--text-secondary);
  font-size: 27rpx;
  line-height: 1.55;
}

.rating-comment.empty {
  color: var(--text-tertiary);
  font-style: normal;
}

.empty {
  padding: 42rpx 0;
  color: var(--text-tertiary);
  font-size: 27rpx;
  text-align: center;
}
