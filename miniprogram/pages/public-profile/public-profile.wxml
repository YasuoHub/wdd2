<view class="container wdd-page">
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <block wx:else>
    <!-- 用户基本信息 -->
    <view class="profile-card" wx:if="{{userInfo}}">
      <view class="avatar-wrap">
        <image wx:if="{{userInfo.avatar}}" class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"/>
        <view wx:else class="avatar-default">{{userInfo.nickname[0] || '?'}}</view>
      </view>
      <view class="nickname">{{userInfo.nickname}}</view>
      <view class="rating-wrap">
        <view class="stars">
          <wdd-icon wx:for="{{[1,2,3,4,5]}}" wx:key="*this" name="star" color="{{userInfo.ratingRounded >= item ? '#FFD166' : '#C4D8E5'}}" size="28"></wdd-icon>
        </view>
        <text class="rating-num">{{userInfo.ratingFormatted}}</text>
        <text class="rating-count">({{userInfo.ratingCount}}条评价)</text>
      </view>
    </view>

    <!-- 帮助者信息 -->
    <view class="section" wx:if="{{userInfo.helpTypes.length > 0}}">
      <view class="section-title">提供帮助</view>
      <view class="tag-list">
        <view wx:for="{{userInfo.helpTypes}}" wx:key="index" class="tag">
          <wdd-icon name="{{item.icon}}" color="{{item.color || '#1677D2'}}" size="24"></wdd-icon>
          <text style="margin-left: 8rpx;">{{item.name}}</text>
        </view>
      </view>
    </view>

    <view class="section" wx:if="{{userInfo.frequentLocations.length > 0}}">
      <view class="section-title">帮助范围</view>
      <view class="location-list">
        <view wx:for="{{userInfo.frequentLocations}}" wx:key="index"
          class="location-item {{item.latitude && item.longitude ? 'clickable' : ''}}"
          bindtap="{{item.latitude && item.longitude ? 'goToLocation' : ''}}"
          data-index="{{index}}">
          <view class="location-info">
            <wdd-icon name="map-pin" color="#7B8794" size="24"></wdd-icon>
            <text class="location-name">{{item.name || '未知地点'}}</text>
            <wdd-icon wx:if="{{item.latitude && item.longitude}}" name="chevron-right" color="#9AA5B1" size="24"></wdd-icon>
          </view>
        </view>
      </view>
    </view>

    <!-- 最近五星好评 -->
    <view class="section" wx:if="{{ratings.length > 0}}">
      <view class="section-title">最近五星好评</view>
      <view class="rating-list">
        <view wx:for="{{ratings}}" wx:key="_id" class="rating-item">
          <view class="rating-stars">
            <wdd-icon wx:for="{{[1,2,3,4,5]}}" wx:key="*this" name="star" color="#FFD166" size="24"></wdd-icon>
          </view>
          <text wx:if="{{item.comment}}" class="rating-comment">{{item.comment}}</text>
          <text wx:else class="rating-comment empty">用户未留下文字评价</text>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{ratings.length === 0}}">
      <text>暂无评价记录</text>
    </view>
  </block>
</view>
