/* 积分明细页面样式 - 城市服务清爽可信风格 */

.container {
  height: 100vh;
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 50%, var(--bg-tertiary) 100%);
  box-sizing: border-box;
  width: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 积分卡片 - 克制主色 */
.points-card {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 50%, var(--sky-soft) 100%);
  margin: 30rpx;
  border-radius: var(--radius-xl);
  padding: 48rpx;
  color: #fff;
  box-shadow: var(--shadow-lg);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  flex-shrink: 0;
}

.points-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
}

.points-title {
  font-size: 34rpx;
  font-weight: 400;
  opacity: 0.98;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.rules-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
}

.rules-btn:active {
  background: rgba(255, 255, 255, 0.35);
}

.rules-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.rules-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.points-total {
  display: flex;
  align-items: baseline;
  margin-bottom: 36rpx;
}

.total-number {
  font-size: 104rpx;
  font-weight: 400;
  line-height: 1;
  margin-right: 16rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.total-unit {
  font-size: 34rpx;
  opacity: 0.95;
  font-weight: 400;
}

.points-detail {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 24rpx;
  padding: 28rpx 0;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10rpx);
}

.detail-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 10rpx;
  font-weight: 400;
}

.detail-value {
  font-size: 40rpx;
  font-weight: 400;
}

.points-hint {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hint-text {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 10rpx;
  font-size: 24rpx;
  opacity: 0.95;
  font-weight: 400;
}

.hint-text text {
  flex: 1;
}

.points-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 28rpx;
}

.exchange-entry-btn {
  width: auto;
  min-width: 236rpx;
  height: 68rpx;
  padding: 0 28rpx;
  margin: 0;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.34) 0%, rgba(255, 255, 255, 0.18) 100%);
  color: #fff;
  font-size: 25rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  box-shadow: 0 10rpx 24rpx rgba(22, 119, 210, 0.18);
  backdrop-filter: blur(8rpx);
}

.exchange-entry-btn:active {
  transform: translateY(1rpx);
  background: rgba(255, 255, 255, 0.38);
}

.exchange-sheet {
  padding: 4rpx 0 20rpx;
}

.exchange-rate-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, var(--brand-primary-05) 0%, rgba(17, 155, 114, 0.08) 100%);
  border: 1rpx solid var(--brand-primary-10);
  margin-bottom: 24rpx;
}

.rate-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
}

.rate-number {
  font-size: 48rpx;
  color: var(--text-primary);
  line-height: 1;
}

.rate-unit {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.exchange-note {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: var(--vitality-orange-08);
  margin-bottom: 28rpx;
}

.exchange-note text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.exchange-input-block {
  margin-bottom: 20rpx;
}

.exchange-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

.exchange-input-wrapper {
  height: 88rpx;
  border: 2rpx solid var(--border-light);
  border-radius: 20rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  background: var(--bg-primary);
}

.exchange-input {
  flex: 1;
  font-size: 32rpx;
  color: var(--text-primary);
}

.exchange-placeholder,
.exchange-unit {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.exchange-preview-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: rgba(17, 155, 114, 0.08);
  margin-bottom: 14rpx;
}

.preview-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.preview-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.exchange-error {
  min-height: 34rpx;
  line-height: 34rpx;
  font-size: 24rpx;
  color: var(--danger-color);
  margin: 0 4rpx 16rpx;
  opacity: 0;
}

.exchange-error.visible {
  opacity: 1;
}

.exchange-confirm-btn {
  width: 100%;
  height: 84rpx;
  border-radius: 42rpx;
  background: var(--brand-primary);
  color: #fff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx var(--brand-primary-20);
}

.exchange-confirm-btn.disabled {
  background: #D8E1EA;
  color: #7B8794;
  box-shadow: none;
}

/* 记录列表区域 - 城市服务色调 */
.records-section {
  background: var(--bg-card);
  margin: 0 30rpx 30rpx;
  border-radius: var(--radius-xl);
  padding: 40rpx;
  min-height: 0;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--brand-primary-08);
  display: flex;
  flex: 1;
  flex-direction: column;
}

.section-title {
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-text {
  font-size: 34rpx;
  font-weight: 400;
  color: var(--text-primary);
}

.title-icon {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.loading-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--bg-secondary) 0%, #EEF7FD 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 24rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 28rpx;
  background: linear-gradient(135deg, var(--bg-secondary) 0%, #EEF7FD 50%, #C4E5F5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 88rpx;
  box-shadow: 0 6rpx 30rpx var(--brand-primary-16);
}

.empty-text {
  font-size: 34rpx;
  color: var(--text-primary);
  font-weight: 400;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* 记录列表 */
.records-list {
  display: flex;
  flex-direction: column;
  flex: 1;
  height: 0;
  min-height: 0;
  overflow-y: auto;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 2rpx solid var(--border-light);
  transition: all 0.3s ease;
}

.record-item:active {
  background: var(--brand-primary-05);
  border-radius: 16rpx;
}

.record-item:last-child {
  border-bottom: none;
}

.record-item.last {
  border-bottom: none;
}

.record-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 400;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.record-icon.income {
  background: linear-gradient(135deg, var(--brand-primary-16) 0%, rgba(126, 200, 232, 0.1) 100%);
  color: var(--sky-dark);
}

.record-icon.expense {
  background: linear-gradient(135deg, var(--vitality-orange-15) 0%, rgba(233, 130, 58, 0.1) 100%);
  color: var(--danger-color);
}

.record-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.record-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 400;
  flex: 1;
  margin-right: 20rpx;
  line-height: 1.4;
}

.record-amount {
  font-size: 34rpx;
  font-weight: 400;
  flex-shrink: 0;
  line-height: 0.4;
}

.record-amount.income {
  color: var(--sky-dark);
}

.record-amount.expense {
  color: var(--danger-color);
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-type {
  font-size: 22rpx;
  color: var(--text-tertiary);
  background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  padding: 8rpx 18rpx;
  border-radius: var(--radius-full);
  font-weight: 400;
}

.record-time {
  font-size: 22rpx;
  color: var(--text-light);
}

/* 加载更多 */
.load-more,
.loading-more,
.no-more {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.loading-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.loading-dots text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.load-more-text,
.loading-more .loading-text,
.no-more-text {
  font-size: 26rpx;
  color: var(--text-light);
}

.no-more text {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 规则弹窗 */
.rules-modal-body {
  max-height: 60vh;
  overflow-y: auto;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--brand-primary-10);
}

.rule-item:last-child {
  border-bottom: none;
}

.rule-content {
  flex: 1;
}

.rule-title {
  display: block;
  font-size: 30rpx;
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.rule-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  flex: 1;
}
@import "../../styles/wdd-polish.wxss";
