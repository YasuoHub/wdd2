<page-meta page-style="{{showRulesModal ? 'overflow: hidden;' : ''}}" />
<!-- 积分明细页面 -->
<view class="container wdd-page">
  <view class="wdd-page-bg"></view>
  <!-- 顶部积分卡片 -->
  <view class="points-card">
    <view class="points-header">
      <text class="points-title">积分总额</text>
      <view class="rules-btn" bindtap="showRules">
        <wdd-icon name="info" color="#FFFFFF" size="24"></wdd-icon>
        <text class="rules-text">规则</text>
      </view>
    </view>

    <view class="points-total">
      <text class="total-number">{{currentPoints.total}}</text>
      <text class="total-unit">积分</text>
    </view>

    <view class="points-hint">
      <view class="hint-text">
        <wdd-icon name="lightbulb" color="#FFD166" size="24"></wdd-icon>
        <text>每满100积分可兑换1元平台抵扣金，不可提现、无现金价值</text>
      </view>
    </view>

    <view class="points-actions">
      <button class="exchange-entry-btn" bindtap="showExchangeModal">兑换平台抵扣金</button>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="records-section">
    <view class="section-title">
      <text class="title-text">收支明细</text>
    </view>

    <!-- 加载中 -->
    <loading wx:if="{{isLoading && records.length === 0}}" type="normal" text="加载中..." mode="spinner" size="56"></loading>

    <!-- 空状态 -->
    <empty wx:if="{{isEmpty}}" type="normal" icon="chart-column" title="暂无积分记录" desc="可通过每日签到或邀请好友获得积分"></empty>

    <!-- 记录列表 -->
    <scroll-view
      class="records-list"
      wx:if="{{records.length > 0}}"
      scroll-y="{{!showRulesModal}}"
      enhanced
      show-scrollbar="{{false}}"
      lower-threshold="80"
      bindscrolltolower="loadMoreRecords"
    >
      <view
        class="record-item {{index === records.length - 1 ? 'last' : ''}}"
        wx:for="{{records}}"
        wx:key="_id"
      >
        <view class="record-icon" style="background-color: {{item.typeColor}}20; color: {{item.typeColor}}">
          <text>{{item.icon}}</text>
        </view>

        <view class="record-content">
          <view class="record-header">
            <text class="record-title">{{item.description}}</text>
            <text class="record-amount" style="color: {{item.typeColor}}">
              {{item.amount > 0 ? '+' : ''}}{{item.amount}}
            </text>
          </view>

          <view class="record-footer">
            <text class="record-type">{{item.typeLabel}}</text>
            <text class="record-time">{{item.timeText}}</text>
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{isLoadingMore}}" class="loading-more">
        <text class="loading-text">加载中...</text>
      </view>

      <view wx:if="{{!isLoadingMore && !hasMore && records.length > 0}}" class="no-more">
        <text class="no-more-text">没有更多记录了</text>
      </view>
    </scroll-view>
  </view>

  <!-- 积分规则弹窗 -->
  <bottom-sheet show="{{showRulesModal}}" title="积分规则" maxHeight="76vh" bind:close="hideRulesModal">
    <view class="rules-modal-body">
      <view class="rule-item">
        <wdd-icon name="gift" color="var(--brand-primary)" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">新用户注册</text>
          <text class="rule-desc">首次注册问当地账号，可获得 100 积分。</text>
        </view>
      </view>
      <view class="rule-item">
        <wdd-icon name="calendar-check" color="var(--vitality-orange)" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">每日签到</text>
          <text class="rule-desc">每日签到可获得 5~30 积分，连续签到会递增。</text>
        </view>
      </view>
      <view class="rule-item">
        <wdd-icon name="users" color="var(--brand-primary)" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">邀请好友</text>
          <text class="rule-desc">好友通过你的邀请注册后，双方各得 50 积分。</text>
        </view>
      </view>
      <view class="rule-item">
        <wdd-icon name="ticket" color="var(--fresh-mint)" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">积分用途</text>
          <text class="rule-desc">每满100积分可兑换1元平台抵扣金。平台抵扣金仅用于发布求助时抵扣悬赏，不可提现、不可转让。</text>
        </view>
      </view>
      <view class="rule-item">
        <wdd-icon name="info" color="#7B8794" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">重要说明</text>
          <text class="rule-desc">积分和平台抵扣金均无现金价值。积分兑换平台抵扣金后不可撤回，平台保留调整积分发放规则与兑换比例的权利。</text>
        </view>
      </view>
    </view>
  </bottom-sheet>

  <bottom-sheet show="{{showExchangeModal}}" title="兑换平台抵扣金" maxHeight="70vh" bind:close="hideExchangeModal">
    <view class="exchange-sheet">
      <view class="exchange-rate-card">
        <view class="rate-main">
          <text class="rate-number">100</text>
          <text class="rate-unit">积分</text>
        </view>
        <wdd-icon name="arrow-right" color="var(--brand-primary)" size="34"></wdd-icon>
        <view class="rate-main">
          <text class="rate-number">1</text>
          <text class="rate-unit">元抵扣金</text>
        </view>
      </view>

      <view class="exchange-note">
        <wdd-icon name="info" color="var(--vitality-orange)" size="28"></wdd-icon>
        <text>请输入100的整数倍积分。兑换后不可撤销，平台抵扣金仅用于发布求助抵扣悬赏，不可提现。</text>
      </view>

      <view class="exchange-input-block">
        <text class="exchange-label">兑换积分</text>
        <view class="exchange-input-wrapper">
          <input
            class="exchange-input"
            type="number"
            value="{{exchangeInput}}"
            bindinput="onExchangeInput"
            placeholder="例如 100、200、300"
            placeholder-class="exchange-placeholder"
          />
          <text class="exchange-unit">积分</text>
        </view>
      </view>

      <view class="exchange-preview-card">
        <text class="preview-label">预计到账</text>
        <view class="preview-value">
          <wdd-icon name="ticket" color="var(--fresh-mint)" size="28"></wdd-icon>
          <text>{{exchangePreviewAmount}} 元平台抵扣金</text>
        </view>
      </view>

      <view class="exchange-error {{exchangeErrorTip ? 'visible' : ''}}">
        <text>{{exchangeErrorTip}}</text>
      </view>

      <button class="exchange-confirm-btn {{exchangeInput && !exchangeErrorTip ? '' : 'disabled'}}" bindtap="doExchangeDeduction" disabled="{{!exchangeInput || !!exchangeErrorTip}}">确认兑换</button>
    </view>
  </bottom-sheet>
</view>
