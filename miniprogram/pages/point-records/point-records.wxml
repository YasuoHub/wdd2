<!-- 积分明细页面 -->
<view class="container">
  <!-- 顶部积分卡片 -->
  <view class="points-card">
    <view class="points-header">
      <text class="points-title">积分总额</text>
      <view class="rules-btn" bindtap="showRules">
        <text class="rules-icon">📋</text>
        <text class="rules-text">规则</text>
      </view>
    </view>

    <view class="points-total">
      <text class="total-number">{{currentPoints.total}}</text>
      <text class="total-unit">积分</text>
    </view>

    <view class="points-hint">
      <text class="hint-text">💡 积分可兑换免单券、提现免手续费券等权益，不可提现、无现金价值</text>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="records-section">
    <view class="section-title">
      <text class="title-text">收支明细</text>
    </view>

    <!-- 加载中 -->
    <loading wx:if="{{isLoading && records.length === 0}}" type="normal" text="加载中..." mode="spinner" size="56"></loading>

    <!-- 空状态 -->
    <empty wx:if="{{isEmpty}}" type="normal" icon="📊" title="暂无积分记录" desc="快去签到或完成任务赚取积分吧~"></empty>

    <!-- 记录列表 -->
    <view class="records-list" wx:if="{{records.length > 0}}">
      <view
        class="record-item"
        wx:for="{{records}}"
        wx:key="_id"
      >
        <view class="record-icon" style="background-color: {{item.typeColor}}20; color: {{item.typeColor}}">
          <text>{{item.icon}}</text>
        </view>

        <view class="record-content">
          <view class="record-header">
            <text class="record-title">{{item.description}}</text>
            <text class="record-amount" style="color: {{item.typeColor}}">
              {{item.icon}}{{item.amount}}
            </text>
          </view>

          <view class="record-footer">
            <text class="record-type">{{item.typeLabel}}</text>
            <text class="record-time">{{item.timeText}}</text>
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{hasMore}}">
        <view class="loading-dots" wx:if="{{isLoadingMore}}">
          <text>加载中...</text>
        </view>
        <text class="load-more-text" wx:else>上拉加载更多</text>
      </view>

      <view class="no-more" wx:if="{{!hasMore && records.length > 0}}">
        <text>— 没有更多记录了 —</text>
      </view>
    </view>
  </view>
</view>

<!-- 积分规则弹窗 -->
<view class="modal {{showRulesModal ? 'show' : ''}}" wx:if="{{showRulesModal}}">
  <view class="modal-mask" bindtap="hideRulesModal"></view>
  <view class="modal-content">
    <view class="modal-title">积分规则</view>
    <view class="modal-body">
      <view class="rule-section">
        <text class="section-title">获取方式</text>
        <text class="section-text">1. 新用户注册：+100积分</text>
        <text class="section-text">2. 每日签到：+5~30积分（连续签到递增）</text>
        <text class="section-text">3. 邀请好友：双方各+50积分</text>
      </view>
      <view class="rule-section">
        <text class="section-title">积分用途</text>
        <text class="section-text">积分可兑换平台内免单券、提现免手续费券等权益（功能开发中，敬请期待）。</text>
      </view>
      <view class="rule-section">
        <text class="section-title">重要说明</text>
        <text class="section-text">积分仅用于平台内权益兑换，不可提现、不可转让、无现金价值。</text>
        <text class="section-text">平台保留调整积分发放规则、有效期、可兑换权益种类与比例的权利。</text>
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn confirm" bindtap="hideRulesModal">我知道了</button>
    </view>
  </view>
</view>
