<!-- 我的举报列表 -->
<view class="page-bg"></view>

<wxs src="../../utils/money.wxs" module="money" />
<view class="container wdd-page">
  <view class="wdd-page-bg"></view>
  <!-- Tab 栏 -->
  <view class="tab-wrap">
    <view class="tab-bar">
      <view
        class="tab-item {{activeTab === 'pending' ? 'active' : ''}}"
        data-tab="pending"
        bindtap="switchTab"
      >
        <text>处理中</text>
      </view>
      <view
        class="tab-item {{activeTab === 'processed' ? 'active' : ''}}"
        data-tab="processed"
        bindtap="switchTab"
      >
        <text>已处理</text>
      </view>
      <view class="tab-indicator {{activeTab === 'pending' ? 'left' : 'right'}}"></view>
    </view>
  </view>

  <!-- 处理中列表 -->
  <scroll-view
    wx:if="{{activeTab === 'pending'}}"
    class="list-scroll"
    scroll-y
    bindscrolltolower="loadMore"
    lower-threshold="100"
    enhanced
    show-scrollbar="{{false}}"
  >
    <!-- 骨架屏 -->
    <view wx:if="{{loading && pendingList.length === 0}}" class="skeleton-list">
      <view wx:for="{{[1,2,3]}}" wx:key="*this" class="skeleton-card">
        <view class="sk-header">
          <view class="sk-tag"></view>
          <view class="sk-badge"></view>
        </view>
        <view class="sk-line long"></view>
        <view class="sk-line short"></view>
        <view class="sk-footer">
          <view class="sk-time"></view>
          <view class="sk-btns">
            <view class="sk-btn"></view>
            <view class="sk-btn"></view>
          </view>
        </view>
      </view>
    </view>

    <view wx:elif="{{pendingList.length === 0}}" class="empty-state">
      <view class="empty-illustration">
        <wdd-icon name="clipboard-list" color="#9AA5B1" size="72"></wdd-icon>
      </view>
      <text class="empty-title">暂无处理中的举报</text>
      <text class="empty-desc">你提交的举报会显示在这里</text>
    </view>

    <view wx:else class="card-list">
      <view wx:for="{{pendingList}}" wx:key="_id" class="card">
        <view class="card-main">
          <view class="card-header">
            <text class="status-tag status-pending">处理中</text>
            <view class="task-tag">
              <wdd-icon name="{{item.taskIcon}}" color="{{item.taskColor || 'var(--brand-primary)'}}" size="22"></wdd-icon>
              <text>{{item.displayTaskName}}</text>
            </view>
          </view>

          <text class="card-title">{{item.displayTitle}}</text>

          <view class="info-list">
            <view class="info-row">
              <text class="info-label">被举报对象</text>
              <text class="info-value">{{item.displayTarget}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">举报原因</text>
              <text class="info-value">{{item.reportTypeLabel}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">生成时间</text>
              <text class="info-value">{{item.createTimeText || ''}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">悬赏金额</text>
              <text class="info-value amount-value">¥{{money.format(item.displayRewardAmount)}}</text>
            </view>
          </view>

          <view class="card-footer">
            <view class="card-actions">
              <view class="btn btn-cancel" data-id="{{item._id}}" bindtap="cancelReport" hover-class="btn-cancel-hover">
                <text>撤销</text>
              </view>
              <view class="btn btn-detail" data-id="{{item._id}}" bindtap="goDetail" hover-class="btn-detail-hover">
                <text>详情</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{!pendingHasMore && pendingList.length > 0}}" class="no-more">— 没有更多了 —</view>
  </scroll-view>

  <!-- 已处理列表 -->
  <scroll-view
    wx:if="{{activeTab === 'processed'}}"
    class="list-scroll"
    scroll-y
    bindscrolltolower="loadMore"
    lower-threshold="100"
    enhanced
    show-scrollbar="{{false}}"
  >
    <view wx:if="{{loading && processedList.length === 0}}" class="skeleton-list">
      <view wx:for="{{[1,2,3]}}" wx:key="*this" class="skeleton-card">
        <view class="sk-header">
          <view class="sk-tag"></view>
          <view class="sk-badge"></view>
        </view>
        <view class="sk-line long"></view>
        <view class="sk-line short"></view>
        <view class="sk-footer">
          <view class="sk-time"></view>
          <view class="sk-btns">
            <view class="sk-btn"></view>
          </view>
        </view>
      </view>
    </view>

    <view wx:elif="{{processedList.length === 0}}" class="empty-state">
      <view class="empty-illustration">
        <wdd-icon name="circle-check-big" color="#6DD5B0" size="72"></wdd-icon>
      </view>
      <text class="empty-title">暂无已处理的举报</text>
      <text class="empty-desc">已处理的举报会归档到这里</text>
    </view>

    <view wx:else class="card-list">
      <view wx:for="{{processedList}}" wx:key="_id" class="card processed">
        <view class="card-main">
          <view class="card-header">
            <text class="status-tag status-{{item.status}}">{{item.status === 'cancelled' ? '已撤销' : '已处理'}}</text>
            <view class="task-tag {{item.status === 'cancelled' ? 'cancelled' : ''}}">
              <wdd-icon name="{{item.taskIcon}}" color="{{item.status === 'cancelled' ? '#98A2AE' : (item.taskColor || 'var(--brand-primary)')}}" size="22"></wdd-icon>
              <text>{{item.displayTaskName}}</text>
            </view>
          </view>

          <text class="card-title">{{item.displayTitle}}</text>

          <view class="info-list">
            <view class="info-row">
              <text class="info-label">被举报对象</text>
              <text class="info-value">{{item.displayTarget}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">举报原因</text>
              <text class="info-value">{{item.reportTypeLabel}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">生成时间</text>
              <text class="info-value">{{item.createTimeText || ''}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">悬赏金额</text>
              <text class="info-value amount-value">¥{{money.format(item.displayRewardAmount)}}</text>
            </view>
          </view>

          <view class="card-footer">
            <view class="card-actions">
              <view class="btn btn-detail" data-id="{{item._id}}" bindtap="goDetail" hover-class="btn-detail-hover">
                <text>详情</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{!processedHasMore && processedList.length > 0}}" class="no-more">— 没有更多了 —</view>
  </scroll-view>
</view>
