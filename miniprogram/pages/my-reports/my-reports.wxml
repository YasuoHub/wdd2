<!-- 我的举报列表 -->
<view class="page-bg"></view>

<wxs src="../../utils/money.wxs" module="money" />
<view class="container wdd-page">
  <view class="wdd-page-bg"></view>
  <!-- Tab 栏 -->
  <view class="tab-wrap">
    <view class="tab-bar">
      <view
        class="tab-item {{activeTab === 'pending' ? 'active' : ''}}"
        data-tab="pending"
        bindtap="switchTab"
      >
        <text>处理中</text>
      </view>
      <view
        class="tab-item {{activeTab === 'processed' ? 'active' : ''}}"
        data-tab="processed"
        bindtap="switchTab"
      >
        <text>已处理</text>
      </view>
      <view class="tab-indicator {{activeTab === 'pending' ? 'left' : 'right'}}"></view>
    </view>
  </view>

  <!-- 处理中列表 -->
  <scroll-view
    wx:if="{{activeTab === 'pending'}}"
    class="list-scroll"
    scroll-y
    bindscrolltolower="loadMore"
    lower-threshold="100"
    enhanced
    show-scrollbar="{{false}}"
  >
    <!-- 骨架屏 -->
    <view wx:if="{{loading && pendingList.length === 0}}" class="skeleton-list">
      <view wx:for="{{[1,2,3]}}" wx:key="*this" class="skeleton-card">
        <view class="sk-header">
          <view class="sk-tag"></view>
          <view class="sk-badge"></view>
        </view>
        <view class="sk-line long"></view>
        <view class="sk-line short"></view>
        <view class="sk-footer">
          <view class="sk-time"></view>
          <view class="sk-btns">
            <view class="sk-btn"></view>
            <view class="sk-btn"></view>
          </view>
        </view>
      </view>
    </view>

    <view wx:elif="{{pendingList.length === 0}}" class="empty-state">
      <view class="empty-illustration">
        <wdd-icon name="clipboard-list" color="#9AA5B1" size="72"></wdd-icon>
      </view>
      <text class="empty-title">暂无处理中的举报</text>
      <text class="empty-desc">你提交的举报会显示在这里</text>
    </view>

    <view wx:else class="card-list">
      <view wx:for="{{pendingList}}" wx:key="_id" class="record-card">
        <view class="amount"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(item.displayRewardAmount)}}</text></view>
        <view class="card-main">
          <view class="tag-row">
            <view class="status-badge breaking">处理中</view>
            <view class="type-tag">{{item.displayTaskName}}</view>
          </view>

          <text class="card-title">{{item.displayTitle}}</text>

          <view class="info-list">
            <view class="info-row">
              <text class="info-label">被举报对象</text>
              <view class="info-value user-value">
                <image wx:if="{{item.displayTargetAvatar}}" class="target-avatar" src="{{item.displayTargetAvatar}}" mode="aspectFill"></image>
                <view wx:else class="target-avatar placeholder"><wdd-icon name="user-round" color="#7B8794" size="22"></wdd-icon></view>
                <text class="target-name">{{item.displayTarget}}</text>
                <text wx:if="{{item.displayTargetRole}}" class="target-role">{{item.displayTargetRole}}</text>
              </view>
            </view>
            <view class="info-row">
              <text class="info-label">举报原因</text>
              <text class="info-value">{{item.reportTypeLabel}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">生成时间</text>
              <text class="info-value">{{item.createTimeText || ''}}</text>
            </view>
          </view>

          <view class="card-footer">
            <view class="card-actions">
              <view class="action-btn outline" data-id="{{item._id}}" bindtap="cancelReport">
                <text>撤销</text>
              </view>
              <view class="action-btn outline" data-id="{{item._id}}" bindtap="goDetail">
                <text>详情</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{!pendingHasMore && pendingList.length > 0}}" class="no-more">— 没有更多了 —</view>
  </scroll-view>

  <!-- 已处理列表 -->
  <scroll-view
    wx:if="{{activeTab === 'processed'}}"
    class="list-scroll"
    scroll-y
    bindscrolltolower="loadMore"
    lower-threshold="100"
    enhanced
    show-scrollbar="{{false}}"
  >
    <view wx:if="{{loading && processedList.length === 0}}" class="skeleton-list">
      <view wx:for="{{[1,2,3]}}" wx:key="*this" class="skeleton-card">
        <view class="sk-header">
          <view class="sk-tag"></view>
          <view class="sk-badge"></view>
        </view>
        <view class="sk-line long"></view>
        <view class="sk-line short"></view>
        <view class="sk-footer">
          <view class="sk-time"></view>
          <view class="sk-btns">
            <view class="sk-btn"></view>
          </view>
        </view>
      </view>
    </view>

    <view wx:elif="{{processedList.length === 0}}" class="empty-state">
      <view class="empty-illustration">
        <wdd-icon name="circle-check-big" color="#6DD5B0" size="72"></wdd-icon>
      </view>
      <text class="empty-title">暂无已处理的举报</text>
      <text class="empty-desc">已处理的举报会归档到这里</text>
    </view>

    <view wx:else class="card-list">
      <view wx:for="{{processedList}}" wx:key="_id" class="record-card processed">
        <view class="amount"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(item.displayRewardAmount)}}</text></view>
        <view class="card-main">
          <view class="tag-row">
            <view class="status-badge {{item.status === 'cancelled' ? 'cancelled' : 'completed'}}">{{item.status === 'cancelled' ? '已撤销' : '已处理'}}</view>
            <view class="type-tag {{item.status === 'cancelled' ? 'cancelled' : ''}}">{{item.displayTaskName}}</view>
          </view>

          <text class="card-title">{{item.displayTitle}}</text>

          <view class="info-list">
            <view class="info-row">
              <text class="info-label">被举报对象</text>
              <view class="info-value user-value">
                <image wx:if="{{item.displayTargetAvatar}}" class="target-avatar" src="{{item.displayTargetAvatar}}" mode="aspectFill"></image>
                <view wx:else class="target-avatar placeholder"><wdd-icon name="user-round" color="#7B8794" size="22"></wdd-icon></view>
                <text class="target-name">{{item.displayTarget}}</text>
                <text wx:if="{{item.displayTargetRole}}" class="target-role">{{item.displayTargetRole}}</text>
              </view>
            </view>
            <view class="info-row">
              <text class="info-label">举报原因</text>
              <text class="info-value">{{item.reportTypeLabel}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">生成时间</text>
              <text class="info-value">{{item.createTimeText || ''}}</text>
            </view>
          </view>

          <view class="card-footer">
            <view class="card-actions">
              <view class="action-btn outline" data-id="{{item._id}}" bindtap="goDetail">
                <text>详情</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{!processedHasMore && processedList.length > 0}}" class="no-more">— 没有更多了 —</view>
  </scroll-view>
</view>
