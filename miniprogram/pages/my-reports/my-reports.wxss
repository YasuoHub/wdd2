@import "../../styles/wdd-polish.wxss";

page {
  width: 100%;
  min-height: 100vh;
  background: #f5f7fa;
}

.page-bg,
.wdd-page-bg {
  display: none;
}

.container {
  min-height: 100vh;
  background: #f5f7fa;
  box-sizing: border-box;
}

.tab-wrap {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 24rpx 30rpx 18rpx;
  background: rgba(255, 255, 255, 0.96);
  border-bottom: 1rpx solid #edf1f5;
  box-sizing: border-box;
}

.tab-bar {
  position: relative;
  display: flex;
  gap: 18rpx;
  width: 100%;
}

.tab-item {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  line-height: 58rpx;
  text-align: center;
  border: 1rpx solid #dce4ed;
  border-radius: 10rpx;
  background: #ffffff;
  color: #1f2933;
  font-size: 26rpx;
  font-weight: 400;
  box-sizing: border-box;
  white-space: nowrap;
}

.tab-item.active {
  border-color: #6eacff;
  background: #f0f7ff;
  color: #096bd8;
  font-weight: 600;
  box-shadow: none;
}

.tab-indicator {
  display: none;
}

.list-scroll {
  height: calc(100vh - 104rpx);
  padding: 22rpx 30rpx 34rpx;
  width: 100%;
  box-sizing: border-box;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.record-card {
  position: relative;
  overflow: hidden;
  width: 100%;
  padding: 26rpx 26rpx 24rpx;
  border: 1rpx solid #e5ebf2;
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(22, 34, 51, 0.08);
  box-sizing: border-box;
}

.record-card:active {
  transform: scale(0.992);
  box-shadow: 0 6rpx 18rpx rgba(22, 34, 51, 0.06);
}

.record-card.processed {
  background: #fbfcfd;
}

.card-main {
  box-sizing: border-box;
}

.tag-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 16rpx;
  min-width: 0;
}

.status-badge,
.type-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 600;
  box-sizing: border-box;
  white-space: nowrap;
}

.status-badge.breaking {
  background: #fff1df;
  color: #ec6a00;
}

.status-badge.completed {
  background: #e8f8ec;
  color: #24a148;
}

.status-badge.cancelled {
  background: #eef1f4;
  color: #58616d;
}

.type-tag {
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  background: #eaf3ff;
  color: #096bd8;
}

.type-tag.cancelled {
  background: #eef1f4;
  color: #58616d;
}

.card-title {
  display: block;
  margin-bottom: 18rpx;
  color: #05070a;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 22rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
  color: #4f5b68;
}

.info-label {
  flex-shrink: 0;
  width: 136rpx;
  color: #5f6975;
  font-size: 26rpx;
  line-height: 1.45;
}

.info-value {
  flex: 1;
  min-width: 0;
  color: #4f5b68;
  font-size: 26rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.amount-value {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  color: #f06a00;
  font-size: 28rpx;
  line-height: 36rpx;
  font-weight: 600;
}

.user-value {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.target-avatar {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #eef1f4;
}

.target-avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.target-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.target-role {
  flex-shrink: 0;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  background: #eef1f4;
  color: #5f6975;
  font-size: 22rpx;
  line-height: 30rpx;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 22rpx;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 18rpx;
  width: 100%;
}

.action-btn {
  min-width: 148rpx;
  height: 58rpx;
  line-height: 56rpx;
  padding: 0 28rpx;
  border-radius: 8rpx;
  border: 1rpx solid #0f73df;
  color: #096bd8;
  background: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.action-btn.outline {
  background: #ffffff;
}

.action-btn:active {
  opacity: 0.82;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 48rpx 0;
}

.empty-illustration {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--brand-primary-08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #1f2933;
  font-weight: 400;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #52616f;
}

.skeleton-list {
  width: 100%;
}

.skeleton-card {
  background: #ffffff;
  border-radius: 14rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(22, 34, 51, 0.08);
  border: 1rpx solid #e5ebf2;
  width: 100%;
  box-sizing: border-box;
}

.sk-header,
.sk-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sk-header {
  margin-bottom: 20rpx;
}

.sk-tag,
.sk-badge,
.sk-line,
.sk-time,
.sk-btn {
  border-radius: 8rpx;
  background: linear-gradient(90deg, #e8edf2 25%, #f0f4f8 50%, #e8edf2 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.sk-tag {
  width: 150rpx;
  height: 40rpx;
}

.sk-badge {
  width: 160rpx;
  height: 40rpx;
}

.sk-line {
  height: 28rpx;
  margin-bottom: 14rpx;
}

.sk-line.long {
  width: 100%;
}

.sk-line.short {
  width: 65%;
}

.sk-footer {
  margin-top: 20rpx;
}

.sk-time {
  width: 160rpx;
  height: 24rpx;
}

.sk-btns {
  display: flex;
  gap: 16rpx;
}

.sk-btn {
  width: 100rpx;
  height: 52rpx;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.no-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #8a96a3;
}
