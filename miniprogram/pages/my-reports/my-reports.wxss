/* 我的举报/申诉列表 — 问当地城市服务风格 */

/* 页面背景层 */
.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  background: linear-gradient(
    180deg,
    var(--bg-primary, #f5f7fa) 0%,
    var(--bg-secondary, #eef2f6) 30%,
    var(--bg-tertiary, #e8f4fd) 70%,
    #f5faff 100%
  );
}

.container {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

/* ========== Tab 栏 ========== */
.tab-wrap {
  padding: 0;
}

.tab-bar {
  display: flex;
  position: relative;
  background: #fff;
  padding: 0 40rpx;
  height: 88rpx;
  flex-shrink: 0;
  border-radius: 0;
  box-shadow: none;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--text-secondary);
  position: relative;
  z-index: 1;
  height: auto;
  border-radius: 0;
  transition: none;
}

.tab-item.active {
  color: var(--primary-color, #07c160);
  font-weight: 400;
  background: none;
  box-shadow: none;
}

.tab-indicator {
  position: absolute;
  left: 40rpx;
  bottom: 0;
  width: calc(50% - 40rpx);
  height: 4rpx;
  background: var(--primary-color, #07c160);
  border-radius: 2rpx;
  transition: transform 0.3s;
}

.tab-indicator.left { transform: translateX(0); }
.tab-indicator.right { transform: translateX(100%); }

/* ========== 滚动区 ========== */
.list-scroll {
  flex: 1;
  padding: 16rpx 16rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
}

/* ========== 卡片 ========== */
.card-list {
  width: 100%;
}

.card {
  display: block;
  background: #ffffff;
  border-radius: 14rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 2rpx 14rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid #e8edf3;
  overflow: hidden;
  transition: transform 0.15s ease;
  width: 100%;
  box-sizing: border-box;
}

.card:active {
  transform: scale(0.985);
}

.card.processed {
  opacity: 1;
}

/* 左侧色条 */
.card-accent {
  width: 8rpx;
  flex-shrink: 0;
  border-radius: 4rpx;
  margin: 28rpx 0 28rpx 24rpx;
}

/* 右侧内容区 */
.card-main {
  padding: 28rpx 28rpx 0;
  min-width: 0;
}

.card-header {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

/* 类型标签 */
.type-tag-wrap {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.type-tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  background: rgba(253, 121, 168, 0.1);
  color: #e17055;
  border-radius: 8rpx;
  font-size: 24rpx;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.type-tag.cancelled {
  background: rgba(178, 190, 195, 0.15);
  color: #636e72;
}

.task-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  max-width: 260rpx;
  height: 42rpx;
  padding: 0 16rpx;
  background: var(--brand-primary-08);
  color: var(--brand-primary);
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 42rpx;
  box-sizing: border-box;
}

.task-tag text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-tag.cancelled {
  background: rgba(152, 162, 174, 0.12);
  color: #7b8794;
}

/* 状态标签 */
.status-tag {
  display: inline-flex;
  align-items: center;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 42rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.status-pending {
  background: var(--brand-primary-10);
  color: var(--brand-primary);
}

.status-cancelled {
  background: rgba(178, 190, 195, 0.15);
  color: #636e72;
}

.status-resolved {
  background: rgba(39, 174, 96, 0.1);
  color: #27ae60;
}

.card-title {
  display: block;
  color: #1f2933;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 600;
  margin-bottom: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.info-label {
  flex-shrink: 0;
  color: #7b8794;
  font-size: 25rpx;
  line-height: 34rpx;
}

.info-value {
  min-width: 0;
  color: #52616f;
  font-size: 25rpx;
  line-height: 34rpx;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.amount-value {
  color: #ff6b1a;
  font-size: 32rpx;
  line-height: 38rpx;
  font-weight: 600;
}

/* 理由 */
.card-body {
  margin-bottom: 16rpx;
}

.reason-text {
  font-size: 28rpx;
  color: var(--text-primary, #1f2933);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-all;
}

/* 关联任务条 */
.card-task {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 18rpx;
  border-radius: var(--radius-xs, 12rpx);
  margin-bottom: 18rpx;
}

.task-icon {
  font-size: 26rpx;
  flex-shrink: 0;
}

.task-type {
  font-size: 24rpx;
  color: var(--text-secondary, #52616f);
  flex: 1;
}

.task-reward {
  font-size: 26rpx;
  color: #e17055;
  font-weight: 400;
  flex-shrink: 0;
}

/* 底部 */
.card-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin: 0 -28rpx;
  padding: 18rpx 24rpx 20rpx;
  border-top: 1rpx solid #eef2f6;
}

.time-text {
  font-size: 22rpx;
  color: #b2bec3;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 18rpx;
  width: 100%;
}

/* 按钮 */
.btn {
  min-width: 146rpx;
  height: 54rpx;
  padding: 0 26rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 400;
  line-height: 54rpx;
  text-align: center;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.btn-cancel {
  background: #ffffff;
  color: #52616f;
  border: 1rpx solid #d7dee8;
}

.btn-cancel-hover {
  background: #f5f7fa;
}

.btn-detail {
  background: #ffffff;
  color: var(--brand-primary);
  border: 1rpx solid var(--brand-primary);
}

.btn-detail-hover {
  background: var(--brand-primary-08);
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 48rpx 0;
}

.empty-illustration {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--brand-primary-08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 72rpx;
}

.empty-title {
  font-size: 30rpx;
  color: var(--text-primary, #1f2933);
  font-weight: 400;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: var(--text-secondary, #52616f);
}

/* ========== 骨架屏 ========== */
.skeleton-list {
  width: 100%;
}

.skeleton-card {
  background: var(--bg-card, rgba(255,255,255,0.95));
  border-radius: var(--radius-md, 28rpx);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm, 0 2rpx 12rpx var(--brand-primary-08));
  width: 100%;
  box-sizing: border-box;
}

.sk-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.sk-tag {
  width: 180rpx;
  height: 36rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #e8edf2 25%, #f0f4f8 50%, #e8edf2 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.sk-line {
  height: 28rpx;
  border-radius: 8rpx;
  margin-bottom: 14rpx;
  background: linear-gradient(90deg, #e8edf2 25%, #f0f4f8 50%, #e8edf2 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.sk-line.long { width: 100%; }
.sk-line.short { width: 65%; }

.sk-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.sk-time {
  width: 160rpx;
  height: 24rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #e8edf2 25%, #f0f4f8 50%, #e8edf2 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.sk-btns {
  display: flex;
  gap: 16rpx;
}

.sk-btn {
  width: 100rpx;
  height: 52rpx;
  border-radius: 9999rpx;
  background: linear-gradient(90deg, #e8edf2 25%, #f0f4f8 50%, #e8edf2 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* ========== 底部 ========== */
.no-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #b2bec3;
}
@import "../../styles/wdd-polish.wxss";
