@import "../../styles/wdd-polish.wxss";

page {
  width: 100%;
  min-height: 100vh;
  background: #f5f7fa;
}

.page-bg,
.wdd-page-bg {
  display: none;
}

.container {
  min-height: 100vh;
  background: #f5f7fa;
  box-sizing: border-box;
}

.tab-wrap {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 24rpx 30rpx 18rpx;
  background: rgba(255, 255, 255, 0.96);
  border-bottom: 1rpx solid #edf1f5;
  box-sizing: border-box;
}

.tab-bar {
  position: relative;
  display: flex;
  gap: 18rpx;
  width: 100%;
}

.tab-item {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  line-height: 58rpx;
  text-align: center;
  border: 1rpx solid #dce4ed;
  border-radius: 10rpx;
  background: #ffffff;
  color: #1f2933;
  font-size: 26rpx;
  font-weight: 400;
  box-sizing: border-box;
  white-space: nowrap;
}

.tab-item.active {
  border-color: #6eacff;
  background: #f0f7ff;
  color: #096bd8;
  font-weight: 600;
  box-shadow: none;
}

.tab-indicator {
  display: none;
}

.list-scroll {
  height: calc(100vh - 104rpx);
  padding: 26rpx 30rpx 36rpx;
  width: 100%;
  box-sizing: border-box;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.record-card,
.skeleton-card {
  width: 100%;
  border: 1rpx solid #e1e8f0;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.045);
  box-sizing: border-box;
}

.record-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx 30rpx 28rpx;
}

.record-card:active {
  transform: scale(0.994);
  box-shadow: 0 5rpx 16rpx rgba(15, 23, 42, 0.045);
}

.record-card.processed {
  background: #ffffff;
}

.card-main {
  box-sizing: border-box;
}

.amount {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  z-index: 1;
  max-width: 156rpx;
  color: var(--money-gold);
  font-size: 36rpx;
  line-height: 1.1;
  font-weight: 700;
  text-align: right;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

.tag-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  min-width: 0;
  margin-bottom: 28rpx;
  padding-right: 162rpx;
}

.status-badge,
.type-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 38rpx;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  border: 1rpx solid transparent;
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 500;
  box-sizing: border-box;
  white-space: nowrap;
}

.status-badge.breaking {
  background: #fff8e6;
  border-color: var(--vitality-yellow-26);
  color: #946b00;
}

.status-badge.completed {
  background: var(--fresh-mint-08);
  border-color: var(--fresh-mint-18);
  color: var(--fresh-mint);
}

.status-badge.cancelled {
  background: #eef2f6;
  border-color: #d9e2ec;
  color: var(--text-secondary);
}

.type-tag {
  max-width: 260rpx;
  overflow: hidden;
  color: var(--sky-deep);
  text-overflow: ellipsis;
  background: var(--brand-primary-08);
  border-color: #d9ecfb;
}

.type-tag.cancelled {
  color: var(--text-secondary);
  background: #eef2f6;
  border-color: #d9e2ec;
}

.card-title {
  display: block;
  margin-bottom: 24rpx;
  color: #111827;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 0;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  color: var(--text-secondary);
}

.info-label {
  flex-shrink: 0;
  width: auto;
  color: var(--text-tertiary);
  font-size: 25rpx;
  line-height: 1.45;
}

.info-label::after {
  content: "：";
}

.info-value {
  flex: 1;
  min-width: 0;
  color: var(--text-secondary);
  font-size: 25rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-value {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.target-avatar {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #eef2f6;
}

.target-avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.target-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.target-role {
  flex-shrink: 0;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  background: #eef2f6;
  color: var(--text-secondary);
  font-size: 21rpx;
  line-height: 28rpx;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 26rpx;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  width: 100%;
}

.action-btn {
  min-width: 136rpx;
  height: 58rpx;
  line-height: 56rpx;
  padding: 0 26rpx;
  border-radius: 8rpx;
  border: 1rpx solid #c9d7e4;
  color: var(--sky-deep);
  background: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.action-btn.outline {
  background: #ffffff;
}

.action-btn:active {
  opacity: 0.86;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 48rpx 0;
}

.empty-illustration {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 148rpx;
  height: 148rpx;
  margin-bottom: 30rpx;
  border-radius: 16rpx;
  background: var(--brand-primary-08);
}

.empty-title {
  margin-bottom: 12rpx;
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 500;
}

.empty-desc {
  color: var(--text-secondary);
  font-size: 24rpx;
}

.skeleton-list {
  width: 100%;
}

.skeleton-card {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.sk-header,
.sk-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sk-header {
  margin-bottom: 20rpx;
}

.sk-tag,
.sk-badge,
.sk-line,
.sk-time,
.sk-btn {
  border-radius: 6rpx;
  background: linear-gradient(90deg, #e8edf2 25%, #f0f4f8 50%, #e8edf2 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.sk-tag {
  width: 150rpx;
  height: 40rpx;
}

.sk-badge {
  width: 160rpx;
  height: 40rpx;
}

.sk-line {
  height: 28rpx;
  margin-bottom: 14rpx;
}

.sk-line.long {
  width: 100%;
}

.sk-line.short {
  width: 65%;
}

.sk-footer {
  margin-top: 20rpx;
}

.sk-time {
  width: 160rpx;
  height: 24rpx;
}

.sk-btns {
  display: flex;
  gap: 16rpx;
}

.sk-btn {
  width: 100rpx;
  height: 52rpx;
}

@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}

.no-more {
  padding: 32rpx 0 4rpx;
  color: #8a96a3;
  font-size: 24rpx;
  text-align: center;
}
