<view class="container">
  <view wx:if="{{isLoading}}" class="loading-wrap">
    <text>加载中...</text>
  </view>

  <block wx:else>
    <!-- 对方申诉摘要 -->
    <view class="opponent-card" wx:if="{{opponentInfo}}">
      <view class="card-title">对方申诉摘要</view>
      <view class="info-row">
        <text class="info-label">申诉类型</text>
        <text class="info-value">{{opponentInfo.typeLabel || opponentInfo.typeValue}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">申诉理由</text>
        <text class="info-value reason">{{opponentInfo.reason}}</text>
      </view>
      <view class="images-wrap" wx:if="{{opponentInfo.images.length > 0}}">
        <image wx:for="{{opponentInfo.images}}" wx:key="index" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
      </view>
    </view>

    <!-- 倒计时 -->
    <view class="countdown-card">
      <text class="countdown-label">补充材料剩余时间</text>
      <text class="countdown-value {{!canSupplement ? 'timeout' : ''}}">{{supplementCountdown || '已超时'}}</text>
    </view>

    <!-- 操作按钮 -->
    <button class="action-btn {{canSupplement ? '' : 'disabled'}}" bindtap="goToSupplement" disabled="{{!canSupplement}}">
      {{canSupplement ? '补充申诉材料' : '补充材料已截止'}}
    </button>
  </block>
</view>
