<!-- 消息中心页面 -->
<view class="container wdd-page">
  <view class="wdd-page-bg"></view>
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">消息</text>
    <!-- 右上角系统通知铃铛 -->
    <view class="notification-bell" bindtap="openSystemNotifications">
      <wdd-icon name="bell" color="#1677D2" size="36"></wdd-icon>
      <view wx:if="{{systemUnread > 0}}" class="bell-badge">{{systemUnread > 99 ? '99+' : systemUnread}}</view>
    </view>
  </view>

  <!-- 聊天类型标签 -->
  <view class="message-tabs">
    <view
      class="tab {{currentChatTab === 'seeker' ? 'active' : ''}}"
      bindtap="switchChatTab"
      data-tab="seeker"
    >
      <wdd-icon name="send" color="#1677D2" size="26"></wdd-icon>
      <text>求助</text>
      <view wx:if="{{seekerChatUnread > 0}}" class="tab-badge">{{seekerChatUnread}}</view>
    </view>
    <view
      class="tab {{currentChatTab === 'helper' ? 'active' : ''}}"
      bindtap="switchChatTab"
      data-tab="helper"
    >
      <wdd-icon name="handshake" color="#1677D2" size="28"></wdd-icon>
      <text>帮助</text>
      <view wx:if="{{helperChatUnread > 0}}" class="tab-badge">{{helperChatUnread}}</view>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view class="message-list" scroll-y enhanced show-scrollbar="{{false}}" refresher-enabled="{{true}}" refresher-triggered="{{isRefreshing}}" bindrefresherrefresh="onRefresh">
    <!-- 求助聊天 -->
    <block wx:if="{{currentChatTab === 'seeker'}}">
      <block wx:if="{{seekerChatList.length === 0}}">
        <empty type="normal" icon="message-square-text" title="暂无求助聊天" desc="你发布的求助将会在这里显示"></empty>
        <view wx:if="{{hiddenSeekerCount > 0}}" class="hidden-tip">已折叠超过30天的任务</view>
      </block>

      <view wx:else class="chat-list">
        <view
          wx:for="{{seekerChatList}}"
          wx:key="needId"
          class="message-card {{item.unread > 0 ? 'unread' : ''}}"
          bindtap="goToChat"
          data-needid="{{item.needId}}"
          data-isseeker="{{true}}"
        >
          <!-- 左侧头像 -->
          <view class="message-avatar">
            <image wx:if="{{item.otherUserAvatar}}" src="{{item.otherUserAvatar}}" mode="aspectFill" />
            <text wx:else>{{item.otherUserNickname ? item.otherUserNickname[0] : '?'}}</text>
          </view>
          <!-- 右侧信息 -->
          <view class="message-info">
            <!-- 第一行：昵称 + 任务类型、位置、状态 -->
            <view class="message-top-row">
              <view class="message-nickname">{{item.otherUserNickname}}</view>
              <view class="message-meta-inline">
                <view class="meta-icon">
                  <wdd-icon name="{{item.typeIcon}}" color="{{item.typeColor || '#1677D2'}}" size="24"></wdd-icon>
                </view>
                <view class="meta-location" wx:if="{{item.locationName}}">
                  <wdd-icon name="map-pin" color="#7B8794" size="20"></wdd-icon>
                  <text>{{item.locationName}}</text>
                </view>
                <view class="message-status {{item.needStatus}}">{{item.statusText}}</view>
              </view>
            </view>
            <!-- 第二行：最后消息和时间 -->
            <view class="message-bottom">
              <view class="message-last">{{item.lastMessage}}</view>
              <view class="message-right">
                <view class="message-time">{{item.lastTime}}</view>
                <view wx:if="{{item.unread > 0}}" class="unread-count">{{item.unread < 100 ? item.unread : '99+'}}</view>
              </view>
            </view>
          </view>
        </view>
        <view wx:if="{{hiddenSeekerCount > 0}}" class="hidden-tip">已折叠超过30天的任务</view>
      </view>
    </block>

    <!-- 帮助聊天 -->
    <block wx:if="{{currentChatTab === 'helper'}}">
      <block wx:if="{{helperChatList.length === 0}}">
        <empty type="normal" icon="handshake" title="暂无帮助聊天" desc="去任务大厅接单开始聊天吧" showBtn="true" btnText="去大厅" btnType="primary" bind:btnTap="goToHall"></empty>
        <view wx:if="{{hiddenHelperCount > 0}}" class="hidden-tip">已折叠超过30天的任务</view>
      </block>

      <view wx:else class="chat-list">
        <view
          wx:for="{{helperChatList}}"
          wx:key="needId"
          class="message-card {{item.unread > 0 ? 'unread' : ''}}"
          bindtap="goToChat"
          data-needid="{{item.needId}}"
          data-isseeker="{{false}}"
        >
          <!-- 左侧头像 -->
          <view class="message-avatar">
            <image wx:if="{{item.otherUserAvatar}}" src="{{item.otherUserAvatar}}" mode="aspectFill" />
            <text wx:else>{{item.otherUserNickname ? item.otherUserNickname[0] : '?'}}</text>
          </view>
          <!-- 右侧信息 -->
          <view class="message-info">
            <!-- 第一行：昵称 + 任务类型、位置、状态 -->
            <view class="message-top-row">
              <view class="message-nickname">{{item.otherUserNickname}}</view>
              <view class="message-meta-inline">
                <view class="meta-icon">
                  <wdd-icon name="{{item.typeIcon}}" color="{{item.typeColor || '#1677D2'}}" size="24"></wdd-icon>
                </view>
                <view class="meta-location" wx:if="{{item.locationName}}">
                  <wdd-icon name="map-pin" color="#7B8794" size="20"></wdd-icon>
                  <text>{{item.locationName}}</text>
                </view>
                <view class="message-status {{item.needStatus}}">{{item.statusText}}</view>
              </view>
            </view>
            <!-- 第二行：最后消息和时间 -->
            <view class="message-bottom">
              <view class="message-last">{{item.lastMessage}}</view>
              <view class="message-right">
                <view class="message-time">{{item.lastTime}}</view>
                <view wx:if="{{item.unread > 0}}" class="unread-count">{{item.unread < 100 ? item.unread : '99+'}}</view>
              </view>
            </view>
          </view>
        </view>
        <view wx:if="{{hiddenHelperCount > 0}}" class="hidden-tip">已折叠超过30天的任务</view>
      </view>
    </block>
  </scroll-view>

  <bottom-sheet show="{{showSystemModal}}" title="系统通知" maxHeight="82vh" bind:close="closeSystemNotifications">
    <scroll-view class="system-sheet-body" scroll-y enhanced show-scrollbar="{{false}}">
      <view wx:if="{{systemList.length === 0}}" class="system-sheet-empty">
        <view class="system-sheet-empty-icon">
          <wdd-icon name="bell" color="#9AA5B1" size="70"></wdd-icon>
        </view>
        <view class="system-sheet-empty-text">暂无系统通知</view>
      </view>

      <view wx:else class="system-list sheet-system-list">
        <view
          wx:for="{{systemList}}"
          wx:key="_id"
          class="system-card {{!item.is_read ? 'unread' : ''}}"
          bindtap="onSystemNotificationTap"
          data-item="{{item}}"
        >
          <view class="system-icon-wrapper">
            <wdd-icon name="{{item.icon}}" color="{{item.iconColor || '#1677D2'}}" size="40"></wdd-icon>
          </view>
          <view class="system-info">
            <view class="system-top">
              <view class="system-title">{{item.title}}</view>
              <view class="system-time">{{item.timeText}}</view>
            </view>
            <view class="system-content">{{item.content}}</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </bottom-sheet>
</view>
