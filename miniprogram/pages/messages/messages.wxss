/* ============================================
   问当地 - 消息中心 - 城市服务清爽可信风格
   ============================================ */

.container {
  height: 100vh;
  background:
    linear-gradient(180deg, rgba(240, 248, 255, 0.92) 0%, rgba(247, 251, 255, 0.98) 46%, #f5f7fa 100%);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  width: 100%;
  /* 使用 flex 布局，让列表区域自动填充剩余空间 */
  display: flex;
  flex-direction: column;
}

.container::before {
  display: none;
}

.container::after {
  display: none;
}

/* 页面标题 - 毛玻璃效果 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 32rpx 24rpx;
  position: relative;
  z-index: 1;
  /* 防止被压缩 */
  flex-shrink: 0;
}

.page-title {
  font-size: 44rpx;
  font-weight: 400;
  color: #1f2d3d;
  letter-spacing: 0;
}

.unread-badge {
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  color: white;
  font-size: 22rpx;
  font-weight: 400;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-orange);
  position: relative;
  overflow: hidden;
}

.unread-badge::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--bg-glass) 0%, transparent 100%);
}

/* 右上角通知铃铛 */
.notification-bell {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--brand-primary-16);
  transition: all 0.3s ease;
}

.notification-bell:active {
  transform: scale(0.95);
  background: var(--border-light);
}

.bell-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  color: white;
  font-size: 20rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-orange);
  border: 2rpx solid white;
}

/* 消息标签 - 精致胶囊按钮 */
.message-tabs {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx 28rpx;
  position: relative;
  z-index: 1;
  /* 防止被压缩 */
  flex-shrink: 0;
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 24rpx;
  font-size: 28rpx;
  color: var(--text-tertiary);
  position: relative;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--brand-primary-12);
  transition: all 0.3s ease;
  font-weight: 400;
}

.tab.active {
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  color: white;
  box-shadow: var(--shadow-sky);
  transform: translateY(-2rpx);
}

.tab:active {
  transform: scale(0.98);
}

.tab-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  color: white;
  font-size: 20rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-orange);
  border: 2rpx solid white;
}

/* 消息列表 - 使用 flex: 1 自动填充剩余空间 */
.message-list {
  flex: 1;
  padding: 0 32rpx;
  position: relative;
  z-index: 1;
  box-sizing: border-box;
  width: 100%;
  /* 确保列表内容可以滚动 */
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 已折叠超过30天的任务 - 底部提示 */
.hidden-tip {
  padding: 32rpx 0 64rpx;
  text-align: center;
  color: var(--text-light);
  font-size: 24rpx;
}

/* 聊天列表 */
.chat-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

/* 系统通知列表 */
.system-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

/* 消息卡片 - 毛玻璃效果 */
.message-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 28rpx 30rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 28rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--brand-primary-10);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  animation: cardSlideIn 0.4s ease-out;
}

.message-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

@keyframes cardSlideIn {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.message-card.unread {
  background: rgba(232, 246, 255, 0.92);
  border-color: var(--brand-primary-20);
}

.message-card.unread::before {
  content: "";
  position: absolute;
  left: 0;
  top: 20%;
  width: 6rpx;
  height: 60%;
  background: linear-gradient(
    180deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  border-radius: 0 4rpx 4rpx 0;
}

/* 消息头像 */
.message-avatar {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: white;
  flex-shrink: 0;
  box-shadow: 0 10rpx 26rpx var(--brand-primary-18);
  position: relative;
  overflow: hidden;
}

.message-avatar image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.message-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* 第一行：昵称 + 任务信息 */
.message-top-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

/* 昵称 - 自适应宽度 */
.message-nickname {
  font-size: 32rpx;
  font-weight: 400;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 0;
  max-width: 200rpx;
}

/* 内联元信息 - 右对齐 */
.message-meta-inline {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  justify-content: flex-end;
}

.message-meta-inline .meta-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.message-meta-inline .meta-location {
  font-size: 22rpx;
  color: var(--text-tertiary);
  width: 150rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: left;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.message-meta-inline .meta-location text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 元信息行（类型、位置、状态） */
.message-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: var(--border-light);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
}

.meta-icon {
  font-size: 22rpx;
}

.meta-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部行（最后消息和时间） */
.message-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.message-last {
  font-size: 26rpx;
  color: var(--text-light);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.message-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.message-time {
  font-size: 22rpx;
  color: var(--text-light);
  font-weight: 400;
}

/* 消息状态标签 */
.message-status {
  font-size: 22rpx;
  font-weight: 400;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-full);
  position: relative;
  overflow: hidden;
}

.message-status::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--bg-glass) 0%, transparent 100%);
}

.message-status.ongoing {
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  color: white;
  box-shadow: var(--shadow-sky);
}

.message-status.completed {
  background: var(--border-light);
  color: var(--text-light);
}

.message-status.cancelled {
  background: var(--border-light);
  color: var(--vitality-orange);
}

/* 未读消息数 */
.unread-count {
  min-width: 40rpx;
  height: 40rpx;
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  color: white;
  font-size: 22rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-orange);
  position: relative;
  overflow: hidden;
}

.unread-count::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--bg-glass) 0%, transparent 100%);
}

/* 系统通知列表 */
.system-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

/* 系统通知卡片 */
.system-card {
  display: block;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 26rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--brand-primary-10);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  animation: cardSlideIn 0.4s ease-out;
  width: 100%;
  box-sizing: border-box;
}

.system-card:active {
  transform: scale(0.98);
}

.system-card.unread {
  background: var(--border-light);
  border-color: var(--border-color);
}

.system-card.unread::before {
  content: "";
  position: absolute;
  left: 0;
  top: 20%;
  width: 6rpx;
  height: 60%;
  background: linear-gradient(
    180deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  border-radius: 0 4rpx 4rpx 0;
}

.system-icon-wrapper {
  width: 44rpx;
  height: 44rpx;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: none;
  position: relative;
  overflow: visible;
}

.system-icon-wrapper::before {
  display: none;
}

.system-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.system-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  gap: 16rpx;
}

.system-title-line {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.system-title {
  font-size: 30rpx;
  font-weight: 400;
  color: var(--text-primary);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.system-time {
  font-size: 22rpx;
  color: var(--text-light);
  font-weight: 400;
  flex-shrink: 0;
}

.system-content {
  font-size: 26rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
  word-wrap: break-word;
  word-break: break-all;
}

/* 空状态 - 城市服务风格 */
.empty-state {
  text-align: center;
  padding: 140rpx 40rpx;
  position: relative;
  z-index: 1;
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 40rpx;
  background: linear-gradient(
    135deg,
    var(--bg-secondary) 0%,
    var(--bg-tertiary) 50%,
    var(--sky-pale) 100%
  );
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  box-shadow: var(--shadow-md);
  position: relative;
  overflow: hidden;
}

.empty-icon::before {
  content: "";
  position: absolute;
  width: 60%;
  height: 60%;
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  border-radius: 50%;
  opacity: 0.1;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 加载动画 */
.loading {
  text-align: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--sky-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* 系统通知底部抽屉 */
.system-sheet-body {
  max-height: calc(82vh - 140rpx);
  width: 100%;
  box-sizing: border-box;
  padding: 4rpx 0 8rpx;
}

.sheet-system-list {
  padding-bottom: 8rpx;
}

.modal-empty {
  text-align: center;
  padding: 116rpx 40rpx 124rpx;
}

.modal-empty-icon {
  margin-bottom: 24rpx;
  display: flex;
  justify-content: center;
}

.modal-empty-text {
  font-size: 28rpx;
  color: var(--text-light);
}
@import "../../styles/wdd-polish.wxss";
