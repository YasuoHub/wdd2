/* ============================================
   问当地 - 消息中心 - 梦幻渐变风格
   风格：柔和粉彩 / 毛玻璃 / 精致优雅
   ============================================ */

/* CSS变量 - 设计令牌 */
:root {
  /* 主色调 - 梦幻渐变 */
  --gradient-dream: linear-gradient(135deg, #FFE6FA 0%, #E6F4FF 50%, #F0FFFA 100%);
  --gradient-primary: linear-gradient(135deg, #8093F1 0%, #B388EB 100%);
  --gradient-accent: linear-gradient(135deg, #FF9A9E 0%, #FAD0C4 100%);

  /* 文字颜色 */
  --text-primary: #2A2D43;
  --text-secondary: #6C6F8B;
  --text-tertiary: #A0A3BD;
  --text-light: #FFFFFF;

  /* 阴影 */
  --shadow-soft: 0 4rpx 20rpx rgba(42, 45, 67, 0.08);
  --shadow-medium: 0 8rpx 32rpx rgba(42, 45, 67, 0.12);
  --shadow-glow: 0 0 40rpx rgba(179, 136, 235, 0.3);

  /* 圆角 */
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  --radius-full: 9999rpx;

  /* 间距 */
  --space-xs: 12rpx;
  --space-sm: 20rpx;
  --space-md: 32rpx;
  --space-lg: 48rpx;
}

/* 页面容器 - 梦幻渐变背景 */
.container {
  min-height: 100vh;
  background: var(--gradient-dream);
  padding-bottom: 40rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰元素 */
.container::before {
  content: '';
  position: absolute;
  top: 100rpx;
  left: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, rgba(179, 136, 235, 0.08) 0%, rgba(128, 147, 241, 0.08) 100%);
  border-radius: 50%;
  z-index: 0;
}

.container::after {
  content: '';
  position: absolute;
  bottom: 200rpx;
  right: -150rpx;
  width: 350rpx;
  height: 350rpx;
  background: linear-gradient(135deg, rgba(255, 154, 158, 0.08) 0%, rgba(250, 208, 196, 0.08) 100%);
  border-radius: 50%;
  z-index: 0;
}

/* 页面标题 - 毛玻璃效果 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 32rpx 20rpx;
  position: relative;
  z-index: 1;
}

.page-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-primary);
  background: linear-gradient(135deg, #2A2D43 0%, #6C6F8B 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.unread-badge {
  background: var(--gradient-accent);
  color: white;
  font-size: 22rpx;
  font-weight: 700;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 16rpx rgba(255, 154, 158, 0.4);
  position: relative;
  overflow: hidden;
}

.unread-badge::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

/* 消息标签 - 精致胶囊按钮 */
.message-tabs {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 24rpx;
  position: relative;
  z-index: 1;
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
  box-shadow: var(--shadow-soft);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
}

.tab.active {
  background: var(--gradient-primary);
  color: white;
  box-shadow: 0 4rpx 20rpx rgba(128, 147, 241, 0.4);
  transform: translateY(-2rpx);
}

.tab:active {
  transform: scale(0.98);
}

.tab-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #FF6B8B 0%, #FF8E53 100%);
  color: white;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  border-radius: var(--radius-full);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 139, 0.4);
  border: 2rpx solid white;
}

/* 消息列表 */
.message-list {
  height: calc(100vh - 200rpx);
  padding: 0 32rpx;
  position: relative;
  z-index: 1;
}

/* 聊天列表 */
.chat-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 消息卡片 - 毛玻璃效果 */
.message-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-soft);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  animation: cardSlideIn 0.4s ease-out;
}

.message-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(42, 45, 67, 0.06);
}

@keyframes cardSlideIn {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.message-card.unread {
  background: rgba(128, 147, 241, 0.08);
  border-color: rgba(128, 147, 241, 0.2);
}

.message-card.unread::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  width: 4rpx;
  height: 60%;
  background: var(--gradient-primary);
  border-radius: 0 4rpx 4rpx 0;
}

/* 消息头像 */
.message-avatar {
  width: 88rpx;
  height: 88rpx;
  background: var(--gradient-primary);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(128, 147, 241, 0.3);
  position: relative;
  overflow: hidden;
}

.message-avatar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.message-info {
  flex: 1;
  min-width: 0;
}

.message-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.message-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.message-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

.message-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.message-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 消息状态标签 */
.message-status {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-full);
  position: relative;
  overflow: hidden;
}

.message-status::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.message-status.ongoing {
  background: linear-gradient(135deg, #A1C4FD 0%, #C2E9FB 100%);
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(161, 196, 253, 0.3);
}

.message-status.completed {
  background: rgba(160, 163, 189, 0.2);
  color: var(--text-tertiary);
}

.message-status.cancelled {
  background: rgba(255, 154, 158, 0.2);
  color: #FF6B8B;
}

/* 未读消息数 */
.unread-count {
  min-width: 40rpx;
  height: 40rpx;
  background: var(--gradient-accent);
  color: white;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  border-radius: var(--radius-full);
  box-shadow: 0 2rpx 10rpx rgba(255, 154, 158, 0.4);
  position: relative;
  overflow: hidden;
}

.unread-count::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

/* 系统通知列表 */
.system-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 系统通知卡片 */
.system-card {
  display: flex;
  gap: 20rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-soft);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  animation: cardSlideIn 0.4s ease-out;
}

.system-card:active {
  transform: scale(0.98);
}

.system-card.unread {
  background: rgba(255, 154, 158, 0.05);
  border-color: rgba(255, 154, 158, 0.2);
}

.system-card.unread::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  width: 4rpx;
  height: 60%;
  background: var(--gradient-accent);
  border-radius: 0 4rpx 4rpx 0;
}

.system-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  background: var(--gradient-accent);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(255, 154, 158, 0.3);
  position: relative;
  overflow: hidden;
}

.system-icon-wrapper::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.system-icon {
  font-size: 44rpx;
  position: relative;
  z-index: 1;
}

.system-info {
  flex: 1;
}

.system-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.system-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.system-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

.system-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 空状态 - 梦幻风格 */
.empty-state {
  text-align: center;
  padding: 140rpx 40rpx;
  position: relative;
  z-index: 1;
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 40rpx;
  background: linear-gradient(135deg, rgba(128, 147, 241, 0.1) 0%, rgba(179, 136, 235, 0.1) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  position: relative;
  overflow: hidden;
}

.empty-icon::before {
  content: '';
  position: absolute;
  width: 60%;
  height: 60%;
  background: linear-gradient(135deg, #8093F1 0%, #B388EB 100%);
  border-radius: 50%;
  opacity: 0.1;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* 加载动画 */
.loading {
  text-align: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(128, 147, 241, 0.2);
  border-top-color: #8093F1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}
