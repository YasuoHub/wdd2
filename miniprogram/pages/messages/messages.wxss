/* ============================================
   问当地 - 消息中心 - 天蓝色青春活力风格
   ============================================ */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F8FF 0%, #E6F3FF 30%, #EDF7FF 70%, #F5FAFF 100%);
  padding-bottom: 40rpx;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  width: 100%;
}

/* 背景装饰元素 */
.container::before {
  content: '';
  position: absolute;
  top: 100rpx;
  left: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(93, 184, 230, 0.1) 0%, transparent 70%);
  border-radius: 50%;
  z-index: 0;
}

.container::after {
  content: '';
  position: absolute;
  bottom: 200rpx;
  right: -150rpx;
  width: 350rpx;
  height: 350rpx;
  background: radial-gradient(circle, rgba(255, 140, 105, 0.08) 0%, transparent 70%);
  border-radius: 50%;
  z-index: 0;
}

/* 页面标题 - 毛玻璃效果 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 32rpx 24rpx;
  position: relative;
  z-index: 1;
}

.page-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #2C3E50;
  background: linear-gradient(135deg, #2C3E50 0%, #5DB8E6 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.unread-badge {
  background: linear-gradient(135deg, #FF8C69 0%, #FF9A8B 100%);
  color: white;
  font-size: 22rpx;
  font-weight: 700;
  padding: 10rpx 24rpx;
  border-radius: 9999rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 140, 105, 0.35);
  position: relative;
  overflow: hidden;
}

.unread-badge::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

/* 消息标签 - 精致胶囊按钮 */
.message-tabs {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx 28rpx;
  position: relative;
  z-index: 1;
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 28rpx;
  font-size: 28rpx;
  color: #6B8BA4;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
  transition: all 0.3s ease;
  font-weight: 500;
}

.tab.active {
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  color: white;
  box-shadow: 0 4rpx 20rpx rgba(93, 184, 230, 0.35);
  transform: translateY(-2rpx);
}

.tab:active {
  transform: scale(0.98);
}

.tab-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #FF8C69 0%, #FF9A8B 100%);
  color: white;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  border-radius: 9999rpx;
  box-shadow: 0 2rpx 10rpx rgba(255, 140, 105, 0.4);
  border: 2rpx solid white;
}

/* 消息列表 */
.message-list {
  height: calc(100vh - 200rpx);
  padding: 0 32rpx;
  position: relative;
  z-index: 1;
  box-sizing: border-box;
  width: 100%;
}

/* 聊天列表 */
.chat-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

/* 系统通知列表 */
.system-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

/* 消息卡片 - 毛玻璃效果 */
.message-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  animation: cardSlideIn 0.4s ease-out;
}

.message-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(93, 184, 230, 0.08);
}

@keyframes cardSlideIn {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.message-card.unread {
  background: rgba(93, 184, 230, 0.06);
  border-color: rgba(93, 184, 230, 0.15);
}

.message-card.unread::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  width: 6rpx;
  height: 60%;
  background: linear-gradient(180deg, #5DB8E6 0%, #7EC8E8 100%);
  border-radius: 0 4rpx 4rpx 0;
}

/* 消息头像 */
.message-avatar {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.3);
  position: relative;
  overflow: hidden;
}

.message-avatar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.message-info {
  flex: 1;
  min-width: 0;
}

.message-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  gap: 16rpx;
}

.message-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E50;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-time {
  font-size: 22rpx;
  color: #A8C4D4;
  font-weight: 500;
  flex-shrink: 0;
}

.message-content {
  font-size: 26rpx;
  color: #6B8BA4;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 12rpx;
}
.message-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.message-body-right {
  display: flex;
  flex: 1;
  justify-content: flex-end;
  gap: 8rpx;
  align-items: center;
  flex-direction: row;
}

/* 消息状态标签 */
.message-status {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 9999rpx;
  position: relative;
  overflow: hidden;
}

.message-status::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.message-status.ongoing {
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  color: white;
  box-shadow: 0 2rpx 10rpx rgba(93, 184, 230, 0.3);
}

.message-status.completed {
  background: rgba(168, 196, 212, 0.2);
  color: #8FA8B8;
}

.message-status.cancelled {
  background: rgba(255, 140, 105, 0.15);
  color: #FF8C69;
}

/* 未读消息数 */
.unread-count {
  min-width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #FF8C69 0%, #FF9A8B 100%);
  color: white;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  border-radius: 9999rpx;
  box-shadow: 0 2rpx 10rpx rgba(255, 140, 105, 0.35);
  position: relative;
  overflow: hidden;
}

.unread-count::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

/* 系统通知列表 */
.system-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

/* 系统通知卡片 */
.system-card {
  display: flex;
  gap: 20rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  animation: cardSlideIn 0.4s ease-out;
}

.system-card:active {
  transform: scale(0.98);
}

.system-card.unread {
  background: rgba(255, 140, 105, 0.05);
  border-color: rgba(255, 140, 105, 0.15);
}

.system-card.unread::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  width: 6rpx;
  height: 60%;
  background: linear-gradient(180deg, #FF8C69 0%, #FF9A8B 100%);
  border-radius: 0 4rpx 4rpx 0;
}

.system-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #FF8C69 0%, #FF9A8B 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(255, 140, 105, 0.3);
  position: relative;
  overflow: hidden;
}

.system-icon-wrapper::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.system-icon {
  font-size: 44rpx;
  position: relative;
  z-index: 1;
}

.system-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.system-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  gap: 16rpx;
}

.system-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E50;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.system-time {
  font-size: 22rpx;
  color: #A8C4D4;
  font-weight: 500;
  flex-shrink: 0;
}

.system-content {
  font-size: 26rpx;
  color: #6B8BA4;
  line-height: 1.5;
  word-wrap: break-word;
  word-break: break-all;
}

/* 空状态 - 天蓝风格 */
.empty-state {
  text-align: center;
  padding: 140rpx 40rpx;
  position: relative;
  z-index: 1;
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 40rpx;
  background: linear-gradient(135deg, #E6F3FF 0%, #D4EDF7 50%, #C4E5F5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  box-shadow: 0 6rpx 30rpx rgba(93, 184, 230, 0.15);
  position: relative;
  overflow: hidden;
}

.empty-icon::before {
  content: '';
  position: absolute;
  width: 60%;
  height: 60%;
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  border-radius: 50%;
  opacity: 0.1;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #8FA8B8;
}

/* 加载动画 */
.loading {
  text-align: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(93, 184, 230, 0.2);
  border-top-color: #5DB8E6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #6B8BA4;
}
