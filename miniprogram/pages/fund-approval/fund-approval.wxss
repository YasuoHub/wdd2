page { background: var(--bg-secondary); }
.container { display: flex; flex-direction: column; height: 100vh; }

.loading, .empty { text-align: center; padding: 80rpx 40rpx; font-size: 28rpx; color: var(--text-tertiary); }

/* Tab 栏 */
.tab-bar {
  display: flex; position: relative; background: #fff;
  padding: 0 40rpx; height: 88rpx; flex-shrink: 0;
}
.tab-item {
  flex: 1; display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; color: var(--text-secondary); position: relative; z-index: 1;
}
.tab-item.active { color: var(--primary-color, #07c160); font-weight: 600; }
.tab-indicator {
  position: absolute; left: 40rpx; bottom: 0; width: calc(50% - 40rpx);
  height: 4rpx; background: var(--primary-color, #07c160);
  transition: transform 0.3s; border-radius: 2rpx;
}
.tab-indicator.left { transform: translateX(0); }
.tab-indicator.right { transform: translateX(100%); }

/* 滚动列表 */
.scroll-list { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; }
.application-list { display: flex; flex-direction: column; gap: 16rpx; padding: 20rpx; }

/* 卡片 */
.application-card {
  display: flex; background: #fff; border-radius: 16rpx; overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.application-card:active { background: #fafafa; }
.application-card.resolved { opacity: 0.7; }

/* 左侧色条 */
.card-left { width: 6rpx; flex-shrink: 0; }
.left-pending { background: #5DB8E6; }
.left-approved { background: #07c160; }
.left-rejected { background: #e74c3c; }

.card-body { flex: 1; padding: 24rpx 24rpx 20rpx; min-width: 0; }

/* 用户信息行 */
.card-user-row {
  display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx;
}
.user-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; flex-shrink: 0; }
.user-avatar-default {
  width: 48rpx; height: 48rpx; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  background: var(--bg-secondary); font-size: 28rpx;
}
.user-name { flex: 1; font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.status-tag {
  flex-shrink: 0; font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 20rpx;
}
.status-pending { color: #5DB8E6; background: rgba(93,184,230,0.1); }
.status-approved { color: #07c160; background: rgba(7,193,96,0.08); }
.status-rejected { color: #e74c3c; background: rgba(231,76,60,0.08); }

/* 金额行 */
.card-amount-row {
  display: flex; align-items: baseline; gap: 16rpx; margin-bottom: 12rpx;
}
.amount-label { font-size: 26rpx; color: var(--text-tertiary); }
.amount-value { font-size: 40rpx; font-weight: 700; color: #e86a4a; }

/* 信息行 */
.card-info-row {
  display: flex; align-items: center; margin-bottom: 8rpx; font-size: 26rpx;
}
.info-label { color: var(--text-tertiary); width: 140rpx; flex-shrink: 0; }
.info-value { color: var(--text-primary); }
.info-value.fee { color: var(--text-tertiary); }
.info-value.withdrawn-text { color: #07c160; }

/* 驳回理由 */
.reject-reason-row {
  display: flex; align-items: flex-start; gap: 8rpx;
  margin: 10rpx 0; padding: 12rpx 16rpx;
  background: rgba(231,76,60,0.06); border-radius: 8rpx;
}
.reject-label { font-size: 24rpx; color: var(--text-tertiary); flex-shrink: 0; }
.reject-text { font-size: 24rpx; color: #e74c3c; flex: 1; }

/* 底部 */
.card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 14rpx; }
.footer-time { display: flex; align-items: center; gap: 6rpx; font-size: 24rpx; color: var(--text-light); }
.footer-approve-time { font-size: 22rpx; color: var(--text-tertiary); }

/* 审批按钮 */
.approve-btn {
  font-size: 24rpx; color: #fff; background: #5DB8E6;
  padding: 8rpx 28rpx; border-radius: 32rpx; font-weight: 500;
}

.loading-more, .no-more { text-align: center; padding: 24rpx 0; font-size: 26rpx; color: var(--text-tertiary); }

/* 弹窗 */
.modal {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1000;
  display: flex; align-items: flex-end; justify-content: center;
  opacity: 0; visibility: hidden; transition: all 0.3s;
}
.modal.show { opacity: 1; visibility: visible; }
.modal-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.5); }
.modal-content {
  position: relative; background: #fff; border-radius: 24rpx 24rpx 0 0;
  width: 100%; padding: 40rpx 30rpx; max-height: 80vh; overflow-y: auto; z-index: 1;
}
.modal-title { font-size: 36rpx; font-weight: 600; text-align: center; margin-bottom: 32rpx; }

.approve-info {
  background: var(--bg-secondary); border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 28rpx;
}
.approve-label { display: block; font-size: 28rpx; color: var(--text-primary); margin-bottom: 8rpx; }
.approve-label:last-child { margin-bottom: 0; }

.form-row { margin-bottom: 24rpx; }
.form-label { display: block; font-size: 28rpx; color: var(--text-primary); margin-bottom: 12rpx; font-weight: 500; }
.picker {
  height: 80rpx; background: var(--bg-secondary); border-radius: 16rpx;
  display: flex; align-items: center; justify-content: space-between; padding: 0 24rpx;
  font-size: 28rpx; color: var(--text-primary);
}
.arrow { font-size: 22rpx; color: var(--text-light); }

.modal-footer { display: flex; gap: 20rpx; margin-top: 32rpx; }
.modal-btn { flex: 1; height: 80rpx; border-radius: 40rpx; font-size: 30rpx; display: flex; align-items: center; justify-content: center; }
.modal-btn.cancel { background: var(--bg-secondary); color: var(--text-primary); }
.modal-btn.confirm { background: #5DB8E6; color: #fff; }
