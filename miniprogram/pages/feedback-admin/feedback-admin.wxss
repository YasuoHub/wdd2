page { background: var(--bg-secondary); }
.container { display: flex; flex-direction: column; height: 100vh; box-sizing: border-box; background: #F5F7FA; }
.tab-bar { position: relative; z-index: 1; display: flex; flex-shrink: 0; height: 76rpx; margin: 18rpx 24rpx 6rpx; padding: 6rpx; box-sizing: border-box; background: #FFFFFF; border: 1rpx solid var(--border-light); border-radius: 22rpx; box-shadow: var(--shadow-card-ios); }
.tab-item { position: relative; z-index: 1; display: flex; flex: 1; align-items: center; justify-content: center; color: var(--text-secondary); font-size: 28rpx; border-radius: 16rpx; }
.tab-item.active { color: var(--sky-deep); font-weight: 400; background: var(--brand-primary-08); }
.tab-indicator { display: none; }
.list-scroll { position: relative; z-index: 1; flex: 1; min-height: 0; box-sizing: border-box; }
.card-list { display: flex; flex-direction: column; gap: 20rpx; padding: 22rpx 24rpx 32rpx; }
.feedback-card { padding: 26rpx; background: #FFFFFF; border: 1rpx solid rgba(217, 226, 236, 0.92); border-radius: 24rpx; box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.055); }
.feedback-card.resolved { opacity: .88; }
.card-head { display: flex; align-items: flex-start; gap: 20rpx; }
.card-title { flex: 1; color: var(--text-primary); font-size: 31rpx; font-weight: 600; line-height: 1.45; }
.status { flex-shrink: 0; padding: 7rpx 15rpx; font-size: 22rpx; border-radius: 10rpx; }
.status.pending { color: #946B00; background: #FFF3D6; }
.status.resolved { color: #167A5D; background: #E5F7F0; }
.card-content { display: -webkit-box; margin-top: 18rpx; overflow: hidden; color: var(--text-secondary); font-size: 26rpx; line-height: 1.6; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
.meta-row { display: flex; gap: 20rpx; margin-top: 22rpx; padding-top: 18rpx; color: var(--text-light); font-size: 22rpx; border-top: 1rpx solid #EEF1F5; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 180rpx 40rpx 80rpx; }
.empty-title { margin-top: 24rpx; color: var(--text-primary); font-size: 30rpx; }
.state-text { padding: 50rpx 0; color: var(--text-light); font-size: 24rpx; text-align: center; }
