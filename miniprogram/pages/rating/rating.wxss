@import "../../styles/wdd-polish.wxss";

/* ============================================
   问当地 - 评价页
   对齐设计图：清爽蓝白、整合卡片、底部固定提交
   ============================================ */

.container {
  width: 100%;
  min-height: 100vh;
  padding: 58rpx 32rpx 56rpx;
  box-sizing: border-box;
  overflow: visible;
  position: relative;
  background:
    linear-gradient(180deg, #f6f9fe 0%, #f9fbff 42%, #f5f8fc 100%);
}

.container::before,
.container::after,
.wdd-page-bg {
  display: none;
}

.rating-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  margin: 0 0 44rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.hero-title {
  display: block;
  color: #151922;
  font-size: 40rpx;
  font-weight: 400;
  line-height: 1.25;
  letter-spacing: 0;
}

.hero-highlight {
  color: var(--brand-primary);
}

.hero-subtitle {
  color: #7b8794;
  font-size: 26rpx;
  line-height: 1.5;
}

/* 设计图不展示头像信息，但保留结构和数据加载逻辑 */
.target-card {
  display: none;
}

.rating-card {
  overflow: hidden;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid rgba(217, 226, 236, 0.78);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 42rpx rgba(15, 23, 42, 0.06);
  position: relative;
  z-index: 1;
}

.rating-section,
.tags-section,
.comment-section {
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
  margin: 0;
  position: relative;
  z-index: 1;
}

.rating-section {
  padding: 36rpx 30rpx 34rpx;
}

.rating-title,
.section-title {
  display: block;
  color: #151922;
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.4;
  text-align: left;
}

.rating-title {
  margin-bottom: 34rpx;
}

.stars-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 18rpx;
}

.star {
  width: 62rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: transform 0.16s ease, opacity 0.16s ease;
}

.star:active {
  transform: scale(0.9);
}

.star:not(.active) {
  opacity: 0.78;
}

.star-symbol {
  color: #d4dbe5;
  font-size: 68rpx;
  font-weight: 400;
  line-height: 1;
  text-align: center;
  text-shadow: none;
}

.star.active .star-symbol {
  color: var(--money-gold);
}

.rating-text {
  display: block;
  color: var(--brand-primary);
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.4;
  text-align: center;
}

.tags-section,
.comment-section {
  border-top: 1rpx solid #e8eef5;
}

.tags-section {
  padding: 34rpx 28rpx 30rpx;
}

.section-title {
  margin-bottom: 28rpx;
}

.section-title-muted {
  color: #8a94a3;
  font-weight: 400;
}

.tags-wrapper {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 20rpx 14rpx;
}

.tag {
  min-width: 0;
  height: 66rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: #ffffff;
  border: 2rpx solid #d7dde6;
  border-radius: 999rpx;
  color: #7b8794;
  font-size: 26rpx;
  font-weight: 400;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  box-shadow: none;
  transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease;
}

.tag text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tag:active {
  transform: scale(0.96);
}

.tag.active {
  color: var(--brand-primary);
  background: var(--brand-primary-05);
  border-color: var(--brand-primary);
  box-shadow: none;
}

.tag-check {
  width: 28rpx;
  height: 28rpx;
  flex: 0 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--brand-primary);
}

.comment-section {
  padding: 34rpx 28rpx 32rpx;
}

.comment-box {
  width: 100%;
  min-height: 224rpx;
  padding: 22rpx 24rpx 54rpx;
  position: relative;
  background: #ffffff;
  border: 1.5rpx solid #cfd6df;
  border-radius: 16rpx;
  box-shadow: none;
}

.comment-input {
  width: 100%;
  min-height: 164rpx;
  color: #1f2933;
  font-size: 26rpx;
  line-height: 1.6;
}

.comment-input::placeholder {
  color: #a3acb8;
}

.char-count {
  position: absolute;
  right: 24rpx;
  bottom: 18rpx;
  color: #7b8794;
  font-size: 26rpx;
  font-weight: 400;
  line-height: 1;
}

.tips-section {
  margin: 22rpx 8rpx 0;
  padding: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
  position: relative;
  z-index: 1;
}

.tips-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
  color: #8a94a3;
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1.4;
}

.tips-title::before,
.tips-item::before {
  display: none;
}

.tips-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 0;
  color: #9aa5b1;
  font-size: 22rpx;
  line-height: 1.7;
}

.tips-item + .tips-item {
  margin-top: 8rpx;
}

.tips-item text {
  flex: 1;
}

.submit-section {
  margin-top: 28rpx;
  padding: 0;
  background: transparent;
  box-shadow: none;
  position: relative;
  z-index: 1;
}

.submit-btn {
  width: 100%;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: 12rpx;
  background: #c6d6e6;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1;
  box-shadow: none;
  transition: transform 0.16s ease, box-shadow 0.16s ease, background 0.16s ease;
}

.submit-btn.active {
  background: var(--brand-primary);
  box-shadow: 0 12rpx 26rpx var(--brand-primary-20);
  transform: none;
}

.submit-btn.active:active {
  transform: scale(0.985);
  box-shadow: 0 8rpx 18rpx var(--brand-primary-18);
}

.submit-btn::after {
  border: none;
}

@media screen and (max-width: 320px) {
  .container {
    padding-left: 24rpx;
    padding-right: 24rpx;
  }

  .hero-title {
    font-size: 36rpx;
  }

  .stars-wrapper {
    gap: 18rpx;
  }

  .tag {
    font-size: 24rpx;
    padding: 0 12rpx;
  }
}
