/* ============================================
   问当地 - 星级评价 - 城市服务清爽可信风格
   ============================================ */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #fafbfc 46%, #f3f8fc 100%);
  padding: 32rpx;
  padding-bottom: 80rpx;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  width: 100%;
}

.container::before {
  display: none;
}

.container::after {
  display: none;
}

/* 评价对象信息卡片 */
.target-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid rgba(22, 119, 210, 0.08);
  position: relative;
  z-index: 1;
}

.target-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: white;
  overflow: hidden;
  border: 4rpx solid white;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 210, 0.3);
  position: relative;
}

.target-avatar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.target-avatar image {
  width: 100%;
  height: 100%;
}

.target-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.target-label {
  font-size: 24rpx;
  color: var(--text-light);
  font-weight: 500;
}

.target-name {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-primary);
}

/* 任务信息卡片 */
.task-card {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid rgba(22, 119, 210, 0.08);
  position: relative;
  z-index: 1;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.task-type {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.task-points {
  font-size: 28rpx;
  background: linear-gradient(135deg, var(--vitality-orange) 0%, var(--vitality-coral) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: 800;
}

.task-desc {
  font-size: 28rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
}

/* 星级评分区域 - 精致卡片 */
.rating-section {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-xl);
  padding: 48rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid rgba(22, 119, 210, 0.08);
  text-align: center;
  position: relative;
  z-index: 1;
}

.rating-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 700;
  margin-bottom: 36rpx;
  display: block;
}

/* 星星容器 */
.stars-wrapper {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.star {
  padding: 10rpx;
  transition: all 0.2s ease;
}

.star:active {
  transform: scale(0.9);
}

.star-icon {
  font-size: 72rpx;
  color: #E8F0F5;
  transition: all 0.3s ease;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

/* 激活状态的星星 - 金色渐变 */
.star.active .star-icon {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 0 4rpx 12rpx rgba(255, 215, 0, 0.4);
  animation: starPop 0.3s ease-out;
}

@keyframes starPop {
  0% {
    transform: scale(0.5);
    opacity: 0;
  }
  50% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 评分文字 */
.rating-text {
  font-size: 34rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: 800;
  padding: 12rpx 28rpx;
  background-color: rgba(255, 215, 0, 0.1);
  border-radius: var(--radius-full);
  display: inline-block;
}

/* 评价标签区域 */
.tags-section {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid rgba(22, 119, 210, 0.08);
  position: relative;
  z-index: 1;
}

.section-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 700;
  margin-bottom: 28rpx;
  display: block;
}

.tags-wrapper {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 评价标签 - 精致胶囊 */
.tag {
  padding: 18rpx 36rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: var(--radius-full);
  font-size: 26rpx;
  color: var(--text-tertiary);
  border: 2rpx solid var(--border-light);
  transition: all 0.3s ease;
  font-weight: 500;
}

.tag:active {
  transform: scale(0.95);
}

/* 选中状态的标签 */
.tag.active {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  color: white;
  border-color: transparent;
  box-shadow: var(--shadow-sky);
}

/* 评价内容输入 */
.comment-section {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid rgba(22, 119, 210, 0.08);
  position: relative;
  z-index: 1;
}

.comment-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  padding-bottom: 40rpx;
}

.comment-input::placeholder {
  color: var(--text-light);
}

.char-count {
  position: absolute;
  bottom: 16rpx;
  right: 24rpx;
  font-size: 24rpx;
  color: var(--text-light);
  font-weight: 500;
}

/* 提交按钮 */
.submit-section {
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
}

.submit-btn {
  width: 100%;
  padding: 32rpx 0;
  background: linear-gradient(135deg, #D4E5F0 0%, #C4D8E5 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: var(--radius-full);
  border: none;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 210, 0.15);
}

.submit-btn.active {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  box-shadow: 0 8rpx 32rpx rgba(22, 119, 210, 0.4);
  transform: translateY(-2rpx);
}

.submit-btn.active:active {
  transform: scale(0.98) translateY(0);
  box-shadow: 0 4rpx 20rpx rgba(22, 119, 210, 0.3);
}

.submit-btn::after {
  border: none;
}

/* 评价说明 - 提示卡片 */
.tips-section {
  background: rgba(255, 215, 0, 0.08);
  backdrop-filter: blur(10rpx);
  border-radius: 28rpx;
  padding: 28rpx;
  border: 2rpx solid rgba(255, 215, 0, 0.15);
  position: relative;
  z-index: 1;
}

.tips-title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 700;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tips-title::before {
  display: none;
}

.tips-item {
  display: block;
  font-size: 26rpx;
  color: var(--text-tertiary);
  line-height: 1.8;
  padding-left: 44rpx;
  position: relative;
}

.tips-item::before {
  content: '•';
  position: absolute;
  left: 20rpx;
  color: #FFD700;
  font-weight: 700;
}
/* ============================================
   城市服务风格视觉覆盖：清爽可信、交易清楚、低装饰
   ============================================ */
.container,
.chat-container {
  background: #f5f7fa;
}

.header,
.footer,
.input-area,
.popup-content,
.modal-content,
.rules-modal-content {
  background: #ffffff;
  border-color: var(--border-light);
  box-shadow: var(--shadow-card);
}

.section-card,
.task-card,
.user-card,
.menu-list,
.quick-panel,
.need-feed,
.login-tip-card,
.balance-section,
.record-card,
.ticket-card,
.report-card,
.appeal-card,
.profile-card,
.rating-card,
.info-card,
.form-card,
.stat-card,
.card {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.location-bar,
.filter-item,
.sort-section,
.distance-section,
.type-badge,
.card-location,
.distance-tag,
.quick-tag,
.type-item,
.time-option,
.quick-point,
.quick-amount,
.payment-option,
.amount-detail,
.rules-tip,
.points-tip-wrapper,
.input-wrapper,
.toolbar-toggle-btn,
.more-btn,
.system-message-text,
.time-divider text {
  background: #f8fafc;
  border-color: var(--border-light);
  box-shadow: none;
}

.filter-item.active,
.type-item.active,
.quick-tag.active,
.time-option.active,
.payment-option.active {
  background: rgba(22, 119, 210, 0.08);
  border-color: rgba(22, 119, 210, 0.34);
  box-shadow: none;
}

.filter-item.active .filter-name,
.quick-tag.active,
.time-option.active,
.payment-option.active .payment-name {
  color: var(--sky-deep);
  font-weight: 600;
}

.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.amount-badge,
.quick-amount.active,
.quick-point.active,
.time-recommend,
.btn-vitality {
  background: var(--vitality-orange);
  box-shadow: var(--shadow-orange);
}

.balance-value.points,
.balance-value.available,
.points-number,
.publish-points,
.publish-amount {
  color: var(--text-primary);
  background: none;
  -webkit-text-fill-color: currentColor;
}

.wdd-amount,
.need-amount,
.amount-current,
.amount-symbol,
.detail-value.fee,
.warning-text,
.balance-value.insufficient,
.task-points-mini {
  color: var(--vitality-orange);
}

.detail-value.income,
.tag-mint,
.status-success,
.success-text {
  color: var(--fresh-mint);
}

.message-item.other .message-bubble.text {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-sm);
}

.message-item.self .message-bubble.text {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.popup-overlay,
.modal-mask,
.rules-modal {
  background: rgba(15, 23, 42, 0.46);
}

.helper-profile-tip,
.balance-insufficient,
.task-ended-bar.breaking-bar {
  background: #fff8e6;
  border-color: rgba(233, 185, 73, 0.34);
}

image,
button,
view {
  letter-spacing: 0;
}
/* 城市服务按钮对比修正 */
.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  color: #ffffff;
}

.publish-btn.disabled,
.send-btn[disabled],
.disabled {
  color: var(--text-muted);
}