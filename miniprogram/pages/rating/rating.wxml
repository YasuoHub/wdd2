<!-- 星级评价页面 -->
<view class="container wdd-page">
  <view class="wdd-page-bg"></view>
  <view class="rating-hero">
    <text class="hero-title">请对本次<text class="hero-highlight">{{ratingType === 'seeker' ? '帮助' : '求助'}}</text>进行评价</text>
    <text class="hero-subtitle">你的评价将帮助对方获得更多机会</text>
  </view>

  <!-- 评价对象信息 -->
  <view class="target-card">
    <view class="target-avatar">
      <text wx:if="{{!targetUser.avatar && targetUser.nickname}}">{{targetUser.nickname[0]}}</text>
      <wdd-icon wx:elif="{{!targetUser.avatar}}" name="circle-user" color="#FFFFFF" size="54"></wdd-icon>
      <image wx:else src="{{targetUser.avatar}}" mode="aspectFill"/>
    </view>
    <view class="target-info">
      <text class="target-label">{{ratingType === 'seeker' ? '帮助者' : '求助者'}}</text>
      <text class="target-name">{{targetUser.nickname || '未知用户'}}</text>
    </view>
  </view>

  <view class="rating-card">
    <!-- 星级评分 -->
    <view class="rating-section">
      <text class="rating-title">总体评分</text>
      <view class="stars-wrapper">
        <view
          wx:for="{{[1,2,3,4,5]}}"
          wx:key="*this"
          class="star {{rating >= item ? 'active' : ''}}"
          bindtap="setRating"
          data-score="{{item}}"
        >
          <text class="star-symbol">{{rating >= item ? '★' : '☆'}}</text>
        </view>
      </view>
      <text class="rating-text">{{rating === 5 ? '非常满意' : ratingText}}</text>
    </view>

    <!-- 评价标签 -->
    <view class="tags-section" wx:if="{{rating > 0}}">
      <text class="section-title">评价标签 <text class="section-title-muted">（多选）</text></text>
      <view class="tags-wrapper">
        <view
          wx:for="{{ratingTags}}"
          wx:key="*this"
          class="tag {{item.selected ? 'active' : ''}}"
          bindtap="toggleTag"
          data-index="{{index}}"
        >
          <text>{{item.text}}</text>
          <view wx:if="{{item.selected}}" class="tag-check">
            <wdd-icon name="check" color="#FFFFFF" size="22"></wdd-icon>
          </view>
        </view>
      </view>
    </view>

    <!-- 评价内容 -->
    <view class="comment-section">
      <text class="section-title">详细评价 <text class="section-title-muted">（选填）</text></text>
      <view class="comment-box">
        <textarea
          class="comment-input"
          placeholder="可以补充说说这次体验"
          maxlength="200"
          bindinput="onCommentInput"
          value="{{comment}}"
        />
        <text class="char-count">{{comment.length}}/200</text>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button
      class="submit-btn {{rating > 0 ? 'active' : ''}}"
      bindtap="submitRating"
      disabled="{{rating === 0 || submitting || loadFailed}}"
    >
      {{submitting ? '提交中...' : '提交评价'}}
    </button>
  </view>

  <!-- 评价说明 -->
  <view class="tips-section">
    <view class="tips-title">
      <wdd-icon name="info" color="#9AA5B1" size="24"></wdd-icon>
      <text>评价说明</text>
    </view>
    <view class="tips-item">
      <wdd-icon name="shield-check" color="#A7B0BC" size="24"></wdd-icon>
      <text>评价提交后无法修改，请认真对待每一次评价</text>
    </view>
    <view class="tips-item">
      <wdd-icon name="shield-check" color="#A7B0BC" size="24"></wdd-icon>
      <text>好的评价会帮助对方获得更多任务机会</text>
    </view>
    <view class="tips-item">
      <wdd-icon name="shield-check" color="#A7B0BC" size="24"></wdd-icon>
      <text>恶意评价、虚假内容将被平台处理</text>
    </view>
  </view>
</view>
