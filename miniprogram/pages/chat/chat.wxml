<!-- 聊天页面 -->
<view class="chat-container">
  <!-- 任务卡片区域（含下拉菜单） -->
  <view class="task-card-wrapper" wx:if="{{!isCustomerServiceMode}}">
    <!-- 任务信息卡片（仅收起样式） -->
    <view class="task-card collapsed">
      <view class="task-card-collapsed">
        <view class="collapsed-left">
          <text class="type-icon">{{task.typeIcon}}</text>
          <text class="type-name">{{task.typeName}}</text>
          <text class="location-name">{{task.locationName || ''}}</text>
          <text class="task-points-mini">¥{{task.rewardAmount || 0}}</text>
        </view>
        <view class="more-btn" catchtap="toggleTaskMenu">
          <text class="more-icon">⋮</text>
        </view>
      </view>
    </view>

    <!-- 下拉菜单遮罩 -->
    <view class="task-menu-mask {{showTaskMenu ? 'show' : ''}}" catchtap="hideTaskMenu"></view>

    <!-- 下拉菜单内容 -->
    <view class="task-menu-content {{showTaskMenu ? 'show' : ''}}">
      <view wx:if="{{isSeeker && task.status === 'ongoing'}}" class="menu-item" catchtap="onCompleteMenuTap">
        <text class="menu-item-icon">✅</text>
        <text class="menu-item-text">完成</text>
      </view>
      <view class="menu-item" catchtap="goToReport">
        <text class="menu-item-icon">🚨</text>
        <text class="menu-item-text">举报</text>
      </view>
      <view class="menu-item" catchtap="goToTaskDetail">
        <text class="menu-item-icon">📋</text>
        <text class="menu-item-text">详情</text>
      </view>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="message-list"
    scroll-y
    scroll-into-view="{{lastMessageId}}"
    scroll-top="{{scrollTop}}"
    enhanced
    show-scrollbar="{{false}}"
    refresher-enabled="{{hasMoreMessages}}"
    refresher-triggered="{{isRefreshing}}"
    bindrefresherrefresh="onRefresh"
    bindrefresherrestore="onRestore"
    bindscroll="onScroll"
  >

    <!-- 首屏骨架屏：仅在加载中且没有任何消息时显示 -->
    <view wx:if="{{loading && messages.length === 0}}" class="chat-skeleton">
      <view class="skel-row other">
        <view class="skel-avatar"></view>
        <view class="skel-bubble skel-bubble-md"></view>
      </view>
      <view class="skel-row self">
        <view class="skel-bubble skel-bubble-sm"></view>
        <view class="skel-avatar"></view>
      </view>
      <view class="skel-row other">
        <view class="skel-avatar"></view>
        <view class="skel-bubble skel-bubble-lg"></view>
      </view>
      <view class="skel-row self">
        <view class="skel-bubble skel-bubble-md"></view>
        <view class="skel-avatar"></view>
      </view>
    </view>

    <!-- 消息项 -->
    <view
      wx:for="{{messages}}"
      wx:key="clientMsgId"
      id="msg-{{item.clientMsgId}}"
      class="message-item {{item.isSelf ? 'self' : 'other'}}"
    >
      <!-- 时间分隔线 -->
      <view class="time-divider" wx:if="{{item.showTime}}">
        <text>{{item.timeText}}</text>
      </view>

      <!-- 消息内容 -->
      <view class="message-content">
        <!-- 系统消息：居中显示，无头像 -->
        <block wx:if="{{item.isSystem}}">
          <view class="system-message">
            <text class="system-message-text">{{item.content}}</text>
          </view>
        </block>

        <!-- 普通消息：原有逻辑 -->
        <block wx:else>
          <!-- 对方头像 -->
          <view wx:if="{{!item.isSelf}}" class="avatar" bindtap="goToPublicProfile">
            <image wx:if="{{item.senderAvatar}}" src="{{item.senderAvatar}}" mode="aspectFill" />
            <text wx:else>{{item.senderName ? item.senderName[0] : '?'}}</text>
          </view>

          <!-- 文字消息 loading 指示器（自己发的临时消息显示在左侧） -->
          <view class="message-loading" wx:if="{{item.isSelf && item.sendStatus === 'sending' && item.type === 'text'}}">
            <view class="loading-dot"></view>
          </view>

          <!-- 消息气泡 -->
          <view class="message-bubble {{item.type}} {{item.isLocalImage ? 'sending' : ''}}">
            <!-- 文字消息 -->
            <block wx:if="{{item.type === 'text'}}">
              <text class="message-text" selectable>{{item.content}}</text>
            </block>

            <!-- 图片消息 -->
            <block wx:if="{{item.type === 'image'}}">
              <view class="image-wrapper">
                <image
                  class="message-image {{item.imageWidth ? 'has-size' : ''}}"
                  src="{{item.imageUrl}}"
                  mode="{{item.imageWidth ? 'scaleToFill' : 'aspectFit'}}"
                  style="{{item.imageWidth ? 'width: ' + item.imageWidth + 'rpx; height: ' + item.imageHeight + 'rpx;' : ''}}"
                  bindtap="previewImage"
                  data-url="{{item.imageUrl}}"
                  lazy-load
                />
                <!-- 图片 loading 指示器 -->
                <view class="image-loading" wx:if="{{item.isLocalImage}}">
                  <view class="loading-spinner"></view>
                </view>
              </view>
            </block>
          </view>

          <!-- 自己头像 -->
          <view wx:if="{{item.isSelf}}" class="avatar">
            <image wx:if="{{item.senderAvatar}}" src="{{item.senderAvatar}}" mode="aspectFill" />
            <text wx:else>我</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 底部占位 -->
    <view id="bottom-anchor" style="height: 20rpx;"></view>
  </scroll-view>

  <!-- 未读新消息提示按钮 -->
  <view 
    class="new-message-btn {{newMessageCount > 0 ? 'show' : ''}}" 
    bindtap="scrollToBottomAndClear"
    wx:if="{{newMessageCount > 0}}"
  >
    <text class="btn-arrow">↓</text>
    <text class="btn-text">{{newMessageCount}}条新消息</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="input-area" wx:if="{{!isCustomerServiceMode}}">
    <!-- breaking 状态：客服审核中，禁止发消息 -->
    <view wx:if="{{task.status === 'breaking'}}" class="task-ended-bar breaking-bar">
      <text class="task-ended-text">审核中</text>
    </view>

    <!-- 任务已结束：显示提示 -->
    <view wx:elif="{{task.status !== 'ongoing'}}" class="task-ended-bar">
      <text class="task-ended-text">任务已结束</text>
    </view>

    <!-- 任务进行中：显示输入框 -->
    <block wx:else>
      <!-- 输入框区域 -->
      <view class="input-row">
        <!-- 展开/收起工具栏按钮 -->
        <view class="toolbar-toggle-btn {{isToolbarExpanded ? 'expanded' : ''}}" catchtap="toggleToolbar">
          <text class="toggle-icon">{{isToolbarExpanded ? '▲' : '📎'}}</text>
        </view>

        <view class="input-wrapper">
          <input
            class="message-input"
            type="text"
            value="{{inputValue}}"
            placeholder="输入消息..."
            confirm-type="confirm"
            bindinput="onInput"
            bindconfirm="sendTextMessage"
            bindfocus="onInputFocus"
            focus="{{inputFocus}}"
            hold-keyboard
          />
        </view>

        <!-- 发送按钮 -->
        <button
          class="send-btn {{inputValue ? 'active' : ''}}"
          catchtap="sendTextMessage"
          disabled="{{!inputValue}}"
        >
          发送
        </button>
      </view>

      <!-- 工具栏 -->
      <view class="toolbar {{isToolbarExpanded ? 'show' : ''}}">
        <view class="tool-item" bindtap="chooseImage" data-source="album">
          <text class="tool-icon">🖼️</text>
          <text class="tool-text">相册</text>
        </view>
        <view class="tool-item" bindtap="chooseImage" data-source="camera">
          <text class="tool-icon">📸</text>
          <text class="tool-text">拍照</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 完成任务确认弹窗 -->
  <view class="modal {{showCompleteModal ? 'show' : ''}}" wx:if="{{showCompleteModal}}">
    <view class="modal-mask" bindtap="hideCompleteModal"></view>
    <view class="modal-content">
      <view class="modal-title">确认完成任务</view>
      <view class="modal-body">
        <text>确认已获得所需信息？确认后任务将完成，悬赏金额将结算给帮助者。</text>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="hideCompleteModal">取消</button>
        <button class="modal-btn confirm" bindtap="completeTask">确认</button>
      </view>
    </view>
  </view>
</view>
