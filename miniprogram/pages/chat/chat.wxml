<!-- 聊天页面 -->
<view class="chat-container">
  <!-- 任务信息卡片 -->
  <view class="task-card {{isTaskCardCollapsed ? 'collapsed' : ''}}">
    <!-- 收起状态：只显示类型和积分，以及展开按钮 -->
    <view wx:if="{{isTaskCardCollapsed}}" class="task-card-collapsed" bindtap="toggleTaskCard">
      <view class="collapsed-left">
        <text class="type-icon">{{task.typeIcon}}</text>
        <text class="type-name">{{task.typeName}}</text>
        <text class="task-points-mini">{{task.points}}积分</text>
      </view>
      <view class="expand-btn">
        <text class="expand-icon">▼</text>
      </view>
    </view>

    <!-- 展开状态：显示完整信息 -->
    <block wx:else>
      <view class="task-header">
        <view class="task-type">
          <text class="type-icon">{{task.typeIcon}}</text>
          <text class="type-name">{{task.typeName}}</text>
        </view>
        <view class="task-meta">
          <view class="task-status {{task.status}}">{{task.statusText}}</view>
          <view class="task-points">{{task.points}}积分</view>
          <!-- 完成按钮（仅在任务进行中且是求助者时显示） -->
          <view wx:if="{{isSeeker && task.status === 'ongoing'}}" class="complete-btn" bindtap="showCompleteConfirm">
            <text class="complete-icon">✓</text>
            <text>完成</text>
          </view>
        </view>
      </view>
      <view class="task-location" bindtap="openLocation" wx:if="{{task.location && task.location.name}}">
        <text class="location-icon">📍</text>
        <text class="location-name">{{task.location.name}}</text>
      </view>
      <view class="task-content">{{task.description}}</view>

      <!-- 求助图片 -->
      <view class="task-images" wx:if="{{task.images && task.images.length > 0}}">
        <view class="images-list">
          <image
            wx:for="{{task.images}}"
            wx:key="index"
            class="task-image"
            src="{{item}}"
            mode="aspectFill"
            bindtap="previewTaskImages"
            data-index="{{index}}"
          />
        </view>
      </view>

      <!-- 收起按钮 -->
      <view class="collapse-btn" bindtap="toggleTaskCard">
        <text class="collapse-icon">▲</text>
        <text class="collapse-text">收起</text>
      </view>
    </block>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="message-list"
    scroll-y
    scroll-into-view="{{lastMessageId}}"
    enhanced
    show-scrollbar="{{false}}"
  >
    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMoreMessages}}">
      <text bindtap="loadMoreMessages">加载更多消息</text>
    </view>

    <!-- 消息项 -->
    <view
      wx:for="{{messages}}"
      wx:key="_id"
      id="msg-{{item._id}}"
      class="message-item {{item.isSelf ? 'self' : 'other'}}"
    >
      <!-- 时间分隔线 -->
      <view class="time-divider" wx:if="{{item.showTime}}">
        <text>{{item.timeText}}</text>
      </view>

      <!-- 消息内容 -->
      <view class="message-content">
        <!-- 对方头像 -->
        <view wx:if="{{!item.isSelf}}" class="avatar">
          <image wx:if="{{item.senderAvatar}}" src="{{item.senderAvatar}}" mode="aspectFill" />
          <text wx:else>{{item.senderName ? item.senderName[0] : '?'}}</text>
        </view>

        <!-- 文字消息 loading 指示器（自己发的临时消息显示在左侧） -->
        <view class="message-loading" wx:if="{{item.isSelf && item._id.startsWith('temp_') && item.type === 'text'}}">
          <view class="loading-dot"></view>
        </view>

        <!-- 消息气泡 -->
        <view class="message-bubble {{item.type}} {{item.isLocalImage ? 'sending' : ''}}">
          <!-- 文字消息 -->
          <block wx:if="{{item.type === 'text'}}">
            <text class="message-text" selectable>{{item.content}}</text>
          </block>

          <!-- 图片消息 -->
          <block wx:if="{{item.type === 'image'}}">
            <view class="image-wrapper">
              <image
                class="message-image"
                src="{{item.imageUrl}}"
                mode="aspectFit"
                bindtap="previewImage"
                data-url="{{item.imageUrl}}"
              />
              <!-- 图片 loading 指示器 -->
              <view class="image-loading" wx:if="{{item.isLocalImage}}">
                <view class="loading-spinner"></view>
              </view>
            </view>
          </block>
        </view>

        <!-- 自己头像 -->
        <view wx:if="{{item.isSelf}}" class="avatar">
          <image wx:if="{{item.senderAvatar}}" src="{{item.senderAvatar}}" mode="aspectFill" />
          <text wx:else>我</text>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view id="bottom-anchor" style="height: 20rpx;"></view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="input-area">
    <!-- 输入框区域 -->
    <view class="input-row">
      <view class="input-wrapper">
        <input
          class="message-input"
          type="text"
          value="{{inputValue}}"
          placeholder="{{task.status === 'ongoing' ? '输入消息...' : '任务已结束'}}"
          disabled="{{task.status !== 'ongoing'}}"
          confirm-type="send"
          bindinput="onInput"
          bindconfirm="sendTextMessage"
          focus="{{inputFocus}}"
        />
      </view>

      <!-- 发送按钮 -->
      <button
        class="send-btn {{inputValue ? 'active' : ''}}"
        bindtap="sendTextMessage"
        disabled="{{!inputValue || task.status !== 'ongoing'}}"
      >
        发送
      </button>
    </view>

    <!-- 工具栏 -->
    <view class="toolbar">
      <view class="tool-item" bindtap="chooseImage" data-source="album">
        <text class="tool-icon">🖼️</text>
        <text class="tool-text">相册</text>
      </view>
      <view class="tool-item" bindtap="chooseImage" data-source="camera">
        <text class="tool-icon">📸</text>
        <text class="tool-text">拍照</text>
      </view>
    </view>
  </view>

  <!-- 完成任务确认弹窗 -->
  <view class="modal {{showCompleteModal ? 'show' : ''}}" wx:if="{{showCompleteModal}}">
    <view class="modal-mask" bindtap="hideCompleteModal"></view>
    <view class="modal-content">
      <view class="modal-title">确认完成任务</view>
      <view class="modal-body">
        <text>确认已获得所需信息？确认后任务将完成，积分将转给帮助者。</text>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="hideCompleteModal">取消</button>
        <button class="modal-btn confirm" bindtap="completeTask">确认</button>
      </view>
    </view>
  </view>
</view>
