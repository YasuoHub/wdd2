<!-- 聊天页面 -->
<wxs src="../../utils/money.wxs" module="money" />
<view class="chat-container wdd-page">
  <view class="wdd-page-bg"></view>
  <!-- 任务卡片区域（含下拉菜单） -->
  <view class="task-card-wrapper" wx:if="{{!isCustomerServiceMode}}">
    <!-- 任务信息卡片（仅收起样式） -->
    <view class="task-card collapsed status-{{task.status}}">
      <view class="task-card-collapsed">
        <view class="task-summary-left">
          <view class="type-icon">
            <wdd-icon name="{{task.typeIcon || 'circle-help'}}" color="var(--brand-primary)" size="38"></wdd-icon>
          </view>
          <view class="task-summary-copy">
            <view class="task-title-row">
              <text class="type-name">{{task.typeName || '任务沟通'}}</text>
              <text class="task-status-pill status-{{task.status}}">{{task.statusText}}</text>
            </view>
            <view class="task-meta-line">
              <view class="task-location-inline">
                <wdd-icon name="map-pin" color="var(--text-tertiary)" size="24"></wdd-icon>
                <text class="task-location-text">{{task.locationName || '任务地点'}}</text>
              </view>
              <view wx:if="{{task.displayRewardAmount > 0}}" class="task-reward-inline"><view class="task-meta-dot"></view><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(task.displayRewardAmount || 0)}}</text></view>
            </view>
          </view>
        </view>
        <view class="more-btn" catchtap="toggleTaskMenu">
          <wdd-icon name="more-vertical" color="#111827" size="34"></wdd-icon>
        </view>
      </view>
    </view>

    <!-- 下拉菜单内容 -->
    <view wx:if="{{showTaskMenu}}" class="task-menu-content show">
      <view wx:if="{{canCompleteTask}}" class="menu-item" catchtap="onCompleteMenuTap">
        <wdd-icon name="circle-check-big" color="#6DD5B0" size="28"></wdd-icon>
        <text class="menu-item-text">完成</text>
      </view>
      <view wx:if="{{showReportBtn}}" class="menu-item" catchtap="goToReport">
        <wdd-icon name="siren" color="#FF6B6B" size="28"></wdd-icon>
        <text class="menu-item-text">举报</text>
      </view>
      <view class="menu-item" catchtap="goToTaskDetail">
        <wdd-icon name="clipboard-list" color="var(--brand-primary)" size="28"></wdd-icon>
        <text class="menu-item-text">详情</text>
      </view>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="message-list"
    scroll-y
    scroll-into-view="{{lastMessageId}}"
    scroll-top="{{scrollTop}}"
    enhanced
    show-scrollbar="{{false}}"
    refresher-enabled="{{hasMoreMessages}}"
    refresher-triggered="{{isRefreshing}}"
    bindrefresherrefresh="onRefresh"
    bindrefresherrestore="onRestore"
    bindscroll="onScroll"
  >

    <!-- 首屏骨架屏：仅在加载中且没有任何消息时显示 -->
    <view wx:if="{{loading && messages.length === 0}}" class="chat-skeleton">
      <view class="skel-row other">
        <view class="skel-avatar"></view>
        <view class="skel-bubble skel-bubble-md"></view>
      </view>
      <view class="skel-row self">
        <view class="skel-bubble skel-bubble-sm"></view>
        <view class="skel-avatar"></view>
      </view>
      <view class="skel-row other">
        <view class="skel-avatar"></view>
        <view class="skel-bubble skel-bubble-lg"></view>
      </view>
      <view class="skel-row self">
        <view class="skel-bubble skel-bubble-md"></view>
        <view class="skel-avatar"></view>
      </view>
    </view>

    <!-- 消息项 -->
    <view
      wx:for="{{messages}}"
      wx:key="clientMsgId"
      id="msg-{{item.clientMsgId}}"
      class="message-item {{item.isSelf ? 'self' : 'other'}}"
    >
      <!-- 时间分隔线 -->
      <view class="time-divider" wx:if="{{item.showTime}}">
        <text>{{item.timeText}}</text>
      </view>

      <!-- 消息内容 -->
      <view class="message-content">
        <!-- 系统消息：居中显示，无头像 -->
        <block wx:if="{{item.isSystem}}">
          <view class="system-message">
            <text class="system-message-text">{{item.content}}</text>
          </view>
        </block>

        <!-- 普通消息：原有逻辑 -->
        <block wx:else>
          <!-- 对方头像 -->
          <view wx:if="{{!item.isSelf}}" class="avatar" bindtap="{{isCustomerServiceMode ? '' : 'goToPublicProfile'}}" data-user-id="{{item.sender_id}}">
            <image wx:if="{{item.senderAvatar}}" src="{{item.senderAvatar}}" mode="aspectFill" />
            <text wx:else>{{item.senderName ? item.senderName[0] : '?'}}</text>
          </view>

          <!-- 发送中指示器 -->
          <view class="message-loading" wx:if="{{item.isSelf && item.sendStatus === 'sending' && item.type === 'text'}}">
            <view class="loading-dot"></view>
          </view>

          <!-- 消息气泡 -->
          <view class="message-bubble {{item.type}} {{item.isLocalImage ? 'sending' : ''}}">
            <!-- 文字消息 -->
            <block wx:if="{{item.type === 'text'}}">
              <text class="message-text" selectable>{{item.content}}</text>
            </block>

            <!-- 图片消息 -->
            <block wx:if="{{item.type === 'image' && (item.status !== 'violated' || item.isSelf)}}">
              <view class="image-wrapper">
                <image
                  class="message-image {{item.imageWidth ? 'has-size' : ''}}"
                  src="{{item.imageUrl}}"
                  mode="{{item.imageWidth ? 'scaleToFill' : 'aspectFit'}}"
                  style="{{item.imageWidth ? 'width: ' + item.imageWidth + 'rpx; height: ' + item.imageHeight + 'rpx;' : ''}}"
                  bindtap="previewImage"
                  data-url="{{item.imageUrl}}"
                  data-status="{{item.status}}"
                  data-is-self="{{item.isSelf}}"
                  lazy-load
                />
                <view wx:if="{{item.isTrustedPhoto}}" class="trusted-photo-badge">
                  <text>现场拍摄</text>
                </view>
                <!-- 图片 loading 指示器 -->
                <view class="image-loading" wx:if="{{item.isLocalImage}}">
                  <view class="loading-spinner"></view>
                </view>
              </view>
            </block>
            <block wx:elif="{{item.type === 'image' && item.status === 'violated'}}">
              <text class="message-text">图片未通过审核</text>
            </block>

            <!-- 语音消息：审核通过后才可播放，再次点击可停止 -->
            <block wx:if="{{item.type === 'voice'}}">
              <view
                class="voice-message {{playingVoiceId === item._id ? 'playing' : ''}} {{item.status !== 'normal' && !(item.isSelf && item.status === 'pending') ? 'disabled' : ''}} {{item.status === 'pending' ? 'pending' : ''}} {{item.status === 'violated' ? 'violated' : ''}}"
                style="width: {{item.voiceWidth}}rpx;"
                bindtap="toggleVoicePlayback"
                data-id="{{item._id}}"
              >
                <view class="voice-waves">
                  <view class="voice-wave wave-1"></view>
                  <view class="voice-wave wave-2"></view>
                  <view class="voice-wave wave-3"></view>
                </view>
                <text class="voice-duration">{{item.voiceDuration}}″</text>
                <text wx:if="{{item.status === 'violated'}}" class="voice-blocked-text">未通过审核</text>
              </view>
            </block>
          </view>

          <!-- 待审核媒体仅发送者可见；失败后点击感叹号可重新提交 -->
          <view wx:if="{{item.isSelf && (item.type === 'image' || item.type === 'voice') && item.status === 'pending' && item.reviewLoadingVisible}}" class="media-review-status">
            <view class="voice-review-spinner"></view>
          </view>
          <view
            wx:elif="{{item.isSelf && (item.type === 'image' || item.type === 'voice') && item.status === 'violated'}}"
            class="voice-review-status voice-review-failed"
            catchtap="retryMediaMessage"
            data-id="{{item._id}}"
          >
            <text>!</text>
          </view>

          <!-- 自己头像 -->
          <view wx:if="{{item.isSelf}}" class="avatar">
            <image wx:if="{{item.senderAvatar}}" src="{{item.senderAvatar}}" mode="aspectFill" />
            <text wx:else>我</text>
          </view>
        </block>
      </view>
    </view>

    <!-- 底部占位 -->
    <view id="bottom-anchor" style="height: 20rpx;"></view>
  </scroll-view>

  <!-- 未读新消息提示按钮 -->
  <view
    class="new-message-btn {{newMessageCount > 0 ? 'show' : ''}}"
    bindtap="scrollToBottomAndClear"
    wx:if="{{newMessageCount > 0}}"
  >
    <wdd-icon name="arrow-down" color="var(--brand-primary)" size="24"></wdd-icon>
    <text class="btn-text">{{newMessageCount}}条新消息</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="input-area" wx:if="{{!isCustomerServiceMode}}">
    <!-- breaking 状态：客服审核中，禁止发消息 -->
    <view wx:if="{{task.status === 'breaking'}}" class="task-ended-bar breaking-bar">
      <wdd-icon name="hourglass" color="#946B00" size="34"></wdd-icon>
      <text class="task-ended-text">审核中，暂不可发送消息</text>
    </view>

    <!-- 任务已结束：显示提示 -->
    <view wx:elif="{{task.status !== 'ongoing'}}" class="task-ended-bar">
      <wdd-icon name="circle-check-big" color="var(--fresh-mint)" size="34"></wdd-icon>
      <text class="task-ended-text">任务已结束</text>
    </view>

    <!-- 任务进行中：显示输入框 -->
    <block wx:else>
      <!-- 输入框区域 -->
      <view class="input-row">
        <!-- 展开/收起工具栏按钮 -->
        <view class="toolbar-toggle-btn {{isToolbarExpanded ? 'expanded' : ''}}" catchtap="toggleToolbar">
          <wdd-icon name="{{isToolbarExpanded ? 'chevron-down' : 'plus'}}" color="#111827" size="34"></wdd-icon>
        </view>

        <view class="input-wrapper {{isRecording ? 'recording' : ''}} {{voiceRecordCancelActive ? 'recording-cancel' : ''}}">
          <input
            wx:if="{{isInputFocused}}"
            class="message-input"
            type="text"
            value="{{inputValue}}"
            placeholder="发消息或按住说话..."
            confirm-type="confirm"
            bindinput="onInput"
            bindconfirm="sendTextMessage"
            bindfocus="onInputFocus"
            bindblur="onInputBlur"
            focus="{{inputFocus}}"
            hold-keyboard
          />
          <view
            wx:else
            class="message-input-touch-target {{inputValue ? 'has-value' : ''}}"
            catchtouchstart="onMessageInputTouchStart"
            catchtouchmove="onMessageInputTouchMove"
            catchtouchend="onMessageInputTouchEnd"
            catchtouchcancel="onMessageInputTouchCancel"
          >
            <text>{{isRecording ? (voiceRecordCancelActive ? '松开取消' : '松开发送') : (inputValue || '按住说话')}}</text>
          </view>
        </view>

        <!-- 发送按钮 -->
        <button
          wx:if="{{inputValue}}"
          class="send-btn {{inputValue ? 'active' : ''}}"
          catchtap="sendTextMessage"
          disabled="{{!inputValue}}"
        >
          发送
        </button>
      </view>

      <view wx:if="{{isRecording}}" class="recording-panel {{voiceRecordCancelActive ? 'cancel' : ''}}">
        <view class="recording-cancel-hint">
          <wdd-icon name="{{voiceRecordCancelActive ? 'x' : 'chevron-up'}}" color="#FFFFFF" size="30"></wdd-icon>
          <text>{{voiceRecordCancelActive ? '松开手指，取消发送' : '上滑取消'}}</text>
        </view>
        <view class="recording-card">
          <view class="recording-icon">
            <wdd-icon name="{{voiceRecordCancelActive ? 'x' : 'radio'}}" color="#FFFFFF" size="42"></wdd-icon>
          </view>
          <view class="recording-meter {{voiceRecordCancelActive ? 'muted' : ''}}">
            <view class="recording-bar bar-1"></view>
            <view class="recording-bar bar-2"></view>
            <view class="recording-bar bar-3"></view>
            <view class="recording-bar bar-4"></view>
            <view class="recording-bar bar-5"></view>
          </view>
          <text class="recording-title">{{voiceRecordCancelActive ? '取消这条语音' : '正在录音 ' + recordingSeconds + '″'}}</text>
          <text wx:if="{{recordingCountdown > 0}}" class="recording-countdown">还剩 {{recordingCountdown}} 秒</text>
          <text wx:else class="recording-tip">{{voiceRecordCancelActive ? '移回输入框，继续发送' : '松开发送'}}</text>
        </view>
      </view>

      <!-- 工具栏 -->
      <view class="toolbar {{isToolbarExpanded ? 'show' : ''}}">
        <view class="tool-item" bindtap="chooseImage" data-source="album">
          <view class="tool-icon">
            <wdd-icon name="image" color="#FFFFFF" size="34"></wdd-icon>
          </view>
          <text class="tool-text">相册</text>
        </view>
        <view class="tool-item" bindtap="chooseImage" data-source="camera">
          <view class="tool-icon">
            <wdd-icon name="camera" color="#FFFFFF" size="34"></wdd-icon>
          </view>
          <text class="tool-text">拍照</text>
        </view>
      </view>
    </block>
  </view>

  <canvas
    canvas-id="trustedPhotoCanvas"
    class="trusted-photo-canvas"
    style="width: {{watermarkCanvasWidth}}px; height: {{watermarkCanvasHeight}}px;"
  ></canvas>

</view>
