/* ============================================
   问当地 - 聊天页面 - 城市服务清爽可信风格
   ============================================ */
@import "../../styles/wdd-polish.wxss";

/* 页面容器 - 浅灰服务背景 */
.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #fafbfc 46%, #f3f8fc 100%);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  width: 100%;
  max-width: 100vw;
}

.chat-container::before {
  display: none;
}

.chat-container::after {
  display: none;
}

.type-name {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--text-primary);
  flex-shrink: 0;
}

.task-points-mini {
  font-size: 22rpx;
  color: var(--vitality-orange);
  font-weight: 400;
  padding: 6rpx 12rpx;
  border-radius: var(--radius-full);
  border: 2rpx solid var(--vitality-orange-30);
  background: var(--vitality-orange-08);
  flex-shrink: 0;
}

.menu-item-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 400;
}


/* 消息列表容器 */
.message-list {
  flex: 1;
  padding: 20rpx 32rpx 24rpx;
  position: relative;
  z-index: 1;
  overflow-y: scroll;
  box-sizing: border-box;
  width: 100%;
}

/* 时间分隔线 */
.time-divider {
  text-align: center;
  margin: 40rpx 0;
  position: relative;
}

.time-divider::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    transparent 0%,
    var(--border-color) 50%,
    transparent 100%
  );
}

.time-divider text {
  font-size: 22rpx;
  color: var(--text-tertiary);
  background: var(--bg-glass);
  backdrop-filter: blur(10rpx);
  padding: 10rpx 28rpx;
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border-light);
  position: relative;
  z-index: 1;
}

/* 消息项 */
.message-item {
  margin-bottom: 32rpx;
  animation: messageFadeIn 0.3s ease-out;
}

@keyframes messageFadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.message-content {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

/* 对方消息 */
.message-item.other .message-content {
  flex-direction: row;
  justify-content: flex-start;
}

/* 自己消息 */
.message-item.self .message-content {
  flex-direction: row;
  justify-content: flex-end;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: var(--shadow-sky);
  border: 3rpx solid var(--text-white);
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: white;
  font-weight: 400;
  overflow: hidden;
}

.avatar image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.message-item.self .avatar {
  background: linear-gradient(135deg, var(--vitality-orange) 0%, var(--vitality-coral) 100%);
}

/* 消息气泡 */
.message-bubble {
  max-width: 70%;
  position: relative;
  word-break: break-word;
  animation: bubblePop 0.2s ease-out;
  box-sizing: border-box;
}

@keyframes bubblePop {
  0% {
    transform: scale(0.8);
  }
  70% {
    transform: scale(1.05);
  }
  100% {
    transform: scale(1);
  }
}

/* 文字消息气泡 */
.message-bubble.text {
  padding: 24rpx 32rpx;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
  position: relative;
}

/* 对方文字消息 - 左侧箭头 */
.message-item.other .message-bubble.text::before {
  content: "";
  position: absolute;
  left: -10rpx;
  top: 20rpx;
  width: 0;
  height: 0;
  border: 10rpx solid transparent;
  border-right-color: var(--text-white);
  border-left: 0;
  filter: drop-shadow(-2rpx 0 2rpx rgba(0, 0, 0, 0.05));
}

/* 自己文字消息 - 右侧箭头 */
.message-item.self .message-bubble.text::before {
  content: "";
  position: absolute;
  right: -10rpx;
  top: 20rpx;
  width: 0;
  height: 0;
  border: 10rpx solid transparent;
  border-left-color: var(--sky-primary);
  border-right: 0;
  filter: drop-shadow(2rpx 0 2rpx rgba(0, 0, 0, 0.05));
}

/* 对方文字消息 */
.message-item.other .message-bubble.text {
  background: linear-gradient(135deg, #ffffff 0%, #f8faff 100%);
  border: 1rpx solid var(--brand-primary-10);
  border-top-left-radius: 12rpx;
}

/* 自己文字消息 */
.message-item.self .message-bubble.text {
  background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-primary) 100%);
  border-top-right-radius: 12rpx;
  color: white;
}

.message-text {
  font-size: 30rpx;
  line-height: 1.5;
}

.message-item.other .message-text {
  color: var(--text-primary);
}

.message-item.self .message-text {
  color: var(--text-white);
}

/* 图片消息 - 纯CSS高性能方案 */
.message-bubble.image {
  padding: 0;
  overflow: hidden;
  border-radius: 24rpx;
  box-shadow: var(--shadow-md);
  /* 限制最大尺寸 */
  max-width: 400rpx;
  max-height: 500rpx;
  /* 去除行高导致的底部留白 */
  line-height: 0;
  font-size: 0;
}

.message-image {
  display: block;
  border-radius: 24rpx;
  /* 后端已预计算尺寸，直接使用 scaleToFill */
  max-width: 400rpx;
  max-height: 500rpx;
}

/* 已有尺寸的图片，使用精确尺寸 */
.message-image.has-size {
  max-width: none;
  max-height: none;
}

.trusted-photo-badge {
  position: absolute;
  top: 12rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(31, 111, 91, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.18);
  line-height: 1;
  z-index: 2;
}

.message-item.other .trusted-photo-badge {
  right: 12rpx;
}

.message-item.self .trusted-photo-badge {
  left: 12rpx;
}

.trusted-photo-badge text {
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 400;
  line-height: 1;
}

.trusted-photo-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  pointer-events: none;
}

/* 语音消息 */
.message-bubble.voice {
  max-width: 430rpx;
}

.voice-message {
  min-width: 150rpx;
  max-width: 430rpx;
  height: 82rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-sizing: border-box;
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
  position: relative;
}

.message-item.self .voice-message {
  flex-direction: row-reverse;
  background: var(--brand-primary);
  color: #ffffff;
  border-color: transparent;
}

.voice-message.disabled {
  opacity: 0.72;
}

.voice-message.violated {
  min-width: 320rpx;
}

.voice-waves {
  width: 42rpx;
  height: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  flex-shrink: 0;
}

.voice-wave {
  width: 5rpx;
  border-radius: 999rpx;
  background: var(--brand-primary);
}

.message-item.self .voice-wave {
  background: #ffffff;
}

.wave-1 { height: 14rpx; }
.wave-2 { height: 30rpx; }
.wave-3 { height: 20rpx; }

.voice-message.playing .voice-wave {
  animation: voiceWave 0.65s ease-in-out infinite alternate;
}

.voice-message.playing .wave-2 { animation-delay: 0.12s; }
.voice-message.playing .wave-3 { animation-delay: 0.24s; }

@keyframes voiceWave {
  from { transform: scaleY(0.55); }
  to { transform: scaleY(1.15); }
}

.voice-duration {
  font-size: 27rpx;
  line-height: 1;
  white-space: nowrap;
}

.voice-blocked-text {
  font-size: 21rpx;
  white-space: nowrap;
}

.media-review-status {
  width: 44rpx;
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  z-index: 3;
}

.message-item.self .media-review-status {
  order: -1;
}

.voice-review-spinner {
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid rgba(31, 111, 91, 0.18);
  border-top-color: var(--brand-primary);
  border-right-color: rgba(31, 111, 91, 0.42);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.12);
  box-sizing: border-box;
  animation: mediaReviewSpin 0.75s linear infinite;
}

@keyframes mediaReviewSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.voice-review-failed {
  width: 36rpx;
  height: 36rpx;
  margin-top: 23rpx;
  border-radius: 50%;
  background: #e5484d;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

/* 底部输入区域 - 毛玻璃效果 */
.input-area {
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid var(--brand-primary-12);
  padding: 24rpx 32rpx;
  position: relative;
  z-index: 2;
  /* 固定最小高度避免布局抖动 */
  min-height: 128rpx;
  box-sizing: border-box;
}

/* 任务已结束提示条 */
.task-ended-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: var(--bg-glass);
  border-radius: var(--radius-full);
}

/* breaking 状态提示条 */
.task-ended-bar.breaking-bar {
  background: rgba(255, 193, 7, 0.15);
  border: 1rpx solid rgba(255, 193, 7, 0.3);
}

.task-ended-bar.breaking-bar .task-ended-text {
  color: #f39c12;
  font-weight: 400;
}

.task-ended-text {
  font-size: 28rpx;
  color: var(--text-light);
  font-weight: 400;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 80rpx;
}

/* 展开/收起工具栏按钮 */
.toolbar-toggle-btn {
  width: 72rpx;
  height: 72rpx;
  background: var(--brand-primary-10);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.toolbar-toggle-btn:active {
  background: var(--bg-glass);
  transform: scale(0.95);
}

.toolbar-toggle-btn.expanded {
  background: var(--border-color);
}

.recording-panel {
  position: fixed;
  left: 50%;
  bottom: 168rpx;
  transform: translateX(-50%);
  width: 430rpx;
  padding: 0;
  border-radius: 40rpx;
  background: transparent;
  color: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  z-index: 1000;
  pointer-events: none;
  transition: transform 0.18s ease;
}

.recording-panel.cancel {
  transform: translateX(-50%) scale(1.02);
}

.recording-cancel-hint {
  min-width: 188rpx;
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: var(--radius-full);
  background: rgba(17, 24, 39, 0.76);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 24rpx;
  line-height: 1;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.18);
  transition: all 0.18s ease;
}

.recording-panel.cancel .recording-cancel-hint {
  background: #ff4d55;
  box-shadow: 0 12rpx 34rpx rgba(255, 77, 85, 0.3);
}

.recording-card {
  width: 100%;
  min-height: 286rpx;
  padding: 34rpx 36rpx 30rpx;
  border-radius: 40rpx;
  background: rgba(24, 31, 43, 0.92);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 20rpx 56rpx rgba(15, 23, 42, 0.28);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  transition: background 0.18s ease, box-shadow 0.18s ease;
}

.recording-panel.cancel .recording-card {
  background: rgba(255, 77, 85, 0.94);
  box-shadow: 0 22rpx 60rpx rgba(255, 77, 85, 0.28);
}

.recording-icon {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1ec6a6 0%, #58d7f4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: recordingPulse 1.08s ease-in-out infinite;
  box-shadow: 0 10rpx 26rpx rgba(30, 198, 166, 0.28);
}

.recording-panel.cancel .recording-icon {
  background: rgba(255, 255, 255, 0.18);
  animation: none;
  box-shadow: none;
}

.recording-meter {
  height: 54rpx;
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.recording-bar {
  width: 8rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  transform-origin: center;
  animation: voiceMeter 0.78s ease-in-out infinite;
}

.recording-bar.bar-1 { height: 18rpx; animation-delay: 0s; opacity: 0.62; }
.recording-bar.bar-2 { height: 34rpx; animation-delay: 0.08s; opacity: 0.86; }
.recording-bar.bar-3 { height: 48rpx; animation-delay: 0.16s; }
.recording-bar.bar-4 { height: 30rpx; animation-delay: 0.24s; opacity: 0.82; }
.recording-bar.bar-5 { height: 22rpx; animation-delay: 0.32s; opacity: 0.68; }

.recording-meter.muted .recording-bar {
  animation: none;
  height: 12rpx;
  opacity: 0.55;
}

.recording-title {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.3;
}

.recording-tip {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.35;
  opacity: 0.76;
  text-align: center;
}

.recording-countdown {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #ffd4d7;
}

@keyframes recordingPulse {
  0%, 100% { transform: scale(0.94); }
  50% { transform: scale(1.05); }
}

@keyframes voiceMeter {
  0%, 100% { transform: scaleY(0.72); }
  50% { transform: scaleY(1.18); }
}

.input-wrapper {
  flex: 1;
  height: 80rpx;
  background: rgba(240, 248, 255, 0.9);
  border-radius: var(--radius-full);
  padding: 0 32rpx;
  border: 2rpx solid var(--border-light);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.input-wrapper:focus-within {
  border-color: var(--border-color);
  box-shadow: 0 0 0 4rpx var(--border-light);
}

.input-wrapper.recording {
  border-color: rgba(30, 198, 166, 0.52);
  background: rgba(229, 251, 247, 0.96);
  box-shadow: inset 0 0 0 2rpx rgba(30, 198, 166, 0.12), 0 8rpx 20rpx rgba(30, 198, 166, 0.12);
  transform: translateY(2rpx);
}

.input-wrapper.recording-cancel {
  border-color: rgba(255, 77, 85, 0.54);
  background: rgba(255, 241, 242, 0.98);
  box-shadow: inset 0 0 0 2rpx rgba(255, 77, 85, 0.1), 0 8rpx 22rpx rgba(255, 77, 85, 0.12);
}

.message-input {
  height: 80rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  caret-color: var(--sky-primary);
  width: 100%;
}

.message-input::placeholder {
  color: var(--text-light);
  opacity: 0.7;
}

.message-input-touch-target {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  padding: 0 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(240, 248, 255, 0.96));
  color: var(--text-light);
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  user-select: none;
}

.message-input-touch-target.has-value {
  color: var(--text-primary);
}

.input-wrapper.recording .message-input-touch-target {
  background: rgba(229, 251, 247, 0.96);
  color: #12836f;
  justify-content: center;
  font-weight: 600;
  letter-spacing: 0;
}

.input-wrapper.recording-cancel .message-input-touch-target {
  background: rgba(255, 241, 242, 0.98);
  color: #e11d48;
}

/* 发送按钮 */
.send-btn {
  width: 140rpx;
  height: 80rpx;
  padding: 0;
  font-size: 28rpx;
  font-weight: 400;
  color: white;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  border-radius: var(--radius-full);
  border: none;
  box-shadow: 0 4rpx 20rpx var(--brand-primary-35);
  transition: all 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.send-btn::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    var(--bg-glass),
    transparent
  );
  transition: left 0.5s;
}

.send-btn:active::before {
  left: 100%;
}

.send-btn.active {
  background: linear-gradient(135deg, var(--sky-light) 0%, var(--sky-primary) 100%);
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-md);
}

.send-btn[disabled] {
  background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
  box-shadow: none;
  transform: none;
}

/* 工具栏 */
.toolbar {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  transition:
    max-height 0.25s ease,
    opacity 0.2s ease,
    margin-top 0.25s ease;
}

.toolbar.show {
  max-height: 200rpx;
  opacity: 1;
  padding-top: 20rpx;
  margin-top: 16rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.tool-item:active {
  background: var(--border-light);
  transform: scale(0.95);
}

.tool-icon {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  box-shadow: var(--shadow-sky);
  transition: all 0.3s;
}

.tool-item:active .tool-icon {
  transform: scale(0.9);
  box-shadow: var(--shadow-sm);
}

.tool-item:nth-child(2) .tool-icon {
  background: linear-gradient(135deg, var(--vitality-orange) 0%, var(--vitality-coral) 100%);
}

.tool-item:nth-child(3) .tool-icon {
  background: linear-gradient(135deg, var(--fresh-mint) 0%, var(--fresh-green) 100%);
}

.tool-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 400;
}

/* 消息状态指示器 */
.message-status {
  position: absolute;
  bottom: -28rpx;
  right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.message-item.other .message-status {
  left: 12rpx;
  right: auto;
}

.status-icon {
  font-size: 20rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.status-icon.loading {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  animation: pulse 1.5s infinite ease-in-out;
}

.status-icon.failed {
  background: linear-gradient(135deg, var(--vitality-orange) 0%, var(--vitality-coral) 100%);
  color: white;
  font-weight: 400;
  padding: 0;
}

.status-icon.failed:active {
  background: linear-gradient(135deg, #e9823a 0%, var(--vitality-orange) 100%);
  transform: scale(0.95);
}

@keyframes pulse {
  0%,
  100% {
    opacity: 0.6;
    transform: scale(0.8);
  }
  50% {
    opacity: 1;
    transform: scale(1);
  }
}

/* 发送中消息样式 */
.message-bubble.sending {
  opacity: 0.8;
}

.message-bubble.sending .message-text,
.message-bubble.sending .message-image {
  filter: brightness(0.95);
}

/* 文字消息 loading 指示器 */
.message-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  margin-right: 6rpx;
  align-self: center;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--sky-primary);
  border-radius: 50%;
  animation: loadingPulse 1s ease-in-out infinite;
}

@keyframes loadingPulse {
  0%,
  100% {
    transform: scale(0.6);
    opacity: 0.5;
  }
  50% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 图片 wrapper */
.image-wrapper {
  position: relative;
  display: block;
  line-height: 0;
  font-size: 0;
}

/* 图片 loading 指示器 */
.image-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 24rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spinnerRotate 0.8s linear infinite;
}

@keyframes spinnerRotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* 未读新消息提示按钮 */
.new-message-btn {
  position: fixed;
  right: 30rpx;
  bottom: 150rpx;
  background: var(--sky-pale);
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: var(--shadow-md);
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.3s ease;
  z-index: 100;
}

.new-message-btn.show {
  opacity: 1;
  transform: translateY(0);
}

.btn-arrow {
  font-size: 24rpx;
  color: var(--text-primary);
}

.btn-text {
  font-size: 24rpx;
  color: var(--text-primary);
}

/* 系统消息 */
.system-message {
  display: flex;
  justify-content: center;
  width: 100%;
  margin: 24rpx 0;
}

.system-message-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  background: var(--bg-glass);
  backdrop-filter: blur(10rpx);
  padding: 16rpx 32rpx;
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border-light);
  text-align: center;
  line-height: 1.5;
}

/* 首屏骨架屏 */
.chat-skeleton {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding: 24rpx 0;
}

.skel-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.skel-row.self {
  flex-direction: row-reverse;
}

.skel-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, rgba(0, 0, 0, 0.06) 0%, rgba(0, 0, 0, 0.1) 50%, rgba(0, 0, 0, 0.06) 100%);
  background-size: 200% 100%;
  animation: skeletonShimmer 1.4s ease-in-out infinite;
  flex-shrink: 0;
}

.skel-bubble {
  height: 72rpx;
  border-radius: 32rpx;
  background: linear-gradient(90deg, rgba(0, 0, 0, 0.05) 0%, rgba(0, 0, 0, 0.09) 50%, rgba(0, 0, 0, 0.05) 100%);
  background-size: 200% 100%;
  animation: skeletonShimmer 1.4s ease-in-out infinite;
}

.skel-bubble-sm {
  width: 200rpx;
}

.skel-bubble-md {
  width: 320rpx;
}

.skel-bubble-lg {
  width: 460rpx;
  height: 120rpx;
}

@keyframes skeletonShimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}
/* 聊天页专属任务摘要栏：避免被通用任务卡样式破坏 */
.chat-container.wdd-page > view.task-card-wrapper {
  position: relative;
  z-index: 9000 !important;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.98);
  border-bottom: 1rpx solid var(--border-light);
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
  overflow: visible;
}

.chat-container .task-card,
.chat-container .task-card.collapsed {
  width: 100%;
  min-height: auto;
  margin: 0;
  padding: 20rpx 28rpx;
  border: none;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  animation: none;
  overflow: visible;
  transform: none;
  position: relative;
  z-index: auto;
}

.chat-container .task-card:active {
  transform: none;
  box-shadow: none;
}

.chat-container .task-card-collapsed {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 76rpx;
}

.chat-container .task-summary-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}

.chat-container .task-card .type-icon,
.chat-container .task-card-collapsed .type-icon {
  width: 46rpx;
  height: 46rpx;
  border-radius: 0;
  background: transparent;
  border: 0;
  box-shadow: none;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat-container .task-summary-copy {
  flex: 1;
  min-width: 0;
}

.chat-container .task-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.chat-container .task-title-row .type-name {
  flex: 0 1 auto;
  min-width: 0;
  max-width: 240rpx;
  color: #111827;
  font-size: 29rpx;
  font-weight: 400;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-container .task-status-pill {
  flex-shrink: 0;
  min-height: 34rpx;
  padding: 4rpx 12rpx;
  font-size: 21rpx;
}

.chat-container .task-meta-line {
  margin-top: 5rpx;
  color: var(--text-tertiary);
  font-size: 23rpx;
  line-height: 1.35;
  display: flex;
  align-items: center;
  gap: 10rpx;
  overflow: hidden;
}

.chat-container .task-location-inline {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
  white-space: nowrap;
}

.chat-container .task-location-inline wdd-icon {
  flex-shrink: 0;
}

.chat-container .task-location-text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-container .task-reward-inline {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  white-space: nowrap;
}

.chat-container .task-meta-dot {
  width: 6rpx;
  height: 6rpx;
  margin-right: 4rpx;
  border-radius: 50%;
  background: currentColor;
  opacity: 0.72;
}

.chat-container .more-btn {
  width: 68rpx;
  height: 68rpx;
  padding: 0;
  border-radius: 50%;
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.05);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat-container .task-menu-content {
  display: block;
  position: fixed;
  top: 108rpx;
  right: 24rpx;
  z-index: 9999;
  min-width: 188rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-shadow: 0 16rpx 44rpx rgba(15, 23, 42, 0.16);
  overflow: hidden;
}

.chat-container .task-menu-content.show {
  display: block;
}

.chat-container .menu-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 22rpx 28rpx;
  border-bottom: 1rpx solid var(--border-light);
  background: #ffffff;
}

.chat-container .menu-item:last-child {
  border-bottom: 0;
}

.chat-container.wdd-page > scroll-view.message-list {
  position: relative;
  z-index: 1;
}
