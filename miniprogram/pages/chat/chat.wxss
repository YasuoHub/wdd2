/* ============================================
   问当地 - 聊天页面 - 城市服务清爽可信风格
   ============================================ */

/* 页面容器 - 浅灰服务背景 */
.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #fafbfc 46%, #f3f8fc 100%);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  width: 100%;
  max-width: 100vw;
}

.chat-container::before {
  display: none;
}

.chat-container::after {
  display: none;
}

/* 任务卡片 - 毛玻璃效果 */
.task-card {
  background: rgba(255, 255, 255, 0.95);
  margin: 24rpx 32rpx 18rpx;
  padding: 28rpx 30rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(22, 119, 210, 0.12);
  box-shadow: var(--shadow-card);
  position: relative;
  z-index: 1;
  animation: cardSlideIn 0.5s ease-out;
  overflow: hidden;
  box-sizing: border-box;
  width: calc(100% - 64rpx);
}

.task-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  /* background: linear-gradient(90deg, #1677D2 0%, #2B8AD8 50%, #D9ECFB 100%); */
}

@keyframes cardSlideIn {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.type-icon {
  width: 52rpx;
  height: 52rpx;
  background: rgba(22, 119, 210, 0.12);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
  flex-shrink: 0;
}

.type-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  flex-shrink: 0;
}

/* 任务卡片收起状态 */
.task-card.collapsed {
  padding: 20rpx 32rpx;
}

.task-card-collapsed {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.collapsed-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.task-card-collapsed .type-icon {
  font-size: 32rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
}

.task-card-collapsed .type-name {
  font-size: 28rpx;
}

.task-points-mini {
  font-size: 22rpx;
  color: var(--vitality-orange);
  font-weight: 600;
  padding: 6rpx 12rpx;
  border-radius: var(--radius-full);
  border: 2rpx solid rgba(217, 106, 34, 0.3);
  background: rgba(217, 106, 34, 0.08);
  flex-shrink: 0;
}

/* 收起状态中的地点名 */
.task-card-collapsed .location-name {
  font-size: 22rpx;
  color: var(--text-tertiary);
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 1;
  min-width: 0;
}

/* 任务卡片外层容器 */
.task-card-wrapper {
  position: relative;
}

/* 下拉菜单遮罩 */
.task-menu-mask {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
}

.task-menu-mask.show {
  display: block;
}

/* 下拉菜单内容 */
.task-menu-content {
  display: none;
  position: absolute;
  top: 130rpx;
  right: 32rpx;
  z-index: 100;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 24rpx;
  border: 1rpx solid rgba(22, 119, 210, 0.14);
  box-shadow: var(--shadow-float);
  min-width: 200rpx;
  overflow: hidden;
  animation: menuFadeIn 0.15s ease-out;
}

.task-menu-content.show {
  display: block;
}

@keyframes menuFadeIn {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid var(--border-light);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--bg-glass);
}

.menu-item-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* 更多按钮（三个点） */
.more-btn {
  padding: 8rpx 16rpx;
  background: rgba(22, 119, 210, 0.1);
  border-radius: 52rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.more-btn:active {
  background: var(--border-light);
}


/* 消息列表容器 */
.message-list {
  flex: 1;
  padding: 20rpx 32rpx 24rpx;
  position: relative;
  z-index: 1;
  overflow-y: scroll;
  box-sizing: border-box;
  width: 100%;
}

/* 时间分隔线 */
.time-divider {
  text-align: center;
  margin: 40rpx 0;
  position: relative;
}

.time-divider::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    transparent 0%,
    var(--border-color) 50%,
    transparent 100%
  );
}

.time-divider text {
  font-size: 22rpx;
  color: var(--text-tertiary);
  background: var(--bg-glass);
  backdrop-filter: blur(10rpx);
  padding: 10rpx 28rpx;
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border-light);
  position: relative;
  z-index: 1;
}

/* 消息项 */
.message-item {
  margin-bottom: 32rpx;
  animation: messageFadeIn 0.3s ease-out;
}

@keyframes messageFadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.message-content {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

/* 对方消息 */
.message-item.other .message-content {
  flex-direction: row;
  justify-content: flex-start;
}

/* 自己消息 */
.message-item.self .message-content {
  flex-direction: row;
  justify-content: flex-end;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: var(--shadow-sky);
  border: 3rpx solid var(--text-white);
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: white;
  font-weight: 600;
  overflow: hidden;
}

.avatar image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.message-item.self .avatar {
  background: linear-gradient(135deg, var(--vitality-orange) 0%, var(--vitality-coral) 100%);
}

/* 消息气泡 */
.message-bubble {
  max-width: 70%;
  position: relative;
  word-break: break-word;
  animation: bubblePop 0.2s ease-out;
  box-sizing: border-box;
}

@keyframes bubblePop {
  0% {
    transform: scale(0.8);
  }
  70% {
    transform: scale(1.05);
  }
  100% {
    transform: scale(1);
  }
}

/* 文字消息气泡 */
.message-bubble.text {
  padding: 24rpx 32rpx;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
  position: relative;
}

/* 对方文字消息 - 左侧箭头 */
.message-item.other .message-bubble.text::before {
  content: "";
  position: absolute;
  left: -10rpx;
  top: 20rpx;
  width: 0;
  height: 0;
  border: 10rpx solid transparent;
  border-right-color: var(--text-white);
  border-left: 0;
  filter: drop-shadow(-2rpx 0 2rpx rgba(0, 0, 0, 0.05));
}

/* 自己文字消息 - 右侧箭头 */
.message-item.self .message-bubble.text::before {
  content: "";
  position: absolute;
  right: -10rpx;
  top: 20rpx;
  width: 0;
  height: 0;
  border: 10rpx solid transparent;
  border-left-color: var(--sky-primary);
  border-right: 0;
  filter: drop-shadow(2rpx 0 2rpx rgba(0, 0, 0, 0.05));
}

/* 对方文字消息 */
.message-item.other .message-bubble.text {
  background: linear-gradient(135deg, #ffffff 0%, #f8faff 100%);
  border: 1rpx solid rgba(22, 119, 210, 0.1);
  border-top-left-radius: 12rpx;
}

/* 自己文字消息 */
.message-item.self .message-bubble.text {
  background: linear-gradient(135deg, #1677d2 0%, #1677d2 100%);
  border-top-right-radius: 12rpx;
  color: white;
}

.message-text {
  font-size: 30rpx;
  line-height: 1.5;
}

.message-item.other .message-text {
  color: var(--text-primary);
}

.message-item.self .message-text {
  color: var(--text-white);
}

/* 图片消息 - 纯CSS高性能方案 */
.message-bubble.image {
  padding: 0;
  overflow: hidden;
  border-radius: 24rpx;
  box-shadow: var(--shadow-md);
  /* 限制最大尺寸 */
  max-width: 400rpx;
  max-height: 500rpx;
  /* 去除行高导致的底部留白 */
  line-height: 0;
  font-size: 0;
}

.message-image {
  display: block;
  border-radius: 24rpx;
  /* 后端已预计算尺寸，直接使用 scaleToFill */
  max-width: 400rpx;
  max-height: 500rpx;
}

/* 已有尺寸的图片，使用精确尺寸 */
.message-image.has-size {
  max-width: none;
  max-height: none;
}

.trusted-photo-badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(31, 111, 91, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.18);
  line-height: 1;
  z-index: 2;
}

.trusted-photo-badge text {
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1;
}

.trusted-photo-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  pointer-events: none;
}

/* 底部输入区域 - 毛玻璃效果 */
.input-area {
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(22, 119, 210, 0.12);
  padding: 24rpx 32rpx;
  position: relative;
  z-index: 2;
  /* 固定最小高度避免布局抖动 */
  min-height: 128rpx;
  box-sizing: border-box;
}

/* 任务已结束提示条 */
.task-ended-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: var(--bg-glass);
  border-radius: var(--radius-full);
}

/* breaking 状态提示条 */
.task-ended-bar.breaking-bar {
  background: rgba(255, 193, 7, 0.15);
  border: 1rpx solid rgba(255, 193, 7, 0.3);
}

.task-ended-bar.breaking-bar .task-ended-text {
  color: #f39c12;
  font-weight: 500;
}

.task-ended-text {
  font-size: 28rpx;
  color: var(--text-light);
  font-weight: 500;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 80rpx;
}

/* 展开/收起工具栏按钮 */
.toolbar-toggle-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(22, 119, 210, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.toolbar-toggle-btn:active {
  background: var(--bg-glass);
  transform: scale(0.95);
}

.toolbar-toggle-btn.expanded {
  background: var(--border-color);
}

.input-wrapper {
  flex: 1;
  background: rgba(240, 248, 255, 0.9);
  border-radius: var(--radius-full);
  padding: 0 32rpx;
  border: 2rpx solid var(--border-light);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.input-wrapper:focus-within {
  border-color: var(--border-color);
  box-shadow: 0 0 0 4rpx var(--border-light);
}

.message-input {
  height: 80rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  caret-color: var(--sky-primary);
}

.message-input::placeholder {
  color: var(--text-light);
  opacity: 0.7;
}

/* 发送按钮 */
.send-btn {
  width: 140rpx;
  height: 80rpx;
  padding: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: white;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  border-radius: var(--radius-full);
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(22, 119, 210, 0.35);
  transition: all 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.send-btn::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    var(--bg-glass),
    transparent
  );
  transition: left 0.5s;
}

.send-btn:active::before {
  left: 100%;
}

.send-btn.active {
  background: linear-gradient(135deg, var(--sky-light) 0%, var(--sky-primary) 100%);
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-md);
}

.send-btn[disabled] {
  background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
  box-shadow: none;
  transform: none;
}

/* 工具栏 */
.toolbar {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  transition:
    max-height 0.25s ease,
    opacity 0.2s ease,
    margin-top 0.25s ease;
}

.toolbar.show {
  max-height: 200rpx;
  opacity: 1;
  padding-top: 20rpx;
  margin-top: 16rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.tool-item:active {
  background: var(--border-light);
  transform: scale(0.95);
}

.tool-icon {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  box-shadow: var(--shadow-sky);
  transition: all 0.3s;
}

.tool-item:active .tool-icon {
  transform: scale(0.9);
  box-shadow: var(--shadow-sm);
}

.tool-item:nth-child(2) .tool-icon {
  background: linear-gradient(135deg, var(--vitality-orange) 0%, var(--vitality-coral) 100%);
}

.tool-item:nth-child(3) .tool-icon {
  background: linear-gradient(135deg, var(--fresh-mint) 0%, var(--fresh-green) 100%);
}

.tool-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

/* 完成任务确认弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 80, 0.5);
  backdrop-filter: blur(8rpx);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background: var(--bg-card);
  backdrop-filter: blur(40rpx);
  border-radius: var(--radius-xl);
  border: 2rpx solid var(--border-light);
  box-shadow: var(--shadow-lg);
  overflow: hidden;
  padding: 52rpx;
  transform: translateY(20rpx) scale(0.95);
  transition: all 0.3s;
}

.modal.show .modal-content {
  transform: translateY(0) scale(1);
}

.modal-title {
  font-size: 40rpx;
  font-weight: 800;
  text-align: center;
  margin-bottom: 36rpx;
  color: var(--text-primary);
}

.modal-body {
  padding: 24rpx 0 44rpx;
  text-align: center;
}

.modal-body text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  line-height: 1.6;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid rgba(22, 119, 210, 0.08);
}

.modal-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: transparent;
  border: none;
  border-radius: 0;
  transition: all 0.3s;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  color: var(--text-tertiary);
  border-right: 2rpx solid rgba(22, 119, 210, 0.08);
}

.modal-btn.cancel:active {
  background: rgba(22, 119, 210, 0.05);
}

.modal-btn.confirm {
  color: var(--sky-primary);
}

.modal-btn.confirm:active {
  background: var(--bg-glass);
}

/* 消息状态指示器 */
.message-status {
  position: absolute;
  bottom: -28rpx;
  right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.message-item.other .message-status {
  left: 12rpx;
  right: auto;
}

.status-icon {
  font-size: 20rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.status-icon.loading {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  animation: pulse 1.5s infinite ease-in-out;
}

.status-icon.failed {
  background: linear-gradient(135deg, var(--vitality-orange) 0%, var(--vitality-coral) 100%);
  color: white;
  font-weight: 700;
  padding: 0;
}

.status-icon.failed:active {
  background: linear-gradient(135deg, #e9823a 0%, #d96a22 100%);
  transform: scale(0.95);
}

@keyframes pulse {
  0%,
  100% {
    opacity: 0.6;
    transform: scale(0.8);
  }
  50% {
    opacity: 1;
    transform: scale(1);
  }
}

/* 发送中消息样式 */
.message-bubble.sending {
  opacity: 0.8;
}

.message-bubble.sending .message-text,
.message-bubble.sending .message-image {
  filter: brightness(0.95);
}

/* 文字消息 loading 指示器 */
.message-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  margin-right: 6rpx;
  align-self: center;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--sky-primary);
  border-radius: 50%;
  animation: loadingPulse 1s ease-in-out infinite;
}

@keyframes loadingPulse {
  0%,
  100% {
    transform: scale(0.6);
    opacity: 0.5;
  }
  50% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 图片 wrapper */
.image-wrapper {
  position: relative;
  display: block;
  line-height: 0;
  font-size: 0;
}

/* 图片 loading 指示器 */
.image-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 24rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spinnerRotate 0.8s linear infinite;
}

@keyframes spinnerRotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* 未读新消息提示按钮 */
.new-message-btn {
  position: fixed;
  right: 30rpx;
  bottom: 150rpx;
  background: var(--sky-pale);
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: var(--shadow-md);
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.3s ease;
  z-index: 100;
}

.new-message-btn.show {
  opacity: 1;
  transform: translateY(0);
}

.btn-arrow {
  font-size: 24rpx;
  color: var(--text-primary);
}

.btn-text {
  font-size: 24rpx;
  color: var(--text-primary);
}

/* 系统消息 */
.system-message {
  display: flex;
  justify-content: center;
  width: 100%;
  margin: 24rpx 0;
}

.system-message-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  background: var(--bg-glass);
  backdrop-filter: blur(10rpx);
  padding: 16rpx 32rpx;
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border-light);
  text-align: center;
  line-height: 1.5;
}

/* 首屏骨架屏 */
.chat-skeleton {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding: 24rpx 0;
}

.skel-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.skel-row.self {
  flex-direction: row-reverse;
}

.skel-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, rgba(0, 0, 0, 0.06) 0%, rgba(0, 0, 0, 0.1) 50%, rgba(0, 0, 0, 0.06) 100%);
  background-size: 200% 100%;
  animation: skeletonShimmer 1.4s ease-in-out infinite;
  flex-shrink: 0;
}

.skel-bubble {
  height: 72rpx;
  border-radius: 32rpx;
  background: linear-gradient(90deg, rgba(0, 0, 0, 0.05) 0%, rgba(0, 0, 0, 0.09) 50%, rgba(0, 0, 0, 0.05) 100%);
  background-size: 200% 100%;
  animation: skeletonShimmer 1.4s ease-in-out infinite;
}

.skel-bubble-sm {
  width: 200rpx;
}

.skel-bubble-md {
  width: 320rpx;
}

.skel-bubble-lg {
  width: 460rpx;
  height: 120rpx;
}

@keyframes skeletonShimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}
