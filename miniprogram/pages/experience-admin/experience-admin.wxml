<view class="experience-page admin-ticket-page">
  <view class="tab-bar">
    <view class="tab-item {{status === 'published' ? 'active' : ''}}" data-status="published" bindtap="switchStatus">
      <text>已上架</text>
    </view>
    <view class="tab-item {{status === 'down' ? 'active' : ''}}" data-status="down" bindtap="switchStatus">
      <text>已下架</text>
    </view>
  </view>

  <view wx:if="{{list.length === 0 && !loading}}" class="empty-state">暂无记录</view>
  <view class="ticket-list">
    <view wx:for="{{list}}" wx:key="_id" class="ticket-card {{status === 'down' ? 'resolved' : ''}}">
      <view class="card-left {{status === 'published' ? 'left-published' : 'left-down'}}"></view>
      <view class="card-body">
        <view class="card-title-row" bindtap="goDetail" data-id="{{item._id}}">
          <wdd-icon name="file-text" color="{{status === 'published' ? 'var(--brand-primary)' : '#9AA5B1'}}" size="28"></wdd-icon>
          <text class="card-title">{{item.title}}</text>
          <view class="status-tag {{status === 'published' ? 'status-published' : 'status-down'}}">{{status === 'published' ? '已上架' : '已下架'}}</view>
        </view>
        <view class="card-info-row">
          <text class="info-label">公开地点</text>
          <text class="info-value">{{item.publicLocation || '未填写'}}</text>
        </view>
        <view class="card-info-row">
          <text class="info-label">有用次数</text>
          <text class="info-value">{{item.usefulCount || 0}}</text>
        </view>
        <view class="card-footer">
          <view class="footer-time">
            <wdd-icon name="clock-3" color="#9AA5B1" size="22"></wdd-icon>
            <text>{{item.publishedTimeText || '暂无分享时间'}}</text>
          </view>
          <view class="ticket-action {{status === 'published' ? 'danger' : ''}}" data-id="{{item._id}}" data-status="{{status === 'published' ? 'down' : 'published'}}" bindtap="changeStatus">{{status === 'published' ? '下架' : '上架'}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
