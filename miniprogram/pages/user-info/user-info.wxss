/* 用户信息填写页面样式 */
.container {
  min-height: 100vh;
  background: var(--bg-primary);
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.privacy-tip {
  background: rgba(253, 203, 110, 0.2);
  border: 2rpx solid rgba(253, 203, 110, 0.5);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #b7791f;
  margin-bottom: 30rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-light);
}

.form {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: var(--shadow-md);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  display: block;
}

/* 头像选择 */
.avatar-wrapper {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0 auto;
  background: var(--bg-secondary);
  position: relative;
  overflow: hidden;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-wrapper::after {
  border: none;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-hint {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60rpx;
  background: rgba(0,0,0,0.4);
  color: white;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 昵称输入 */
.nickname-input {
  height: 88rpx;
  background: var(--bg-secondary);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
}

/* 按钮组 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn {
  height: 92rpx;
  border-radius: var(--radius-full);
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  color: white;
}

.btn-secondary {
  background: var(--bg-card);
  color: var(--text-secondary);
  border: 2rpx solid var(--border-light);
}

/* 提示 */
.tips {
  margin-top: 40rpx;
  text-align: center;
}

.tip-text {
  font-size: 24rpx;
  color: var(--text-light);
}
