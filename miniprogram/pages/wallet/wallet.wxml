<!-- 钱包/余额页面 -->
<wxs src="../../utils/money.wxs" module="money" />
<view class="container wdd-page">
  <view class="wdd-page-bg"></view>
  <!-- 余额卡片 -->
  <view class="balance-card">
    <view class="balance-header">
      <text class="balance-title">余额</text>
      <view class="balance-rules" bindtap="showWithdrawRules">
        <wdd-icon name="info" color="#FFFFFF" size="24"></wdd-icon>
        <text class="rules-text">提现规则</text>
      </view>
    </view>
    <view class="balance-amount">
      <wdd-icon name="coins" color="#FFFFFF" size="42"></wdd-icon>
      <text class="amount-number">{{money.format(balance)}}</text>
    </view>
    <!-- 冻结金额提示 -->
    <view wx:if="{{frozenBalance > 0}}" class="frozen-info">
      <view class="frozen-row">
        <text class="frozen-label">冻结金额</text>
        <view class="frozen-value"><text class="money-text">{{money.format(frozenBalance)}}</text></view>
      </view>
      <view class="available-row">
        <text class="available-label">可用余额</text>
        <view class="available-value"><text class="money-text">{{money.format(availableBalance)}}</text></view>
      </view>
    </view>
    <view class="balance-actions">
      <button class="withdraw-btn {{canWithdraw ? '' : 'disabled'}}" bindtap="showApplyModal">
        <text wx:if="{{canWithdraw}}">申请提现</text>
        <text wx:else>{{withdrawTip}}</text>
      </button>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-section">
    <view class="stat-card">
      <view class="stat-value"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(totalEarned)}}</text></view>
      <text class="stat-label">累计收入</text>
    </view>
    <view class="stat-card">
      <view class="stat-value"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(totalWithdrawn)}}</text></view>
      <text class="stat-label">累计提现</text>
    </view>
    <view class="stat-card">
      <view class="stat-value"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(totalPaid)}}</text></view>
      <text class="stat-label">累计支付</text>
    </view>
  </view>

  <!-- 申请记录 -->
  <view class="records-section applications-section">
    <view class="records-header">
      <text class="records-title">申请记录</text>
    </view>

    <view wx:if="{{applications.length === 0 && !appLoading}}" class="empty-state small">
      <text class="empty-text">暂无提现申请</text>
    </view>

    <scroll-view
      wx:else
      class="applications-list"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      lower-threshold="80"
      bindscrolltolower="loadMoreApplications"
    >
      <view wx:for="{{applications}}" wx:key="_id" class="application-card">
        <!-- 第一行：金额 + 状态 -->
        <view class="app-row1">
          <view class="app-amount-wrap">
            <text class="app-amount-label">申请金额：</text>
            <view class="app-amount"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(item.amount)}}</text></view>
          </view>
          <view class="app-status-tag {{item.status === 'pending' ? 'tag-pending' : item.status === 'approved' ? 'tag-approved' : item.status === 'expired' ? 'tag-expired' : 'tag-rejected'}}">
            {{item.statusText}}
            <text wx:if="{{item.status === 'approved' && item.withdrawStatus === 'not_withdrawn' && item.expireCountdown}}"> · {{item.expireCountdown}}后过期</text>
          </view>
        </view>
        <!-- 过期提示 -->
        <view wx:if="{{item.isExpired}}" class="app-expire-row">
          <text class="app-expire-text">⏰ 已过期，请重新申请。冻结金额已解冻。</text>
        </view>
        <!-- 驳回理由 -->
        <view wx:if="{{item.status === 'rejected' && item.rejectReason}}" class="app-reject-row">
          <text class="app-reject-label">驳回理由：</text>
          <text class="app-reject-reason">{{item.rejectReason}}</text>
        </view>
        <!-- 时间 + 操作按钮 -->
        <view class="app-action-row">
          <text class="app-time">{{item.applyTime}}</text>
          <button
            class="app-withdraw-btn {{item.status === 'approved' && item.withdrawStatus === 'not_withdrawn' && !item.isExpired ? 'active' : 'disabled'}}"
            bindtap="goToWithdraw"
            data-id="{{item._id}}"
            disabled="{{!(item.status === 'approved' && item.withdrawStatus === 'not_withdrawn' && !item.isExpired)}}"
          >提现</button>
        </view>
      </view>

      <view wx:if="{{appLoading}}" class="loading-more">
        <text class="loading-text">加载中...</text>
      </view>

      <view wx:if="{{!appLoading && !appHasMore && applications.length > 0}}" class="no-more">
        <text class="no-more-text">没有更多申请了</text>
      </view>
    </scroll-view>
  </view>

  <!-- 账单列表 -->
  <view class="records-section">
    <view class="records-header">
      <text class="records-title">收支明细</text>
    </view>

    <view wx:if="{{records.length === 0 && !loading}}" class="empty-state">
      <view class="empty-icon">
        <wdd-icon name="receipt-text" color="#9AA5B1" size="70"></wdd-icon>
      </view>
      <text class="empty-text">暂无收支记录</text>
    </view>

    <scroll-view
      wx:else
      class="records-list"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      lower-threshold="80"
      bindscrolltolower="loadMoreRecords"
    >
      <view
        wx:for="{{records}}"
        wx:key="_id"
        class="record-item {{index === records.length - 1 ? 'last' : ''}}"
      >
        <view class="record-icon-wrapper" style="background: {{item.iconBg}}">
          <wdd-icon name="{{item.icon || 'receipt'}}" color="{{item.iconColor || 'var(--brand-primary)'}}" size="34"></wdd-icon>
        </view>
        <view class="record-content">
          <view class="record-main-row">
            <text class="record-title">{{item.title}}</text>
            <view class="record-amount {{item.type}}"><text class="money-prefix">{{item.amountPrefix}}</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{item.displayAmountAbs}}</text></view>
          </view>
          <view class="record-sub-row">
            <text class="record-time">{{item.time}}</text>
            <view class="record-balance record-balance-money"><text>余额</text><text class="money-text">{{money.format(item.balance)}}</text></view>
          </view>
        </view>
      </view>

      <view wx:if="{{loading}}" class="loading-more">
        <text class="loading-text">加载中...</text>
      </view>

      <view wx:if="{{!loading && !hasMore && records.length > 0}}" class="no-more">
        <text class="no-more-text">没有更多记录了</text>
      </view>
    </scroll-view>
  </view>

  <!-- 申请提现弹窗 -->
  <view class="modal {{showApplyModal ? 'show' : ''}}" wx:if="{{showApplyModal}}">
    <view class="modal-mask" bindtap="hideApplyModal"></view>
    <view class="modal-content">
      <view class="modal-title">申请提现</view>
      <view class="apply-info">
        <view class="apply-balance apply-balance-money"><text>可提现余额：</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(availableBalance)}}</text></view>
      </view>
      <view class="amount-input-wrapper">
        <wdd-icon name="coins" color="var(--money-gold)" size="38"></wdd-icon>
        <input
          class="amount-input"
          type="digit"
          value="{{applyAmount}}"
          bindinput="onApplyAmountInput"
          placeholder="请输入提现金额"
          placeholder-class="input-placeholder"
        />
      </view>
      <view wx:if="{{applyAmount > 0}}" class="apply-detail">
        <view class="detail-row">
          <text class="detail-label">手续费（{{withdrawFeeRate}}%）</text>
          <view class="detail-value fee"><text class="money-prefix">-</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(applyFee)}}</text></view>
        </view>
        <view class="detail-row">
          <text class="detail-label">预计到账</text>
          <view class="detail-value actual"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(applyActual)}}</text></view>
        </view>
      </view>
      <!-- 审批提示 -->
      <view wx:if="{{applyAmount > 0}}" class="approval-hint {{needApproval ? 'need-approval' : 'instant'}}">
        <wdd-icon wx:if="{{needApproval}}" name="hourglass" color="#E67E22" size="24"></wdd-icon>
        <wdd-icon wx:else name="circle-check-big" color="#07C160" size="24"></wdd-icon>
        <view wx:if="{{needApproval}}" class="approval-copy"><text>单笔超过</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawApprovalThreshold)}}</text><text>，需管理员审批</text></view>
        <view wx:else class="approval-copy"><text>未超过</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawApprovalThreshold)}}</text><text>，即时到账</text></view>
      </view>
      <view wx:if="{{applyErrorTip}}" class="error-tip">
        <text>{{applyErrorTip}}</text>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="hideApplyModal">取消</button>
        <button class="modal-btn confirm {{canSubmitApply ? '' : 'disabled'}}" bindtap="submitApply" disabled="{{!canSubmitApply || isSubmitting}}">
          <text wx:if="{{isSubmitting}}">提交中...</text>
          <text wx:elif="{{needApproval}}">提交审批</text>
          <text wx:else>立即提现</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 提现规则弹窗 -->
  <bottom-sheet show="{{showRulesModal}}" title="提现规则" maxHeight="76vh" bind:close="hideRulesModal">
    <view class="rules-modal-body">
      <view class="rule-item">
        <wdd-icon name="landmark" color="var(--brand-primary)" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">提现门槛</text>
          <view class="rule-desc rule-desc-money"><text>余额满</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawMinAmount)}}</text><text>后可申请提现。</text></view>
        </view>
      </view>
      <view class="rule-item">
        <wdd-icon name="receipt-text" color="var(--vitality-orange)" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">手续费</text>
          <text class="rule-desc">每笔提现收取 {{withdrawFeeRate}}% 手续费，提交前会展示预计到账金额。</text>
        </view>
      </view>
      <view class="rule-item">
        <wdd-icon name="wallet-cards" color="var(--brand-primary)" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">单次限额</text>
          <view class="rule-desc rule-desc-money"><text>单次最低</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawMinPerRequest)}}</text><text>，最高</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawMaxPerRequest)}}</text><text>。</text></view>
        </view>
      </view>
      <view class="rule-item">
        <wdd-icon name="hourglass" color="#E67E22" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">审批规则</text>
          <view class="rule-desc rule-desc-money"><text>单笔超过</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawApprovalThreshold)}}</text><text>需提交审批，审批通过后方可提现。</text></view>
        </view>
      </view>
      <view class="rule-item">
        <wdd-icon name="circle-check-big" color="var(--fresh-mint)" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">即时到账</text>
          <view class="rule-desc rule-desc-money"><text>不超过</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawApprovalThreshold)}}</text><text>的提现将按即时到账流程处理。</text></view>
        </view>
      </view>
      <view class="rule-item">
        <wdd-icon name="calendar-days" color="#7B8794" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">每日限制</text>
          <view class="rule-desc rule-desc-money"><text>单日提现上限</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawDailyLimit)}}</text><text>，每日最多 {{withdrawDailyTimes}} 次。</text></view>
        </view>
      </view>
    </view>
  </bottom-sheet>
</view>
