/* 钱包/余额页面 */
.container {
  min-height: 100vh;
  background: linear-gradient(
    180deg,
    #f0f8ff 0%,
    #e6f3ff 20%,
    #f5faff 100%
  );
  padding: 32rpx;
  box-sizing: border-box;
}

/* 余额卡片 */
.balance-card {
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(93, 184, 230, 0.3);
  margin-bottom: 32rpx;
}

.balance-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.balance-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.balance-rules {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
}

.rules-icon {
  font-size: 24rpx;
}

.rules-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.balance-amount {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 32rpx;
}

.amount-symbol {
  font-size: 40rpx;
  font-weight: 700;
  color: white;
}

.amount-number {
  font-size: 72rpx;
  font-weight: 800;
  color: white;
}

.balance-actions {
  display: flex;
  gap: 20rpx;
}

.withdraw-btn {
  flex: 1;
  height: 80rpx;
  background: white;
  border-radius: 40rpx;
  color: var(--sky-primary);
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.withdraw-btn.disabled {
  background: rgba(255, 255, 255, 0.6);
  color: rgba(255, 255, 255, 0.8);
}

/* 统计区域 */
.stats-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(93, 184, 230, 0.08);
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 账单列表 */
.records-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(93, 184, 230, 0.08);
}

.records-header {
  margin-bottom: 24rpx;
}

.records-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-light);
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid rgba(93, 184, 230, 0.08);
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.record-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-icon {
  font-size: 32rpx;
}

.record-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.record-time {
  font-size: 24rpx;
  color: var(--text-light);
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.record-amount {
  font-size: 30rpx;
  font-weight: 700;
}

.record-amount.income {
  color: var(--fresh-mint);
}

.record-amount.expense {
  color: var(--vitality-orange);
}

.record-balance {
  font-size: 22rpx;
  color: var(--text-light);
}

.loading-more,
.no-more {
  text-align: center;
  padding: 32rpx 0;
}

.loading-text,
.no-more-text {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 申请记录 */
.applications-section {
  margin-bottom: 32rpx;
}

.empty-state.small {
  padding: 40rpx 0;
}

.applications-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.application-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(93, 184, 230, 0.06);
}

/* 第一行：金额 + 状态 */
.app-row1 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.app-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.app-status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.tag-pending {
  color: #e67e22;
  background: rgba(230, 126, 34, 0.08);
}

.tag-approved {
  color: #07c160;
  background: rgba(7, 193, 96, 0.08);
}

.tag-rejected {
  color: #e74c3c;
  background: rgba(231, 76, 60, 0.08);
}

/* 时间 */
.app-time {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 驳回理由 */
.app-reject-row {
  display: flex;
  align-items: flex-start;
  gap: 6rpx;
  padding: 14rpx 16rpx;
  margin-top: 12rpx;
  background: rgba(231, 76, 60, 0.05);
  border-radius: 10rpx;
}

.app-reject-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.app-reject-reason {
  font-size: 24rpx;
  color: #e74c3c;
  flex: 1;
  line-height: 1.5;
}

/* 操作行 */
.app-action-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(93, 184, 230, 0.1);
}

.app-withdraw-btn {
  width: 140rpx;
  height: 60rpx;
  font-size: 26rpx;
  border-radius: 30rpx;
  background: #e0e0e0;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 60rpx;
}

.app-withdraw-btn.active {
  background: #5DB8E6;
  color: #fff;
}

/* 申请提现弹窗 */
.modal {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1000;
  display: flex; align-items: flex-end; justify-content: center;
  opacity: 0; visibility: hidden; transition: all 0.3s;
}
.modal.show { opacity: 1; visibility: visible; }
.modal-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.5); }
.modal-content {
  position: relative; background: #fff; border-radius: 24rpx 24rpx 0 0;
  width: 100%; padding: 40rpx 30rpx; max-height: 80vh; overflow-y: auto; z-index: 1;
}
.modal-title { font-size: 36rpx; font-weight: 600; text-align: center; margin-bottom: 24rpx; }

.apply-info {
  background: var(--bg-secondary); border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 24rpx;
  text-align: center;
}
.apply-balance { font-size: 28rpx; color: var(--text-secondary); }

.amount-input-wrapper {
  display: flex; align-items: center; gap: 12rpx;
  padding: 20rpx 24rpx; background: var(--bg-secondary); border-radius: 16rpx; margin-bottom: 16rpx;
}
.input-symbol { font-size: 40rpx; font-weight: 700; color: var(--text-primary); }
.amount-input { flex: 1; font-size: 40rpx; font-weight: 700; color: var(--text-primary); height: 60rpx; }
.input-placeholder { font-size: 30rpx; color: var(--text-light); }

.apply-detail {
  background: var(--bg-secondary); border-radius: 16rpx; padding: 16rpx 24rpx; margin-bottom: 12rpx;
}
.detail-row { display: flex; justify-content: space-between; align-items: center; padding: 8rpx 0; }
.detail-label { font-size: 26rpx; color: var(--text-secondary); }
.detail-value { font-size: 26rpx; color: var(--text-primary); font-weight: 500; }
.detail-value.fee { color: #e86a4a; }
.detail-value.actual { color: #07c160; font-weight: 600; }

.error-tip {
  padding: 12rpx 16rpx; background: rgba(231, 76, 60, 0.08); border-radius: 8rpx;
  margin-bottom: 16rpx;
}
.error-tip text { font-size: 24rpx; color: #e74c3c; }

.modal-footer { display: flex; gap: 20rpx; margin-top: 24rpx; }
.modal-btn { flex: 1; height: 80rpx; border-radius: 40rpx; font-size: 30rpx; display: flex; align-items: center; justify-content: center; }
.modal-btn.cancel { background: var(--bg-secondary); color: var(--text-primary); }
.modal-btn.confirm { background: #5DB8E6; color: #fff; }
.modal-btn.confirm.disabled { background: #e0e0e0; color: #999; }

/* 规则弹窗 */
.rules-content {
  padding: 8rpx 0;
}
.rule-item {
  display: flex; align-items: flex-start; gap: 10rpx;
  padding: 14rpx 0; border-bottom: 1rpx solid var(--bg-secondary);
}
.rule-item:last-child { border-bottom: none; }
.rule-num {
  font-size: 28rpx; font-weight: 600; color: #5DB8E6;
  min-width: 36rpx; text-align: right;
}
.rule-desc {
  font-size: 28rpx; color: var(--text-primary); line-height: 1.6;
  flex: 1;
}

/* 审批提示 */
.approval-hint {
  display: flex; align-items: center; justify-content: center;
  padding: 16rpx 20rpx; border-radius: 12rpx; margin-bottom: 8rpx;
  font-size: 24rpx;
}
.approval-hint.need-approval {
  background: rgba(230, 126, 34, 0.08); color: #e67e22;
}
.approval-hint.instant {
  background: rgba(7, 193, 96, 0.08); color: #07c160;
}

/* 冻结余额信息 */
.frozen-info {
  background: rgba(255, 255, 255, 0.25);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
}

.frozen-row,
.available-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4rpx 0;
}

.frozen-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.frozen-value {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.available-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.available-value {
  font-size: 26rpx;
  color: #fff;
  font-weight: 700;
}

/* 过期申请样式 */
.tag-expired {
  background: rgba(153, 153, 153, 0.15) !important;
  color: #999 !important;
  border: 1rpx solid rgba(153, 153, 153, 0.3) !important;
}

.app-expire-row {
  padding: 8rpx 16rpx;
  margin-top: 12rpx;
  background: rgba(230, 126, 34, 0.08);
  border-radius: 10rpx;
}

.app-expire-text {
  font-size: 24rpx;
  color: #e67e22;
}
