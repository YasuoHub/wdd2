<!-- 发布求助页面 - 城市绿洲风格 -->
<view class="container">
  <!-- 主内容区 -->
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- 地点选择卡片 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon location">🗺️</view>
        <view class="section-info">
          <text class="section-title">求助地点</text>
          <text class="section-subtitle">选择你想了解的位置</text>
        </view>
      </view>

      <!-- 已选地点展示 -->
      <view wx:if="{{locationName}}" class="selected-location" bindtap="goToLocationPicker">
        <view class="location-info">
          <text class="location-icon">📍</text>
          <view class="location-text">
            <text class="location-name">{{locationName}}</text>
            <text wx:if="{{addressDetail}}" class="location-detail">{{addressDetail}}</text>
          </view>
        </view>
        <text class="change-btn">修改</text>
      </view>

      <!-- 未选择地点 -->
      <view wx:else class="location-picker-trigger required" bindtap="goToLocationPicker">
        <view class="picker-icon-wrapper">
          <text class="picker-icon">📍</text>
        </view>
        <view class="picker-text">
          <text class="picker-title">请选择地点 <text class="required-mark">*</text></text>
          <text class="picker-desc">在地图上选择你想了解的位置</text>
        </view>
        <text class="picker-arrow">›</text>
      </view>

      <!-- 常用地点快捷选择 -->
      <view class="quick-locations">
        <text class="quick-label">常用地点：</text>
        <view class="quick-tags">
          <text
            wx:for="{{quickLocations}}"
            wx:key="name"
            class="quick-tag {{selectedLocation === item.name ? 'active' : ''}}"
            bindtap="selectQuickLocation"
            data-location="{{item}}"
          >{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 求助类型选择 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon type">🎯</view>
        <view class="section-info">
          <text class="section-title">求助类型</text>
          <text class="section-subtitle">选择你想了解的信息类型</text>
        </view>
      </view>

      <view class="type-grid">
        <view
          wx:for="{{needTypes}}"
          wx:key="id"
          class="type-item {{selectedType === item.id ? 'active' : ''}}"
          bindtap="selectType"
          data-type="{{item.id}}"
          style="--type-color: {{item.color}}; --type-bg: {{item.bgColor}}"
        >
          <view class="type-icon-wrapper" style="background: {{item.bgColor}}">
            <text class="type-icon">{{item.icon}}</text>
          </view>
          <text class="type-name">{{item.name}}</text>
          <view wx:if="{{selectedType === item.id}}" class="type-check">✓</view>
        </view>
      </view>
    </view>

    <!-- 问题描述 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon desc">📝</view>
        <view class="section-info">
          <text class="section-title">详细描述</text>
          <text class="section-subtitle">选填，让帮助者更了解你的需求</text>
        </view>
      </view>

      <textarea
        class="desc-textarea"
        placeholder="例如：想确认春熙路的XX餐厅今天是否营业，排队人多吗？大概要等多久？"
        placeholder-class="textarea-placeholder"
        maxlength="500"
        bindinput="onDescriptionInput"
        value="{{description}}"
      ></textarea>
      <text class="char-count">{{description.length}}/500</text>
    </view>

    <!-- 图片上传 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon image">📷</view>
        <view class="section-info">
          <text class="section-title">添加图片</text>
          <text class="section-subtitle">选填，最多3张，每张不超过10MB</text>
        </view>
      </view>

      <view class="image-upload-area">
        <!-- 已选择的图片预览 -->
        <view
          wx:for="{{images}}"
          wx:key="index"
          class="image-preview"
        >
          <image
            class="preview-img"
            src="{{item.path}}"
            mode="aspectFill"
            bindtap="previewImage"
            data-index="{{index}}"
          />
          <view class="delete-btn" bindtap="deleteImage" data-index="{{index}}">
            <text class="delete-icon">×</text>
          </view>
        </view>

        <!-- 添加图片按钮 -->
        <view
          wx:if="{{images.length < maxImageCount}}"
          class="image-add-btn"
          bindtap="chooseImage"
        >
          <text class="add-icon">+</text>
          <text class="add-text">{{images.length}}/{{maxImageCount}}</text>
        </view>
      </view>
    </view>

    <!-- 有效期选择 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon time">⏱️</view>
        <view class="section-info">
          <text class="section-title">有效时间</text>
          <text class="section-subtitle">超时自动取消，积分退还</text>
        </view>
      </view>

      <view class="time-options">
        <view
          wx:for="{{timeOptions}}"
          wx:key="value"
          class="time-option {{selectedTime === item.value ? 'active' : ''}}"
          bindtap="selectTime"
          data-time="{{item.value}}"
        >
          <text class="time-value">{{item.label}}</text>
          <text wx:if="{{item.recommended}}" class="time-recommend">推荐</text>
        </view>
      </view>
    </view>

    <!-- 悬赏积分 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon points">💎</view>
        <view class="section-info">
          <text class="section-title">悬赏积分</text>
          <text class="section-subtitle">设置悬赏，吸引更多帮助者</text>
        </view>
      </view>

      <view class="points-setting">
        <view class="points-slider-wrapper">
          <slider
            class="points-slider"
            min="10"
            max="100"
            step="5"
            value="{{rewardPoints}}"
            activeColor="#A8E6CF"
            backgroundColor="#F5EDE4"
            block-size="28"
            bindchange="onPointsChange"
          />
          <view class="points-range">
            <text>10</text>
            <text class="points-current">
              <text class="points-number">{{rewardPoints}}</text>
              <text class="points-unit">积分</text>
            </text>
            <text>100</text>
          </view>
        </view>

        <!-- 快捷积分选择 -->
        <view class="quick-points">
          <view
            wx:for="{{quickPoints}}"
            wx:key="*this"
            class="quick-point {{rewardPoints === item ? 'active' : ''}}"
            bindtap="selectQuickPoints"
            data-points="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </view>

      <!-- 积分提示 -->
      <view class="points-tip-wrapper">
        <view class="points-balance">
          <text class="balance-label">可用积分</text>
          <text class="balance-value {{availablePoints < rewardPoints ? 'insufficient' : ''}}">{{availablePoints}}</text>
        </view>
        <view wx:if="{{availablePoints < rewardPoints}}" class="points-warning">
          <text class="warning-icon">⚠️</text>
          <text class="warning-text">积分不足，去签到获取</text>
        </view>
        <view wx:else class="points-estimate">
          <text class="estimate-label">约等于</text>
          <text class="estimate-value">{{estimateValue}}元</text>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-spacer"></view>
  </scroll-view>

  <!-- 底部发布按钮 -->
  <view class="footer">
    <view class="footer-content">
      <view class="publish-info">
        <text class="publish-label">悬赏</text>
        <text class="publish-points">{{rewardPoints}}积分</text>
      </view>
      <button
        class="publish-btn {{!canPublish ? 'disabled' : ''}}"
        bindtap="handlePublish"
        disabled="{{!canPublish || isPublishing}}"
      >
        <text wx:if="{{isPublishing}}" class="loading">发布中...</text>
        <text wx:else>立即发布</text>
      </button>
    </view>
  </view>
</view>
