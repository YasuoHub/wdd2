<!-- 发布求助页面 - 城市绿洲风格 -->
<view class="container">
  <!-- 主内容区 -->
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- 地点选择卡片 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon location">🗺️</view>
        <view class="section-info">
          <text class="section-title">求助地点</text>
          <text class="section-subtitle">选择你想了解的位置</text>
        </view>
      </view>

      <!-- 已选地点展示 -->
      <view wx:if="{{locationName}}" class="selected-location" bindtap="goToLocationPicker">
        <view class="location-info">
          <text class="location-icon">📍</text>
          <view class="location-text">
            <text class="location-name">{{locationName}}</text>
            <text wx:if="{{addressDetail}}" class="location-detail">{{addressDetail}}</text>
          </view>
        </view>
        <text class="change-btn">修改</text>
      </view>

      <!-- 未选择地点 -->
      <view wx:else class="location-picker-trigger required" bindtap="goToLocationPicker">
        <view class="picker-icon-wrapper">
          <text class="picker-icon">📍</text>
        </view>
        <view class="picker-text">
          <text class="picker-title">请选择地点 <text class="required-mark">*</text></text>
          <text class="picker-desc">在地图上选择你想了解的位置</text>
        </view>
        <text class="picker-arrow">›</text>
      </view>

      <!-- 常用地点快捷选择 -->
      <view class="quick-locations">
        <text class="quick-label">常用地点：</text>
        <view class="quick-tags">
          <text
            wx:for="{{quickLocations}}"
            wx:key="name"
            class="quick-tag {{selectedLocation === item.name ? 'active' : ''}}"
            bindtap="selectQuickLocation"
            data-location="{{item}}"
          >{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 求助类型选择 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon type">🎯</view>
        <view class="section-info">
          <text class="section-title">求助类型</text>
          <text class="section-subtitle">选择你想了解的信息类型</text>
        </view>
      </view>

      <view class="type-grid">
        <view
          wx:for="{{needTypes}}"
          wx:key="id"
          class="type-item {{selectedType === item.id ? 'active' : ''}}"
          bindtap="selectType"
          data-type="{{item.id}}"
          style="--type-color: {{item.color}}; --type-bg: {{item.bgColor}}"
        >
          <view class="type-icon-wrapper" style="background: {{item.bgColor}}">
            <text class="type-icon">{{item.icon}}</text>
          </view>
          <text class="type-name">{{item.name}}</text>
          <view wx:if="{{selectedType === item.id}}" class="type-check">✓</view>
        </view>
      </view>
    </view>

    <!-- 问题描述 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon desc">📝</view>
        <view class="section-info">
          <text class="section-title">详细描述</text>
          <text class="section-subtitle">选填，让帮助者更了解你的需求</text>
        </view>
      </view>

      <textarea
        class="desc-textarea"
        placeholder="例如：想确认春熙路的XX餐厅今天是否营业，排队人多吗？大概要等多久？"
        placeholder-class="textarea-placeholder"
        maxlength="500"
        bindinput="onDescriptionInput"
        value="{{description}}"
      ></textarea>
      <text class="char-count">{{description.length}}/500</text>
    </view>

    <!-- 图片上传 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon image">📷</view>
        <view class="section-info">
          <text class="section-title">添加图片</text>
          <text class="section-subtitle">选填，最多3张，每张不超过10MB</text>
        </view>
      </view>

      <view class="image-upload-area">
        <!-- 已选择的图片预览 -->
        <view
          wx:for="{{images}}"
          wx:key="index"
          class="image-preview"
        >
          <image
            class="preview-img"
            src="{{item.path}}"
            mode="aspectFill"
            bindtap="previewImage"
            data-index="{{index}}"
          />
          <view class="delete-btn" bindtap="deleteImage" data-index="{{index}}">
            <text class="delete-icon">×</text>
          </view>
        </view>

        <!-- 添加图片按钮 -->
        <view
          wx:if="{{images.length < maxImageCount}}"
          class="image-add-btn"
          bindtap="chooseImage"
        >
          <text class="add-icon">+</text>
          <text class="add-text">{{images.length}}/{{maxImageCount}}</text>
        </view>
      </view>
    </view>

    <!-- 有效期选择 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon time">⏱️</view>
        <view class="section-info">
          <text class="section-title">有效时间</text>
          <text class="section-subtitle">超时自动取消，金额原路退回</text>
        </view>
      </view>

      <view class="time-options">
        <view
          wx:for="{{timeOptions}}"
          wx:key="value"
          class="time-option {{selectedTime === item.value ? 'active' : ''}}"
          bindtap="selectTime"
          data-time="{{item.value}}"
        >
          <text class="time-value">{{item.label}}</text>
          <text wx:if="{{item.recommended}}" class="time-recommend">推荐</text>
        </view>
      </view>
    </view>

    <!-- 悬赏金额 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon amount">💰</view>
        <view class="section-info">
          <text class="section-title">悬赏金额</text>
          <text class="section-subtitle">设置悬赏，吸引更多帮助者</text>
        </view>
      </view>

      <!-- 金额输入 -->
      <view class="amount-setting">
        <view class="amount-input-wrapper">
          <text class="amount-symbol">¥</text>
          <input
            class="amount-input"
            type="digit"
            value="{{rewardAmount}}"
            bindinput="onAmountInput"
            placeholder="{{minRewardAmount}}"
            placeholder-class="amount-placeholder"
          />
          <text class="amount-unit">元</text>
        </view>

        <slider
          class="amount-slider"
          min="{{minRewardAmount}}"
          max="{{maxRewardAmount}}"
          step="1"
          value="{{rewardAmount}}"
          activeColor="#FF8C69"
          backgroundColor="#F5EDE4"
          block-size="28"
          bindchange="onAmountChange"
        />
        <view class="amount-range">
          <text>{{minRewardAmount}}元</text>
          <text class="amount-current">{{rewardAmount}}元</text>
          <text>{{maxRewardAmount}}元</text>
        </view>

        <!-- 快捷金额选择 -->
        <view class="quick-amounts">
          <view
            wx:for="{{quickAmounts}}"
            wx:key="*this"
            class="quick-amount {{rewardAmount === item ? 'active' : ''}}"
            bindtap="selectQuickAmount"
            data-amount="{{item}}"
          >
            {{item}}元
          </view>
        </view>
      </view>

      <!-- 金额明细与平台规则 -->
      <view class="amount-detail">
        <view class="detail-row">
          <text class="detail-label">悬赏金额</text>
          <text class="detail-value">¥{{rewardAmount}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">平台服务费（{{platformFeeRate}}%）</text>
          <text class="detail-value fee">-¥{{platformFee}}</text>
        </view>
        <view class="detail-divider"></view>
        <view class="detail-row total">
          <text class="detail-label">帮助者实际获得</text>
          <text class="detail-value income">¥{{takerIncome}}</text>
        </view>
      </view>

      <!-- 平台规则提示 -->
      <view class="rules-tip" bindtap="showPlatformRules">
        <text class="rules-icon">ℹ️</text>
        <text class="rules-text">平台规则：{{feePolicy}}。{{refundPolicy}}</text>
        <text class="rules-arrow">›</text>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-spacer"></view>
  </scroll-view>

  <!-- 底部发布按钮 -->
  <view class="footer">
    <view class="footer-content">
      <view class="publish-info">
        <text class="publish-label">需支付</text>
        <text class="publish-amount">¥{{rewardAmount}}</text>
      </view>
      <button
        class="publish-btn {{!canPublish ? 'disabled' : ''}}"
        bindtap="handlePublish"
        disabled="{{!canPublish || isPublishing}}"
      >
        <text wx:if="{{isPublishing}}" class="loading">处理中...</text>
        <text wx:else>立即支付并发布</text>
      </button>
    </view>
  </view>

  <!-- 平台规则弹窗 -->
  <view wx:if="{{showRulesModal}}" class="rules-modal" bindtap="hidePlatformRules">
    <view class="rules-modal-content" catchtap="preventHide">
      <view class="rules-modal-header">
        <text class="rules-modal-title">平台规则说明</text>
        <text class="rules-modal-close" bindtap="hidePlatformRules">×</text>
      </view>
      <view class="rules-modal-body">
        <view class="rule-item">
          <text class="rule-icon">💰</text>
          <view class="rule-content">
            <text class="rule-title">悬赏支付</text>
            <text class="rule-desc">发布任务时需先支付悬赏金额，支付成功后任务才会上线。</text>
          </view>
        </view>
        <view class="rule-item">
          <text class="rule-icon">📊</text>
          <view class="rule-content">
            <text class="rule-title">平台服务费</text>
            <text class="rule-desc">平台对每单任务收取{{platformFeeRate}}%服务费，用于平台运营和技术维护。</text>
          </view>
        </view>
        <view class="rule-item">
          <text class="rule-icon">↩️</text>
          <view class="rule-content">
            <text class="rule-title">取消退款</text>
            <text class="rule-desc">任务超时无人接单或手动取消，悬赏金额将原路退回至您的支付账户。</text>
          </view>
        </view>
        <view class="rule-item">
          <text class="rule-icon">✅</text>
          <view class="rule-content">
            <text class="rule-title">任务完成</text>
            <text class="rule-desc">求助者确认完成后，帮助者获得悬赏金额（扣除服务费），计入余额。</text>
          </view>
        </view>
        <view class="rule-item">
          <text class="rule-icon">🏦</text>
          <view class="rule-content">
            <text class="rule-title">提现规则</text>
            <text class="rule-desc">余额满{{withdrawMinAmount}}元可申请提现，提现收取{{withdrawFeeRate}}%手续费。</text>
          </view>
        </view>
      </view>
      <button class="rules-modal-btn" bindtap="hidePlatformRules">我知道了</button>
    </view>
  </view>
</view>
