<page-meta page-style="{{showAmountDetailSheet || showRulesModal ? 'overflow: hidden;' : ''}}" />
<!-- 发布求助页面 - 城市绿洲风格 -->
<wxs src="../../utils/money.wxs" module="money" />
<view class="container wdd-page">
  <view class="wdd-page-bg"></view>
  <!-- 主内容区 -->
  <scroll-view class="content" scroll-y="{{!(showAmountDetailSheet || showRulesModal)}}" enhanced show-scrollbar="{{false}}">

    <!-- 地点选择卡片 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon location">
          <wdd-icon name="map-pinned" color="var(--brand-primary)" size="44"></wdd-icon>
        </view>
        <view class="section-info">
          <text class="section-title">求助地点</text>
          <text class="section-subtitle">选择你想了解的位置</text>
        </view>
      </view>

      <!-- 已选地点展示 -->
      <view wx:if="{{locationName}}" class="selected-location" bindtap="goToLocationPicker">
        <view class="location-info">
          <wdd-icon name="map-pin" color="var(--brand-primary)" size="28"></wdd-icon>
          <view class="location-text">
            <text class="location-name">{{locationName}}</text>
            <text wx:if="{{addressDetail}}" class="location-detail">{{addressDetail}}</text>
          </view>
        </view>
        <text class="change-btn">修改</text>
      </view>

      <!-- 未选择地点 -->
      <view wx:else class="location-picker-trigger required" bindtap="goToLocationPicker">
        <view class="picker-icon-wrapper">
          <wdd-icon name="map-pin" color="#FFFFFF" size="34"></wdd-icon>
        </view>
        <view class="picker-text">
          <text class="picker-title">请选择地点 <text class="required-mark">*</text></text>
          <text class="picker-desc">在地图上选择你想了解的位置</text>
        </view>
        <wdd-icon name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>

      <!-- 曾用地点快捷选择 -->
      <view wx:if="{{quickLocations.length > 0}}" class="quick-locations">
        <text class="quick-label">曾用地点：</text>
        <view class="quick-tags">
          <text
            wx:for="{{quickLocations}}"
            wx:key="name"
            class="quick-tag {{selectedLocation === item.name ? 'active' : ''}}"
            bindtap="selectQuickLocation"
            data-location="{{item}}"
          >{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 求助类型选择 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon type">
          <wdd-icon name="target" color="var(--brand-primary)" size="44"></wdd-icon>
        </view>
        <view class="section-info">
          <text class="section-title">求助类型 <text class="required-mark">*</text></text>
          <text class="section-subtitle">选择你想了解的信息类型</text>
        </view>
      </view>

      <view class="type-grid">
        <view
          wx:for="{{needTypes}}"
          wx:key="id"
          class="type-item {{selectedType === item.id ? 'active' : ''}}"
          bindtap="selectType"
          data-type="{{item.id}}"
          style="--type-color: {{item.color}}; --type-bg: {{item.bgColor}}"
        >
          <view class="type-icon-wrapper">
            <wdd-icon name="{{item.icon}}" color="{{item.color}}" size="54"></wdd-icon>
          </view>
          <text class="type-name">{{item.name}}</text>
          <view wx:if="{{selectedType === item.id}}" class="type-check">
            <wdd-icon name="check" color="#FFFFFF" size="20"></wdd-icon>
          </view>
        </view>
      </view>
    </view>

    <!-- 问题描述 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon desc">
          <wdd-icon name="notebook-pen" color="var(--brand-primary)" size="44"></wdd-icon>
        </view>
        <view class="section-info">
          <text class="section-title">详细描述 <text class="required-mark">*</text></text>
          <text class="section-subtitle">不少于5个字，请写清楚你想确认的信息</text>
        </view>
      </view>

      <textarea
        class="desc-textarea"
        placeholder="例如：想确认春熙路的XX餐厅今天是否营业，排队人多吗？大概要等多久？"
        placeholder-class="textarea-placeholder"
        maxlength="500"
        bindinput="onDescriptionInput"
        value="{{description}}"
      ></textarea>
      <text class="char-count">{{description.length}}/500</text>
    </view>

    <!-- 有效期选择 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon time">
          <wdd-icon name="clock-3" color="var(--brand-primary)" size="44"></wdd-icon>
        </view>
        <view class="section-info">
          <text class="section-title">有效时间 <text class="required-mark">*</text></text>
          <text class="section-subtitle">超时自动取消，金额原路退回</text>
        </view>
      </view>

      <view class="time-options">
        <view
          wx:for="{{timeOptions}}"
          wx:key="value"
          class="time-option {{selectedTime === item.value ? 'active' : ''}}"
          bindtap="selectTime"
          data-time="{{item.value}}"
        >
          <text class="time-value">{{item.label}}</text>
          <text wx:if="{{item.recommended}}" class="time-recommend">推荐</text>
        </view>
      </view>
    </view>

    <!-- 图片上传 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon image">
          <wdd-icon name="image-plus" color="var(--brand-primary)" size="44"></wdd-icon>
        </view>
        <view class="section-info">
          <text class="section-title">图片描述</text>
          <text class="section-subtitle">选填，最多3张，每张不超过10MB</text>
        </view>
      </view>

      <view class="image-upload-area">
        <!-- 已选择的图片预览 -->
        <view
          wx:for="{{images}}"
          wx:key="index"
          class="image-preview"
        >
          <image
            class="preview-img"
            src="{{item.path}}"
            mode="aspectFill"
            bindtap="previewImage"
            data-index="{{index}}"
          />
          <view class="delete-btn" bindtap="deleteImage" data-index="{{index}}">
            <wdd-icon name="x" color="#FFFFFF" size="22"></wdd-icon>
          </view>
        </view>

        <!-- 添加图片按钮 -->
        <view
          wx:if="{{images.length < maxImageCount}}"
          class="image-add-btn"
          bindtap="chooseImage"
        >
          <text class="add-icon">+</text>
          <text class="add-text">{{images.length}}/{{maxImageCount}}</text>
        </view>
      </view>
    </view>

    <!-- 悬赏金额 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-icon amount">
          <wdd-icon name="circle-dollar-sign" color="var(--brand-primary)" size="44"></wdd-icon>
        </view>
        <view class="section-info">
          <text class="section-title">悬赏金额</text>
          <text class="section-subtitle">设置悬赏，吸引更多帮助者</text>
        </view>
      </view>

      <!-- 金额输入 -->
      <view class="amount-setting">
        <view class="amount-input-wrapper">
          <wdd-icon name="coins" color="var(--money-gold)" size="38"></wdd-icon>
          <input
            class="amount-input"
            type="digit"
            value="{{rewardAmount}}"
            bindinput="onAmountInput"
            placeholder="{{minRewardAmount}}"
            placeholder-class="amount-placeholder"
          />
          <text class="amount-unit">元</text>
        </view>

        <slider
          class="amount-slider"
          min="{{minRewardAmount}}"
          max="{{maxRewardAmount}}"
          step="1"
          value="{{rewardAmount}}"
          activeColor="var(--vitality-orange)"
          backgroundColor="#F5EDE4"
          block-size="28"
          bindchange="onAmountChange"
        />
        <view class="amount-range">
          <view class="amount-range-value"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(minRewardAmount)}}</text></view>
          <view class="amount-range-value"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(maxRewardAmount)}}</text></view>
        </view>

        <!-- 快捷金额选择 -->
        <view class="quick-amounts">
          <view
            wx:for="{{quickAmounts}}"
            wx:key="*this"
            class="quick-amount {{rewardAmount === item ? 'active' : ''}}"
            bindtap="selectQuickAmount"
            data-amount="{{item}}"
          >
            <wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(item)}}</text>
          </view>
        </view>
      </view>

      <!-- 支付方式选择 -->
      <view class="payment-method-section">
        <text class="section-label">支付方式</text>
        <view class="payment-options">
          <view
            class="payment-option {{useDeduction ? 'active' : ''}}"
            data-method="deduction"
            bindtap="onTogglePaymentMethod"
          >
            <view class="payment-option-main">
              <wdd-icon class="payment-icon" name="ticket" color="var(--fresh-mint)" size="32"></wdd-icon>
              <text class="payment-name">平台抵扣金</text>
              <view class="payment-option-tail">
                <view class="payment-balance payment-balance-money"><text>可用 </text><wdd-icon name="ticket" color="var(--fresh-mint)" size="24"></wdd-icon><text class="money-text">{{money.format(availableDeductionBalance)}}</text></view>
                <wdd-icon class="payment-check" name="{{useDeduction ? 'circle-check' : 'circle'}}" color="{{useDeduction ? 'var(--sky-primary)' : '#B8C2CC'}}" size="28"></wdd-icon>
              </view>
            </view>
          </view>
          <view
            class="payment-option {{useBalance ? 'active' : ''}}"
            data-method="balance"
            bindtap="onTogglePaymentMethod"
          >
            <view class="payment-option-main">
              <wdd-icon class="payment-icon" name="wallet" color="var(--brand-primary)" size="32"></wdd-icon>
              <text class="payment-name">余额</text>
              <view class="payment-option-tail">
                <view class="payment-balance payment-balance-money"><text>可用 </text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(availableBalance)}}</text></view>
                <wdd-icon class="payment-check" name="{{useBalance ? 'circle-check' : 'circle'}}" color="{{useBalance ? 'var(--sky-primary)' : '#B8C2CC'}}" size="28"></wdd-icon>
              </view>
            </view>
          </view>
          <view
            class="payment-option {{useWechat ? 'active' : ''}}"
            data-method="wechat"
            bindtap="onTogglePaymentMethod"
          >
            <view class="payment-option-main">
              <wdd-icon class="payment-icon" name="credit-card" color="var(--brand-primary)" size="32"></wdd-icon>
              <text class="payment-name">微信支付</text>
              <view class="payment-option-tail">
                <wdd-icon class="payment-check" name="{{useWechat ? 'circle-check' : 'circle'}}" color="{{useWechat ? 'var(--sky-primary)' : '#B8C2CC'}}" size="28"></wdd-icon>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 平台规则提示 -->
      <view class="rules-tip" bindtap="showPlatformRules">
        <wdd-icon name="info" color="var(--brand-primary)" size="28"></wdd-icon>
        <text class="rules-text">平台规则：服务费、退款与提现说明</text>
        <wdd-icon name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>
    </view>
  </scroll-view>

  <!-- 底部发布按钮 -->
  <view class="footer">
    <view class="footer-content">
      <view class="publish-info">
        <text class="publish-label">悬赏总额</text>
        <view class="publish-amount"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(rewardAmount)}}</text></view>
      </view>
      <view class="amount-detail-trigger" bindtap="showAmountDetail">
        <text>详情</text>
        <wdd-icon name="chevron-up" color="#7B8794" size="22"></wdd-icon>
      </view>
      <button
        class="publish-btn {{!canPublish ? 'disabled' : ''}}"
        bindtap="handlePublish"
        disabled="{{!canPublish || isPublishing}}"
      >
        <text wx:if="{{isPublishing}}" class="loading">处理中...</text>
        <text wx:else>立即支付并发布</text>
      </button>
    </view>
  </view>

  <bottom-sheet show="{{showAmountDetailSheet}}" title="费用详情" bind:close="hideAmountDetail">
    <view class="amount-detail sheet-amount-detail">
      <view class="detail-row">
        <text class="detail-label">悬赏金额</text>
        <view class="detail-value"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(rewardAmount)}}</text></view>
      </view>
      <view wx:if="{{deductionAmount > 0}}" class="detail-row">
        <text class="detail-label">平台抵扣金</text>
        <view class="detail-value"><wdd-icon name="ticket" color="var(--fresh-mint)" size="26"></wdd-icon><text class="money-text">{{money.format(deductionAmount)}}</text></view>
      </view>
      <view wx:if="{{balanceAmount > 0}}" class="detail-row">
        <text class="detail-label">余额支付</text>
        <view class="detail-value"><wdd-icon name="wallet" color="var(--brand-primary)" size="26"></wdd-icon><text class="money-text">{{money.format(balanceAmount)}}</text></view>
      </view>
      <view wx:if="{{wechatAmount > 0}}" class="detail-row">
        <text class="detail-label">微信支付</text>
        <view class="detail-value"><wdd-icon name="credit-card" color="var(--brand-primary)" size="26"></wdd-icon><text class="money-text">{{money.format(wechatAmount)}}</text></view>
      </view>
      <view class="detail-row">
        <text class="detail-label">平台服务费（{{platformFeeRate}}%）</text>
        <view class="detail-value fee"><text class="money-prefix">-</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(platformFee)}}</text></view>
      </view>
      <view class="detail-divider"></view>
      <view class="detail-row total">
        <text class="detail-label">帮助者获得</text>
        <view class="detail-value income"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(takerIncome)}}</text></view>
      </view>
    </view>
  </bottom-sheet>

  <bottom-sheet show="{{showRulesModal}}" title="平台规则说明" maxHeight="80vh" bind:close="hidePlatformRules">
    <view class="rules-modal-body">
      <view class="rule-item">
        <wdd-icon name="circle-dollar-sign" color="var(--vitality-orange)" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">悬赏支付</text>
          <text class="rule-desc">余额、平台抵扣金和微信支付可自行选择；抵扣金与余额不足时，可使用微信支付补足剩余金额。</text>
        </view>
      </view>
      <view class="rule-item">
        <wdd-icon name="chart-column" color="var(--brand-primary)" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">平台服务费</text>
          <text class="rule-desc">平台对每单任务收取{{platformFeeRate}}%服务费，用于平台运营和技术维护。</text>
        </view>
      </view>
      <view class="rule-item">
        <wdd-icon name="refresh-cw" color="#7B8794" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">取消退款</text>
          <text class="rule-desc">任务超时无人响应或手动取消，悬赏金额将原路退回至您的支付账户。</text>
        </view>
      </view>
      <view class="rule-item">
        <wdd-icon name="circle-check-big" color="var(--fresh-mint)" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">任务完成</text>
          <text class="rule-desc">求助者确认完成后，帮助者获得悬赏金额（扣除服务费），计入余额。</text>
        </view>
      </view>
      <view class="rule-item">
        <wdd-icon name="landmark" color="var(--brand-primary)" size="40"></wdd-icon>
        <view class="rule-content">
          <text class="rule-title">提现规则</text>
          <text class="rule-desc">帮助者可提现余额大于 0 元即可发起申请，手续费按平台配置执行；实际转账金额需符合微信单笔转账限制，并受每日额度和次数限制。</text>
        </view>
      </view>
    </view>
  </bottom-sheet>
</view>
