/* ============================================
   问当地 - 发布求助 - 天蓝色青春活力风格
   ============================================ */

.container {
  min-height: 100vh;
  background: linear-gradient(
    180deg,
    var(--bg-primary) 0%,
    var(--bg-secondary) 30%,
    var(--bg-tertiary) 70%,
    #f5faff 100%
  );
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
}

/* 主内容区 - 顶部增加padding以适应系统导航栏 */
.content {
  flex: 1;
  padding: 60rpx 32rpx 40rpx;
  box-sizing: border-box;
  width: 100%;
}

/* 区块卡片 */
.section-card {
  background: var(--bg-card);
  backdrop-filter: blur(40rpx);
  border-radius: var(--radius-lg);
  padding: 36rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--border-light);
  box-sizing: border-box;
  width: 100%;
}

.section-header {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.section-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.section-icon.location {
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
}

.section-icon.type {
  background: linear-gradient(135deg, var(--vitality-yellow) 0%, #ffe08c 100%);
}

.section-icon.desc {
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
}

.section-icon.time {
  background: linear-gradient(
    135deg,
    var(--fresh-mint) 0%,
    var(--fresh-green) 100%
  );
}

.section-icon.points {
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
}

.section-info {
  flex: 1;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 地点选择触发器 */
.location-picker-trigger {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: 28rpx;
  border: 2rpx dashed rgba(93, 184, 230, 0.3);
  margin-bottom: 24rpx;
  transition: all 0.3s;
}

.location-picker-trigger:active {
  background: var(--bg-glass);
  border-color: rgba(93, 184, 230, 0.5);
}

.picker-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.3);
}

.picker-icon {
  font-size: 40rpx;
}

.picker-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.picker-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.picker-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.picker-arrow {
  font-size: 40rpx;
  color: var(--text-light);
  font-weight: 300;
}

/* 已选地点展示 */
.selected-location {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: var(--bg-glass);
  border-radius: 28rpx;
  border: 2rpx solid rgba(93, 184, 230, 0.2);
  margin-bottom: 24rpx;
  transition: all 0.3s;
}

.selected-location:active {
  background: rgba(93, 184, 230, 0.15);
}

.location-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.location-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.location-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.location-detail {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.change-btn {
  font-size: 26rpx;
  color: var(--sky-primary);
  font-weight: 600;
  padding: 8rpx 20rpx;
  background: rgba(93, 184, 230, 0.15);
  border-radius: var(--radius-full);
}

/* 必填标记 */
.required-mark {
  color: var(--vitality-orange);
  font-weight: 700;
  margin-left: 4rpx;
}

/* 必填状态下的选择器 */
.location-picker-trigger.required {
  border: 2rpx dashed rgba(255, 140, 105, 0.5);
  background: rgba(255, 140, 105, 0.05);
}

.location-picker-trigger.required .picker-title {
  color: var(--vitality-orange);
  font-weight: 600;
}

/* 常用地点 */
.quick-locations {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-tag {
  padding: 14rpx 28rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--text-tertiary);
  transition: all 0.3s;
  border: 2rpx solid rgba(93, 184, 230, 0.1);
}

.quick-tag.active {
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  color: white;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.3);
}

/* 类型选择网格 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  width: 100%;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 12rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: 28rpx;
  position: relative;
  transition: all 0.3s;
  border: 2rpx solid transparent;
  min-width: 0;
  box-sizing: border-box;
}

.type-item.active {
  background: white;
  border-color: var(--type-color, var(--sky-primary));
  box-shadow: 0 8rpx 24rpx rgba(93, 184, 230, 0.2);
  transform: translateY(-4rpx);
}

.type-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  background: linear-gradient(
    135deg,
    rgba(93, 184, 230, 0.15) 0%,
    rgba(168, 216, 240, 0.1) 100%
  );
}

.type-icon {
  font-size: 40rpx;
}

.type-name {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
  text-align: center;
}

.type-check {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 32rpx;
  height: 32rpx;
  background: var(--type-color, var(--sky-primary));
  border-radius: var(--radius-full);
  color: white;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 描述输入 */
.desc-textarea {
  width: 100%;
  height: 200rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: 24rpx;
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
  border: 2rpx solid rgba(93, 184, 230, 0.1);
}

.textarea-placeholder {
  color: var(--text-light);
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 12rpx;
}

/* 有效期选择 */
.time-options {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  width: 100%;
}

.time-option {
  padding: 20rpx 32rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: var(--radius-full);
  font-size: 26rpx;
  color: var(--text-tertiary);
  position: relative;
  transition: all 0.3s;
  border: 2rpx solid rgba(93, 184, 230, 0.1);
}

.time-option.active {
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  color: white;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.3);
}

.time-recommend {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  color: white;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
  font-weight: 600;
}

/* 积分设置 */
.points-setting {
  margin-bottom: 24rpx;
}

.points-slider-wrapper {
  padding: 20rpx 0;
}

.points-slider {
  margin: 20rpx 0;
}

.points-range {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-light);
  padding: 0 10rpx;
}

.points-current {
  text-align: center;
}

.points-number {
  font-size: 52rpx;
  font-weight: 800;
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.points-unit {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-left: 8rpx;
}

/* 快捷积分 */
.quick-points {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 24rpx;
  width: 100%;
  flex-wrap: wrap;
}

.quick-point {
  width: 80rpx;
  height: 80rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 600;
  transition: all 0.3s;
  border: 2rpx solid rgba(93, 184, 230, 0.1);
}

.quick-point.active {
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(255, 140, 105, 0.35);
  transform: scale(1.05);
}

/* 积分提示 */
.points-tip-wrapper {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: 20rpx;
  border: 2rpx solid rgba(93, 184, 230, 0.1);
}

.points-balance {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.balance-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.balance-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.balance-value.insufficient {
  color: var(--vitality-orange);
}

.points-warning {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.warning-icon {
  font-size: 28rpx;
}

.warning-text {
  font-size: 24rpx;
  color: var(--vitality-orange);
  font-weight: 500;
}

.points-estimate {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.estimate-label {
  font-size: 24rpx;
  color: var(--text-light);
}

.estimate-value {
  font-size: 24rpx;
  color: var(--sky-primary);
  font-weight: 600;
}

/* 底部占位 */
.bottom-spacer {
  height: 180rpx;
}

/* 底部发布栏 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(40rpx);
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(93, 184, 230, 0.1);
  border-top: 2rpx solid rgba(93, 184, 230, 0.08);
}

.footer-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.publish-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.publish-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.publish-points {
  font-size: 40rpx;
  font-weight: 800;
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.publish-btn {
  flex: 1;
  max-width: 400rpx;
  height: 96rpx;
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  border-radius: var(--radius-full);
  color: white;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(93, 184, 230, 0.4);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.publish-btn::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.3),
    transparent
  );
  transition: left 0.5s;
}

.publish-btn:active::before {
  left: 100%;
}

.publish-btn.disabled {
  background: linear-gradient(135deg, #d4e5f0 0%, #c4d8e5 100%);
  box-shadow: none;
}

.loading {
  opacity: 0.8;
}

/* 图片上传区域 */
.section-icon.image {
  background: linear-gradient(135deg, #a29bfe 0%, #b8b3ff 100%);
}

.image-upload-area {
  display: flex;
  flex-wrap: nowrap;
  gap: 20rpx;
}

.image-preview {
  position: relative;
  flex: 1;
  max-width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.preview-img {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: white;
  font-size: 32rpx;
  line-height: 1;
}

.image-add-btn {
  width: 200rpx;
  height: 200rpx;
  background: rgba(240, 248, 255, 0.8);
  border: 2rpx dashed rgba(93, 184, 230, 0.3);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.add-icon {
  font-size: 60rpx;
  color: var(--sky-primary);
  font-weight: 300;
}

.add-text {
  font-size: 24rpx;
  color: var(--text-light);
}
