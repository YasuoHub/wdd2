/* ============================================
   问当地 - 发布求助 - 城市服务清爽可信风格
   ============================================ */

page {
  height: 100%;
  overflow: hidden;
}

.container {
  min-height: 100vh;
  height: 100vh;
  background:
    radial-gradient(circle at 82% 6%, var(--brand-primary-16) 0 76rpx, transparent 180rpx),
    linear-gradient(180deg, #f5f7fa 0%, #ffffff 46%, #f5f7fa 100%);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
  position: relative;
  overflow: hidden;
}

/* 主内容区 - 顶部增加padding以适应系统导航栏 */
.content {
  flex: none;
  height: calc(100vh - 126rpx - env(safe-area-inset-bottom));
  padding: 28rpx 32rpx 24rpx;
  box-sizing: border-box;
  width: 100%;
}

/* 区块卡片 */
.section-card {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 30rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 34rpx rgba(15, 23, 42, 0.07);
  border: 1rpx solid var(--brand-primary-12);
  box-sizing: border-box;
  width: 100%;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.section-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
}

.section-icon.location,
.section-icon.type,
.section-icon.desc,
.section-icon.time,
.section-icon.image,
.section-icon.amount,
.section-icon.points {
  background: var(--brand-primary-10);
  border: 1rpx solid var(--brand-primary-16);
}

.section-info {
  flex: 1;
}

.section-title {
  display: block;
  font-size: 31rpx;
  font-weight: 400;
  color: #1f2d3d;
  margin-bottom: 8rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 地点选择触发器 */
.location-picker-trigger {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx;
  background: rgba(239, 248, 255, 0.72);
  border-radius: 28rpx;
  border: 2rpx dashed rgba(17, 120, 220, 0.26);
  margin-bottom: 24rpx;
  transition: all 0.3s;
}

.location-picker-trigger:active {
  background: var(--bg-glass);
  border-color: var(--brand-primary-50);
}

.picker-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-primary) 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx var(--brand-primary-30);
}

.picker-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.picker-title {
  font-size: 30rpx;
  font-weight: 400;
  color: #1f2d3d;
}

.picker-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.picker-arrow {
  font-size: 40rpx;
  color: var(--text-light);
  font-weight: 300;
}

/* 已选地点展示 */
.selected-location {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: var(--bg-glass);
  border-radius: 28rpx;
  border: 2rpx solid var(--brand-primary-20);
  margin-bottom: 24rpx;
  transition: all 0.3s;
}

.selected-location:active {
  background: var(--brand-primary-16);
}

.location-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.location-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.location-name {
  font-size: 30rpx;
  font-weight: 400;
  color: var(--text-primary);
}

.location-detail {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.change-btn {
  font-size: 26rpx;
  color: var(--sky-primary);
  font-weight: 400;
  padding: 8rpx 20rpx;
  background: var(--brand-primary-16);
  border-radius: var(--radius-full);
}

/* 必填标记 */
.required-mark {
  color: var(--vitality-orange);
  font-weight: 400;
  margin-left: 4rpx;
}

/* 必填状态下的选择器 */
.location-picker-trigger.required {
  border: 2rpx dashed var(--vitality-orange-50);
  background: var(--vitality-orange-05);
}

.location-picker-trigger.required .picker-title {
  color: var(--vitality-orange);
  font-weight: 400;
}

/* 曾用地点 */
.quick-locations {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-tag {
  padding: 14rpx 28rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--text-tertiary);
  transition: all 0.3s;
  border: 2rpx solid var(--brand-primary-10);
}

.quick-tag.active {
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  color: white;
  font-weight: 400;
  box-shadow: 0 4rpx 16rpx var(--brand-primary-30);
}

/* 类型选择网格 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  width: 100%;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 12rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: 28rpx;
  position: relative;
  transition: all 0.3s;
  border: 2rpx solid transparent;
  min-width: 0;
  box-sizing: border-box;
}

.type-item.active {
  background: white;
  border-color: var(--type-color, var(--sky-primary));
  box-shadow: 0 8rpx 24rpx var(--brand-primary-20);
  transform: translateY(-4rpx);
}

.type-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  background: var(--type-bg);
}

.type-name {
  font-size: 24rpx;
  color: #1f2d3d;
  font-weight: 400;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
  text-align: center;
}

.type-check {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 32rpx;
  height: 32rpx;
  background: var(--type-color, var(--sky-primary));
  border-radius: var(--radius-full);
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 描述输入 */
.desc-textarea {
  width: 100%;
  height: 200rpx;
  background: rgba(239, 248, 255, 0.72);
  border-radius: 24rpx;
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
  border: 1rpx solid var(--brand-primary-16);
}

.textarea-placeholder {
  color: var(--text-light);
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 12rpx;
}

/* 有效期选择 */
.time-options {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  width: 100%;
}

.time-option {
  min-width: 0;
  height: 76rpx;
  padding: 0 12rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: 22rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
  position: relative;
  transition: all 0.3s;
  border: 2rpx solid var(--brand-primary-10);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.time-value {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time-option.active {
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  color: white;
  font-weight: 400;
  box-shadow: 0 4rpx 16rpx var(--brand-primary-30);
}

.time-recommend {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  color: white;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
  font-weight: 400;
}

/* 积分设置 */
.points-setting {
  margin-bottom: 24rpx;
}

.points-slider-wrapper {
  padding: 20rpx 0;
}

.points-slider {
  margin: 20rpx 0;
}

.points-range {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-light);
  padding: 0 10rpx;
}

.points-current {
  text-align: center;
}

.points-number {
  font-size: 52rpx;
  font-weight: 400;
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.points-unit {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-left: 8rpx;
}

/* 快捷积分 */
.quick-points {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 24rpx;
  width: 100%;
  flex-wrap: wrap;
}

.quick-point {
  width: 80rpx;
  height: 80rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 400;
  transition: all 0.3s;
  border: 2rpx solid var(--brand-primary-10);
}

.quick-point.active {
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  color: white;
  box-shadow: 0 4rpx 16rpx var(--vitality-orange-35);
  transform: scale(1.05);
}

/* 积分提示 */
.points-tip-wrapper {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: 20rpx;
  border: 2rpx solid var(--brand-primary-10);
}

.points-balance {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.balance-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.balance-value {
  font-size: 32rpx;
  font-weight: 400;
  color: var(--text-primary);
}

.balance-value.insufficient {
  color: var(--vitality-orange);
}

.points-warning {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.warning-icon {
  font-size: 28rpx;
}

.warning-text {
  font-size: 24rpx;
  color: var(--vitality-orange);
  font-weight: 400;
}

.points-estimate {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.estimate-label {
  font-size: 24rpx;
  color: var(--text-light);
}

.estimate-value {
  font-size: 24rpx;
  color: var(--sky-primary);
  font-weight: 400;
}

/* 底部发布栏 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(40rpx);
  padding: 18rpx 32rpx calc(18rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx var(--brand-primary-10);
  border-top: 2rpx solid var(--brand-primary-08);
  z-index: 80;
}

.footer-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.publish-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex-shrink: 0;
  min-width: 128rpx;
}

.publish-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.publish-points {
  font-size: 40rpx;
  font-weight: 400;
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.publish-btn {
  flex: 1;
  max-width: 400rpx;
  min-width: 0;
  height: 88rpx;
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  border-radius: var(--radius-full);
  color: white;
  font-size: 32rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx var(--brand-primary-35);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.publish-btn::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.3),
    transparent
  );
  transition: left 0.5s;
}

.publish-btn:active::before {
  left: 100%;
}

.publish-btn.disabled {
  background: linear-gradient(135deg, #d4e5f0 0%, #c4d8e5 100%);
  box-shadow: none;
}

.loading {
  opacity: 0.8;
}

.amount-detail-trigger {
  min-width: 96rpx;
  height: 64rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border-radius: 18rpx;
  color: var(--text-tertiary);
  font-size: 24rpx;
  font-weight: 400;
  flex-shrink: 0;
}

.amount-detail-trigger:active {
  background: rgba(15, 23, 42, 0.04);
}

/* 图片上传区域 */
.image-upload-area {
  display: flex;
  flex-wrap: nowrap;
  gap: 20rpx;
}

.image-preview {
  position: relative;
  flex: 1;
  max-width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.preview-img {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: white;
  font-size: 32rpx;
  line-height: 1;
}

.image-add-btn {
  width: 200rpx;
  height: 200rpx;
  background: rgba(240, 248, 255, 0.8);
  border: 2rpx dashed var(--brand-primary-30);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.add-icon {
  font-size: 60rpx;
  color: var(--sky-primary);
  font-weight: 300;
}

.add-text {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 金额图标 */
/* 金额输入 */
.amount-input-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx;
  background: rgba(255, 209, 102, 0.08);
  border-radius: 28rpx;
  border: 2rpx solid rgba(255, 209, 102, 0.2);
  margin-bottom: 24rpx;
}

.amount-symbol {
  font-size: 48rpx;
  font-weight: 400;
  color: var(--vitality-orange);
}

.amount-input {
  flex: 1;
  max-width: 200rpx;
  font-size: 64rpx;
  font-weight: 400;
  color: var(--text-primary);
  text-align: center;
  height: auto;
  min-height: 80rpx;
}

.amount-placeholder {
  color: var(--text-light);
  font-size: 48rpx;
}

.amount-unit {
  font-size: 32rpx;
  color: var(--text-tertiary);
}

/* 金额滑块 */
.amount-slider {
  margin: 20rpx 0;
}

.amount-range {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-light);
  padding: 0 10rpx;
}

.amount-current {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--vitality-orange);
}

.amount-range-value,
.quick-amount {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

/* 快捷金额 */
.quick-amounts {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 24rpx;
  width: 100%;
  flex-wrap: nowrap;
}

.quick-amount {
  flex: 1;
  min-width: 0;
  padding: 16rpx 0;
  background: rgba(240, 248, 255, 0.8);
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 400;
  transition: all 0.3s;
  border: 2rpx solid var(--brand-primary-10);
  text-align: center;
  white-space: nowrap;
}

.quick-amount.active {
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  color: white;
  box-shadow: 0 4rpx 16rpx var(--vitality-orange-35);
}

/* 金额明细 */
.sheet-amount-detail {
  background: #f8fafc;
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid var(--border-light);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.detail-row.total {
  padding-top: 16rpx;
  margin-top: 8rpx;
}

.detail-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.detail-value {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--text-primary);
}

.detail-value.fee {
  color: var(--vitality-orange);
}

.detail-value.income {
  color: var(--fresh-mint);
  font-size: 32rpx;
  font-weight: 400;
}

.detail-divider {
  height: 2rpx;
  background: var(--brand-primary-16);
  margin: 8rpx 0;
}

/* 平台规则提示 */
.rules-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  background: var(--brand-primary-08);
  border-radius: 16rpx;
  margin-top: 24rpx;
  border: 2rpx solid var(--brand-primary-16);
}

.rules-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部发布栏 */
.publish-amount {
  font-size: 40rpx;
  font-weight: 400;
  background: linear-gradient(
    135deg,
    var(--vitality-orange) 0%,
    var(--vitality-coral) 100%
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* 平台规则弹窗 */
.rules-modal-body {
  max-height: 60vh;
  overflow-y: auto;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--brand-primary-10);
}

.rule-item:last-child {
  border-bottom: none;
}

.rule-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.rule-content {
  flex: 1;
}

.rule-title {
  display: block;
  font-size: 30rpx;
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.rule-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 费用详情抽屉 */
/* 支付方式选择 */
.payment-method-section {
  margin-top: 24rpx;
}

.section-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 12rpx;
  display: block;
}

.payment-options {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.payment-option {
  flex: 1;
  background: var(--bg-card);
  border: 2rpx solid var(--border-light);
  border-radius: 16rpx;
  padding: 20rpx;
  transition: all 0.2s;
}

.payment-option.active {
  border-color: var(--sky-primary);
  background: var(--brand-primary-08);
  box-shadow: 0 0 0 1rpx var(--sky-primary);
}

.payment-option.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.payment-option-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.payment-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.payment-name {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--text-primary);
}

.payment-balance,
.payment-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
  display: block;
}

.balance-insufficient {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: rgba(230, 126, 34, 0.08);
  border-radius: 10rpx;
}

.balance-insufficient text {
  font-size: 24rpx;
  color: #e67e22;
}
@import "../../styles/wdd-polish.wxss";

/* 发布页局部覆盖：放在共享视觉层之后，保证弹层和底栏不被全局样式压回去 */
.content {
  height: calc(100vh - 126rpx - env(safe-area-inset-bottom));
  padding-bottom: 24rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 18rpx 32rpx calc(18rpx + env(safe-area-inset-bottom));
  z-index: 80;
}

.section-icon.location,
.section-icon.type,
.section-icon.desc,
.section-icon.time,
.section-icon.image,
.section-icon.amount,
.section-icon.points {
  background: var(--brand-primary-10);
  border-color: var(--brand-primary-16);
  box-shadow: none;
}

.rules-modal-body {
  max-height: 60vh;
}

.time-options {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.time-option {
  min-width: 0;
  height: 76rpx;
  padding: 0 12rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.time-value {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time-recommend {
  background: var(--vitality-orange);
  border: 1rpx solid var(--vitality-orange);
  color: #ffffff;
  box-shadow: 0 6rpx 14rpx var(--vitality-orange-24);
}
