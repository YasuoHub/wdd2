<view class="experience-page">
  <view wx:if="{{loading}}" class="empty-state">加载中...</view>
  <block wx:elif="{{experience}}">
    <view class="status-note">
      {{statusNote}}
    </view>
    <view wx:if="{{deadlineText || autoRuleText}}" class="confirm-rule-panel">
      <text wx:if="{{deadlineText}}" class="confirm-rule-line">{{deadlineText}}</text>
      <text wx:if="{{autoRuleText}}" class="confirm-rule-line">{{autoRuleText}}</text>
    </view>
    <view class="detail-section">
      <text class="section-title">公开标题</text>
      <text class="detail-value strong-value">{{experience.title}}</text>
    </view>
    <view class="detail-section">
      <text class="section-title">公开地点</text>
      <text class="detail-value">{{experience.public_location}}</text>
    </view>
    <view class="detail-section">
      <text class="section-title">公开描述</text>
      <text class="detail-value">{{experience.question}}</text>
    </view>
    <view class="detail-section">
      <text class="section-title">任务结果</text>
      <text class="detail-value">{{experience.result}}</text>
    </view>
    <view class="detail-section">
      <text class="section-title">有效期</text>
      <text class="detail-value">{{experience.freshness || '未填写'}}</text>
    </view>
    <view class="detail-section">
      <text class="section-title">注意事项</text>
      <text class="detail-value">{{experience.tips || '无'}}</text>
    </view>
    <view wx:if="{{experience.images.length > 0}}" class="detail-section">
      <text class="section-title">公开图片</text>
      <view class="detail-image-grid">
        <view wx:for="{{experience.images}}" wx:key="*this" class="detail-image-wrap">
          <image class="detail-image" src="{{item}}" mode="aspectFill" />
        </view>
      </view>
    </view>
    <view wx:if="{{canHandle}}" class="fixed-actions">
      <button class="danger-button" data-accepted="{{false}}" bindtap="handle">暂不分享</button>
      <button class="primary-button" data-accepted="{{true}}" bindtap="handle">确认分享</button>
    </view>
  </block>
</view>
