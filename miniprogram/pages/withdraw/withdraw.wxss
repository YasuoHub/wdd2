/* 提现页面 */
.container {
  min-height: 100vh;
  background: linear-gradient(
    180deg,
    #f5f7fa 0%,
    #f5faff 100%
  );
  padding: 32rpx;
  box-sizing: border-box;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* 余额展示 */
.balance-section {
  text-align: center;
  padding: 48rpx 0;
}

.balance-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.balance-amount {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
}

.amount-symbol {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.amount-number {
  font-size: 72rpx;
  font-weight: 800;
  color: var(--text-primary);
}

/* 提现金额输入 */
.withdraw-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(22, 119, 210, 0.08);
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.all-btn {
  font-size: 26rpx;
  color: var(--sky-primary);
  font-weight: 600;
}

.amount-input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid rgba(22, 119, 210, 0.15);
}

.input-symbol {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.amount-input {
  flex: 1;
  font-size: 64rpx;
  font-weight: 800;
  color: var(--text-primary);
  height: auto;
  min-height: 80rpx;
}

.amount-input.locked {
  color: var(--text-secondary);
}

/* 关联申请提示 */
.application-notice {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 24rpx; background: rgba(7, 193, 96, 0.08);
  border-radius: 16rpx; margin-bottom: 24rpx;
  border: 1rpx solid rgba(7, 193, 96, 0.2);
}
.notice-text { font-size: 26rpx; color: #07c160; }
.notice-amount { font-size: 30rpx; font-weight: 700; color: #07c160; }

.all-btn.locked {
  color: var(--text-tertiary);
  cursor: not-allowed;
}

.input-placeholder {
  color: var(--text-light);
  font-size: 48rpx;
}

.error-tip {
  margin-top: 16rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 107, 107, 0.1);
  border-radius: 12rpx;
}

.error-tip text {
  font-size: 26rpx;
  color: var(--danger-color);
}

/* 到账信息 */
.detail-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(22, 119, 210, 0.08);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.detail-row.total {
  padding-top: 24rpx;
}

.detail-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.detail-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.detail-value.fee {
  color: var(--vitality-orange);
}

.detail-value.actual {
  color: var(--fresh-mint);
  font-size: 36rpx;
  font-weight: 700;
}

.detail-divider {
  height: 2rpx;
  background: rgba(22, 119, 210, 0.12);
  margin: 8rpx 0;
}

/* 提现规则 */
.rules-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(22, 119, 210, 0.08);
}

.rules-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}

.rule-dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--sky-primary);
  border-radius: 50%;
  flex-shrink: 0;
}

.rule-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(40rpx);
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(22, 119, 210, 0.1);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  border-radius: 48rpx;
  color: white;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(22, 119, 210, 0.4);
}

.submit-btn.disabled {
  background: linear-gradient(135deg, #d4e5f0 0%, #c4d8e5 100%);
  box-shadow: none;
}
/* ============================================
   城市服务风格视觉覆盖：清爽可信、交易清楚、低装饰
   ============================================ */
.container,
.chat-container {
  background: #f5f7fa;
}

.header,
.footer,
.input-area,
.popup-content,
.modal-content,
.rules-modal-content {
  background: #ffffff;
  border-color: var(--border-light);
  box-shadow: var(--shadow-card);
}

.section-card,
.task-card,
.user-card,
.menu-list,
.quick-panel,
.need-feed,
.login-tip-card,
.balance-section,
.record-card,
.ticket-card,
.report-card,
.appeal-card,
.profile-card,
.rating-card,
.info-card,
.form-card,
.stat-card,
.card {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.location-bar,
.filter-item,
.sort-section,
.distance-section,
.type-badge,
.card-location,
.distance-tag,
.quick-tag,
.type-item,
.time-option,
.quick-point,
.quick-amount,
.payment-option,
.amount-detail,
.rules-tip,
.points-tip-wrapper,
.input-wrapper,
.toolbar-toggle-btn,
.more-btn,
.system-message-text,
.time-divider text {
  background: #f8fafc;
  border-color: var(--border-light);
  box-shadow: none;
}

.filter-item.active,
.type-item.active,
.quick-tag.active,
.time-option.active,
.payment-option.active {
  background: rgba(22, 119, 210, 0.08);
  border-color: rgba(22, 119, 210, 0.34);
  box-shadow: none;
}

.filter-item.active .filter-name,
.quick-tag.active,
.time-option.active,
.payment-option.active .payment-name {
  color: var(--sky-deep);
  font-weight: 600;
}

.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.amount-badge,
.quick-amount.active,
.quick-point.active,
.time-recommend,
.btn-vitality {
  background: var(--vitality-orange);
  box-shadow: var(--shadow-orange);
}

.balance-value.points,
.balance-value.available,
.points-number,
.publish-points,
.publish-amount {
  color: var(--text-primary);
  background: none;
  -webkit-text-fill-color: currentColor;
}

.wdd-amount,
.need-amount,
.amount-current,
.amount-symbol,
.detail-value.fee,
.warning-text,
.balance-value.insufficient,
.task-points-mini {
  color: var(--vitality-orange);
}

.detail-value.income,
.tag-mint,
.status-success,
.success-text {
  color: var(--fresh-mint);
}

.message-item.other .message-bubble.text {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-sm);
}

.message-item.self .message-bubble.text {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.popup-overlay,
.modal-mask,
.rules-modal {
  background: rgba(15, 23, 42, 0.46);
}

.helper-profile-tip,
.balance-insufficient,
.task-ended-bar.breaking-bar {
  background: #fff8e6;
  border-color: rgba(233, 185, 73, 0.34);
}

image,
button,
view {
  letter-spacing: 0;
}
/* 城市服务按钮对比修正 */
.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  color: #ffffff;
}

.publish-btn.disabled,
.send-btn[disabled],
.disabled {
  color: var(--text-muted);
}