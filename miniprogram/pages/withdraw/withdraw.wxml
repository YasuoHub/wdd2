<!-- 提现页面 -->
<wxs src="../../utils/money.wxs" module="money" />
<view class="container wdd-page">
  <view class="wdd-page-bg"></view>
  <!-- 余额展示 -->
  <view class="balance-section">
    <text class="balance-label">{{balanceLabel}}</text>
    <view class="balance-amount">
      <wdd-icon name="coins" color="var(--money-gold)" size="42"></wdd-icon>
      <text class="amount-number">{{money.format(balanceDisplayAmount)}}</text>
    </view>
    <text wx:if="{{balanceTip}}" class="balance-tip">{{balanceTip}}</text>
  </view>

  <!-- 关联申请提示 -->
  <view wx:if="{{application}}" class="application-notice">
    <text class="notice-text">审批通过金额</text>
    <view class="notice-amount"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(application.amount)}}</text></view>
  </view>

  <!-- 提现金额输入 -->
  <view class="withdraw-section">
    <view class="section-title">
      <text>提现金额</text>
    </view>

    <view class="amount-input-wrapper">
      <wdd-icon name="coins" color="var(--money-gold)" size="38"></wdd-icon>
      <input
        class="amount-input {{application ? 'locked' : ''}}"
        type="digit"
        value="{{withdrawAmount}}"
        bindinput="onAmountInput"
        placeholder="{{withdrawMinAmount}}"
        placeholder-class="input-placeholder"
        focus="{{!application}}"
        disabled="{{!!application}}"
      />
    </view>

    <view wx:if="{{limitTip}}" class="limit-tip">
      <text>{{limitTip}}</text>
    </view>

    <view wx:if="{{errorTip}}" class="error-tip">
      <text>{{errorTip}}</text>
    </view>
  </view>

  <!-- 到账信息 -->
  <view class="detail-section">
    <view class="detail-row">
      <text class="detail-label">提现金额</text>
      <view class="detail-value"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawAmount || 0)}}</text></view>
    </view>
    <view class="detail-row">
      <text class="detail-label">手续费（{{withdrawFeeRate}}%）</text>
      <view class="detail-value fee"><text class="money-prefix">-</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawFee)}}</text></view>
    </view>
    <view class="detail-divider"></view>
    <view class="detail-row total">
      <text class="detail-label">实际到账</text>
      <view class="detail-value actual"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(actualAmount)}}</text></view>
    </view>
  </view>

  <!-- 提现规则 -->
  <view class="rules-section">
    <view class="rules-title">提现规则</view>
    <view class="rule-item">
      <text class="rule-dot"></text>
      <view class="rule-text rule-text-money"><text>最低提现金额：</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawMinAmount)}}</text></view>
    </view>
    <view class="rule-item">
      <text class="rule-dot"></text>
      <view class="rule-text rule-text-money"><text>单次最低：</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawMinPerRequest)}}</text><text>，最高：</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawMaxPerRequest)}}</text></view>
    </view>
    <view class="rule-item">
      <text class="rule-dot"></text>
      <text class="rule-text">手续费率：{{withdrawFeeRate}}%</text>
    </view>
    <view class="rule-item">
      <text class="rule-dot"></text>
      <view class="rule-text rule-text-money"><text>单笔超过</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawApprovalThreshold)}}</text><text>需审批，不超过即时到账</text></view>
    </view>
    <view class="rule-item">
      <text class="rule-dot"></text>
      <view class="rule-text rule-text-money"><text>单日提现上限：</text><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(withdrawDailyLimit)}}</text><text>，每日最多{{withdrawDailyTimes}}次</text></view>
    </view>
    <view class="rule-item">
      <text class="rule-dot"></text>
      <text class="rule-text">到账时间：确认收款后实时到账</text>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="footer">
    <button
      class="submit-btn {{canSubmit ? '' : 'disabled'}}"
      bindtap="handleSubmit"
      disabled="{{!canSubmit || isSubmitting}}"
    >
      <text wx:if="{{isSubmitting}}">提交中...</text>
      <text wx:else>确认提现</text>
    </button>
  </view>
</view>
