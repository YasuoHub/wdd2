page { background: var(--bg-secondary); }
.container { display: flex; flex-direction: column; height: 100vh; }

.loading, .empty { text-align: center; padding: 80rpx 40rpx; font-size: 28rpx; color: var(--text-tertiary); }

/* Tab 栏 */
.tab-bar {
  display: flex; position: relative; background: #fff;
  padding: 0 40rpx; height: 88rpx; flex-shrink: 0;
}
.tab-item {
  flex: 1; display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; color: var(--text-secondary); position: relative; z-index: 1;
}
.tab-item.active { color: var(--primary-color, #07c160); font-weight: 600; }
.tab-indicator {
  position: absolute; left: 40rpx; bottom: 0; width: calc(50% - 40rpx);
  height: 4rpx; background: var(--primary-color, #07c160);
  transition: transform 0.3s; border-radius: 2rpx;
}
.tab-indicator.left { transform: translateX(0); }
.tab-indicator.right { transform: translateX(100%); }

/* 滚动列表 */
.scroll-list { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; }
.ticket-list { display: flex; flex-direction: column; gap: 16rpx; padding: 20rpx; }

/* 卡片 */
.ticket-card {
  display: flex; background: #fff; border-radius: 16rpx; overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.ticket-card:active { background: #fafafa; }
.ticket-card.resolved { opacity: 0.7; }

/* 左侧色条 */
.card-left { width: 6rpx; flex-shrink: 0; }
.left-report { background: #e74c3c; }
.left-appeal { background: #f39c12; }

.card-body { flex: 1; padding: 24rpx 24rpx 20rpx; min-width: 0; }

/* 标题行 */
.card-title-row {
  display: flex; align-items: center; gap: 10rpx; margin-bottom: 16rpx;
}
.type-icon { font-size: 32rpx; flex-shrink: 0; }
.card-title { flex: 1; font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.status-tag {
  flex-shrink: 0; font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 20rpx;
}
.status-pending { color: #e67e22; background: rgba(230,126,34,0.08); }
.status-resolved { color: var(--text-tertiary); background: rgba(0,0,0,0.04); }

/* 信息行 */
.card-info-row {
  display: flex; align-items: center; margin-bottom: 10rpx; font-size: 26rpx;
}
.info-label { color: var(--text-tertiary); width: 140rpx; flex-shrink: 0; }
.info-value { color: var(--text-primary); }
.info-value.reward { color: #e86a4a; font-weight: 600; }

/* 用户行 */
.card-users-row {
  display: flex; align-items: center; gap: 12rpx;
  padding: 14rpx 0; margin: 6rpx 0 10rpx;
  border-top: 1rpx solid var(--border-light, #eee);
  border-bottom: 1rpx solid var(--border-light, #eee);
}
.user-text { display: flex; align-items: center; gap: 6rpx; font-size: 26rpx; color: var(--text-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; min-width: 0; }
.user-text text { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.user-arrow { font-size: 24rpx; color: var(--text-light); flex-shrink: 0; }

/* 底部 */
.card-footer { display: flex; align-items: center; justify-content: space-between; }
.footer-time { display: flex; align-items: center; gap: 6rpx; font-size: 24rpx; color: var(--text-light); }
.supplement-tag {
  font-size: 22rpx; color: #2980b9;
  padding: 4rpx 14rpx; background: rgba(52,152,219,0.08); border-radius: 20rpx;
}

.loading-more, .no-more { text-align: center; padding: 24rpx 0; font-size: 26rpx; color: var(--text-tertiary); }
/* ============================================
   城市服务风格视觉覆盖：清爽可信、交易清楚、低装饰
   ============================================ */
.container,
.chat-container {
  background: #f5f7fa;
}

.header,
.footer,
.input-area,
.popup-content,
.modal-content,
.rules-modal-content {
  background: #ffffff;
  border-color: var(--border-light);
  box-shadow: var(--shadow-card);
}

.section-card,
.task-card,
.user-card,
.menu-list,
.quick-panel,
.need-feed,
.login-tip-card,
.balance-section,
.record-card,
.ticket-card,
.report-card,
.appeal-card,
.profile-card,
.rating-card,
.info-card,
.form-card,
.stat-card,
.card {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.location-bar,
.filter-item,
.sort-section,
.distance-section,
.type-badge,
.card-location,
.distance-tag,
.quick-tag,
.type-item,
.time-option,
.quick-point,
.quick-amount,
.payment-option,
.amount-detail,
.rules-tip,
.points-tip-wrapper,
.input-wrapper,
.toolbar-toggle-btn,
.more-btn,
.system-message-text,
.time-divider text {
  background: #f8fafc;
  border-color: var(--border-light);
  box-shadow: none;
}

.filter-item.active,
.type-item.active,
.quick-tag.active,
.time-option.active,
.payment-option.active {
  background: rgba(22, 119, 210, 0.08);
  border-color: rgba(22, 119, 210, 0.34);
  box-shadow: none;
}

.filter-item.active .filter-name,
.quick-tag.active,
.time-option.active,
.payment-option.active .payment-name {
  color: var(--sky-deep);
  font-weight: 600;
}

.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.amount-badge,
.quick-amount.active,
.quick-point.active,
.time-recommend,
.btn-vitality {
  background: var(--vitality-orange);
  box-shadow: var(--shadow-orange);
}

.balance-value.points,
.balance-value.available,
.points-number,
.publish-points,
.publish-amount {
  color: var(--text-primary);
  background: none;
  -webkit-text-fill-color: currentColor;
}

.wdd-amount,
.need-amount,
.amount-current,
.amount-symbol,
.detail-value.fee,
.warning-text,
.balance-value.insufficient,
.task-points-mini {
  color: var(--vitality-orange);
}

.detail-value.income,
.tag-mint,
.status-success,
.success-text {
  color: var(--fresh-mint);
}

.message-item.other .message-bubble.text {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-sm);
}

.message-item.self .message-bubble.text {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.popup-overlay,
.modal-mask,
.rules-modal {
  background: rgba(15, 23, 42, 0.46);
}

.helper-profile-tip,
.balance-insufficient,
.task-ended-bar.breaking-bar {
  background: #fff8e6;
  border-color: rgba(233, 185, 73, 0.34);
}

image,
button,
view {
  letter-spacing: 0;
}
/* 城市服务按钮对比修正 */
.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  color: #ffffff;
}

.publish-btn.disabled,
.send-btn[disabled],
.disabled {
  color: var(--text-muted);
}