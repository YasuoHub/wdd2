<wxs module="icon">
  var map = { weather: '🌤', traffic: '🚗', shop: '🏪', parking: '🅿', queue: '👥', other: '📋' }
  module.exports = function(type) { return map[type] || '📋' }
</wxs>

<view class="container">
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'pending' ? 'active' : ''}}" bindtap="onTabChange" data-tab="pending">
      <text>待处理</text>
    </view>
    <view class="tab-item {{activeTab === 'resolved' ? 'active' : ''}}" bindtap="onTabChange" data-tab="resolved">
      <text>已处理</text>
    </view>
    <view class="tab-indicator {{activeTab === 'pending' ? 'left' : 'right'}}"></view>
  </view>

  <!-- 未处理列表 -->
  <scroll-view wx:if="{{activeTab === 'pending'}}" class="scroll-list" scroll-y bindscrolltolower="onScrollToLower" lower-threshold="100">
    <view wx:if="{{pendingLoading && pendingTickets.length === 0}}" class="loading">加载中...</view>
    <view wx:elif="{{pendingTickets.length === 0}}" class="empty">暂无待处理工单</view>
    <view wx:else class="ticket-list">
      <view wx:for="{{pendingTickets}}" wx:key="_id" class="ticket-card" bindtap="goToDetail" data-id="{{item._id}}">
        <view class="card-left {{item.type === 'report' ? 'left-report' : 'left-appeal'}}"></view>
        <view class="card-body">
          <!-- 标题行 -->
          <view class="card-title-row">
            <text class="type-icon">{{icon(item.taskType)}}</text>
            <text class="card-title text-ellipsis">{{item.taskTitle}}</text>
            <view class="status-tag status-pending">待处理</view>
          </view>
          <!-- 工单编号 -->
          <view class="card-info-row">
            <text class="info-label">工单编号</text>
            <text class="info-value">{{item.taskNumber}}</text>
          </view>
          <!-- 悬赏 -->
          <view class="card-info-row">
            <text class="info-label">任务悬赏</text>
            <text class="info-value reward">¥{{item.rewardAmount}}</text>
          </view>
          <!-- 双方用户 -->
          <view class="card-users-row">
            <text class="user-text">🙏 {{item.seekerNickname || '未知'}}</text>
            <text class="user-arrow">→</text>
            <text class="user-text">🤗 {{item.takerNickname || '未知'}}</text>
          </view>
          <!-- 底部 -->
          <view class="card-footer">
            <text class="footer-time">🕐 {{item.createTimeFormatted}}</text>
            <text wx:if="{{item.supplementStatus}}" class="supplement-tag">{{item.supplementStatus}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{pendingLoadingMore}}" class="loading-more">加载更多...</view>
      <view wx:elif="{{!pendingHasMore && pendingTickets.length > 0}}" class="no-more">没有更多了</view>
    </view>
  </scroll-view>

  <!-- 已处理列表 -->
  <scroll-view wx:elif="{{activeTab === 'resolved'}}" class="scroll-list" scroll-y bindscrolltolower="onScrollToLower" lower-threshold="100">
    <view wx:if="{{resolvedLoading && resolvedTickets.length === 0}}" class="loading">加载中...</view>
    <view wx:elif="{{resolvedTickets.length === 0}}" class="empty">暂无已处理工单</view>
    <view wx:else class="ticket-list">
      <view wx:for="{{resolvedTickets}}" wx:key="_id" class="ticket-card resolved" bindtap="goToDetail" data-id="{{item._id}}">
        <view class="card-left {{item.type === 'report' ? 'left-report' : 'left-appeal'}}"></view>
        <view class="card-body">
          <!-- 标题行 -->
          <view class="card-title-row">
            <text class="type-icon">{{icon(item.taskType)}}</text>
            <text class="card-title text-ellipsis">{{item.taskTitle}}</text>
            <view class="status-tag status-resolved">已处理</view>
          </view>
          <!-- 工单编号 -->
          <view class="card-info-row">
            <text class="info-label">工单编号</text>
            <text class="info-value">{{item.taskNumber}}</text>
          </view>
          <!-- 悬赏 -->
          <view class="card-info-row">
            <text class="info-label">任务悬赏</text>
            <text class="info-value reward">¥{{item.rewardAmount}}</text>
          </view>
          <!-- 双方用户 -->
          <view class="card-users-row">
            <text class="user-text">🙏 {{item.seekerNickname || '未知'}}</text>
            <text class="user-arrow">→</text>
            <text class="user-text">🤗 {{item.takerNickname || '未知'}}</text>
          </view>
          <!-- 底部 -->
          <view class="card-footer">
            <text class="footer-time">🕐 {{item.createTimeFormatted}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{resolvedLoadingMore}}" class="loading-more">加载更多...</view>
      <view wx:elif="{{!resolvedHasMore && resolvedTickets.length > 0}}" class="no-more">没有更多了</view>
    </view>
  </scroll-view>
</view>
