<view class="container">
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:elif="{{tickets.length === 0}}" class="empty">
    <text>暂无待处理工单</text>
  </view>

  <view wx:else class="ticket-list">
    <view wx:for="{{tickets}}" wx:key="_id" class="ticket-card" bindtap="goToDetail" data-id="{{item._id}}">
      <view class="ticket-header">
        <text class="ticket-type {{item.type}}">{{item.type === 'report' ? '举报' : '申诉'}}</text>
        <text class="ticket-status {{item.status}}">{{item.status === 'pending' ? '待处理' : '已处理'}}</text>
      </view>
      <view class="ticket-title">{{item.taskTitle}}</view>
      <view class="ticket-meta">
        <text>编号：{{item.taskNumber}}</text>
        <text>悬赏：¥{{item.rewardAmount}}</text>
      </view>
      <view class="ticket-users">
        <text>求助者：{{item.seekerNickname}}</text>
        <text>帮助者：{{item.takerNickname}}</text>
      </view>
      <view class="ticket-time">工单生成时间：{{item.createTimeFormatted}}</view>
      <view wx:if="{{item.supplementStatus}}" class="supplement-tag">{{item.supplementStatus}}</view>
    </view>
  </view>
</view>