<view class="container">
  <!-- Tab 栏（始终显示） -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'pending' ? 'active' : ''}}" bindtap="onTabChange" data-tab="pending">
      <text>未处理</text>
    </view>
    <view class="tab-item {{activeTab === 'resolved' ? 'active' : ''}}" bindtap="onTabChange" data-tab="resolved">
      <text>已处理</text>
    </view>
    <view class="tab-indicator {{activeTab === 'pending' ? 'left' : 'right'}}"></view>
  </view>

  <!-- 未处理列表 -->
  <scroll-view wx:if="{{activeTab === 'pending'}}" class="scroll-list" scroll-y bindscrolltolower="onScrollToLower" lower-threshold="100">
    <view wx:if="{{pendingLoading && pendingTickets.length === 0}}" class="loading">加载中...</view>
    <view wx:elif="{{pendingTickets.length === 0}}" class="empty">暂无待处理工单</view>
    <view wx:else class="ticket-list">
      <view wx:for="{{pendingTickets}}" wx:key="_id" class="ticket-card pending-card" bindtap="goToDetail" data-id="{{item._id}}">
        <view class="ticket-header">
          <view class="ticket-type-wrap">
            <text class="ticket-type {{item.type}}">{{item.type === 'report' ? '举报' : '申诉'}}</text>
            <text class="ticket-priority">客服介入</text>
          </view>
          <view class="ticket-status pending">
            <text class="status-dot"></text>
            <text>待处理</text>
          </view>
        </view>
        <view class="ticket-title text-ellipsis-2">{{item.taskTitle}}</view>
        <view class="ticket-meta-grid">
          <view class="meta-item meta-number">
            <text class="meta-label">工单编号</text>
            <text class="meta-value">{{item.taskNumber}}</text>
          </view>
          <view class="meta-item meta-reward">
            <text class="meta-label">悬赏</text>
            <text class="meta-value reward">¥{{item.rewardAmount}}</text>
          </view>
        </view>
        <view class="ticket-users">
          <view class="user-chip">
            <text class="user-role">求助者</text>
            <text class="user-name">{{item.seekerNickname}}</text>
          </view>
          <view class="user-chip">
            <text class="user-role">帮助者</text>
            <text class="user-name">{{item.takerNickname}}</text>
          </view>
        </view>
        <view class="ticket-footer">
          <view class="ticket-time">
            <text class="time-label">生成时间</text>
            <text>{{item.createTimeFormatted}}</text>
          </view>
          <view wx:if="{{item.supplementStatus}}" class="supplement-tag">{{item.supplementStatus}}</view>
        </view>
      </view>
      <view wx:if="{{pendingLoadingMore}}" class="loading-more">加载更多...</view>
      <view wx:elif="{{!pendingHasMore && pendingTickets.length > 0}}" class="no-more">没有更多了</view>
    </view>
  </scroll-view>

  <!-- 已处理列表 -->
  <scroll-view wx:elif="{{activeTab === 'resolved'}}" class="scroll-list" scroll-y bindscrolltolower="onScrollToLower" lower-threshold="100">
    <view wx:if="{{resolvedLoading && resolvedTickets.length === 0}}" class="loading">加载中...</view>
    <view wx:elif="{{resolvedTickets.length === 0}}" class="empty">暂无已处理工单</view>
    <view wx:else class="ticket-list">
      <view wx:for="{{resolvedTickets}}" wx:key="_id" class="ticket-card resolved-card" bindtap="goToDetail" data-id="{{item._id}}">
        <view class="ticket-header">
          <view class="ticket-type-wrap">
            <text class="ticket-type {{item.type}}">{{item.type === 'report' ? '举报' : '申诉'}}</text>
            <text class="ticket-priority">客服介入</text>
          </view>
          <view class="ticket-status resolved">
            <text class="status-dot"></text>
            <text>已处理</text>
          </view>
        </view>
        <view class="ticket-title text-ellipsis-2">{{item.taskTitle}}</view>
        <view class="ticket-meta-grid">
          <view class="meta-item meta-number">
            <text class="meta-label">工单编号</text>
            <text class="meta-value">{{item.taskNumber}}</text>
          </view>
          <view class="meta-item meta-reward">
            <text class="meta-label">悬赏</text>
            <text class="meta-value reward">¥{{item.rewardAmount}}</text>
          </view>
        </view>
        <view class="ticket-users">
          <view class="user-chip">
            <text class="user-role">求助者</text>
            <text class="user-name">{{item.seekerNickname}}</text>
          </view>
          <view class="user-chip">
            <text class="user-role">帮助者</text>
            <text class="user-name">{{item.takerNickname}}</text>
          </view>
        </view>
        <view class="ticket-footer">
          <view class="ticket-time">
            <text class="time-label">生成时间</text>
            <text>{{item.createTimeFormatted}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{resolvedLoadingMore}}" class="loading-more">加载更多...</view>
      <view wx:elif="{{!resolvedHasMore && resolvedTickets.length > 0}}" class="no-more">没有更多了</view>
    </view>
  </scroll-view>
</view>
