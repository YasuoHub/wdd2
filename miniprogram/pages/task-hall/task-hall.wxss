/* ============================================
   问当地 - 任务大厅 - 城市服务清爽可信风格
   ============================================ */

.container {
  height: 100vh;
  background:
    radial-gradient(circle at 78% 8%, rgba(22, 119, 210, 0.16) 0 76rpx, transparent 190rpx),
    linear-gradient(180deg, #f5f7fa 0%, #ffffff 48%, #f5f7fa 100%);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
}

/* 顶部导航栏 */
.header {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(28rpx);
  border-bottom: 1rpx solid rgba(22, 119, 210, 0.12);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.location-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(22, 119, 210, 0.1);
  padding: 16rpx 28rpx;
  border-radius: var(--radius-full);
  border: 2rpx solid rgba(22, 119, 210, 0.1);
}

.location-icon {
  font-size: 28rpx;
}

.location-name {
  font-size: 30rpx;
  font-weight: 400;
  color: var(--text-primary);
}

.location-arrow {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.help-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(22, 119, 210, 0.1);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(22, 119, 210, 0.1);
  transition: all 0.3s ease;
}

.help-btn:active {
  background: rgba(22, 119, 210, 0.2);
}

.help-icon {
  font-size: 32rpx;
  color: var(--sky-primary);
  font-weight: 400;
}

/* 筛选标签栏 */
.filter-bar {
  padding: 22rpx 32rpx 14rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: flex;
}

.filter-item {
  margin-right: 16rpx;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 15rpx 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 9999rpx;
  transition: all 0.3s ease;
  border: 1rpx solid rgba(217, 226, 236, 0.96);
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.035);
}

.filter-item.active {
  background: rgba(22, 119, 210, 0.1);
  box-shadow: none;
  border-color: rgba(22, 119, 210, 0.34);
}

.filter-name {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 400;
}

.filter-item.active .filter-name {
  color: #1677D2;
  font-weight: 400;
}

/* 次级筛选栏 - 排序和距离 */
.sub-filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx 22rpx;
  gap: 20rpx;
}

.sort-section,
.distance-section {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 22rpx;
  background: rgba(255, 255, 255, 0.88);
  border-radius: var(--radius-full);
  border: 1rpx solid rgba(22, 119, 210, 0.16);
  transition: all 0.3s;
}

.sort-section:active,
.distance-section:active {
  background: rgba(22, 119, 210, 0.1);
}

.sort-label,
.distance-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 400;
}

.sort-arrow,
.distance-arrow {
  font-size: 18rpx;
  color: var(--text-light);
}

/* 内容滚动区 */
.content {
  flex: 1;
  height: 0;
  overflow: hidden;
}

/* 统计信息栏 */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 18rpx 32rpx;
  margin: 18rpx 32rpx 14rpx;
  background: rgba(255, 255, 255, 0.82);
  border-radius: var(--radius-full);
  backdrop-filter: blur(10rpx);
}

.stats-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 400;
}

.locating-indicator {
  display: flex;
  gap: 6rpx;
}

.locating-dot {
  width: 8rpx;
  height: 8rpx;
  background: var(--sky-primary);
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.locating-dot:nth-child(1) {
  animation-delay: -0.32s;
}
.locating-dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%,
  80%,
  100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

/* 任务列表 */
.task-list {
  padding: 0 32rpx;
}

/* 任务卡片 */
.task-card {
  display: flex;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 28rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 10rpx 34rpx rgba(15, 23, 42, 0.07);
  border: 1rpx solid rgba(22, 119, 210, 0.1);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.task-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 32rpx rgba(22, 119, 210, 0.15);
}

/* 左侧类型色带 */
.type-strip {
  width: 7rpx;
  align-self: stretch;
  flex-shrink: 0;
}

.type-weather {
  background: linear-gradient(180deg, var(--sky-primary) 0%, var(--sky-light) 100%);
}
.type-traffic {
  background: linear-gradient(180deg, var(--vitality-yellow) 0%, #ffe08c 100%);
}
.type-shop {
  background: linear-gradient(180deg, var(--lavender) 0%, #d4d4f0 100%);
}
.type-parking {
  background: linear-gradient(180deg, var(--fresh-mint) 0%, var(--fresh-green) 100%);
}
.type-queue {
  background: linear-gradient(180deg, var(--vitality-orange) 0%, var(--vitality-coral) 100%);
}
.type-other {
  background: linear-gradient(180deg, var(--sky-soft) 0%, #c8e8f5 100%);
}

/* 卡片内容区 */
.card-content {
  flex: 1;
  padding: 28rpx 24rpx 26rpx;
  min-width: 0;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.type-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 18rpx;
  border-radius: var(--radius-full);
  background: rgba(22, 119, 210, 0.1);
}

.type-icon {
  font-size: 28rpx;
}

.type-name {
  font-size: 26rpx;
  font-weight: 400;
  color: var(--text-primary);
}

.amount-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #d96a22 0%, #d96a22 100%);
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 16rpx rgba(255, 209, 102, 0.35);
}

.amount-value {
  font-size: 25rpx;
  font-weight: 400;
  color: white;
}

/* 描述内容 */
.card-desc {
  font-size: 31rpx;
  color: #1f2d3d;
  line-height: 1.42;
  font-weight: 400;
  margin-bottom: 18rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 位置信息 */
.card-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding: 14rpx 18rpx;
  background: rgba(239, 248, 255, 0.72);
  border-radius: 16rpx;
}

.location-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.distance-tag {
  font-size: 22rpx;
  color: var(--sky-primary);
  font-weight: 400;
  padding: 4rpx 12rpx;
  background: rgba(22, 119, 210, 0.1);
  border-radius: var(--radius-full);
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.publisher-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.publisher-avatar {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #1677d2 0%, #2b8ad8 100%);
  border-radius: 50%;
  flex-shrink: 0;
}

.publisher-name {
  font-size: 26rpx;
  color: #7b8794;
}

.time-info {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.time-icon {
  font-size: 22rpx;
  color: #9aa5b1;
}

.time-text {
  font-size: 24rpx;
  color: #9aa5b1;
}

/* 接单按钮 */
.take-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  background: linear-gradient(135deg, #1677d2 0%, #1677d2 100%);
  border-top-right-radius: 28rpx;
  border-bottom-right-radius: 28rpx;
  position: relative;
  overflow: hidden;
}

.take-btn::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.2) 0%,
    transparent 100%
  );
}

.take-text {
  font-size: 28rpx;
  color: white;
  font-weight: 400;
  writing-mode: vertical-rl;
  letter-spacing: 4rpx;
  position: relative;
  z-index: 1;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-illustration {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-circle {
  position: absolute;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #eef2f6 0%, #eef7fd 50%, #d9ecfb 100%);
  border-radius: 50%;
  box-shadow: 0 8rpx 40rpx rgba(22, 119, 210, 0.15);
}

.empty-icon {
  font-size: 100rpx;
  position: relative;
  z-index: 1;
}

.empty-title {
  font-size: 34rpx;
  color: #1f2933;
  font-weight: 400;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9aa5b1;
  margin-bottom: 40rpx;
}

.empty-actions {
  display: flex;
  gap: 20rpx;
}

.empty-btn {
  padding: 24rpx 40rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 400;
  transition: all 0.3s;
}

.empty-btn.primary {
  background: linear-gradient(135deg, #1677d2 0%, #2b8ad8 100%);
  color: white;
  box-shadow: 0 4rpx 20rpx rgba(22, 119, 210, 0.35);
}

.empty-btn.primary:active {
  transform: scale(0.98);
}

.empty-btn.secondary {
  background: rgba(22, 119, 210, 0.1);
  color: #1677d2;
  border: 2rpx solid rgba(22, 119, 210, 0.2);
}

.empty-btn.secondary:active {
  background: rgba(22, 119, 210, 0.15);
}

/* 加载更多 */
.loading-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(22, 119, 210, 0.2);
  border-top-color: #1677d2;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #9aa5b1;
}

/* 到底提示 */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 40rpx;
}

.no-more-line {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(22, 119, 210, 0.3),
    transparent
  );
}

.no-more-text {
  font-size: 24rpx;
  color: #b8c2cc;
}

/* 底部占位 */
.bottom-spacer {
  height: 40rpx;
}

/* 回到顶部按钮 */
.back-to-top {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(22, 119, 210, 0.2);
  border: 2rpx solid rgba(22, 119, 210, 0.1);
  z-index: 99;
  transition: all 0.3s;
}

.back-to-top:active {
  transform: scale(0.95);
  background: rgba(22, 119, 210, 0.1);
}

.back-icon {
  font-size: 36rpx;
  color: #1677d2;
  font-weight: 400;
}

.popup-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.popup-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.popup-option:active {
  background: rgba(22, 119, 210, 0.05);
}

.popup-option.active {
  background: rgba(22, 119, 210, 0.1);
}

.option-icon {
  font-size: 32rpx;
}

.option-label {
  flex: 1;
  font-size: 30rpx;
  color: #1f2933;
  font-weight: 400;
}

.option-check {
  font-size: 32rpx;
  color: #1677d2;
  font-weight: 400;
}

/* 帮助者资料完善提示 */
.helper-profile-tip {
  margin: 20rpx 32rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #fff9e6 0%, #fff3cc 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 200, 100, 0.3);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tip-content {
  display: flex;
  align-items: flex-start;
  flex: 1;
}

.tip-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.tip-text {
  flex: 1;
}

.tip-title {
  font-size: 30rpx;
  font-weight: 400;
  color: #8b6914;
  margin-bottom: 6rpx;
}

.tip-desc {
  font-size: 24rpx;
  color: #a08030;
}

.tip-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-left: 16rpx;
}

.tip-close {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #b89950;
  font-size: 28rpx;
}

.tip-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #ffc857 0%, #ffb347 100%);
  color: #5d4a0c;
  font-size: 26rpx;
  font-weight: 400;
  border-radius: 12rpx;
}
@import "../../styles/wdd-polish.wxss";

/* 顶部筛选：参考消息中心切换按钮，但降低选中态重量 */
.filter-item.active {
  background: rgba(22, 119, 210, 0.1);
  border-color: rgba(22, 119, 210, 0.34);
  box-shadow: none;
}

.filter-item.active .filter-name {
  color: #1677D2;
}

.sort-section,
.distance-section {
  background: #ffffff;
  border-color: rgba(217, 226, 236, 0.96);
}

.stats-bar {
  background: transparent;
  box-shadow: none;
}

/* 任务大厅卡片精修：正式信息流，不改变接单逻辑 */
.task-card {
  min-height: 244rpx;
  border-radius: 26rpx;
  border-color: rgba(217, 226, 236, 0.92);
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.06);
}

.task-card:active {
  transform: scale(0.992);
}

.type-strip {
  width: 6rpx;
  opacity: 0.82;
}

.card-content {
  padding: 28rpx 26rpx 24rpx;
}

.card-header {
  align-items: flex-start;
  gap: 18rpx;
}

.type-badge {
  min-width: 0;
  max-width: 420rpx;
  border: 1rpx solid rgba(217, 226, 236, 0.78);
  box-shadow: none;
}

.type-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #1f2933;
  font-weight: 400;
}

.amount-badge {
  flex-shrink: 0;
  min-height: 48rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(217, 106, 34, 0.1);
  border: 1rpx solid rgba(217, 106, 34, 0.2);
}

.amount-value {
  color: #d96a22;
  font-size: 25rpx;
  font-weight: 400;
}

.card-desc {
  color: #111827;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1.48;
}

.card-location {
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
}

.distance-tag {
  min-height: 34rpx;
  padding: 4rpx 12rpx;
}

.take-btn {
  width: 104rpx;
  background: #1677d2;
  border-top-right-radius: 26rpx;
  border-bottom-right-radius: 26rpx;
  box-shadow: none;
}

.take-text {
  font-weight: 400;
  letter-spacing: 2rpx;
}
