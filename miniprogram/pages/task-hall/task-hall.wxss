/* ============================================
   问当地 - 任务大厅 - 城市服务清爽可信风格
   ============================================ */
@import "../../styles/wdd-polish.wxss";

.container {
  height: 100vh;
  background:
    radial-gradient(circle at 78% 8%, var(--brand-primary-16) 0 76rpx, transparent 190rpx),
    linear-gradient(180deg, #f5f7fa 0%, #ffffff 48%, #f5f7fa 100%);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
}

/* 顶部导航栏 */
.header {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(28rpx);
  border-bottom: 1rpx solid var(--brand-primary-12);
  position: sticky;
  top: 0;
  z-index: 100;
  margin-bottom: 20rpx;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.location-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--brand-primary-10);
  padding: 16rpx 28rpx;
  border-radius: var(--radius-full);
  border: 2rpx solid var(--brand-primary-10);
}

.location-icon {
  font-size: 28rpx;
}

.location-name {
  font-size: 30rpx;
  font-weight: 400;
  color: var(--text-primary);
}

.location-arrow {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.help-btn {
  width: 72rpx;
  height: 72rpx;
  background: var(--brand-primary-10);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--brand-primary-10);
  transition: all 0.3s ease;
}

.help-btn:active {
  background: var(--brand-primary-20);
}

.help-icon {
  font-size: 32rpx;
  color: var(--sky-primary);
  font-weight: 400;
}

/* 筛选标签栏 */
.filter-bar {
  padding: 22rpx 32rpx 6rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: flex;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-right: 16rpx;
  margin-bottom: 4rpx;
  padding: 15rpx 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 9999rpx;
  transition: all 0.3s ease;
  border: 1rpx solid rgba(217, 226, 236, 0.96);
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.035);
}

.filter-name {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 400;
}

/* 次级筛选栏 - 排序和距离 */
.sub-filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx 14rpx;
  gap: 20rpx;
}

.sort-section,
.distance-section {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 22rpx;
  background: #ffffff;
  border-radius: var(--radius-full);
  border: 1rpx solid rgba(217, 226, 236, 0.96);
  transition: all 0.3s;
}

.sort-section:active,
.distance-section:active {
  background: var(--brand-primary-10);
}

.sort-label,
.distance-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 400;
}

.sort-arrow,
.distance-arrow {
  font-size: 18rpx;
  color: var(--text-light);
}

/* 内容滚动区 */
.content {
  flex: 1;
  height: 0;
  overflow: hidden;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-illustration {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-circle {
  position: absolute;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #eef2f6 0%, #eef7fd 50%, #d9ecfb 100%);
  border-radius: 50%;
  box-shadow: 0 8rpx 40rpx var(--brand-primary-16);
}

.empty-icon {
  font-size: 100rpx;
  position: relative;
  z-index: 1;
}

.empty-title {
  font-size: 34rpx;
  color: #1f2933;
  font-weight: 400;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9aa5b1;
  margin-bottom: 40rpx;
}

.empty-actions {
  display: flex;
  gap: 20rpx;
}

.empty-btn {
  padding: 24rpx 40rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 400;
  transition: all 0.3s;
}

.empty-btn.primary {
  background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-primary-light) 100%);
  color: white;
  box-shadow: 0 4rpx 20rpx var(--brand-primary-35);
}

.empty-btn.primary:active {
  transform: scale(0.98);
}

.empty-btn.secondary {
  background: var(--brand-primary-10);
  color: var(--brand-primary);
  border: 2rpx solid var(--brand-primary-20);
}

.empty-btn.secondary:active {
  background: var(--brand-primary-16);
}

/* 加载更多 */
.loading-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--brand-primary-20);
  border-top-color: var(--brand-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #9aa5b1;
}

/* 到底提示 */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 40rpx;
}

.no-more-line {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(
    90deg,
    transparent,
    var(--brand-primary-30),
    transparent
  );
}

.no-more-text {
  font-size: 24rpx;
  color: #b8c2cc;
}

/* 底部占位 */
.bottom-spacer {
  height: 40rpx;
}

/* 回到顶部按钮 */
.back-to-top {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx var(--brand-primary-20);
  border: 2rpx solid var(--brand-primary-10);
  z-index: 99;
  transition: all 0.3s;
}

.back-to-top:active {
  transform: scale(0.95);
  background: var(--brand-primary-10);
}

.back-icon {
  font-size: 36rpx;
  color: var(--brand-primary);
  font-weight: 400;
}

.popup-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.popup-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.popup-option:active {
  background: var(--brand-primary-05);
}

.popup-option.active {
  background: var(--brand-primary-10);
}

.option-icon {
  font-size: 32rpx;
}

.option-label {
  flex: 1;
  font-size: 30rpx;
  color: #1f2933;
  font-weight: 400;
}

.option-check {
  font-size: 32rpx;
  color: var(--brand-primary);
  font-weight: 400;
}

/* 帮助者资料完善提示 */
.helper-profile-tip {
  margin: 20rpx 32rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #fff9e6 0%, #fff3cc 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 200, 100, 0.3);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tip-content {
  display: flex;
  align-items: flex-start;
  flex: 1;
}

.tip-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.tip-text {
  flex: 1;
}

.tip-title {
  font-size: 30rpx;
  font-weight: 400;
  color: #8b6914;
  margin-bottom: 6rpx;
}

.tip-desc {
  font-size: 24rpx;
  color: #a08030;
}

.tip-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-left: 16rpx;
}

.tip-close {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #b89950;
  font-size: 28rpx;
}

.tip-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #ffc857 0%, #ffb347 100%);
  color: #5d4a0c;
  font-size: 26rpx;
  font-weight: 400;
  border-radius: 12rpx;
}

/* 顶部筛选：参考消息中心切换按钮，但降低选中态重量 */
.filter-item.active {
  background: var(--brand-primary-10);
  border-color: var(--brand-primary-34);
  box-shadow: none;
}

.filter-item.active .filter-name {
  color: var(--brand-primary);
}

/* 任务列表卡片：按设计图收敛为白底信息卡，只调整视觉呈现 */
.task-list {
  padding: 0 16rpx;
}

.task-card {
  display: block;
  min-height: 204rpx;
  margin-bottom: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e8edf3;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.06);
  overflow: hidden;
  position: relative;
}

.task-card:active {
  transform: scale(0.996);
  box-shadow: 0 2rpx 10rpx rgba(15, 23, 42, 0.08);
}

.type-strip {
  display: none;
}

.card-content {
  box-sizing: border-box;
  min-height: 204rpx;
  padding: 26rpx 166rpx 62rpx 28rpx;
}

.card-header {
  display: block;
  margin-bottom: 20rpx;
}

.type-badge {
  display: flex;
  align-items: center;
  gap: 18rpx;
  max-width: 370rpx;
  padding: 0;
  background: transparent !important;
  border: 0;
  border-radius: 0;
  box-shadow: none;
}

.type-name {
  color: #424952;
  font-size: 30rpx;
  line-height: 36rpx;
  font-weight: 400;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.amount-badge {
  position: absolute;
  top: 28rpx;
  right: 30rpx;
  display: flex;
  align-items: center;
  padding: 0;
  min-height: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
}

.amount-value {
  display: flex;
  align-items: center;
  gap: 7rpx;
  color: #ff6b1a;
  font-size: 38rpx;
  line-height: 46rpx;
  font-weight: 600;
  letter-spacing: 0;
  font-variant-numeric: tabular-nums;
}

.card-desc {
  box-sizing: border-box;
  width: 100%;
  color: #111418;
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 500;
  margin: 0;
  max-width: 100%;
  max-height: 44rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  word-break: break-all;
  overflow-wrap: break-word;
  display: block;
  margin-bottom: 26rpx;
}

.card-location {
  position: absolute;
  left: 28rpx;
  bottom: 28rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  width: 244rpx;
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
}

.location-text {
  flex: 0 1 auto;
  max-width: 148rpx;
  color: #858b93;
  font-size: 26rpx;
  line-height: 34rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.distance-tag {
  flex-shrink: 0;
  min-height: 0;
  padding: 0;
  color: #858b93;
  font-size: 26rpx;
  line-height: 34rpx;
  font-weight: 400;
  background: transparent;
  border: 0;
  border-radius: 0;
}

.distance-tag::before {
  content: "·";
  padding: 0 8rpx 0 2rpx;
  color: #9aa0a8;
}

.distance-tag:empty::before {
  content: "";
  padding: 0;
}

.card-footer {
  position: absolute;
  left: 300rpx;
  bottom: 28rpx;
  display: flex;
  align-items: center;
  margin: 0;
  padding: 0;
  border: 0 !important;
}

.publisher-info {
  display: none;
}

.time-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.time-text {
  color: #858b93;
  font-size: 26rpx;
  line-height: 34rpx;
  white-space: nowrap;
}

.take-btn {
  position: absolute;
  right: 28rpx;
  bottom: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 124rpx;
  height: 58rpx;
  background: #0878f6;
  border-radius: 10rpx;
  box-shadow: 0 4rpx 10rpx rgba(8, 120, 246, 0.18);
}

.take-btn::before {
  display: none;
}

.take-btn.disabled {
  background: #c8d0d9;
  box-shadow: none;
  opacity: 0.72;
}

.take-btn.disabled:active {
  transform: none;
}

.take-text {
  color: #ffffff;
  font-size: 30rpx;
  line-height: 36rpx;
  font-weight: 500;
  letter-spacing: 0;
  writing-mode: horizontal-tb;
}
