/* ============================================
   问当地 - 任务大厅 - 天蓝色青春活力风格
   ============================================ */

.container {
  height: 100vh;
  background: linear-gradient(180deg, #F0F8FF 0%, #E6F3FF 30%, #EDF7FF 70%, #F5FAFF 100%);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
}

/* 顶部导航栏 */
.header {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(40rpx);
  border-bottom: 2rpx solid rgba(93, 184, 230, 0.08);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.location-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(93, 184, 230, 0.1);
  padding: 16rpx 28rpx;
  border-radius: 9999rpx;
  border: 2rpx solid rgba(93, 184, 230, 0.1);
}

.location-icon {
  font-size: 28rpx;
}

.location-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E50;
}

.location-arrow {
  font-size: 20rpx;
  color: #6B8BA4;
}

.help-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(93, 184, 230, 0.1);
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(93, 184, 230, 0.1);
  transition: all 0.3s ease;
}

.help-btn:active {
  background: rgba(93, 184, 230, 0.2);
}

.help-icon {
  font-size: 32rpx;
  color: #5DB8E6;
  font-weight: 700;
}

/* 筛选标签栏 */
.filter-bar {
  padding: 0 32rpx 20rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: flex;
}

.filter-item {
  margin-right: 16rpx;
}

.filter-item {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: rgba(93, 184, 230, 0.08);
  border-radius: 9999rpx;
  transition: all 0.3s ease;
  border: 2rpx solid rgba(93, 184, 230, 0.05);
}

.filter-icon {
  margin-right: 8rpx;
}

.filter-item.active {
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  box-shadow: 0 4rpx 20rpx rgba(93, 184, 230, 0.35);
  border-color: transparent;
}

.filter-icon {
  font-size: 28rpx;
}

.filter-name {
  font-size: 26rpx;
  color: #6B8BA4;
  font-weight: 500;
}

.filter-item.active .filter-name {
  color: white;
  font-weight: 600;
}

/* 次级筛选栏 - 排序和距离 */
.sub-filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx 24rpx;
  gap: 20rpx;
}

.sort-section,
.distance-section {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: 9999rpx;
  border: 2rpx solid rgba(93, 184, 230, 0.1);
  transition: all 0.3s;
}

.sort-section:active,
.distance-section:active {
  background: rgba(93, 184, 230, 0.1);
}

.sort-label,
.distance-label {
  font-size: 26rpx;
  color: #6B8BA4;
  font-weight: 500;
}

.sort-arrow,
.distance-arrow {
  font-size: 18rpx;
  color: #8FA8B8;
}

/* 内容滚动区 */
.content {
  flex: 1;
  height: 0;
  overflow: hidden;
}

/* 统计信息栏 */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  margin: 20rpx 32rpx 16rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 9999rpx;
  backdrop-filter: blur(10rpx);
}

.stats-text {
  font-size: 26rpx;
  color: #6B8BA4;
  font-weight: 500;
}

.locating-indicator {
  display: flex;
  gap: 6rpx;
}

.locating-dot {
  width: 8rpx;
  height: 8rpx;
  background: #5DB8E6;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.locating-dot:nth-child(1) { animation-delay: -0.32s; }
.locating-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* 任务列表 */
.task-list {
  padding: 0 32rpx;
}

/* 任务卡片 */
.task-card {
  display: flex;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.task-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 32rpx rgba(93, 184, 230, 0.15);
}

/* 左侧类型色带 */
.type-strip {
  width: 8rpx;
  align-self: stretch;
  flex-shrink: 0;
}

.type-weather { background: linear-gradient(180deg, #5DB8E6 0%, #7EC8E8 100%); }
.type-traffic { background: linear-gradient(180deg, #FFD166 0%, #FFE08C 100%); }
.type-shop { background: linear-gradient(180deg, #B8B8E8 0%, #D4D4F0 100%); }
.type-parking { background: linear-gradient(180deg, #6DD5B0 0%, #88D8A3 100%); }
.type-queue { background: linear-gradient(180deg, #FF8C69 0%, #FF9A8B 100%); }
.type-other { background: linear-gradient(180deg, #A8D8F0 0%, #C8E8F5 100%); }

/* 卡片内容区 */
.card-content {
  flex: 1;
  padding: 28rpx;
  min-width: 0;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.type-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 20rpx;
  border-radius: 9999rpx;
  background: rgba(93, 184, 230, 0.1);
}

.type-icon {
  font-size: 28rpx;
}

.type-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E50;
}

.points-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #FF8C69 0%, #FF9A8B 100%);
  border-radius: 9999rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 105, 0.25);
}

.points-icon {
  font-size: 22rpx;
}

.points-value {
  font-size: 24rpx;
  font-weight: 700;
  color: white;
}

/* 描述内容 */
.card-desc {
  font-size: 30rpx;
  color: #2C3E50;
  line-height: 1.5;
  margin-bottom: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 位置信息 */
.card-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding: 14rpx 18rpx;
  background: rgba(240, 248, 255, 0.6);
  border-radius: 16rpx;
}

.location-icon {
  font-size: 24rpx;
  color: #5DB8E6;
}

.location-text {
  flex: 1;
  font-size: 26rpx;
  color: #6B8BA4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.distance-tag {
  font-size: 22rpx;
  color: #5DB8E6;
  font-weight: 600;
  padding: 4rpx 12rpx;
  background: rgba(93, 184, 230, 0.1);
  border-radius: 9999rpx;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.publisher-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.publisher-avatar {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  border-radius: 50%;
  flex-shrink: 0;
}

.publisher-name {
  font-size: 26rpx;
  color: #6B8BA4;
}

.time-info {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.time-icon {
  font-size: 22rpx;
  color: #8FA8B8;
}

.time-text {
  font-size: 24rpx;
  color: #8FA8B8;
}

/* 接单按钮 */
.take-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  border-top-right-radius: 36rpx;
  border-bottom-right-radius: 36rpx;
  position: relative;
  overflow: hidden;
}

.take-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.take-text {
  font-size: 28rpx;
  color: white;
  font-weight: 700;
  writing-mode: vertical-rl;
  letter-spacing: 4rpx;
  position: relative;
  z-index: 1;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-illustration {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-circle {
  position: absolute;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #E6F3FF 0%, #D4EDF7 50%, #C4E5F5 100%);
  border-radius: 50%;
  box-shadow: 0 8rpx 40rpx rgba(93, 184, 230, 0.15);
}

.empty-icon {
  font-size: 100rpx;
  position: relative;
  z-index: 1;
}

.empty-title {
  font-size: 34rpx;
  color: #2C3E50;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8FA8B8;
  margin-bottom: 40rpx;
}

.empty-actions {
  display: flex;
  gap: 20rpx;
}

.empty-btn {
  padding: 24rpx 40rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.empty-btn.primary {
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  color: white;
  box-shadow: 0 4rpx 20rpx rgba(93, 184, 230, 0.35);
}

.empty-btn.primary:active {
  transform: scale(0.98);
}

.empty-btn.secondary {
  background: rgba(93, 184, 230, 0.1);
  color: #5DB8E6;
  border: 2rpx solid rgba(93, 184, 230, 0.2);
}

.empty-btn.secondary:active {
  background: rgba(93, 184, 230, 0.15);
}

/* 加载更多 */
.loading-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(93, 184, 230, 0.2);
  border-top-color: #5DB8E6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #8FA8B8;
}

/* 到底提示 */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 40rpx;
}

.no-more-line {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(93, 184, 230, 0.3), transparent);
}

.no-more-text {
  font-size: 24rpx;
  color: #A8C4D4;
}

/* 底部占位 */
.bottom-spacer {
  height: 40rpx;
}

/* 回到顶部按钮 */
.back-to-top {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(93, 184, 230, 0.2);
  border: 2rpx solid rgba(93, 184, 230, 0.1);
  z-index: 99;
  transition: all 0.3s;
}

.back-to-top:active {
  transform: scale(0.95);
  background: rgba(93, 184, 230, 0.1);
}

.back-icon {
  font-size: 36rpx;
  color: #5DB8E6;
  font-weight: 700;
}

/* 弹窗遮罩 */
.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 80, 0.5);
  backdrop-filter: blur(8rpx);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.popup-content {
  width: 100%;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 44rpx 44rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(93, 184, 230, 0.08);
}

.popup-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
}

.popup-close {
  width: 56rpx;
  height: 56rpx;
  background: rgba(93, 184, 230, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #6B8BA4;
  transition: all 0.3s;
}

.popup-close:active {
  background: rgba(93, 184, 230, 0.2);
}

.popup-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.popup-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.popup-option:active {
  background: rgba(93, 184, 230, 0.05);
}

.popup-option.active {
  background: rgba(93, 184, 230, 0.1);
}

.option-icon {
  font-size: 32rpx;
}

.option-label {
  flex: 1;
  font-size: 30rpx;
  color: #2C3E50;
  font-weight: 500;
}

.option-check {
  font-size: 32rpx;
  color: #5DB8E6;
  font-weight: 700;
}

/* 帮助者资料完善提示 */
.helper-profile-tip {
  margin: 20rpx 32rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #FFF9E6 0%, #FFF3CC 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 200, 100, 0.3);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tip-content {
  display: flex;
  align-items: flex-start;
  flex: 1;
}

.tip-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.tip-text {
  flex: 1;
}

.tip-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #8B6914;
  margin-bottom: 6rpx;
}

.tip-desc {
  font-size: 24rpx;
  color: #A08030;
}

.tip-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-left: 16rpx;
}

.tip-close {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #B89950;
  font-size: 28rpx;
}

.tip-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #FFC857 0%, #FFB347 100%);
  color: #5D4A0C;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 12rpx;
}
