<page-meta page-style="{{showSortPopup || showDistancePopup ? 'overflow: hidden;' : ''}}" />
<!-- 任务大厅 - 城市绿洲风格 -->
<wxs src="../../utils/money.wxs" module="money" />
<view class="container wdd-page">
  <view class="wdd-page-bg"></view>

  <!-- 顶部导航栏 -->
  <view class="header">
    <!-- 筛选标签栏 -->
    <view class="filter-bar">
      <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="filter-list">
          <view
            wx:for="{{filters}}"
            wx:key="id"
            class="filter-item {{activeFilter === item.id ? 'active' : ''}}"
            bindtap="selectFilter"
            data-filter="{{item.id}}"
          >
            <wdd-icon name="{{item.icon}}" color="{{activeFilter === item.id ? item.color : 'var(--text-tertiary)'}}" size="28"></wdd-icon>
            <text class="filter-name">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 排序和距离筛选 -->
    <view class="sub-filter-bar">
      <view class="sort-section" bindtap="showSortOptions">
        <wdd-icon name="{{currentSort.icon}}" color="{{currentSort.color || 'var(--brand-primary)'}}" size="24"></wdd-icon>
        <text class="sort-label">{{currentSort.label}}</text>
        <wdd-icon name="chevron-down" color="#7B8794" size="18"></wdd-icon>
      </view>
      <view class="distance-section" bindtap="showDistanceOptions">
        <wdd-icon name="{{currentDistance.icon}}" color="{{currentDistance.color || 'var(--brand-primary)'}}" size="24"></wdd-icon>
        <text class="distance-label">{{currentDistance.label}}</text>
        <wdd-icon name="chevron-down" color="#7B8794" size="18"></wdd-icon>
      </view>
    </view>
  </view>

  <!-- 帮助者资料完善提示 -->
  <view class="helper-profile-tip" wx:if="{{showHelperProfileTip}}">
    <view class="tip-content">
      <wdd-icon name="lightbulb" color="#946B00" size="40"></wdd-icon>
      <view class="tip-text">
        <view class="tip-title">完善帮助者资料</view>
        <view class="tip-desc">设置常去地点和可帮助类型，获取更精准的任务推荐</view>
      </view>
    </view>
    <view class="tip-actions">
      <view class="tip-close" bindtap="closeHelperProfileTip">
        <wdd-icon name="x" color="#B89950" size="24"></wdd-icon>
      </view>
      <view class="tip-btn" bindtap="goToHelperProfile">去完善</view>
    </view>
  </view>

  <!-- 任务列表内容区 -->
  <scroll-view
    class="content"
    scroll-y="{{!(showSortPopup || showDistancePopup)}}"
    refresher-enabled="{{!(showSortPopup || showDistancePopup)}}"
    refresher-triggered="{{isRefreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onLoadMore"
    bindscroll="onScroll"
    enhanced
    show-scrollbar="{{false}}"
  >
    <!-- 任务列表 -->
    <view wx:if="{{taskList.length > 0}}" class="task-list">
      <view
        wx:for="{{taskList}}"
        wx:key="_id"
        class="task-card"
        bindtap="goToTaskDetail"
        data-id="{{item._id}}"
      >
        <!-- 左侧色带 -->
        <view class="type-strip type-{{item.type}}"></view>

        <!-- 卡片内容 -->
        <view class="card-content">
          <!-- 头部：类型和积分 -->
          <view class="card-header">
            <view class="type-badge" style="background: {{item.bgColor}}">
              <wdd-icon name="{{item.typeIcon || 'circle-help'}}" color="{{item.iconColor || 'var(--brand-primary)'}}" size="28"></wdd-icon>
              <text class="type-name">{{item.typeName}}</text>
            </view>
            <view class="amount-badge">
              <view class="amount-value"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(item.displayRewardAmount || item.takerIncome || item.rewardAmount || item.points / 10)}}</text></view>
            </view>
          </view>

          <!-- 描述内容 -->
          <view class="card-desc">{{item.description || '暂无详细描述，点击去帮助后沟通详情'}}</view>

          <!-- 位置信息 -->
          <view class="card-location">
            <wdd-icon name="map-pin" color="var(--brand-primary)" size="24"></wdd-icon>
            <text class="location-text">{{item.locationName}}</text>
            <text class="distance-tag">{{item.distanceText}}</text>
          </view>

          <!-- 底部信息 -->
          <view class="card-footer">
            <view class="publisher-info">
              <image class="publisher-avatar" src="{{item.user_avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
              <text class="publisher-name">{{item.userNickname || '匿名用户'}}</text>
            </view>
            <view class="time-info">
              <wdd-icon name="clock-3" color="var(--brand-primary)" size="22"></wdd-icon>
              <text class="time-text">{{item.remainTime}}</text>
            </view>
          </view>
        </view>

        <!-- 帮助按钮 -->
        <view class="take-btn" catchtap="takeTask" data-id="{{item._id}}" data-amount="{{item.displayRewardAmount || item.takerIncome || item.rewardAmount || 0}}">
          <text class="take-text">去帮助</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <empty wx:if="{{taskList.length === 0 && !isRefreshing && !isLoading}}" type="normal" icon="inbox" title="附近暂无求助任务" desc="{{activeFilter === 'all' ? '下拉页面刷新，或稍后再来看看' : '试试查看全部类型，或稍后再来'}}" showBtn="{{activeFilter !== 'all'}}" btnText="查看全部类型" btnType="primary" bind:btnTap="onViewAllTap"></empty>

    <!-- 加载更多 -->
    <loading wx:if="{{isLoadingMore}}" type="normal" text="正在加载更多..." mode="spinner" size="48"></loading>

    <!-- 到底提示 -->
    <view wx:if="{{!hasMore && taskList.length > 0}}" class="no-more">
      <text class="no-more-line"></text>
      <text class="no-more-text">已经到底了</text>
      <text class="no-more-line"></text>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-spacer"></view>
  </scroll-view>

  <!-- 快速回到顶部 -->
  <view wx:if="{{showBackToTop}}" class="back-to-top" bindtap="scrollToTop">
    <wdd-icon name="arrow-up" color="var(--brand-primary)" size="36"></wdd-icon>
  </view>

  <!-- 排序选项弹窗 -->
  <bottom-sheet show="{{showSortPopup}}" title="排序方式" maxHeight="70vh" bind:close="hidePopups">
    <view class="popup-options">
      <view
        wx:for="{{sortOptions}}"
        wx:key="value"
        class="popup-option {{currentSort.value === item.value ? 'active' : ''}}"
        bindtap="selectSort"
        data-sort="{{item}}"
      >
        <wdd-icon name="{{item.icon}}" color="{{item.color}}" size="32"></wdd-icon>
        <text class="option-label">{{item.label}}</text>
        <wdd-icon wx:if="{{currentSort.value === item.value}}" name="check" color="var(--brand-primary)" size="30"></wdd-icon>
      </view>
    </view>
  </bottom-sheet>

  <!-- 距离选项弹窗 -->
  <bottom-sheet show="{{showDistancePopup}}" title="距离范围" maxHeight="70vh" bind:close="hidePopups">
    <view class="popup-options">
      <view
        wx:for="{{distanceOptions}}"
        wx:key="value"
        class="popup-option {{currentDistance.value === item.value ? 'active' : ''}}"
        bindtap="selectDistance"
        data-distance="{{item}}"
      >
        <wdd-icon name="{{item.icon}}" color="{{item.color}}" size="32"></wdd-icon>
        <text class="option-label">{{item.label}}</text>
        <wdd-icon wx:if="{{currentDistance.value === item.value}}" name="check" color="var(--brand-primary)" size="30"></wdd-icon>
      </view>
    </view>
  </bottom-sheet>
</view>
