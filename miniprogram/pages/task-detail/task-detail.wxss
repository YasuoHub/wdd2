@import "../../styles/wdd-polish.wxss";

/* 问当地 - 任务详情 */
.container {
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  background: #F6F8FB;
  padding-top: 22rpx;
}

.detail-card {
  position: relative;
  z-index: 1;
  margin: 0 28rpx 18rpx;
  padding: 32rpx 30rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(226, 232, 240, 0.92);
  border-radius: 18rpx;
  box-shadow: 0 10rpx 32rpx rgba(15, 23, 42, 0.05);
  box-sizing: border-box;
}

.top-tools {
  position: relative;
  z-index: 11;
  height: 68rpx;
  margin: 0 28rpx 12rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.page-more {
  position: relative;
  z-index: 11;
  width: 76rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(217, 226, 236, 0.9);
}

.menu-mask {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: transparent;
}

.more-popover {
  position: absolute;
  top: 86rpx;
  right: 28rpx;
  min-width: 180rpx;
  padding: 12rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(226, 232, 240, 0.95);
  border-radius: 16rpx;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.16);
}

.more-popover::before {
  content: "";
  position: absolute;
  top: -12rpx;
  right: 48rpx;
  width: 24rpx;
  height: 24rpx;
  background: #FFFFFF;
  border-left: 1rpx solid rgba(226, 232, 240, 0.95);
  border-top: 1rpx solid rgba(226, 232, 240, 0.95);
  transform: rotate(45deg);
}

.menu-item {
  position: relative;
  z-index: 1;
  min-height: 72rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #1F2937;
  font-size: 28rpx;
  font-weight: 400;
  border-radius: 12rpx;
}

.menu-item:active {
  background: #F8FAFC;
}

.hero-card {
  padding: 32rpx 30rpx 34rpx;
  min-height: 246rpx;
}

.hero-topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 28rpx;
  margin-bottom: 30rpx;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 400;
  color: #1677D2;
  background: rgba(22, 119, 210, 0.1);
}

.status-pill-pending {
  color: #B7791F;
  background: rgba(233, 185, 73, 0.16);
}

.status-pill-ongoing {
  color: #1677D2;
  background: rgba(22, 119, 210, 0.1);
}

.status-pill-breaking {
  color: #D96A22;
  background: rgba(217, 106, 34, 0.12);
}

.status-pill-completed {
  color: #1F8F7A;
  background: rgba(31, 143, 122, 0.12);
}

.status-pill-cancelled {
  color: #9A3412;
  background: rgba(217, 106, 34, 0.12);
}

.reward {
  flex-shrink: 0;
  display: flex;
  align-items: baseline;
  color: #F05A1A;
  line-height: 1;
}

.reward-symbol {
  margin-right: 8rpx;
  font-size: 32rpx;
  font-weight: 400;
}

.reward-value {
  font-size: 58rpx;
  font-weight: 400;
}

.task-title {
  display: block;
  margin-right: 104rpx;
  color: #101828;
  font-size: 34rpx;
  font-weight: 400;
  line-height: 1.42;
  word-break: break-word;
}

.hero-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 18rpx 24rpx;
  margin-top: 28rpx;
}

.type-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 9rpx;
  font-size: 26rpx;
  font-weight: 400;
}

.publish-time {
  color: #667085;
  font-size: 27rpx;
}

.section-heading {
  margin-bottom: 24rpx;
  color: #111827;
  font-size: 34rpx;
  font-weight: 400;
  line-height: 1.25;
}

.location-card {
  padding-bottom: 30rpx;
}

.location-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.location-marker {
  width: 68rpx;
  height: 68rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.location-main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.location-name {
  color: #111827;
  font-size: 31rpx;
  font-weight: 400;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-sub {
  color: #667085;
  font-size: 25rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.content-text {
  display: block;
  color: #111827;
  font-size: 30rpx;
  line-height: 1.72;
  word-break: break-word;
}

.images-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 26rpx;
}

.task-image {
  width: 178rpx;
  height: 178rpx;
  border-radius: 12rpx;
  background: #EEF2F6;
}

.info-table {
  padding-bottom: 18rpx;
}

.info-row {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border-bottom: 1rpx solid #E5EAF0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: #667085;
  font-size: 28rpx;
}

.info-value {
  min-width: 0;
  flex: 1;
  color: #667085;
  font-size: 28rpx;
  line-height: 1.35;
  text-align: right;
  word-break: break-all;
}

.info-value.muted {
  color: #98A2B3;
}

.person-value {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  color: #667085;
  font-size: 28rpx;
}

.person-value text {
  min-width: 0;
  max-width: 320rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.person-avatar {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #EEF2F6;
}

.clickable:active {
  background: #F8FAFC;
}

.action-bar {
  position: fixed;
  z-index: 10;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid rgba(226, 232, 240, 0.96);
  box-shadow: 0 -8rpx 28rpx rgba(15, 23, 42, 0.05);
  box-sizing: border-box;
}

.action-row {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  height: 78rpx;
  margin: 0;
  padding: 0 24rpx;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  border: 1rpx solid transparent;
  font-size: 31rpx;
  font-weight: 400;
  line-height: 78rpx;
  box-sizing: border-box;
}

.action-btn::after {
  border: none;
}

.action-btn.full {
  width: 100%;
}

.action-btn.primary {
  color: #FFFFFF;
  background: #1677D2;
  border-color: #1677D2;
}

.action-btn.secondary {
  color: #1677D2;
  background: #FFFFFF;
  border-color: #1677D2;
}

.action-btn:active {
  transform: scale(0.985);
}

.status-tip {
  min-height: 72rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 400;
}

.status-tip.warning {
  color: #D96A22;
  background: rgba(217, 106, 34, 0.1);
}

.status-tip.success {
  color: #1F8F7A;
  background: rgba(31, 143, 122, 0.1);
}

.status-tip.danger {
  color: #D96A22;
  background: rgba(217, 106, 34, 0.1);
}
