/* ============================================
   问当地 - 任务详情 - 天蓝色青春活力风格
   ============================================ */

/* 页面容器 - 天蓝渐变背景 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F8FF 0%, #E6F3FF 30%, #EDF7FF 70%, #F5FAFF 100%);
  padding-bottom: 200rpx;
  position: relative;
  box-sizing: border-box;
  width: 100%;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #6B8BA4;
  font-size: 28rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid rgba(93, 184, 230, 0.2);
  border-top-color: #5DB8E6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 状态卡片 - 毛玻璃效果 */
.status-card {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  margin: 32rpx;
  border-radius: 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.12);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
  position: relative;
  overflow: hidden;
}

.status-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
}

.status-card.pending::before {
  background: linear-gradient(180deg, #FFD166 0%, #FFE08C 100%);
}

.status-card.ongoing::before {
  background: linear-gradient(180deg, #5DB8E6 0%, #7EC8E8 100%);
}

.status-card.completed::before {
  background: linear-gradient(180deg, #6DD5B0 0%, #88D8A3 100%);
}

.status-card.cancelled::before {
  background: linear-gradient(180deg, #FF8C69 0%, #FF9A8B 100%);
}

.status-icon {
  font-size: 52rpx;
  margin-right: 24rpx;
  width: 96rpx;
  height: 96rpx;
  background: rgba(93, 184, 230, 0.1);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-info {
  flex: 1;
}

.status-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #2C3E50;
  margin-bottom: 8rpx;
  display: block;
}

.remain-time {
  font-size: 26rpx;
  color: #6B8BA4;
  display: block;
}

/* 任务信息卡片 */
.info-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 36rpx;
  padding: 36rpx;
  margin: 0 32rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
}

/* 类型标签 */
.type-tag {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 28rpx;
  border-radius: 9999rpx;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 28rpx;
}

.type-icon {
  font-size: 28rpx;
}

/* 积分徽章 */
.points-badge {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 32rpx;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, rgba(255, 140, 105, 0.1) 0%, rgba(255, 154, 139, 0.1) 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 140, 105, 0.15);
}

.points-value {
  font-size: 48rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF8C69 0%, #FF9A8B 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.points-label {
  font-size: 26rpx;
  color: #FF8C69;
  font-weight: 600;
}

/* 描述区域 */
.description-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  color: #6B8BA4;
  font-weight: 600;
  margin-bottom: 16rpx;
  display: block;
}

.description-text {
  font-size: 30rpx;
  color: #2C3E50;
  line-height: 1.7;
  display: block;
}

/* 图片区域 */
.images-section {
  margin-bottom: 32rpx;
}

.images-list {
  display: flex;
  flex-wrap: nowrap;
  gap: 16rpx;
}

.task-image {
  width: calc((100% - 32rpx) / 3);
  height: 200rpx;
  border-radius: 16rpx;
  object-fit: cover;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

/* 位置区域 */
.location-section {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid rgba(93, 184, 230, 0.08);
}

.location-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 28rpx;
  background: rgba(240, 248, 255, 0.8);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  transition: all 0.3s;
}

.location-box:active {
  background: rgba(93, 184, 230, 0.1);
}

.location-icon {
  font-size: 32rpx;
}

.location-name {
  flex: 1;
  font-size: 28rpx;
  color: #2C3E50;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-arrow {
  font-size: 32rpx;
  color: #8FA8B8;
  font-weight: 300;
}

.location-actions {
  display: flex;
  gap: 16rpx;
}

/* 用户卡片 */
.user-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 36rpx;
  padding: 36rpx;
  margin: 0 32rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
}

.user-section {
  margin-bottom: 32rpx;
}

.user-section:last-child {
  margin-bottom: 0;
}

.user-section .section-title {
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.25);
}

.user-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.user-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E50;
}

.user-tag {
  font-size: 22rpx;
  color: #5DB8E6;
  background: rgba(93, 184, 230, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 9999rpx;
  font-weight: 500;
}

.waiting-tip {
  text-align: center;
  padding: 32rpx;
  background: rgba(255, 209, 102, 0.1);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 209, 102, 0.15);
}

.waiting-tip text {
  font-size: 28rpx;
  color: #E6A23C;
  font-weight: 500;
}

/* 时间卡片 */
.time-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 36rpx;
  padding: 32rpx 36rpx;
  margin: 0 32rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
}

.time-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid rgba(93, 184, 230, 0.06);
}

.time-row:last-child {
  border-bottom: none;
}

.time-label {
  font-size: 26rpx;
  color: #6B8BA4;
}

.time-value {
  font-size: 26rpx;
  color: #2C3E50;
  font-weight: 500;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(40rpx);
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid rgba(93, 184, 230, 0.08);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 100;
}

.action-btn {
  padding: 28rpx 0;
  border-radius: 9999rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  transition: all 0.3s ease;
  border: none;
  line-height: 1;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  color: white;
  box-shadow: 0 6rpx 24rpx rgba(93, 184, 230, 0.35);
}

.action-btn.primary:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(93, 184, 230, 0.25);
}

.action-btn.primary.large {
  width: 100%;
}

.action-btn.success {
  background: linear-gradient(135deg, #6DD5B0 0%, #88D8A3 100%);
  color: white;
  box-shadow: 0 6rpx 24rpx rgba(109, 213, 176, 0.35);
}

.action-btn.success:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(109, 213, 176, 0.25);
}

.action-btn.danger {
  background: linear-gradient(135deg, #FF8C69 0%, #FF9A8B 100%);
  color: white;
  box-shadow: 0 6rpx 24rpx rgba(255, 140, 105, 0.3);
}

.action-btn.danger:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(255, 140, 105, 0.2);
}

.action-btn.small {
  flex: 1;
  padding: 20rpx 0;
  font-size: 26rpx;
  background: rgba(93, 184, 230, 0.1);
  color: #6B8BA4;
  box-shadow: none;
}

.action-btn.small.primary {
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.3);
}

/* 求助者操作区 */
.seeker-actions {
  display: flex;
  gap: 20rpx;
}

.seeker-actions .action-btn {
  flex: 1;
}

/* 状态提示 */
.status-tip {
  text-align: center;
  padding: 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.status-tip.success {
  background: rgba(109, 213, 176, 0.1);
  color: #4DB895;
  border: 2rpx solid rgba(109, 213, 176, 0.15);
}

.status-tip.danger {
  background: rgba(255, 140, 105, 0.1);
  color: #E86A4A;
  border: 2rpx solid rgba(255, 140, 105, 0.15);
}
