/* ============================================
   问当地 - 任务详情 - 梦幻渐变风格
   风格：柔和粉彩 / 毛玻璃 / 精致优雅
   ============================================ */

/* 页面容器 - 梦幻渐变背景 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFE6FA 0%, #E6F4FF 50%, #F0FFFA 100%);
  padding-bottom: 180rpx;
  position: relative;
}

/* 背景装饰 */
.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(180deg, rgba(179, 136, 235, 0.05) 0%, transparent 100%);
  pointer-events: none;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #6C6F8B;
  font-size: 28rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(128, 147, 241, 0.2);
  border-top-color: #8093F1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 状态卡片 - 毛玻璃效果 */
.status-card {
  display: flex;
  align-items: center;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  margin: 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(42, 45, 67, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  position: relative;
  overflow: hidden;
}

.status-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
}

.status-card.pending::before {
  background: linear-gradient(135deg, #FDCB6E 0%, #FAD0C4 100%);
}

.status-card.matched::before,
.status-card.ongoing::before {
  background: linear-gradient(135deg, #8093F1 0%, #B388EB 100%);
}

.status-card.completed::before {
  background: linear-gradient(135deg, #A1C4FD 0%, #C2E9FB 100%);
}

.status-card.cancelled::before {
  background: linear-gradient(135deg, #FF9A9E 0%, #FAD0C4 100%);
}

.status-icon {
  font-size: 60rpx;
  margin-right: 24rpx;
  width: 100rpx;
  height: 100rpx;
  background: rgba(128, 147, 241, 0.1);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-info {
  flex: 1;
}

.status-text {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #2A2D43;
  margin-bottom: 8rpx;
}

.remain-time {
  font-size: 26rpx;
  color: #FF6B8B;
  font-weight: 600;
  background: rgba(255, 107, 139, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 9999rpx;
  display: inline-block;
}

/* 信息卡片 - 毛玻璃效果 */
.info-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  padding: 40rpx;
  margin: 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(42, 45, 67, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  position: relative;
}

/* 类型标签 */
.type-tag {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 28rpx;
  border-radius: 9999rpx;
  font-size: 26rpx;
  margin-bottom: 24rpx;
  font-weight: 600;
  background: rgba(128, 147, 241, 0.1);
  color: #8093F1;
  box-shadow: 0 2rpx 8rpx rgba(128, 147, 241, 0.1);
}

.type-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* 积分徽章 */
.points-badge {
  position: absolute;
  top: 40rpx;
  right: 40rpx;
  text-align: center;
  background: rgba(255, 154, 158, 0.1);
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 154, 158, 0.2);
}

.points-value {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF9A9E 0%, #FAD0C4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}

.points-label {
  font-size: 22rpx;
  color: #6C6F8B;
  margin-top: 4rpx;
}

/* 区块标题 */
.section-title {
  display: block;
  font-size: 26rpx;
  color: #A0A3BD;
  margin-bottom: 16rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* 描述 */
.description-section {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(128, 147, 241, 0.1);
}

.description-text {
  display: block;
  font-size: 30rpx;
  color: #2A2D43;
  line-height: 1.8;
}

/* 位置 */
.location-section {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(128, 147, 241, 0.1);
}

.location-box {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: rgba(248, 249, 255, 0.8);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.location-icon {
  margin-right: 16rpx;
  font-size: 36rpx;
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #8093F1 0%, #B388EB 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
}

.location-name {
  flex: 1;
  font-size: 28rpx;
  color: #2A2D43;
  font-weight: 500;
}

.location-arrow {
  font-size: 32rpx;
  color: #A0A3BD;
}

.location-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

/* 用户卡片 */
.user-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  padding: 40rpx;
  margin: 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(42, 45, 67, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.user-section {
  margin-bottom: 30rpx;
}

.user-section:last-child {
  margin-bottom: 0;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #8093F1 0%, #B388EB 100%);
  border: 3rpx solid white;
  box-shadow: 0 4rpx 16rpx rgba(128, 147, 241, 0.3);
}

.avatar-default {
  background: linear-gradient(135deg, #8093F1 0%, #B388EB 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-meta {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 30rpx;
  color: #2A2D43;
  margin-bottom: 4rpx;
  font-weight: 600;
}

.user-tag {
  font-size: 22rpx;
  color: #8093F1;
  background: rgba(128, 147, 241, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 9999rpx;
  font-weight: 600;
}

.waiting-tip {
  text-align: center;
  padding: 40rpx;
  color: #A0A3BD;
  font-size: 28rpx;
  background: rgba(248, 249, 255, 0.6);
  border-radius: 24rpx;
}

/* 时间卡片 */
.time-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  padding: 40rpx;
  margin: 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(42, 45, 67, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.time-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(128, 147, 241, 0.08);
}

.time-row:last-child {
  border-bottom: none;
}

.time-label {
  font-size: 26rpx;
  color: #6C6F8B;
}

.time-value {
  font-size: 26rpx;
  color: #2A2D43;
  font-weight: 600;
}

/* 底部操作栏 - 毛玻璃效果 */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(40rpx);
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(42, 45, 67, 0.08);
  border-top: 1rpx solid rgba(255, 255, 255, 0.8);
}

.action-btn {
  font-size: 30rpx;
  padding: 24rpx 40rpx;
  border-radius: 24rpx;
  border: none;
  background: rgba(160, 163, 189, 0.2);
  color: #6C6F8B;
  text-align: center;
  line-height: 1.5;
  font-weight: 600;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.98);
}

.action-btn::after {
  border: none;
}

.action-btn.small {
  font-size: 26rpx;
  padding: 20rpx 30rpx;
  flex: 1;
}

.action-btn.large {
  width: 100%;
  font-size: 32rpx;
  padding: 28rpx 0;
  border-radius: 9999rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, #8093F1 0%, #B388EB 100%);
  color: white;
  box-shadow: 0 8rpx 32rpx rgba(128, 147, 241, 0.4);
}

.action-btn.primary:active {
  box-shadow: 0 4rpx 20rpx rgba(128, 147, 241, 0.3);
}

.action-btn.success {
  background: linear-gradient(135deg, #A1C4FD 0%, #C2E9FB 100%);
  color: white;
  box-shadow: 0 8rpx 32rpx rgba(161, 196, 253, 0.4);
}

.action-btn.danger {
  background: linear-gradient(135deg, #FF9A9E 0%, #FAD0C4 100%);
  color: white;
  box-shadow: 0 8rpx 32rpx rgba(255, 154, 158, 0.4);
}

.seeker-actions {
  display: flex;
  gap: 20rpx;
}

.seeker-actions .action-btn {
  flex: 1;
}

.status-tip {
  text-align: center;
  padding: 30rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 24rpx;
  background: rgba(248, 249, 255, 0.8);
}

.status-tip.success {
  color: #8093F1;
  background: rgba(128, 147, 241, 0.1);
}

.status-tip.danger {
  color: #FF6B8B;
  background: rgba(255, 107, 139, 0.1);
}
