/* ============================================
   问当地 - 任务详情 - 城市服务清爽可信风格
   ============================================ */

/* 页面容器 - 浅灰服务背景 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 30%, var(--bg-tertiary) 70%, #F5FAFF 100%);
  position: relative;
  box-sizing: border-box;
  width: 100%;
}

/* 状态卡片 - 毛玻璃效果 */
.status-card {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  margin: 32rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid rgba(22, 119, 210, 0.08);
  position: relative;
  overflow: hidden;
}

.status-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
}

.status-card.pending::before {
  background: linear-gradient(180deg, #E9B949 0%, #FFE08C 100%);
}

.status-card.ongoing::before {
  background: linear-gradient(180deg, var(--sky-primary) 0%, var(--sky-light) 100%);
}

.status-card.completed::before {
  background: linear-gradient(180deg, var(--fresh-mint) 0%, var(--fresh-green) 100%);
}

.status-card.cancelled::before {
  background: linear-gradient(180deg, var(--vitality-orange) 0%, var(--vitality-coral) 100%);
}

.status-card.breaking::before {
  background: linear-gradient(180deg, #E6A23C 0%, #F0C040 100%);
}

.status-icon {
  font-size: 52rpx;
  margin-right: 24rpx;
  width: 96rpx;
  height: 96rpx;
  background: rgba(22, 119, 210, 0.1);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-info {
  flex: 1;
}

.status-text {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  display: block;
}

.remain-time {
  font-size: 26rpx;
  color: var(--text-tertiary);
  display: block;
}

/* 任务信息卡片 */
.info-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 36rpx;
  margin: 0 32rpx 28rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid rgba(22, 119, 210, 0.08);
}

/* 信息头部：类型标签 + 悬赏金额，两端对齐 */
.info-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

/* 类型标签 */
.type-tag {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 28rpx;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  font-weight: 600;
}

.type-icon {
  font-size: 28rpx;
}

/* 金额徽章 */
.amount-badge {
  display: inline-flex;
  align-items: baseline;
  gap: 4rpx;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, rgba(255, 209, 102, 0.1) 0%, rgba(255, 179, 71, 0.1) 100%);
  border-radius: var(--radius-sm);
  border: 2rpx solid rgba(255, 209, 102, 0.2);
  flex-shrink: 0;
}

.amount-symbol {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--vitality-orange);
}

.amount-value {
  font-size: 48rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #E9B949 0%, #D96A22 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* 平台抽成信息 */
.fee-info {
  margin-bottom: 24rpx;
  padding: 12rpx 16rpx;
  background: rgba(22, 119, 210, 0.06);
  border-radius: 12rpx;
}

.fee-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
}

/* 描述区域 */
.description-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 600;
  margin-bottom: 16rpx;
  display: block;
}

.description-text {
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.7;
  display: block;
  word-break: break-all;
}

/* 图片区域 */
.images-section {
  margin-bottom: 32rpx;
}

.images-list {
  display: flex;
  flex-wrap: nowrap;
  gap: 16rpx;
}

.task-image {
  width: calc((100% - 32rpx) / 3);
  height: 200rpx;
  border-radius: var(--radius-sm);
  object-fit: cover;
  box-shadow: var(--shadow-sm);
  flex-shrink: 0;
}

/* 位置区域 */
.location-section {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid var(--border-light);
}

.location-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 28rpx;
  background: var(--bg-glass);
  border-radius: var(--radius-sm);
  margin-bottom: 20rpx;
  transition: all 0.3s;
}

.location-box:active {
  background: rgba(22, 119, 210, 0.1);
}

.location-icon {
  font-size: 32rpx;
}

.location-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-arrow {
  font-size: 32rpx;
  color: var(--text-light);
  font-weight: 300;
}

/* 单号块 - 位置区域底部 */
.order-id-block {
  padding: 20rpx 0 4rpx;
}

.order-id-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-tertiary);
  font-weight: 600;
  margin-bottom: 10rpx;
}

.order-id-value {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
  letter-spacing: 0.5rpx;
  word-break: break-all;
}

/* 用户卡片 */
.user-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 36rpx;
  margin: 0 32rpx 28rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid rgba(22, 119, 210, 0.08);
}

.user-section {
  margin-bottom: 32rpx;
}

.user-section:last-child {
  margin-bottom: 0;
}

.user-section .section-title {
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  box-shadow: var(--shadow-sky);
}

.user-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.user-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.user-tag {
  font-size: 22rpx;
  color: var(--sky-primary);
  background: rgba(22, 119, 210, 0.1);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}

.title-with-icon {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.waiting-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  text-align: center;
  padding: 32rpx;
  background: rgba(255, 209, 102, 0.1);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 209, 102, 0.15);
}

.waiting-tip text {
  font-size: 28rpx;
  color: #E6A23C;
  font-weight: 500;
}

/* 时间卡片 */
.time-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx 36rpx;
  margin: 0 32rpx 28rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid rgba(22, 119, 210, 0.08);
}

.time-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--border-light);
}

.time-row:last-child {
  border-bottom: none;
}

.time-label {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.time-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(40rpx);
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid var(--border-light);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 100;
}

.action-btn {
  padding: 28rpx 0;
  border-radius: var(--radius-full);
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  transition: all 0.3s ease;
  border: none;
  line-height: 1;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  color: white;
  box-shadow: 0 6rpx 24rpx rgba(22, 119, 210, 0.35);
}

.action-btn.primary:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(22, 119, 210, 0.25);
}

.action-btn.primary.large {
  width: 100%;
}

.action-btn.success {
  background: linear-gradient(135deg, var(--fresh-mint) 0%, var(--fresh-green) 100%);
  color: white;
  box-shadow: 0 6rpx 24rpx rgba(31, 143, 122, 0.35);
}

.action-btn.success:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(31, 143, 122, 0.25);
}

.action-btn.danger {
  background: linear-gradient(135deg, var(--vitality-orange) 0%, var(--vitality-coral) 100%);
  color: white;
  box-shadow: 0 6rpx 24rpx rgba(217, 106, 34, 0.3);
}

.action-btn.danger:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(217, 106, 34, 0.2);
}

.action-btn.small {
  flex: 1;
  padding: 20rpx 0;
  font-size: 26rpx;
  background: rgba(22, 119, 210, 0.1);
  color: var(--text-tertiary);
  box-shadow: none;
}

.action-btn.small.primary {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 210, 0.3);
}

/* 求助者操作区 */
.seeker-actions {
  display: flex;
  gap: 20rpx;
}

.seeker-actions .action-btn {
  flex: 1;
}

/* 状态提示 */
.status-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  text-align: center;
  padding: 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.status-tip.success {
  background: rgba(31, 143, 122, 0.1);
  color: var(--fresh-green);
  border: 2rpx solid rgba(31, 143, 122, 0.15);
}

.status-tip.danger {
  background: rgba(217, 106, 34, 0.1);
  color: var(--danger-color);
  border: 2rpx solid rgba(217, 106, 34, 0.15);
}

.status-tip.warning {
  background: rgba(230, 162, 60, 0.1);
  color: #E6A23C;
  border: 2rpx solid rgba(230, 162, 60, 0.15);
}
/* ============================================
   城市服务风格视觉覆盖：清爽可信、交易清楚、低装饰
   ============================================ */
.container,
.chat-container {
  background: #f5f7fa;
}

.header,
.footer,
.input-area,
.popup-content,
.modal-content,
.rules-modal-content {
  background: #ffffff;
  border-color: var(--border-light);
  box-shadow: var(--shadow-card);
}

.section-card,
.task-card,
.user-card,
.menu-list,
.quick-panel,
.need-feed,
.login-tip-card,
.balance-section,
.record-card,
.ticket-card,
.report-card,
.appeal-card,
.profile-card,
.rating-card,
.info-card,
.form-card,
.stat-card,
.card {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.location-bar,
.filter-item,
.sort-section,
.distance-section,
.type-badge,
.card-location,
.distance-tag,
.quick-tag,
.type-item,
.time-option,
.quick-point,
.quick-amount,
.payment-option,
.amount-detail,
.rules-tip,
.points-tip-wrapper,
.input-wrapper,
.toolbar-toggle-btn,
.more-btn,
.system-message-text,
.time-divider text {
  background: #f8fafc;
  border-color: var(--border-light);
  box-shadow: none;
}

.filter-item.active,
.type-item.active,
.quick-tag.active,
.time-option.active,
.payment-option.active {
  background: rgba(22, 119, 210, 0.08);
  border-color: rgba(22, 119, 210, 0.34);
  box-shadow: none;
}

.filter-item.active .filter-name,
.quick-tag.active,
.time-option.active,
.payment-option.active .payment-name {
  color: var(--sky-deep);
  font-weight: 600;
}

.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.amount-badge,
.quick-amount.active,
.quick-point.active,
.time-recommend,
.btn-vitality {
  background: var(--vitality-orange);
  box-shadow: var(--shadow-orange);
}

.balance-value.points,
.balance-value.available,
.points-number,
.publish-points,
.publish-amount {
  color: var(--text-primary);
  background: none;
  -webkit-text-fill-color: currentColor;
}

.wdd-amount,
.need-amount,
.amount-current,
.amount-symbol,
.detail-value.fee,
.warning-text,
.balance-value.insufficient,
.task-points-mini {
  color: var(--vitality-orange);
}

.detail-value.income,
.tag-mint,
.status-success,
.success-text {
  color: var(--fresh-mint);
}

.message-item.other .message-bubble.text {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-sm);
}

.message-item.self .message-bubble.text {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.popup-overlay,
.modal-mask,
.rules-modal {
  background: rgba(15, 23, 42, 0.46);
}

.helper-profile-tip,
.balance-insufficient,
.task-ended-bar.breaking-bar {
  background: #fff8e6;
  border-color: rgba(233, 185, 73, 0.34);
}

image,
button,
view {
  letter-spacing: 0;
}
/* 城市服务按钮对比修正 */
.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  color: #ffffff;
}

.publish-btn.disabled,
.send-btn[disabled],
.disabled {
  color: var(--text-muted);
}