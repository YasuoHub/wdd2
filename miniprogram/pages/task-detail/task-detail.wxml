<!-- 任务详情页 -->
<wxs src="../../utils/money.wxs" module="money" />
<view class="container wdd-page" style="padding-bottom: {{pagePaddingBottom}}rpx;">
  <view class="wdd-page-bg"></view>
  <!-- 加载中 -->
  <loading wx:if="{{loading}}" type="normal" text="加载中..." mode="spinner" size="56"></loading>

  <!-- 任务内容 -->
  <block wx:elif="{{task}}">
    <!-- 任务状态卡片 -->
    <view class="status-card {{task.status}}">
      <view class="status-icon">
        <wdd-icon name="{{task.statusIcon || 'circle-help'}}" color="#FFFFFF" size="34"></wdd-icon>
      </view>
      <view class="status-info">
        <text class="status-text">{{task.statusText}}</text>
        <text wx:if="{{task.remainTime && task.status === 'pending'}}" class="remain-time">剩余 {{task.remainTime}}</text>
      </view>
    </view>

    <!-- 任务信息卡片 -->
    <view class="info-card">
      <!-- 类型 + 悬赏金额 同排 -->
      <view class="info-header">
        <view class="type-tag" style="background: {{task.bgColor}}; color: {{task.color}};">
          <wdd-icon name="{{task.typeIcon || 'circle-help'}}" color="{{task.color || '#1677D2'}}" size="24"></wdd-icon>
          <text>{{task.typeName}}</text>
        </view>

        <view class="amount-badge">
          <text class="amount-symbol">¥</text>
          <text class="amount-value">{{task.rewardAmount || 0}}</text>
        </view>
      </view>

      <!-- 描述 -->
      <view class="description-section">
        <text class="section-title">求助内容</text>
        <text class="description-text">{{task.description || '暂无描述'}}</text>
      </view>

      <!-- 图片展示 -->
      <view class="images-section" wx:if="{{task.images && task.images.length > 0}}">
        <text class="section-title">求助图片</text>
        <view class="images-list">
          <image
            wx:for="{{task.images}}"
            wx:key="index"
            class="task-image"
            src="{{item}}"
            mode="aspectFill"
            bindtap="previewTaskImages"
            data-index="{{index}}"
          />
        </view>
      </view>

      <!-- 位置 -->
      <view class="location-section">
        <text class="section-title">求助位置</text>
        <view class="location-box" bindtap="previewLocation">
          <wdd-icon name="map-pin" color="#7B8794" size="26"></wdd-icon>
          <text class="location-name">{{task.locationName || '未知位置'}}</text>
          <wdd-icon name="chevron-right" color="#9AA5B1" size="26"></wdd-icon>
        </view>
        <view class="order-id-block">
          <text class="order-id-label">任务单号</text>
          <text class="order-id-value">{{task._id}}</text>
        </view>
      </view>
    </view>

    <!-- 用户信息卡片 -->
    <view class="user-card">
      <!-- 求助者信息 -->
      <view class="user-section">
        <view class="section-title title-with-icon">
          <wdd-icon name="send" color="#1677D2" size="28"></wdd-icon>
          <text>求助者</text>
        </view>
        <view class="user-info" bindtap="goToPublicProfile" data-userid="{{task.user_id}}">
          <image class="user-avatar" src="{{task.user_avatar || '/images/default-avatar.png'}}" mode="aspectFill"/>
          <view class="user-meta">
            <text class="user-name">{{task.user_nickname || '匿名用户'}}</text>
            <text wx:if="{{isSeeker}}" class="user-tag">我自己</text>
          </view>
        </view>
      </view>

      <!-- 帮助者信息（如果有） -->
      <view wx:if="{{task.taker_id}}" class="user-section">
        <view class="section-title title-with-icon">
          <wdd-icon name="handshake" color="#119B72" size="28"></wdd-icon>
          <text>帮助者</text>
        </view>
        <view class="user-info" bindtap="goToPublicProfile" data-userid="{{task.taker_id}}">
          <image class="user-avatar" src="{{task.taker_avatar || '/images/default-avatar.png'}}" mode="aspectFill"/>
          <view class="user-meta">
            <text class="user-name">{{task.taker_nickname || '匿名用户'}}</text>
            <text wx:if="{{isTaker}}" class="user-tag">我自己</text>
          </view>
        </view>
      </view>

      <!-- 等待接单提示（仅求助者可见） -->
      <view wx:if="{{task.status === 'pending' && isSeeker}}" class="waiting-tip">
        <wdd-icon name="hourglass" color="#D96A22" size="24"></wdd-icon>
        <text>等待附近帮助者接单...</text>
      </view>
    </view>

    <!-- 时间信息 -->
    <view class="time-card">
      <view class="time-row">
        <text class="time-label">发布时间</text>
        <text class="time-value">{{task.createTime}}</text>
      </view>
      <view wx:if="{{task.matchTime}}" class="time-row">
        <text class="time-label">接单时间</text>
        <text class="time-value">{{task.matchTime}}</text>
      </view>
      <view wx:if="{{task.completeTime}}" class="time-row">
        <text class="time-label">完成时间</text>
        <text class="time-value">{{task.completeTime}}</text>
      </view>
    </view>
  </block>

  <!-- 底部操作栏 -->
  <view wx:if="{{!loading && task}}" class="action-bar">
    <!-- 待匹配状态：帮助者可以接单 -->
    <button
      wx:if="{{canTake}}"
      class="action-btn primary large"
      bindtap="takeTask"
    >
      立即接单 (+¥{{money.format(task._takerIncome)}})
    </button>

    <!-- 已接单状态：可以聊天 -->
    <button
      wx:if="{{canChat}}"
      class="action-btn primary large"
      bindtap="goToChat"
    >
      进入聊天
    </button>

    <!-- 求助者专属操作 -->
    <view wx:if="{{isSeeker}}" class="seeker-actions">
      <button
        wx:if="{{canComplete}}"
        class="action-btn success"
        bindtap="completeTask"
      >
        确认完成
      </button>
      <button
        wx:if="{{canCancel}}"
        class="action-btn danger"
        bindtap="cancelTask"
      >
        取消任务
      </button>
    </view>

    <!-- 审核中提示 -->
    <view wx:if="{{task.status === 'breaking'}}" class="status-tip warning">
      <wdd-icon name="hourglass" color="#E67E22" size="24"></wdd-icon>
      <text>任务正在审核中，暂不可操作</text>
    </view>

    <!-- 已完成/已取消提示 -->
    <view wx:if="{{task.status === 'completed'}}" class="status-tip success">
      <wdd-icon name="circle-check-big" color="#6DD5B0" size="24"></wdd-icon>
      <text>任务已完成</text>
    </view>
    <view wx:if="{{task.status === 'cancelled'}}" class="status-tip danger">
      <wdd-icon name="circle-x" color="#FF6B6B" size="24"></wdd-icon>
      <text>任务已取消</text>
    </view>
  </view>
</view>
