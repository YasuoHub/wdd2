<!-- 任务详情页 -->
<wxs src="../../utils/money.wxs" module="money" />
<view class="container wdd-page" style="padding-bottom: {{pagePaddingBottom}}rpx;">
  <view class="wdd-page-bg"></view>

  <view wx:if="{{loading}}" class="page-loading-card">
    <loading type="normal" text="加载中..." mode="spinner" size="56"></loading>
  </view>

  <block wx:elif="{{task}}">
    <view wx:if="{{canReport || canAppeal}}" class="top-tools">
      <view class="page-more" bindtap="toggleMoreMenu">
        <wdd-icon name="ellipsis" color="#111827" size="34"></wdd-icon>
      </view>
    </view>

    <view wx:if="{{showMoreMenu}}" class="menu-mask" catchtap="hideMoreMenu">
      <view class="more-popover" catchtap="noop">
        <view wx:if="{{canReport}}" class="menu-item" bindtap="goToReport">
          <wdd-icon name="flag" color="var(--vitality-orange)" size="26"></wdd-icon>
          <text>举报</text>
        </view>
        <view wx:if="{{canAppeal}}" class="menu-item" bindtap="goToAppeal">
          <wdd-icon name="shield-alert" color="var(--vitality-orange)" size="26"></wdd-icon>
          <text>申诉</text>
        </view>
      </view>
    </view>

    <view class="detail-card hero-card status-{{task.status}}">
      <view class="hero-topline">
        <view class="status-pill status-pill-{{task.status}}">
          <text>{{task.statusText}}</text>
        </view>
        <view class="reward">
          <wdd-icon name="coins" color="var(--money-gold)" size="38"></wdd-icon><text class="money-text">{{money.format(task.rewardAmount || 0)}}</text>
        </view>
      </view>

      <text class="task-title">{{task.description || '暂无求助内容'}}</text>

      <view class="hero-meta">
        <view class="type-chip" style="background: {{task.bgColor}}; color: {{task.color}};">
          <wdd-icon name="{{task.typeIcon || 'circle-help'}}" color="{{task.color || task.typeColor || 'var(--brand-primary)'}}" size="24"></wdd-icon>
          <text>{{task.typeName}}</text>
        </view>
        <text class="publish-time">{{task.createTime || '发布时间未知'}}</text>
      </view>
    </view>

    <view class="detail-card location-card" bindtap="previewLocation">
      <view class="section-heading">求助位置</view>
      <view class="location-row">
        <view class="location-marker">
          <wdd-icon name="map-pin" color="var(--brand-primary)" size="48"></wdd-icon>
        </view>
        <view class="location-main">
          <text class="location-name">{{task.locationName || '未知位置'}}</text>
          <text wx:if="{{task._locationSubText}}" class="location-sub">{{task._locationSubText}}</text>
        </view>
        <wdd-icon name="chevron-right" color="#7B8794" size="32"></wdd-icon>
      </view>
    </view>

    <view class="detail-card content-card">
      <view class="section-heading">求助内容</view>
      <text class="content-text">{{task.description || '暂无补充说明'}}</text>

      <view class="images-list" wx:if="{{task.images && task.images.length > 0}}">
        <image
          wx:for="{{task.images}}"
          wx:key="index"
          class="task-image"
          src="{{item}}"
          mode="aspectFill"
          bindtap="previewTaskImages"
          data-index="{{index}}"
        />
      </view>
    </view>

    <view class="detail-card info-table">
      <view class="section-heading">任务信息</view>

      <view class="info-row">
        <view class="info-label">
          <wdd-icon name="clipboard-list" color="#7B8794" size="28"></wdd-icon>
          <text>任务单号</text>
        </view>
        <text class="info-value">{{task._orderNo}}</text>
      </view>

      <view class="info-row clickable" bindtap="goToPublicProfile" data-userid="{{task.user_id}}">
        <view class="info-label">
          <wdd-icon name="user-round" color="#7B8794" size="28"></wdd-icon>
          <text>求助者</text>
        </view>
        <view class="person-value">
          <image class="person-avatar" src="{{task.user_avatar || task.seekerAvatar || '/images/default-avatar.png'}}" mode="aspectFill" />
          <text>{{isSeeker ? '我（求助者）' : (task.user_nickname || task.userNickname || task.seekerNickname || '匿名用户')}}</text>
          <wdd-icon name="chevron-right" color="#9AA5B1" size="26"></wdd-icon>
        </view>
      </view>

      <view wx:if="{{task.taker_id}}" class="info-row clickable" bindtap="goToPublicProfile" data-userid="{{task.taker_id}}">
        <view class="info-label">
          <wdd-icon name="users-round" color="#7B8794" size="28"></wdd-icon>
          <text>帮助者</text>
        </view>
        <view class="person-value">
          <image class="person-avatar" src="{{task.taker_avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
          <text>{{isTaker ? '我（帮助者）' : (task.taker_nickname || task.takerNickname || '匿名用户')}}</text>
          <wdd-icon name="chevron-right" color="#9AA5B1" size="26"></wdd-icon>
        </view>
      </view>

      <view wx:else class="info-row">
        <view class="info-label">
          <wdd-icon name="users-round" color="#7B8794" size="28"></wdd-icon>
          <text>帮助者</text>
        </view>
        <text class="info-value muted">等待帮助者响应</text>
      </view>

      <view class="info-row">
        <view class="info-label">
          <wdd-icon name="clock-3" color="#7B8794" size="28"></wdd-icon>
          <text>发布时间</text>
        </view>
        <text class="info-value">{{task.createTime || '-'}}</text>
      </view>

      <view wx:if="{{task.matchTime}}" class="info-row">
        <view class="info-label">
          <wdd-icon name="clock-3" color="#7B8794" size="28"></wdd-icon>
          <text>响应时间</text>
        </view>
        <text class="info-value">{{task.matchTime}}</text>
      </view>

      <view wx:if="{{task.completeTime}}" class="info-row">
        <view class="info-label">
          <wdd-icon name="circle-check-big" color="#7B8794" size="28"></wdd-icon>
          <text>完成时间</text>
        </view>
        <text class="info-value">{{task.completeTime}}</text>
      </view>

      <view wx:if="{{task.cancelTime}}" class="info-row">
        <view class="info-label">
          <wdd-icon name="circle-x" color="#7B8794" size="28"></wdd-icon>
          <text>取消时间</text>
        </view>
        <text class="info-value">{{task.cancelTime}}</text>
      </view>
    </view>
  </block>

  <view wx:if="{{!loading && task && showActionBar}}" class="action-bar">
    <button
      wx:if="{{canTake}}"
      class="action-btn primary full"
      bindtap="takeTask"
    >
      <text>去帮助</text><text class="money-prefix">+</text><wdd-icon name="coins" color="var(--money-gold)" size="28"></wdd-icon><text class="money-text">{{money.format(task._takerIncome)}}</text>
    </button>

    <button
      wx:if="{{canCancel}}"
      class="action-btn secondary full"
      bindtap="cancelTask"
    >
      取消任务
    </button>

    <view wx:if="{{canChat && canComplete}}" class="action-row">
      <button class="action-btn secondary" bindtap="goToChat">进入聊天</button>
      <button class="action-btn primary" bindtap="completeTask">确认完成</button>
    </view>

    <button
      wx:if="{{canChat && !canComplete}}"
      class="action-btn primary full"
      bindtap="goToChat"
    >
      进入聊天
    </button>

    <view wx:if="{{task.status === 'breaking'}}" class="status-tip warning">
      <wdd-icon name="clock-3" color="var(--vitality-orange)" size="24"></wdd-icon>
      <text>审核中，等待客服裁定</text>
    </view>

    <view wx:if="{{task.status === 'completed'}}" class="status-tip success">
      <wdd-icon name="circle-check-big" color="var(--fresh-mint)" size="24"></wdd-icon>
      <text>任务已完成</text>
    </view>

    <view wx:if="{{task.status === 'cancelled'}}" class="status-tip danger">
      <wdd-icon name="circle-x" color="var(--vitality-orange)" size="24"></wdd-icon>
      <text>任务已取消</text>
    </view>
  </view>
</view>
