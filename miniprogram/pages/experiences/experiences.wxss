@import "../../styles/experience.wxss";

.experience-list-page {
  position: relative;
  min-height: 100vh;
  padding: 36rpx 32rpx 80rpx;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(240, 248, 255, 0.92) 0%, rgba(247, 251, 255, 0.98) 48%, #f5f7fa 100%);
  box-sizing: border-box;
}

.experience-search-panel {
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
  padding: 18rpx;
  border: 1rpx solid var(--brand-primary-12);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}

.experience-list-page .search-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 0;
}

.experience-list-page .search-input {
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d8e1eb;
  border-radius: 18rpx;
  background: #f9fbfd;
  color: #1f2d3d;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 150rpx;
  height: 76rpx;
  margin: 0;
  padding: 0;
  border-radius: 18rpx;
  color: #ffffff;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  box-shadow: var(--shadow-sky);
  font-size: 28rpx;
  line-height: 76rpx;
}

.search-button::after {
  border: 0;
}

.experience-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.experience-list-page .experience-card {
  margin-bottom: 0;
  padding: 28rpx 30rpx;
  border: 1rpx solid var(--brand-primary-10);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: var(--shadow-card);
  animation: experienceCardIn 0.32s ease-out;
}

.experience-list-page .experience-card:active {
  transform: scale(0.985);
  box-shadow: var(--shadow-sm);
}

@keyframes experienceCardIn {
  from {
    opacity: 0;
    transform: translateY(14rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.experience-card-top {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.experience-list-page .experience-title {
  flex: 1;
  min-width: 0;
  color: #1f2d3d;
  font-size: 32rpx;
  font-weight: 400;
  line-height: 1.4;
}

.experience-time {
  flex-shrink: 0;
  max-width: 220rpx;
  color: #9AA5B1;
  font-size: 22rpx;
  line-height: 1.45;
  text-align: right;
}

.experience-list-page .experience-location {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 14rpx;
  color: #7B8794;
  font-size: 24rpx;
  line-height: 1.5;
}

.experience-list-page .experience-location text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.experience-list-page .experience-result {
  display: -webkit-box;
  margin-top: 16rpx;
  overflow: hidden;
  color: #344054;
  font-size: 27rpx;
  line-height: 1.58;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.experience-card-footer {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.experience-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  max-width: 100%;
  padding: 8rpx 14rpx;
  border-radius: var(--radius-full);
  color: #5E7187;
  background: var(--border-light);
  font-size: 23rpx;
  line-height: 1.35;
  box-sizing: border-box;
}

.experience-chip text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.useful-chip {
  color: #119B72;
  background: rgba(17, 155, 114, 0.1);
}

.experience-empty,
.experience-footer {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 18rpx;
  padding: 96rpx 30rpx;
  color: #8A96A3;
  font-size: 27rpx;
  line-height: 1.6;
  text-align: center;
}

.experience-footer {
  padding: 34rpx 0 12rpx;
  font-size: 24rpx;
}

.experience-list-page .experience-error {
  position: relative;
  z-index: 1;
}
