<view class="experience-page experience-list-page wdd-page">
  <view class="wdd-page-bg"></view>
  <view class="experience-header">
    <view>
      <text class="experience-page-title">查经验</text>
      <text class="experience-page-subtitle">按最新分享排序，快速查看真实现场反馈</text>
    </view>
    <view class="experience-header-icon">
      <wdd-icon name="file-text" color="var(--brand-primary)" size="38"></wdd-icon>
    </view>
  </view>

  <view class="experience-search-panel">
    <view class="search-row">
      <input class="search-input" value="{{keyword}}" placeholder="搜索地点或经验标题" bindinput="onKeywordInput" confirm-type="search" bindconfirm="search" />
      <button class="search-button" bindtap="search">
        <wdd-icon name="search" color="#ffffff" size="26"></wdd-icon>
        <text>搜索</text>
      </button>
    </view>
  </view>

  <view wx:if="{{errorMessage && !loading}}" class="experience-error">
    <view class="experience-error-icon">
      <wdd-icon name="triangle-alert" color="var(--brand-primary)" size="44"></wdd-icon>
    </view>
    <view class="experience-error-title">查经验暂不可用</view>
    <view class="experience-error-desc">{{errorMessage}}</view>
    <button class="small-button experience-retry" bindtap="retryLoad">重新加载</button>
  </view>
  <view wx:elif="{{list.length === 0 && !loading}}" class="experience-empty">
    <wdd-icon name="file-text" color="#9AA5B1" size="64"></wdd-icon>
    <text>暂时还没有可查看的查经验内容</text>
  </view>
  <view class="experience-list">
    <view wx:for="{{list}}" wx:key="_id" class="experience-card" bindtap="goDetail" data-id="{{item._id}}">
      <view class="experience-card-top">
        <text class="experience-title">{{item.title}}</text>
        <text class="experience-time">{{item.publishedTimeText || '刚刚分享'}}</text>
      </view>
      <view class="experience-location">
        <wdd-icon name="map-pin" color="#7B8794" size="22"></wdd-icon>
        <text>{{item.publicLocation}}</text>
      </view>
      <text class="experience-result">{{item.result}}</text>
      <view class="experience-card-footer">
        <view class="experience-chip">
          <wdd-icon name="clock-3" color="var(--brand-primary)" size="22"></wdd-icon>
          <text>有效至 {{item.expiresAtText || '请自行判断'}}</text>
        </view>
        <view class="experience-chip useful-chip">
          <wdd-icon name="circle-check-big" color="#119B72" size="22"></wdd-icon>
          <text>{{item.usefulCount}} 有用</text>
        </view>
      </view>
    </view>
  </view>
  <view wx:if="{{loading}}" class="experience-footer">加载中...</view>
  <view wx:elif="{{list.length > 0 && !hasMore}}" class="experience-footer">没有更多经验了</view>
</view>
