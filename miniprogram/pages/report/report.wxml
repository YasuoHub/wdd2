<view class="page-bg"></view>

<view class="container">
  <!-- 剩余补充时间 — 顶部醒目提醒 -->
  <view class="countdown-hero {{!canSupplement ? 'expired' : ''}}" wx:if="{{mode === 'supplement'}}">
    <view class="countdown-hero-inner">
      <view class="countdown-hero-left">
        <view class="countdown-icon">⏳</view>
        <text class="countdown-hero-label">{{canSupplement ? '剩余时间' : '时间已截止'}}</text>
      </view>
      <text class="countdown-hero-value">{{supplementCountdown}}</text>
    </view>
  </view>

  <!-- 补充材料模式：任务摘要卡片 -->
  <view class="card task-card" wx:if="{{mode === 'supplement' && taskSummary}}">
    <view class="card-head">
      <text class="card-head-icon">📌</text>
      <text class="card-head-title">任务摘要</text>
    </view>
    <view class="card-body">
      <view class="info-row">
        <text class="info-label">任务类型</text>
        <text class="info-value">{{taskSummary.typeName || taskSummary.type || '未知'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">任务悬赏</text>
        <text class="info-value highlight-amount">¥{{taskSummary.rewardAmount || 0}}</text>
      </view>
    </view>
    <view class="card-foot">
      <view class="detail-link" bindtap="goToTaskDetail">
        <text>查看任务详情</text>
        <text class="link-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 已提交的补充材料展示（只读） -->
  <view class="card submitted-card" wx:if="{{mySupplement}}">
    <view class="card-head">
      <text class="card-head-icon">✅</text>
      <text class="card-head-title">我的反驳材料</text>
    </view>
    <view class="card-body">
      <view class="info-row">
        <text class="info-label">理由</text>
        <text class="info-value">{{mySupplement.reason}}</text>
      </view>
    </view>
    <view class="image-gallery" wx:if="{{mySupplement.images.length > 0}}">
      <image
        wx:for="{{mySupplement.images}}"
        wx:key="index"
        class="gallery-thumb"
        src="{{item}}"
        mode="aspectFill"
        bindtap="previewImage"
        data-url="{{item}}"
        data-urls="{{mySupplement.images}}"
      />
    </view>
  </view>

  <!-- 表单视图（未提交且非已补充状态下显示） -->
  <block wx:if="{{!isSubmitted && !(mode === 'supplement' && mySupplement)}}">
    <!-- 举报类型（仅发起模式） -->
    <view class="card" wx:if="{{mode !== 'supplement'}}">
      <view class="form-group">
        <view class="form-label">
          <text class="label-icon">🏷️</text>
          <text>举报类型</text>
          <text class="required">*</text>
        </view>
        <picker bindchange="onTypeChange" range="{{reportTypes}}">
          <view class="picker-wrap">
            <text class="picker-text {{selectedTypeValue ? '' : 'placeholder'}}">{{selectedTypeLabel || '请选择举报类型'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 情况说明 / 举报理由 -->
    <view class="card">
      <view class="form-group">
        <view class="form-label">
          <text class="label-icon">✏️</text>
          <text>{{mode === 'supplement' ? '情况说明' : '举报理由'}}</text>
          <text class="required">*</text>
        </view>
        <view class="textarea-wrap">
          <textarea
            placeholder="{{mode === 'supplement' ? '请详细说明情况，5~300字' : '请详细描述举报理由，5~300字'}}"
            maxlength="300"
            bindinput="onReasonInput"
            value="{{reason}}"
            auto-height
          />
        </view>
        <view class="textarea-foot">
          <text class="word-hint">请至少输入5个字</text>
          <text class="word-count {{wordCount > 300 ? 'over' : ''}}">{{wordCount}}<text class="word-max">/300</text></text>
        </view>
      </view>
    </view>

    <!-- 证据截图 -->
    <view class="card">
      <view class="form-group">
        <view class="form-label">
          <text class="label-icon">🖼️</text>
          <text>证据截图</text>
          <text class="required">*</text>
        </view>
        <view class="image-upload">
          <view wx:for="{{images}}" wx:key="index" class="image-item">
            <image src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
            <view class="remove-btn" catchtap="removeImage" data-index="{{index}}">
              <text>×</text>
            </view>
          </view>
          <view wx:if="{{images.length < 3}}" class="upload-btn" bindtap="chooseImage">
            <text class="upload-icon">+</text>
            <text class="upload-text">上传图片</text>
          </view>
        </view>
        <view class="upload-hint">
          <text>最多上传3张，至少上传1张（{{images.length}}/3）</text>
        </view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <button
      class="submit-btn {{isSubmitting || (mode === 'supplement' && !canSupplement) ? 'disabled' : ''}}"
      bindtap="showConfirm"
      disabled="{{isSubmitting || (mode === 'supplement' && !canSupplement)}}"
    >
      <text wx:if="{{!isSubmitting}}">{{mode === 'supplement' ? '提交材料' : '提交举报'}}</text>
      <text wx:else>提交中...</text>
    </button>
  </block>

  <!-- 提交成功视图（仅发起方可见） -->
  <view class="success-wrap" wx:if="{{isSubmitted}}">
    <view class="success-icon-wrap">
      <text class="success-icon">✓</text>
    </view>
    <view class="success-title">举报提交成功</view>
    <view class="success-desc">平台将依据您提交的证据进行仲裁处理，请耐心等待</view>
    <button wx:if="{{canCancel}}" class="cancel-btn" bindtap="cancelReport">撤销举报</button>
    <button class="back-btn" bindtap="goBack">返回</button>
  </view>

  <!-- 确认弹窗 -->
  <view class="modal {{showConfirmModal ? 'show' : ''}}" wx:if="{{showConfirmModal}}">
    <view class="modal-mask" bindtap="hideConfirm"></view>
    <view class="modal-content">
      <view class="modal-icon">⚠️</view>
      <view class="modal-title">确认提交举报</view>
      <view class="modal-body">
        提交举报后，任务将进入客服评审状态，将关闭双方聊天通道，平台将依据证据进行仲裁处理，请如实填写理由并上传证据。您可在客服处理前随时撤销本次举报，撤销后恢复正常任务流程。
      </view>
      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="hideConfirm">取消</view>
        <view class="modal-btn confirm" bindtap="submitReport">确认提交</view>
      </view>
    </view>
  </view>
</view>
