/* 举报页面样式 */
page {
  background: var(--bg-secondary);
  --primary-color: #5db8e6;
}

.container {
  padding: 30rpx;
}

.form-group {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: block;
}

.form-label .required {
  color: #e74c3c;
  margin-left: 8rpx;
}

/* 下拉选择 */
.picker-wrap {
  height: 88rpx;
  background: var(--bg-secondary);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.picker-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.picker-text.placeholder {
  color: var(--text-tertiary);
}

.picker-arrow {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 文本输入 */
.textarea-wrap {
  background: var(--bg-secondary);
  border-radius: 16rpx;
  padding: 20rpx;
}

.textarea-wrap textarea {
  width: 100%;
  height: 240rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
}

.word-count {
  text-align: right;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 12rpx;
}

.word-count.error {
  color: #e74c3c;
}

/* 图片上传 */
.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-item .remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  border: 2rpx dashed var(--border-color);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--bg-secondary);
}

.upload-btn .upload-icon {
  font-size: 48rpx;
  color: var(--text-tertiary);
  margin-bottom: 12rpx;
}

.upload-btn .upload-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.upload-tip {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 16rpx;
}

/* 底部按钮 */
.submit-btn {
  margin-top: 48rpx;
  margin-bottom: 40rpx;
  height: 104rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff5252 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.35);
  letter-spacing: 4rpx;
}

.submit-btn.disabled {
  background: linear-gradient(135deg, #ccc 0%, #bbb 100%);
  color: #fff;
  box-shadow: none;
}

/* 提交成功页 */
.success-wrap {
  padding: 60rpx 40rpx;
  text-align: center;
}

.success-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.success-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.countdown-bar {
  background: rgba(255,193,7,0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.countdown-text {
  font-size: 28rpx;
  color: #f39c12;
}

.countdown-time {
  font-size: 36rpx;
  font-weight: 600;
  color: #e74c3c;
}

.cancel-btn {
  height: 88rpx;
  background: #fff;
  border: 2rpx solid var(--border-color);
  color: var(--text-primary);
  font-size: 30rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.back-btn {
  height: 88rpx;
  background: var(--primary-color);
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.modal-content {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  width: 80%;
  max-width: 600rpx;
  padding: 40rpx;
  z-index: 1;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
  color: var(--text-primary);
}

.modal-body {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  background: var(--bg-secondary);
  color: var(--text-primary);
}

.modal-btn.confirm {
  background: var(--primary-color);
  color: #fff;
}

/* 对方举报摘要卡片（补充材料模式） */
.opponent-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border-left: 8rpx solid #ff6b6b;
}

.opponent-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.opponent-row {
  display: flex;
  margin-bottom: 16rpx;
  align-items: flex-start;
}

.opponent-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
  min-width: 160rpx;
}

.opponent-value {
  font-size: 28rpx;
  color: var(--text-primary);
  flex: 1;
  word-break: break-all;
}

.opponent-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.opponent-images image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
}

.countdown-wrap {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
}

.countdown-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.countdown-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #e74c3c;
  margin-left: 12rpx;
  font-family: monospace;
}

.countdown-value.timeout {
  color: #999;
}

/* 任务摘要详情按钮 */
.detail-btn {
  display: block;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: var(--bg-secondary);
  color: var(--primary-color);
  font-size: 28rpx;
  border-radius: 16rpx;
  margin: 16rpx 0 0;
  padding: 0;
  border: none;
}

.detail-btn::after {
  border: none;
}

/* 已提交的补充材料卡片 */
.my-supplement {
  border-left-color: #2ecc71;
}
