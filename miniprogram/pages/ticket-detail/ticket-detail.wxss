page {
  background: var(--bg-secondary);
}
.container {
  padding-bottom: 120rpx;
}
.loading {
  text-align: center;
  padding: 60rpx;
  color: var(--text-tertiary);
}
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}
.info-row,
.user-row {
  display: flex;
  margin-bottom: 16rpx;
}
.label {
  font-size: 26rpx;
  color: var(--text-tertiary);
  width: 140rpx;
  flex-shrink: 0;
}
.value {
  font-size: 28rpx;
  color: var(--text-primary);
  flex: 1;
}
.value.pre-wrap {
  word-break: break-all;
  line-height: 1.8;
}
.images-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}
.images-row image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
}
.user-avatar-small {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  flex-shrink: 0;
}
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 20rpx 0;
}
.status-section {
  padding: 24rpx 28rpx;
}
.status-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.status-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.status-badge {
  font-size: 26rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-weight: 500;
}
.status-badge.pending {
  color: #e67e22;
  background: rgba(230, 126, 34, 0.1);
}
.status-badge.resolved {
  color: var(--text-tertiary);
  background: var(--bg-secondary);
}
.chat-entry {
  padding: 0;
  overflow: hidden;
}
.chat-entry-content {
  display: flex;
  align-items: center;
  padding: 28rpx;
}
.chat-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}
.chat-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}
.chat-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
}
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid var(--border-color);
}
.arbitrate-btn {
  height: 88rpx;
  background: #e74c3c;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}
.modal.show {
  opacity: 1;
  visibility: visible;
}
.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}
.modal-content {
  position: relative;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  padding: 40rpx 30rpx;
  max-height: 80vh;
  overflow-y: auto;
  z-index: 1;
}
.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
}
.form-row {
  margin-bottom: 24rpx;
}
.form-label {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
}
.picker {
  height: 80rpx;
  background: var(--bg-secondary);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}
.picker text {
  font-size: 28rpx;
  color: var(--text-primary);
}
.picker .arrow {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.credit-hint {
  font-size: 26rpx;
  color: #e74c3c;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: rgba(231, 76, 60, 0.08);
  border-radius: 12rpx;
}
.modal-footer {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}
.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-btn.cancel {
  background: var(--bg-secondary);
  color: var(--text-primary);
}
.modal-btn.confirm {
  background: #e74c3c;
  color: #fff;
}
/* ============================================
   城市服务风格视觉覆盖：清爽可信、交易清楚、低装饰
   ============================================ */
.container,
.chat-container {
  background: #f5f7fa;
}

.header,
.footer,
.input-area,
.popup-content,
.modal-content,
.rules-modal-content {
  background: #ffffff;
  border-color: var(--border-light);
  box-shadow: var(--shadow-card);
}

.section-card,
.task-card,
.user-card,
.menu-list,
.quick-panel,
.need-feed,
.login-tip-card,
.balance-section,
.record-card,
.ticket-card,
.report-card,
.appeal-card,
.profile-card,
.rating-card,
.info-card,
.form-card,
.stat-card,
.card {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.location-bar,
.filter-item,
.sort-section,
.distance-section,
.type-badge,
.card-location,
.distance-tag,
.quick-tag,
.type-item,
.time-option,
.quick-point,
.quick-amount,
.payment-option,
.amount-detail,
.rules-tip,
.points-tip-wrapper,
.input-wrapper,
.toolbar-toggle-btn,
.more-btn,
.system-message-text,
.time-divider text {
  background: #f8fafc;
  border-color: var(--border-light);
  box-shadow: none;
}

.filter-item.active,
.type-item.active,
.quick-tag.active,
.time-option.active,
.payment-option.active {
  background: rgba(22, 119, 210, 0.08);
  border-color: rgba(22, 119, 210, 0.34);
  box-shadow: none;
}

.filter-item.active .filter-name,
.quick-tag.active,
.time-option.active,
.payment-option.active .payment-name {
  color: var(--sky-deep);
  font-weight: 600;
}

.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.amount-badge,
.quick-amount.active,
.quick-point.active,
.time-recommend,
.btn-vitality {
  background: var(--vitality-orange);
  box-shadow: var(--shadow-orange);
}

.balance-value.points,
.balance-value.available,
.points-number,
.publish-points,
.publish-amount {
  color: var(--text-primary);
  background: none;
  -webkit-text-fill-color: currentColor;
}

.wdd-amount,
.need-amount,
.amount-current,
.amount-symbol,
.detail-value.fee,
.warning-text,
.balance-value.insufficient,
.task-points-mini {
  color: var(--vitality-orange);
}

.detail-value.income,
.tag-mint,
.status-success,
.success-text {
  color: var(--fresh-mint);
}

.message-item.other .message-bubble.text {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-sm);
}

.message-item.self .message-bubble.text {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.popup-overlay,
.modal-mask,
.rules-modal {
  background: rgba(15, 23, 42, 0.46);
}

.helper-profile-tip,
.balance-insufficient,
.task-ended-bar.breaking-bar {
  background: #fff8e6;
  border-color: rgba(233, 185, 73, 0.34);
}

image,
button,
view {
  letter-spacing: 0;
}
/* 城市服务按钮对比修正 */
.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  color: #ffffff;
}

.publish-btn.disabled,
.send-btn[disabled],
.disabled {
  color: var(--text-muted);
}