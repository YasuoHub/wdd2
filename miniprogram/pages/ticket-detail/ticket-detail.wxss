page {
  background: var(--bg-secondary);
}
.container {
  padding-bottom: 64rpx;
  padding-bottom: calc(64rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}
.container.has-action-bar {
  padding-bottom: 168rpx;
  padding-bottom: calc(168rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(168rpx + env(safe-area-inset-bottom));
}
.loading {
  text-align: center;
  padding: 60rpx;
  color: var(--text-tertiary);
}
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}
.info-row,
.user-row {
  display: flex;
  margin-bottom: 16rpx;
}
.label {
  font-size: 26rpx;
  color: var(--text-tertiary);
  width: 140rpx;
  flex-shrink: 0;
}
.value {
  font-size: 28rpx;
  color: var(--text-primary);
  flex: 1;
}
.value.pre-wrap {
  word-break: break-all;
  line-height: 1.8;
}
.images-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}
.images-row image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
}
.user-avatar-small {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  flex-shrink: 0;
}
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 20rpx 0;
}
.status-section {
  padding: 24rpx 28rpx;
}
.status-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.status-label {
  font-size: 30rpx;
  font-weight: 400;
  color: var(--text-primary);
}
.status-badge {
  font-size: 26rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-weight: 400;
}
.status-badge.pending {
  color: #e67e22;
  background: rgba(230, 126, 34, 0.1);
}
.status-badge.resolved {
  color: var(--text-tertiary);
  background: var(--bg-secondary);
}
.chat-entry {
  padding: 0;
  overflow: hidden;
}
.chat-entry-content {
  display: flex;
  align-items: center;
  padding: 28rpx;
}
.chat-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}
.chat-text {
  flex: 1;
  margin-left: 16rpx;
  font-size: 30rpx;
  font-weight: 400;
  color: var(--text-primary);
}
.chat-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
}
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--border-color);
  box-sizing: border-box;
  z-index: 20;
}
.arbitrate-btn {
  height: 88rpx;
  background: #e74c3c;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.arbitrate-sheet {
  width: 100%;
  box-sizing: border-box;
  padding-top: 8rpx;
}
.form-row {
  margin-bottom: 24rpx;
}
.form-label {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
}
.picker {
  height: 80rpx;
  background: var(--bg-secondary);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}
.picker text {
  font-size: 28rpx;
  color: var(--text-primary);
}
.picker .arrow {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.credit-hint {
  font-size: 26rpx;
  color: #e74c3c;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: rgba(231, 76, 60, 0.08);
  border-radius: 12rpx;
}
.credit-hint text {
  display: block;
}
.credit-recover {
  margin-top: 8rpx;
  color: var(--text-secondary);
  line-height: 36rpx;
}
.modal-footer {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}
.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-btn.cancel {
  background: var(--bg-secondary);
  color: var(--text-primary);
}
.modal-btn.confirm {
  background: #e74c3c;
  color: #fff;
}
@import "../../styles/wdd-polish.wxss";

/* 工单详情精修：事实信息优先，处理动作保持慎重 */
.container {
  background: #f5f7fa;
}

.section {
  margin: 20rpx 24rpx;
  padding: 30rpx;
  border-radius: 24rpx;
}

.status-section {
  margin-top: 24rpx;
}

.section-title,
.status-label {
  color: #111827;
  font-weight: 400;
}

.info-row,
.user-row {
  padding: 10rpx 0;
  margin-bottom: 4rpx;
}

.label {
  color: var(--text-tertiary);
}

.value {
  color: #1f2933;
  line-height: 1.55;
}

.chat-entry-content {
  min-height: 92rpx;
}

.action-bar {
  background: rgba(255, 255, 255, 0.97);
  border-top: 1rpx solid var(--border-light);
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.arbitrate-btn {
  background: var(--brand-primary);
  box-shadow: var(--shadow-sky);
}

.picker {
  background: #f8fafc;
  border: 1rpx solid var(--border-light);
}

.credit-hint {
  background: #fff8e6;
  border: 1rpx solid var(--vitality-yellow-28);
  color: #946b00;
}

.modal-btn.confirm {
  background: var(--brand-primary);
}
