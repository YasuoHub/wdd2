.container { min-height: 100vh; box-sizing: border-box; padding: 32rpx 32rpx calc(48rpx + env(safe-area-inset-bottom)); background: #F5F7FA; }
.page-head { position: relative; z-index: 1; display: flex; justify-content: space-between; align-items: flex-start; gap: 20rpx; margin-bottom: 24rpx; }
.page-title { display: block; color: var(--text-primary); font-size: 38rpx; font-weight: 600; }
.page-desc { display: block; margin-top: 10rpx; color: var(--text-tertiary); font-size: 25rpx; }
.history-btn { display: flex; align-items: center; gap: 8rpx; flex-shrink: 0; padding: 16rpx 20rpx; color: var(--brand-primary); font-size: 25rpx; background: #FFFFFF; border: 1rpx solid var(--brand-primary-20); border-radius: 18rpx; }
.form-card { position: relative; z-index: 1; padding: 30rpx; background: #FFFFFF; border: 1rpx solid var(--brand-primary-12); border-radius: 28rpx; box-shadow: var(--shadow-card); }
.field + .field { margin-top: 34rpx; }
.field-head { display: flex; align-items: center; margin-bottom: 16rpx; }
.field-label { color: var(--text-primary); font-size: 29rpx; font-weight: 600; }
.required { margin-left: 6rpx; color: #E05252; }
.optional { margin-left: 12rpx; color: var(--text-light); font-size: 23rpx; }
.count { margin-left: auto; color: var(--text-light); font-size: 23rpx; }
.title-input, .content-input { width: 100%; box-sizing: border-box; color: var(--text-primary); font-size: 28rpx; background: #FAFBFC; border: 1rpx solid #E3E8F1; border-radius: 20rpx; }
.title-input { height: 88rpx; padding: 0 24rpx; }
.content-input { min-height: 240rpx; padding: 22rpx 24rpx; line-height: 1.65; }
.image-list { display: flex; flex-wrap: wrap; gap: 18rpx; }
.image-item, .upload-btn { width: 188rpx; height: 188rpx; border-radius: 20rpx; overflow: hidden; box-sizing: border-box; }
.image-item { position: relative; background: #F1F4F7; }
.image-item image { width: 100%; height: 100%; }
.remove-btn { position: absolute; top: 8rpx; right: 8rpx; display: flex; align-items: center; justify-content: center; width: 42rpx; height: 42rpx; background: rgba(25, 34, 44, .72); border-radius: 50%; }
.upload-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12rpx; color: #7B8794; font-size: 24rpx; background: #FAFBFC; border: 2rpx dashed #CCD5DF; }
.upload-btn.disabled { opacity: .55; }
.upload-tip { display: block; margin-top: 14rpx; color: var(--text-light); font-size: 22rpx; }
.quota-limit-tip { position: relative; z-index: 1; display: block; margin: 26rpx 16rpx 0; color: var(--text-tertiary); font-size: 23rpx; line-height: 1.6; text-align: center; }
.submit-btn { position: relative; z-index: 1; height: 92rpx; margin-top: 30rpx; color: #FFFFFF; font-size: 30rpx; font-weight: 600; line-height: 92rpx; background: var(--brand-primary); border-radius: 22rpx; box-shadow: 0 10rpx 28rpx var(--brand-primary-25); }
.submit-btn[disabled] { color: #FFFFFF; background: #B8C2CC; box-shadow: none; }
.submit-btn::after { border: 0; }
