/* ============================================
   问当地 - 帮助者资料 - 天蓝色青春活力风格
   ============================================ */

page {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 50%, var(--bg-tertiary) 100%);
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding-bottom: 160rpx;
  padding-top: 20rpx;
  box-sizing: border-box;
}

/* 区块样式 */
.section {
  background: var(--bg-card);
  margin: 24rpx 32rpx;
  padding: 32rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--border-light);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.required {
  color: var(--danger-color);
  margin-left: 8rpx;
}

.optional {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 400;
  margin-left: 12rpx;
}

.section-tip {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 20rpx;
  padding-left: 12rpx;
}

/* 帮助意愿选择 */
.willingness-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.willingness-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: var(--bg-glass);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.willingness-item.active {
  background: linear-gradient(135deg, rgba(168, 230, 207, 0.3) 0%, rgba(109, 213, 176, 0.2) 100%);
  border-color: var(--fresh-green);
}

.willingness-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  border-radius: 50%;
  box-shadow: var(--shadow-sm);
}

.willingness-content {
  flex: 1;
}

.willingness-label {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.willingness-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.check-icon {
  width: 48rpx;
  height: 48rpx;
  background: var(--fresh-green);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

/* 常去地点 */
.location-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.location-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--bg-glass);
  border-radius: 12rpx;
}

.location-info {
  flex: 1;
  min-width: 0;
}

.location-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-address {
  font-size: 24rpx;
  color: var(--text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-delete {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.delete-icon {
  color: var(--danger-color);
  font-size: 32rpx;
}

/* 添加地点按钮 - 图标版 */
.add-location-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  margin-top: 8rpx;
  border: 2rpx dashed var(--fresh-green);
  border-radius: 16rpx;
  background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  transition: all 0.3s ease;
  min-height: 88rpx;
}

.add-location-btn:active {
  background: linear-gradient(135deg, var(--bg-glass) 0%, rgba(168, 230, 207, 0.2) 100%);
  transform: scale(0.98);
}

.add-location-btn.disabled {
  opacity: 0.5;
  background: var(--bg-secondary);
  border-color: var(--border-light);
  border-style: solid;
}

.add-icon-wrapper {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--fresh-mint) 0%, var(--fresh-green) 100%);
  border-radius: 50%;
  box-shadow: var(--shadow-green);
}

.add-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  line-height: 1;
}

.add-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

/* 可帮助类型网格 */
.help-types-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.help-type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: var(--bg-glass);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  position: relative;
  transition: all 0.3s ease;
}

.help-type-item.active {
  border-width: 2rpx;
  border-style: solid;
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.type-name {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.type-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  background: var(--fresh-green);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx calc(48rpx + env(safe-area-inset-bottom));
  background: var(--bg-card);
  box-shadow: var(--shadow-lg);
  border-top: 2rpx solid var(--border-light);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.footer.with-skip {
  flex-direction: row;
  align-items: center;
}

.btn-skip {
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  border-radius: var(--radius-md);
  transition: all 0.3s ease;
}

.btn-skip:active {
  background: var(--bg-glass);
  color: var(--text-primary);
}

.btn-save {
  flex: 1;
  padding: 28rpx 48rpx;
  background: linear-gradient(135deg, var(--fresh-mint) 0%, var(--fresh-green) 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-green);
  transition: all 0.3s ease;
}

.btn-save:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(109, 213, 176, 0.3);
}

.btn-save.loading {
  opacity: 0.7;
}
