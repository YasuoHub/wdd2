/* 帮助者信息完善页面样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9ff 0%, #ffffff 100%);
  padding-bottom: 160rpx;
  padding-top: 20rpx;
}

/* 区块样式 */
.section {
  background: #fff;
  margin: 24rpx 32rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.required {
  color: #ff6b6b;
  margin-left: 8rpx;
}

.optional {
  font-size: 24rpx;
  color: #95a5a6;
  font-weight: 400;
  margin-left: 12rpx;
}

.section-tip {
  font-size: 24rpx;
  color: #95a5a6;
  margin-top: 20rpx;
  padding-left: 12rpx;
}

/* 帮助意愿选择 */
.willingness-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.willingness-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.willingness-item.active {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  border-color: #81c784;
}

.willingness-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
}

.willingness-content {
  flex: 1;
}

.willingness-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 8rpx;
}

.willingness-desc {
  font-size: 24rpx;
  color: #7f8c8d;
}

.check-icon {
  width: 48rpx;
  height: 48rpx;
  background: #81c784;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

/* 常去地点 */
.location-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.location-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.location-info {
  flex: 1;
  min-width: 0;
}

.location-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #2c3e50;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-address {
  font-size: 24rpx;
  color: #95a5a6;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-delete {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.delete-icon {
  color: #ff6b6b;
  font-size: 32rpx;
}

/* 添加地点按钮 - 图标版 */
.add-location-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  margin-top: 8rpx;
  border: 2rpx dashed #A8E6CF;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f0fff4 0%, #e6fffa 100%);
  transition: all 0.3s ease;
  min-height: 88rpx;
}

.add-location-btn:active {
  background: linear-gradient(135deg, #e6fffa 0%, #d4f5e9 100%);
  transform: scale(0.98);
}

.add-location-btn.disabled {
  opacity: 0.6;
  background: #f5f5f5;
  border-color: #ddd;
  border-style: solid;
}

.add-icon-wrapper {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #A8E6CF 0%, #81c784 100%);
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(168, 230, 207, 0.4);
}

.add-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  line-height: 1;
}

.add-text {
  font-size: 28rpx;
  color: #95a5a6;
  font-weight: 500;
}

/* 可帮助类型网格 */
.help-types-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.help-type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  position: relative;
  transition: all 0.3s ease;
}

.help-type-item.active {
  border-width: 2rpx;
  border-style: solid;
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.type-name {
  font-size: 26rpx;
  color: #2c3e50;
  font-weight: 500;
}

.type-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  background: #81c784;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx 48rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.footer.with-skip {
  flex-direction: row;
  align-items: center;
}

.btn-skip {
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #7f8c8d;
  text-align: center;
  border-radius: 16rpx;
}

.btn-save {
  flex: 1;
  padding: 28rpx 48rpx;
  background: linear-gradient(135deg, #A8E6CF 0%, #81c784 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(168, 230, 207, 0.4);
  transition: all 0.3s ease;
}

.btn-save:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(168, 230, 207, 0.3);
}

.btn-save.loading {
  opacity: 0.7;
}
