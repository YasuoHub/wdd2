<!-- 帮助者信息完善页面 -->
<view class="container wdd-page">
  <view class="wdd-page-bg"></view>
  <!-- 页面加载中 -->
  <view class="page-loading" wx:if="{{pageLoading}}">
    <view class="page-loading-card">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <!-- 主内容区 -->
  <view wx:if="{{!pageLoading}}">
  <!-- 帮助意愿选择 -->
  <view class="section">
    <view class="section-title">
      <wdd-icon class="section-icon" name="circle-question-mark" color="var(--brand-primary)" size="30"></wdd-icon>
      <text>帮助意愿</text>
      <text class="required">*</text>
    </view>
    <view class="willingness-list">
      <view
        wx:for="{{willingnessOptions}}"
        wx:key="value"
        class="willingness-item {{helpWillingness === item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="selectWillingness"
      >
        <view class="willingness-icon">
          <wdd-icon name="{{item.icon}}" color="var(--brand-primary)" size="38"></wdd-icon>
        </view>
        <view class="willingness-content">
          <view class="willingness-label">{{item.label}}</view>
          <view class="willingness-desc">{{item.desc}}</view>
        </view>
        <view class="check-icon" wx:if="{{helpWillingness === item.value}}">
          <wdd-icon name="check" color="#FFFFFF" size="22"></wdd-icon>
        </view>
      </view>
    </view>
  </view>

  <!-- 常去地点 -->
  <view class="section" wx:if="{{helpWillingness === 'willing'}}">
    <view class="section-title">
      <wdd-icon class="section-icon" name="map-pin" color="var(--brand-primary)" size="30"></wdd-icon>
      <text>常去地点</text>
      <text class="optional">（最多{{maxLocations}}个）</text>
    </view>
    <view class="location-list">
      <view
        wx:for="{{frequentLocations}}"
        wx:key="index"
        class="location-item"
      >
        <view class="location-info">
          <view class="location-name">{{item.name}}</view>
          <view class="location-address">{{item.address}}</view>
        </view>
        <view class="location-delete" data-index="{{index}}" bindtap="removeLocation">
          <wdd-icon name="x" color="#FF6B6B" size="24"></wdd-icon>
        </view>
      </view>
      <!-- 添加地点按钮 -->
      <view
        class="add-location-btn {{frequentLocations.length >= maxLocations ? 'disabled' : ''}}"
        bindtap="addLocation"
      >
        <view class="add-icon-wrapper" wx:if="{{frequentLocations.length < maxLocations}}">
          <text class="add-icon">+</text>
        </view>
        <text class="add-text" wx:if="{{frequentLocations.length >= maxLocations}}">已达到上限</text>
      </view>
    </view>
    <view class="section-tip">
      添加您经常活动的地点，系统会优先推荐附近的任务
    </view>
  </view>

  <!-- 可帮助类型 -->
  <view class="section" wx:if="{{helpWillingness === 'willing'}}">
    <view class="section-title">
      <wdd-icon class="section-icon" name="target" color="var(--brand-primary)" size="30"></wdd-icon>
      <text>可帮助类型</text>
      <text class="required">*</text>
    </view>
    <view class="help-types-grid">
      <view
        wx:for="{{helpTypes}}"
        wx:key="id"
        class="help-type-item {{item.selected ? 'active' : ''}}"
        style="{{item.selected ? 'background-color: ' + item.bgColor + '; border-color: ' + item.color : ''}}"
        data-id="{{item.id}}"
        bindtap="toggleHelpType"
      >
        <view class="type-icon">
          <wdd-icon name="{{item.icon}}" color="{{item.color}}" size="42"></wdd-icon>
        </view>
        <view class="type-name">{{item.name}}</view>
        <view class="type-check" wx:if="{{item.selected}}">
          <wdd-icon name="check" color="#FFFFFF" size="20"></wdd-icon>
        </view>
      </view>
    </view>
    <view class="section-tip" wx:if="{{selectedHelpTypes.length > 0}}">
      已选择 {{selectedHelpTypes.length}} 种类型
    </view>
  </view>

  <!-- 底部按钮区域 -->
  <view class="footer {{fromLogin ? 'with-skip' : ''}}">
    <view class="btn-skip" wx:if="{{fromLogin}}" bindtap="skip">
      跳过，仅求助
    </view>
    <view
      class="btn-save {{isLoading ? 'loading' : ''}}"
      bindtap="saveProfile"
    >
      {{isLoading ? '保存中...' : '保存设置'}}
    </view>
  </view>
  </view>
</view>
