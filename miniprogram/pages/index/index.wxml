<!-- 首页 - 问当地 -->
<wxs src="../../utils/money.wxs" module="money" />
<view class="container wdd-page">
  <view class="wdd-page-bg"></view>
  <view class="hero {{!isLoggedIn ? 'hero-guest' : ''}}" style="padding-top: {{safeTop}}px;">
    <image class="hero-bg-map" src="/images/bg-city-map.png" mode="aspectFill"></image>
    <view class="map-grid map-grid-a"></view>
    <view class="map-grid map-grid-b"></view>
    <view class="map-water"></view>
    <view class="map-park map-park-a"></view>
    <view class="map-park map-park-b"></view>

    <view class="topbar">
      <view class="brand">
        <text class="brand-text">问当地</text>
        <view class="city-chip">
          <wdd-icon name="map-pin" color="#7890A8" size="24"></wdd-icon>
          <text>{{currentCity}}</text>
        </view>
      </view>
    </view>

    <view class="hero-copy">
      <text class="hero-title">即时问当地人</text>
      <text class="hero-subtitle">异地求助 当地解答 实时可靠</text>
    </view>

    <view wx:if="{{!isLoggedIn}}" class="hero-login-card">
      <view class="hero-login-icon">
        <wdd-icon name="circle-user-round" color="#1677D2" size="46"></wdd-icon>
      </view>
      <view class="hero-login-copy">
        <text class="hero-login-title">欢迎来到问当地</text>
        <text class="hero-login-subtitle">登录后即可发布求助或帮助他人</text>
      </view>
      <button class="hero-login-btn" bindtap="handleLogin">
        <wdd-icon name="message-circle" color="#FFFFFF" size="28"></wdd-icon>
        <text>微信一键登录</text>
      </button>
    </view>

    <view class="map-pulse">
      <view class="map-pulse-dot"></view>
    </view>

    <view class="action-panel">
      <view class="primary-action" bindtap="goToPublish">
        <view class="primary-main">
          <view class="action-icon primary">
            <wdd-icon name="send" color="#1677D2" size="48"></wdd-icon>
          </view>
          <text class="action-title">发布求助</text>
        </view>
        <view class="primary-footer">
          <text class="action-desc">想问什么，当地人帮你确认</text>
          <view class="primary-arrow">
            <wdd-icon name="chevron-right" color="#1677D2" size="30"></wdd-icon>
          </view>
        </view>
      </view>
      <view class="secondary-action" bindtap="goToTaskHall">
        <view class="action-icon secondary">
          <wdd-icon name="users-round" color="#1677D2" size="42"></wdd-icon>
        </view>
        <text class="secondary-title">去大厅接单</text>
        <wdd-icon name="chevron-right" color="#1677D2" size="26"></wdd-icon>
      </view>
    </view>
  </view>

  <view class="quick-panel">
    <view class="quick-grid">
      <view
        wx:for="{{quickTypes}}"
        wx:key="type"
        class="quick-type-item type-{{item.type}}"
        bindtap="goToPublishWithType"
        data-type="{{item.type}}"
      >
        <view class="quick-type-icon">
          <wdd-icon name="{{item.icon}}" color="{{item.color}}" size="52"></wdd-icon>
        </view>
        <text class="quick-type-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{isLoggedIn && userInfo.total_points < 10}}" class="points-tip">
    积分不足？去<text class="link" bindtap="goToSignIn">签到</text>获取积分
  </view>

  <view class="nearby-section">
    <view class="section-head">
      <view>
        <view class="section-title-row">
          <text class="section-title">附近求助</text>
          <view class="distance-tag">
            <wdd-icon name="map-pin" color="#1677D2" size="26"></wdd-icon>
            <text>5公里内</text>
          </view>
        </view>
      </view>
      <view class="section-more" bindtap="goToTaskHall">
        <text>查看全部</text>
        <wdd-icon name="chevron-right" color="#5E7187" size="26"></wdd-icon>
      </view>
    </view>

    <view wx:if="{{!isLoggedIn}}" class="login-tip-card wdd-card">
      <view class="state-icon">
        <wdd-icon name="lock-keyhole" color="#1677D2" size="46"></wdd-icon>
      </view>
      <view class="empty-text">登录后查看附近任务</view>
      <view class="empty-hint">{{cityHintText}}</view>
    </view>

    <loading wx:elif="{{nearbyLoading}}" type="card" text="正在搜索附近任务..." mode="spinner" size="64"></loading>

    <error wx:elif="{{nearbyError}}" type="card" icon="triangle-alert" title="加载失败" desc="网络异常，请稍后重试" showRetry="true" retryText="重新加载" bind:retry="reloadNearbyNeeds"></error>

    <view wx:elif="{{nearbyNeeds.length > 0}}" class="need-feed">
      <view
        wx:for="{{nearbyNeeds}}"
        wx:key="_id"
        class="need-row type-{{item.type}}"
        bindtap="goToNeedDetail"
        data-id="{{item._id}}"
      >
        <view class="need-main">
          <view class="need-layout">
            <view class="need-type-icon type-{{item.type}}">
              <wdd-icon name="{{item.typeIcon || 'circle-help'}}" color="{{item.iconColor || item.color || '#1677D2'}}" size="50"></wdd-icon>
            </view>
            <view class="need-body">
              <view class="need-topline">
                <view class="need-content">{{item.description || '暂无详细描述'}}</view>
                <view class="need-reward">
                  <text class="need-amount" wx:if="{{item.rewardAmount > 0}}">¥{{money.format(item.rewardAmount)}}</text>
                  <text class="need-amount" wx:elif="{{item.points > 0}}">+{{item.points}}积分</text>
                </view>
              </view>
              <view class="need-meta">
                <view class="meta-item location-item">
                  <wdd-icon name="map-pin" color="#7B8794" size="24"></wdd-icon>
                  <text class="location-name">{{item.locationName}}</text>
                </view>
                <text wx:if="{{item.distanceText}}" class="meta-dot">·</text>
                <view wx:if="{{item.distanceText}}" class="meta-item distance-item">
                  <text>{{item.distanceText}}</text>
                </view>
                <text class="meta-dot">·</text>
                <view class="meta-item time-item">
                  <wdd-icon name="clock-3" color="#7B8794" size="24"></wdd-icon>
                  <text>{{item.remainTime}}</text>
                </view>
              </view>
            </view>
            <view class="row-arrow-wrap">
              <wdd-icon name="chevron-right" color="#7B8794" size="28"></wdd-icon>
            </view>
          </view>
        </view>
      </view>
    </view>

    <empty wx:elif="{{nearbyEmpty}}" type="card" icon="inbox" title="暂无求助任务" desc="周围地区的实时求助信息" showBtn="true" btnText="去大厅看看" btnType="primary" bind:btnTap="goToTaskHall"></empty>
  </view>
</view>
