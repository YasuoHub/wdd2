<!-- 首页 - 问当地 -->
<view class="container">

  <!-- 顶部导航 -->
  <view class="header">
    <view class="brand">
      <view class="brand-icon">🌿</view>
      <text class="brand-text">问当地</text>
    </view>
  </view>

  <!-- 未登录提示卡片 -->
  <view wx:if="{{!isLoggedIn}}" class="login-card">
    <view class="login-illustration">🗺️</view>
    <view class="login-title">欢迎来到问当地</view>
    <view class="login-subtitle">登录后即可发布求助或帮助他人</view>
    <button class="login-btn" bindtap="handleLogin">
      <text class="wechat-icon">💬</text>
      <text>微信一键登录</text>
    </button>
  </view>

  <!-- 发布求助入口 -->
  <view class="publish-section">
    <view class="publish-card" bindtap="goToPublish">
      <view class="publish-content">
        <view class="publish-header">
          <view class="publish-icon">✨</view>
          <text class="publish-title">发布求助</text>
        </view>
        <view class="publish-desc">想问什么，当地人帮你解答</view>
        <view class="publish-features">
          <text class="feature-tag">📍 实时位置</text>
          <text class="feature-tag">🎯 多种类型</text>
          <text class="feature-tag">⚡ 快速响应</text>
        </view>
      </view>
    </view>

    <!-- 快捷类型入口 -->
    <view wx:if="{{isLoggedIn}}" class="quick-types">
      <view
        wx:for="{{quickTypes}}"
        wx:key="type"
        class="quick-type-item"
        bindtap="goToPublishWithType"
        data-type="{{item.type}}"
        style="--type-color: {{item.color}}"
      >
        <view class="quick-type-icon" style="background: linear-gradient(135deg, {{item.color}} 0%, {{item.lightColor}} 100%);">{{item.icon}}</view>
        <text class="quick-type-name">{{item.name}}</text>
      </view>
    </view>

    <view wx:if="{{isLoggedIn && userInfo.total_points < 10}}" class="points-tip">
      积分不足？去<text class="link" bindtap="goToSignIn">签到</text>获取积分
    </view>
  </view>

  <!-- 附近任务 -->
  <view class="nearby-section">
    <view class="section-header">
      <view class="section-title-wrapper">
        <view class="section-icon">📍</view>
        <view class="title-group">
          <text class="section-title">附近求助</text>
          <view class="distance-tag">5公里内</view>
        </view>
      </view>
      <text class="section-more" bindtap="goToTaskHall">查看全部 →</text>
    </view>

    <!-- 未登录状态 -->
    <view wx:if="{{!isLoggedIn}}" class="login-tip-card">
      <view class="lock-icon">🔒</view>
      <view class="empty-text">登录后查看附近任务</view>
      <view class="empty-hint">成都地区的实时求助信息</view>
    </view>

    <!-- 加载中 -->
    <loading wx:elif="{{nearbyLoading}}" type="card" text="正在搜索附近任务..." mode="spinner" size="64"></loading>

    <!-- 加载失败 -->
    <error wx:elif="{{nearbyError}}" type="card" icon="⚠️" title="加载失败" desc="网络异常，请稍后重试" showRetry="true" retryText="重新加载" bind:retry="reloadNearbyNeeds"></error>

    <!-- 任务列表 -->
    <view wx:elif="{{nearbyNeeds.length > 0}}" class="need-list">
      <view
        wx:for="{{nearbyNeeds}}"
        wx:key="_id"
        class="need-card type-{{item.type}}"
        bindtap="goToNeedDetail"
        data-id="{{item._id}}"
      >
        <view class="need-header">
          <view class="need-type">
            <view class="type-icon">{{item.typeIcon}}</view>
            <text class="type-name">{{item.typeName}}</text>
          </view>
          <text class="need-points" wx:if="{{item.rewardAmount > 0}}">¥{{item.rewardAmount}}</text>
          <text class="need-points" wx:elif="{{item.points > 0}}">+{{item.points}}积分</text>
        </view>
        <view class="need-content">{{item.description || '暂无详细描述'}}</view>
        <view class="need-footer">
          <view class="need-meta">
            <view class="meta-item location-item">
              <text class="meta-icon">📍</text>
              <text class="location-name">{{item.locationName}}</text>
              <text wx:if="{{item.distanceText}}" class="distance-text">({{item.distanceText}})</text>
            </view>
            <view class="meta-item">
              <text class="meta-icon">⏱️</text>
              <text>{{item.remainTime}}</text>
            </view>
          </view>
          <view wx:if="{{item.is_urgent}}" class="need-status urgent">急</view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <empty wx:elif="{{nearbyEmpty}}" type="card" icon="🌸" title="暂无求助任务" desc="周围地区的实时求助信息" showBtn="true" btnText="去大厅看看" btnType="primary" bind:btnTap="goToTaskHall"></empty>
  </view>

  <!-- 底部装饰 -->
  <view class="bottom-decoration"></view>
</view>
