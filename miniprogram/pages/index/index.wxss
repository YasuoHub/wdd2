@import "../../styles/wdd-polish.wxss";

/* 首页：清透地图感 + 双入口信息流 */
.container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #ffffff 58%, #f5f7fa 100%);
  font-family: "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  font-synthesis: none;
  box-sizing: border-box;
}

.hero {
  position: relative;
  min-height: 676rpx;
  padding-right: 34rpx;
  padding-bottom: 34rpx;
  padding-left: 34rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 81% 35%, rgba(30, 156, 235, 0.13) 0 68rpx, transparent 132rpx),
    linear-gradient(180deg, rgba(246, 251, 255, 0.86) 0%, rgba(255, 255, 255, 0.5) 76%, rgba(255, 255, 255, 0) 100%);
  box-sizing: border-box;
}

.hero-bg-map {
  position: absolute;
  z-index: 0;
  top: 36rpx;
  right: -64rpx;
  width: 750rpx;
  height: 520rpx;
  opacity: 0.78;
  pointer-events: none;
}

.topbar,
.hero-copy,
.hero-login-card,
.action-panel {
  position: relative;
  z-index: 2;
}

.map-grid {
  position: absolute;
  z-index: 0;
  pointer-events: none;
  background:
    repeating-linear-gradient(30deg, transparent 0 44rpx, rgba(255, 255, 255, 0.92) 45rpx 50rpx),
    repeating-linear-gradient(122deg, transparent 0 58rpx, rgba(255, 255, 255, 0.9) 59rpx 65rpx);
  transform: rotate(-7deg);
}

.map-grid-a {
  top: -66rpx;
  right: -80rpx;
  width: 620rpx;
  height: 466rpx;
  opacity: 0.18;
  background-color: rgba(223, 241, 252, 0.72);
}

.map-grid-b {
  top: 166rpx;
  right: -130rpx;
  width: 520rpx;
  height: 306rpx;
  opacity: 0.12;
  transform: rotate(18deg);
}

.map-water {
  position: absolute;
  z-index: 0;
  top: 310rpx;
  right: -74rpx;
  width: 440rpx;
  height: 84rpx;
  border: 16rpx solid rgba(184, 225, 248, 0.38);
  border-right: 0;
  border-radius: 50% 0 0 50%;
  transform: rotate(18deg);
  pointer-events: none;
}

.map-park {
  position: absolute;
  z-index: 0;
  width: 76rpx;
  height: 54rpx;
  border-radius: 12rpx;
  background: rgba(188, 232, 202, 0.34);
  transform: rotate(-17deg);
}

.map-park-a {
  top: 188rpx;
  right: 66rpx;
}

.map-park-b {
  top: 352rpx;
  right: 304rpx;
}

.topbar,
.brand,
.city-chip,
.action-panel,
.primary-action,
.secondary-action,
.section-head,
.section-title-row,
.section-more,
.quick-grid,
.quick-type-item,
.distance-tag {
  display: flex;
  align-items: center;
}

.topbar {
  min-height: 96rpx;
  justify-content: flex-start;
}

.brand {
  gap: 18rpx;
  min-width: 0;
}

.brand-text {
  color: #135fa7;
  font-size: 49rpx;
  line-height: 1;
  font-weight: 700;
}

.city-chip {
  max-width: 180rpx;
  gap: 6rpx;
  padding: 8rpx 13rpx;
  border-radius: 999rpx;
  color: #71849a;
  background: rgba(255, 255, 255, 0.58);
  font-size: 23rpx;
  font-weight: 400;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  margin-top: 54rpx;
  margin-bottom: 76rpx;
}

.hero-title {
  color: #26313f;
  font-size: 59rpx;
  line-height: 1.12;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 24rpx;
  color: #5d6b7e;
  font-size: 27rpx;
  line-height: 1.35;
  font-weight: 400;
}

.hero-guest .hero-copy {
  margin-bottom: 30rpx;
}

.hero-login-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  width: 100%;
  margin-bottom: 30rpx;
  padding: 22rpx 22rpx;
  border: 2rpx solid rgba(21, 148, 232, 0.13);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 34rpx rgba(42, 105, 150, 0.1);
  box-sizing: border-box;
}

.hero-login-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 72rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: rgba(17, 120, 220, 0.09);
}

.hero-login-copy {
  display: flex;
  flex: 1 1 auto;
  min-width: 0;
  flex-direction: column;
  gap: 8rpx;
}

.hero-login-title {
  color: #26313f;
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 600;
}

.hero-login-subtitle {
  color: var(--text-tertiary);
  font-size: 22rpx;
  line-height: 1.35;
}

.hero-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  gap: 8rpx;
  min-width: 190rpx;
  height: 68rpx;
  margin: 0;
  padding: 0 20rpx;
  border: 0;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(135deg, var(--brand-primary) 0%, #135fa7 100%);
  font-size: 23rpx;
  line-height: 68rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 22rpx rgba(21, 148, 232, 0.2);
}

.hero-login-btn::after {
  border: 0;
}

.hero-login-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.map-pulse {
  position: absolute !important;
  right: 110rpx;
  top: 364rpx;
  width: 124rpx;
  height: 124rpx;
  border: 22rpx solid rgba(21, 148, 232, 0.08);
  border-radius: 50%;
  background: rgba(21, 148, 232, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.map-pulse-dot {
  width: 54rpx;
  height: 54rpx;
  border: 10rpx solid #fff;
  border-radius: 50%;
  background: var(--brand-primary);
  box-shadow: 0 7rpx 22rpx rgba(21, 148, 232, 0.25);
  box-sizing: border-box;
}

.action-panel {
  width: 100%;
  align-items: flex-end;
  gap: 18rpx;
  box-sizing: border-box;
}

.primary-action {
  flex: 0 1 59%;
  min-width: 0;
  height: 218rpx;
  padding: 36rpx 28rpx 30rpx;
  border-radius: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, var(--brand-primary) 0%, #135fa7 58%, #26a7f2 100%);
  box-shadow: 0 18rpx 42rpx rgba(21, 148, 232, 0.22);
  flex-direction: column;
  align-items: stretch;
  justify-content: space-between;
  gap: 22rpx;
  box-sizing: border-box;
}

.secondary-action {
  flex: 1 1 0;
  min-width: 0;
  height: 148rpx;
  padding: 24rpx 18rpx;
  border: 2rpx solid var(--brand-primary);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.88);
  justify-content: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.primary-action:active,
.secondary-action:active,
.quick-type-item:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.action-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.action-icon.primary {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: #fff;
}

.action-icon.secondary {
  width: 48rpx;
  height: 56rpx;
}

.primary-main,
.primary-footer {
  width: 100%;
  display: flex;
  align-items: center;
  min-width: 0;
}

.primary-main {
  gap: 22rpx;
}

.primary-footer {
  justify-content: space-between;
  gap: 14rpx;
}

.action-title {
  min-width: 0;
  color: #fff;
  font-size: 41rpx;
  line-height: 1.12;
  font-weight: 700;
  white-space: nowrap;
}

.action-desc {
  min-width: 0;
  flex: 1;
  color: rgba(255, 255, 255, 0.94);
  font-size: 23rpx;
  line-height: 1.3;
  font-weight: 400;
}

.primary-arrow {
  width: 46rpx;
  height: 46rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.secondary-title {
  flex: 0 1 auto;
  min-width: 0;
  color: #135fa7;
  font-size: 25rpx;
  line-height: 1.2;
  font-weight: 600;
  white-space: nowrap;
}

.quick-panel {
  margin: 0 34rpx;
  padding: 0;
  border: 1rpx solid rgba(217, 226, 236, 0.98);
  border-radius: 27rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 38rpx rgba(15, 23, 42, 0.07);
  overflow: hidden;
}

.quick-grid {
  flex-wrap: wrap;
}

.quick-type-item {
  position: relative;
  width: 33.333%;
  height: 204rpx;
  flex-direction: column;
  justify-content: center;
  gap: 22rpx;
}

.quick-type-item:nth-child(-n + 3) {
  border-bottom: 1rpx solid rgba(217, 226, 236, 0.98);
}

.quick-type-item:nth-child(2)::before,
.quick-type-item:nth-child(3)::before,
.quick-type-item:nth-child(5)::before,
.quick-type-item:nth-child(6)::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 1rpx;
  background: rgba(217, 226, 236, 0.98);
}

.quick-type-icon {
  width: 86rpx;
  height: 76rpx;
  color: var(--brand-primary);
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-type-name {
  color: #202832;
  font-size: 30rpx;
  line-height: 1.1;
  font-weight: 400;
}

.nearby-section {
  margin-top: 42rpx;
  padding-bottom: 48rpx;
}

.section-head {
  justify-content: space-between;
  padding: 0 38rpx 22rpx;
}

.section-title-row {
  gap: 16rpx;
}

.section-title {
  color: #26313f;
  font-size: 42rpx;
  line-height: 1.1;
  font-weight: 700;
}

.distance-tag,
.section-more {
  gap: 8rpx;
  color: #617087;
  font-size: 28rpx;
  font-weight: 400;
}

.distance-tag {
  color: var(--brand-primary);
  min-height: auto;
  padding: 0;
  background: transparent;
  border: 0;
  box-shadow: none;
}

.need-feed {
  margin: 0 34rpx;
  padding: 0 26rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid rgba(217, 226, 236, 0.95);
  border-radius: 26rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.045);
  display: flex;
  flex-direction: column;
  gap: 0;
  overflow: hidden;
  box-sizing: border-box;
}

.nearby-loading-card {
  margin: 0 34rpx;
  box-sizing: border-box;
}

.need-row {
  padding: 0;
  border: 0;
  border-bottom: 1rpx solid rgba(217, 226, 236, 0.95);
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.need-row:last-child {
  border-bottom: 0;
}

.need-row:active {
  transform: none;
  opacity: 1;
  background: var(--brand-primary-05);
}

.need-main {
  padding: 30rpx 0;
  box-sizing: border-box;
}

.need-card-head,
.need-type-badge,
.need-reward,
.need-card-foot,
.need-location,
.need-time {
  display: flex;
  align-items: center;
}

.need-card-head {
  justify-content: space-between;
  gap: 18rpx;
}

.need-type-badge {
  min-width: 0;
  max-width: 420rpx;
  gap: 10rpx;
  padding: 0;
  color: var(--brand-primary);
  background: transparent;
  font-size: 29rpx;
  line-height: 1;
  font-weight: 400;
  box-sizing: border-box;
}

.need-type-badge text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.need-reward {
  flex-shrink: 0;
  gap: 9rpx;
  color: #ff830f;
  justify-content: center;
}

.need-content {
  margin-top: 28rpx;
  overflow: hidden;
  color: #111827;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.need-card-foot {
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 32rpx;
  color: #687386;
  font-size: 29rpx;
  line-height: 1;
}

.need-location {
  flex: 1 1 auto;
  min-width: 0;
  gap: 12rpx;
  white-space: nowrap;
}

.need-time {
  flex: 0 0 auto;
  gap: 12rpx;
  white-space: nowrap;
}

.location-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.distance-text,
.meta-dot {
  flex-shrink: 0;
}

.meta-dot {
  color: #b3bfcc;
  font-size: 24rpx;
  line-height: 1;
}

.need-amount {
  color: #ff830f;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
  white-space: nowrap;
}

.need-amount.points {
  font-size: 29rpx;
}

.login-tip-card {
  margin: 0 34rpx;
  padding: 54rpx 40rpx;
  text-align: center;
}

.state-icon {
  width: 92rpx;
  height: 92rpx;
  margin: 0 auto 22rpx;
  border-radius: 28rpx;
  background: var(--brand-primary-10);
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  color: #202a38;
  font-size: 29rpx;
  font-weight: 600;
}

.empty-hint {
  margin-top: 10rpx;
  color: #6b7f95;
  font-size: 24rpx;
}

@media screen and (max-width: 350px) {
  .brand {
    gap: 12rpx;
  }

  .brand-text {
    font-size: 43rpx;
  }

  .hero-login-card {
    gap: 14rpx;
    padding: 20rpx 18rpx;
  }

  .hero-login-icon {
    flex-basis: 62rpx;
    width: 62rpx;
    height: 62rpx;
  }

  .hero-login-btn {
    min-width: 164rpx;
    padding: 0 14rpx;
    font-size: 21rpx;
  }

  .primary-action {
    flex-basis: 58%;
    height: 202rpx;
    padding: 28rpx 22rpx 24rpx;
    gap: 18rpx;
  }

  .secondary-action {
    height: 138rpx;
    padding-right: 12rpx;
    padding-left: 12rpx;
    gap: 6rpx;
  }

  .primary-main {
    gap: 18rpx;
  }

  .action-icon.primary {
    width: 78rpx;
    height: 78rpx;
  }

  .action-title {
    font-size: 36rpx;
  }

  .action-desc {
    font-size: 22rpx;
  }

  .secondary-title {
    font-size: 23rpx;
  }
}
