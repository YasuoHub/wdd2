/* ============================================
   问当地 - 首页 - 天蓝色青春活力风格
   ============================================ */

/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 30%, var(--bg-tertiary) 70%, #F5FAFF 100%);
  padding-bottom: 40rpx;
  box-sizing: border-box;
  width: 100%;
}

/* ============================================
   顶部导航
   ============================================ */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 32rpx 24rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.brand-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 50%, var(--sky-soft) 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 6rpx 24rpx rgba(93, 184, 230, 0.35);
  animation: float 3s ease-in-out infinite;
}

.brand-text {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

/* ============================================
   未登录提示卡片
   ============================================ */
.login-card {
  margin: 0 32rpx 32rpx;
  background: var(--bg-card);
  backdrop-filter: blur(40rpx);
  border-radius: var(--radius-xl);
  padding: 48rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid rgba(93, 184, 230, 0.12);
  text-align: center;
}

.login-illustration {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 32rpx;
  background: linear-gradient(135deg, var(--bg-secondary) 0%, #D4EDF7 50%, #C4E5F5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  box-shadow: 0 8rpx 32rpx rgba(93, 184, 230, 0.2);
  animation: float 4s ease-in-out infinite;
}

.login-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 36rpx;
}

.login-btn {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 50%, var(--sky-soft) 100%);
  color: white;
  font-size: 30rpx;
  font-weight: 700;
  padding: 28rpx 72rpx;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-sky);
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  transition: all 0.3s ease;
}

.login-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.3);
}

.wechat-icon {
  font-size: 34rpx;
}

/* ============================================
   发布求助入口
   ============================================ */
.publish-section {
  margin: 32rpx;
}

.publish-card {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 50%, var(--sky-soft) 100%);
  border-radius: var(--radius-xl);
  padding: 52rpx 44rpx;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}

/* 装饰性气泡 */
.publish-card::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 50%;
}

.publish-card::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  left: -40rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.publish-content {
  position: relative;
  z-index: 1;
}

.publish-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.publish-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.publish-title {
  font-size: 44rpx;
  font-weight: 800;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.publish-desc {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 36rpx;
  line-height: 1.5;
}

.publish-features {
  display: flex;
  gap: 16rpx;
  flex-wrap: nowrap;
  justify-content: space-between;
}

.feature-tag {
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  color: white;
  font-size: 24rpx;
  padding: 12rpx 0;
  border-radius: 9999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  flex: 1;
  text-align: center;
  white-space: nowrap;
}

.points-tip {
  margin-top: 28rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: rgba(93, 184, 230, 0.1);
  padding: 18rpx 28rpx;
  border-radius: var(--radius-full);
  border: 2rpx solid rgba(93, 184, 230, 0.15);
}

.points-tip .link {
  color: var(--sky-primary);
  font-weight: 700;
}

/* 快捷类型入口 */
.quick-types {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.quick-type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 16rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 28rpx;
  border: 2rpx solid rgba(93, 184, 230, 0.1);
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.08);
  transition: all 0.3s ease;
}

.quick-type-item:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 10rpx rgba(93, 184, 230, 0.15);
}

.quick-type-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.quick-type-item:active .quick-type-icon {
  transform: scale(0.9);
}

.quick-type-name {
  font-size: 24rpx;
  color: #2C3E50;
  font-weight: 600;
}

/* ============================================
   附近任务区域
   ============================================ */
.nearby-section {
  margin: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  padding: 0 8rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.title-group {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.distance-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #5DB8E6;
  background: rgba(93, 184, 230, 0.12);
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  font-weight: 600;
  width: fit-content;
}

.section-icon {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #7EC8E8 0%, #A8D8F0 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.25);
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.section-more {
  font-size: 28rpx;
  color: var(--sky-primary);
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

/* 任务卡片列表 */
.need-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.need-card {
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  padding: 32rpx 32rpx 32rpx 44rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.need-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 32rpx rgba(93, 184, 230, 0.15);
}

/* 左侧天蓝色圆点装饰 */
.need-card::before {
  content: '';
  position: absolute;
  left: 14rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 10rpx;
  height: 48rpx;
  background: linear-gradient(180deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  border-radius: var(--radius-full);
  opacity: 0.9;
}

.need-card.type-weather::before { background: linear-gradient(180deg, var(--sky-primary) 0%, var(--sky-light) 100%); }
.need-card.type-traffic::before { background: linear-gradient(180deg, var(--vitality-yellow) 0%, #FFE08C 100%); }
.need-card.type-shop::before { background: linear-gradient(180deg, var(--lavender) 0%, #D4D4F0 100%); }
.need-card.type-parking::before { background: linear-gradient(180deg, var(--fresh-mint) 0%, var(--fresh-green) 100%); }
.need-card.type-queue::before { background: linear-gradient(180deg, var(--vitality-orange) 0%, var(--vitality-coral) 100%); }

.need-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.need-type {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.type-icon {
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(135deg, rgba(93, 184, 230, 0.15) 0%, rgba(168, 216, 240, 0.1) 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.type-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.need-points {
  background: linear-gradient(135deg, var(--vitality-orange) 0%, var(--vitality-coral) 50%, #FFB6A8 100%);
  color: white;
  font-size: 24rpx;
  font-weight: 700;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-orange);
}

.need-content {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 18rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.need-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.need-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 地点和距离信息 */
.location-item {
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.distance-text {
  color: var(--sky-primary);
  font-weight: 600;
  flex-shrink: 0;
}

.meta-icon {
  font-size: 22rpx;
}

.need-status {
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
}

.need-status.urgent {
  background: rgba(255, 140, 105, 0.15);
  color: var(--vitality-orange);
}

/* ============================================
   空状态
   ============================================ */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 36rpx;
  background: linear-gradient(135deg, #E6F3FF 0%, #D4EDF7 50%, #C4E5F5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 88rpx;
  box-shadow: 0 6rpx 30rpx rgba(93, 184, 230, 0.15);
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  font-weight: 600;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* ============================================
   未登录提示
   ============================================ */
.login-tip-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 36rpx;
  padding: 56rpx;
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.12);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
}

.lock-icon {
  width: 110rpx;
  height: 110rpx;
  margin: 0 auto 28rpx;
  background: linear-gradient(135deg, #E6F3FF 0%, #D4EDF7 50%, #C4E5F5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  box-shadow: 0 4px 20rpx rgba(93, 184, 230, 0.15);
}

/* ============================================
   底部装饰
   ============================================ */
.bottom-decoration {
  height: 44rpx;
  background: linear-gradient(90deg, #5DB8E6 0%, #7EC8E8 33%, #FF8C69 66%, #FFD166 100%);
  opacity: 0.25;
  margin: 44rpx 32rpx;
  border-radius: 9999rpx;
}

/* ============================================
   加载中状态
   ============================================ */
.loading-card {
  text-align: center;
  padding: 80rpx 40rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid rgba(93, 184, 230, 0.2);
  border-top-color: #5DB8E6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 28rpx;
}

.loading-text {
  font-size: 30rpx;
  color: #6B8BA4;
}

/* ============================================
   错误状态
   ============================================ */
.error-card {
  text-align: center;
  padding: 80rpx 40rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
}

.error-icon {
  font-size: 88rpx;
  margin-bottom: 28rpx;
}

.error-text {
  font-size: 30rpx;
  color: #6B8BA4;
  margin-bottom: 28rpx;
}

.retry-btn {
  display: inline-block;
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  color: white;
  font-size: 30rpx;
  padding: 24rpx 56rpx;
  border-radius: 9999rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 24rpx rgba(93, 184, 230, 0.35);
}
