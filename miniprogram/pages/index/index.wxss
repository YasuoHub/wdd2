/* ============================================
   问当地 - 城市绿洲设计系统
   风格：亲和力 / 现代 / ins风
   ============================================ */

/* CSS变量 - 设计令牌 */
:root {
  /* 主色调 - 温暖奶油系 */
  --color-cream: #FDF8F3;
  --color-cream-dark: #F5EDE4;
  --color-mint: #A8E6CF;
  --color-mint-light: #D4F1E4;
  --color-coral: #FFB7B2;
  --color-coral-soft: #FFE5E3;
  --color-lavender: #C7CEEA;
  --color-sand: #E8DCC4;

  /* 文字色 */
  --text-primary: #2D3436;
  --text-secondary: #636E72;
  --text-tertiary: #B2BEC3;

  /* 阴影 */
  --shadow-soft: 0 4rpx 20rpx rgba(45, 52, 54, 0.06);
  --shadow-medium: 0 8rpx 32rpx rgba(45, 52, 54, 0.1);
  --shadow-glow: 0 0 40rpx rgba(168, 230, 207, 0.4);

  /* 圆角 */
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  --radius-full: 9999rpx;

  /* 间距 */
  --space-xs: 12rpx;
  --space-sm: 20rpx;
  --space-md: 32rpx;
  --space-lg: 48rpx;
}

/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FDF8F3 0%, #F8F4EF 100%);
  padding-bottom: 40rpx;
}

/* ============================================
   顶部导航
   ============================================ */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 32rpx 20rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.brand-icon {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #A8E6CF 0%, #88D8C0 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(168, 230, 207, 0.4);
}

.brand-text {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

.notification-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: var(--shadow-soft);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.notification-icon {
  font-size: 32rpx;
}

.notification-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 28rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #FFB7B2 0%, #FF9E99 100%);
  border-radius: var(--radius-full);
  color: white;
  font-size: 18rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 183, 178, 0.5);
}

/* ============================================
   用户卡片 - 毛玻璃效果
   ============================================ */
.user-card {
  margin: 0 32rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(40rpx);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-soft);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.welcome-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-full);
  border: 4rpx solid white;
  box-shadow: var(--shadow-soft);
  background: linear-gradient(135deg, #C7CEEA 0%, #A8B4E0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.welcome-text {
  flex: 1;
}

.welcome-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 4rpx;
}

.welcome-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.sign-in-btn {
  background: linear-gradient(135deg, #A8E6CF 0%, #88D8C0 100%);
  color: white;
  font-size: 24rpx;
  font-weight: 600;
  padding: 16rpx 28rpx;
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 16rpx rgba(168, 230, 207, 0.4);
}

.sign-in-btn.signed {
  background: var(--color-cream-dark);
  color: var(--text-tertiary);
  box-shadow: none;
}

/* 积分展示 - 三栏 */
.points-display {
  display: flex;
  justify-content: space-around;
  position: relative;
}

.points-display::before {
  content: '';
  position: absolute;
  left: 33%;
  top: 10%;
  height: 80%;
  width: 1rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(189, 195, 199, 0.3) 50%, transparent 100%);
}

.points-display::after {
  content: '';
  position: absolute;
  right: 33%;
  top: 10%;
  height: 80%;
  width: 1rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(189, 195, 199, 0.3) 50%, transparent 100%);
}

.points-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.points-value {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

.points-value.available {
  background: linear-gradient(135deg, #A8E6CF 0%, #88D8C0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.points-value.frozen {
  color: var(--color-coral);
}

.points-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 登录区域 */
.login-section {
  text-align: center;
  padding: 40rpx 20rpx;
}

.login-illustration {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 32rpx;
  background: linear-gradient(135deg, var(--color-mint-light) 0%, var(--color-cream) 100%);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
}

.login-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
}

.login-btn {
  background: linear-gradient(135deg, #2D3436 0%, #636E72 100%);
  color: white;
  font-size: 30rpx;
  font-weight: 600;
  padding: 28rpx 80rpx;
  border-radius: var(--radius-full);
  box-shadow: 0 8rpx 32rpx rgba(45, 52, 54, 0.3);
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.wechat-icon {
  font-size: 36rpx;
}

/* ============================================
   发布求助入口 - 有机形状卡片
   ============================================ */
.publish-section {
  margin: 32rpx;
}

.publish-card {
  background: linear-gradient(135deg, #A8E6CF 0%, #88D8C0 50%, #7DD3C0 100%);
  border-radius: var(--radius-lg);
  padding: 48rpx 40rpx;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-glow);
}

/* 装饰性圆点 */
.publish-card::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-full);
}

.publish-card::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: -40rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-full);
}

.publish-content {
  position: relative;
  z-index: 1;
}

.publish-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.publish-icon {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.publish-title {
  font-size: 40rpx;
  font-weight: 800;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.publish-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.publish-features {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.feature-tag {
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  color: white;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.points-tip {
  margin-top: 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  background: rgba(255, 183, 178, 0.15);
  padding: 16rpx 24rpx;
  border-radius: var(--radius-full);
}

.points-tip .link {
  color: #FF6B6B;
  font-weight: 600;
}

/* ============================================
   附近任务区域
   ============================================ */
.nearby-section {
  margin: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #C7CEEA 0%, #A8B4E0 100%);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-more {
  font-size: 26rpx;
  color: #A8E6CF;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

/* 任务卡片列表 */
.need-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.need-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-md);
  padding: 32rpx;
  box-shadow: var(--shadow-soft);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  position: relative;
  overflow: hidden;
}

/* 左侧色条 */
.need-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  width: 6rpx;
  height: 60%;
  background: linear-gradient(180deg, #A8E6CF 0%, #88D8C0 100%);
  border-radius: 0 4rpx 4rpx 0;
}

.need-card.type-weather::before { background: linear-gradient(180deg, #74B9FF 0%, #0984E3 100%); }
.need-card.type-traffic::before { background: linear-gradient(180deg, #FDCB6E 0%, #E17055 100%); }
.need-card.type-shop::before { background: linear-gradient(180deg, #A29BFE 0%, #6C5CE7 100%); }
.need-card.type-parking::before { background: linear-gradient(180deg, #81ECEC 0%, #00CEC9 100%); }
.need-card.type-queue::before { background: linear-gradient(180deg, #FD79A8 0%, #E84393 100%); }

.need-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.need-type {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.type-icon {
  width: 44rpx;
  height: 44rpx;
  background: var(--color-mint-light);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.type-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.need-points {
  background: linear-gradient(135deg, #FFB7B2 0%, #FF9E99 100%);
  color: white;
  font-size: 24rpx;
  font-weight: 700;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  box-shadow: 0 2rpx 8rpx rgba(255, 183, 178, 0.3);
}

.need-content {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.need-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.need-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.meta-icon {
  font-size: 20rpx;
}

.need-status {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
}

.need-status.urgent {
  background: rgba(255, 183, 178, 0.2);
  color: #FF6B6B;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: var(--radius-md);
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 32rpx;
  background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-mint-light) 100%);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 未登录提示 */
.login-tip-card {
  background: rgba(255, 255, 255, 0.8);
  border-radius: var(--radius-md);
  padding: 48rpx;
  text-align: center;
  box-shadow: var(--shadow-soft);
}

.lock-icon {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 24rpx;
  background: linear-gradient(135deg, var(--color-cream-dark) 0%, var(--color-sand) 100%);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

/* 底部装饰 */
.bottom-decoration {
  height: 40rpx;
  background: linear-gradient(90deg, var(--color-mint) 0%, var(--color-coral) 50%, var(--color-lavender) 100%);
  opacity: 0.3;
  margin: 40rpx 32rpx;
  border-radius: var(--radius-full);
}

/* 加载中状态 */
.loading-card {
  text-align: center;
  padding: 80rpx 40rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: var(--radius-md);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(168, 230, 207, 0.3);
  border-top-color: #A8E6CF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 错误状态 */
.error-card {
  text-align: center;
  padding: 80rpx 40rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: var(--radius-md);
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}

.retry-btn {
  display: inline-block;
  background: #A8E6CF;
  color: white;
  font-size: 28rpx;
  padding: 20rpx 48rpx;
  border-radius: var(--radius-full);
  font-weight: 600;
}
