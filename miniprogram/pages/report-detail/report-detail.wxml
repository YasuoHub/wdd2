<!-- 举报详情 - 纯展示 -->
<view class="page-bg"></view>

<view class="container">
  <view wx:if="{{loading}}" class="loading-wrap">
    <text>加载中...</text>
  </view>

  <block wx:elif="{{detail}}">
    <!-- 举报信息 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">举报信息</text>
        <text class="inline-status status-{{detail.status}}">
          <text wx:if="{{detail.status === 'pending'}}">处理中</text>
          <text wx:elif="{{detail.status === 'cancelled'}}">已撤销</text>
          <text wx:elif="{{detail.status === 'resolved'}}">已处理</text>
        </text>
      </view>
      <view class="section-card">
        <view class="info-row">
          <text class="info-label">举报类型</text>
          <text class="info-value type-tag">{{detail.reportTypeLabel}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">举报理由</text>
          <text class="info-value">{{detail.reason}}</text>
        </view>
        <view wx:if="{{detail.images.length > 0}}" class="info-row">
          <text class="info-label">证据图片</text>
          <view class="image-gallery">
            <image
              wx:for="{{detail.images}}"
              wx:key="index"
              class="thumb"
              src="{{item}}"
              mode="aspectFill"
              data-url="{{item}}"
              bindtap="previewImage"
            />
          </view>
        </view>
      </view>
    </view>

    <!-- 查看关联任务 -->
    <view class="section">
      <view class="task-link-btn" bindtap="goToTask" hover-class="task-link-btn-hover">
        <text>查看关联任务</text>
        <text class="link-arrow">›</text>
      </view>
    </view>

    <!-- 时间信息 -->
    <view class="section">
      <view class="section-title">时间信息</view>
      <view class="section-card">
        <view class="info-row">
          <text class="info-label">提交时间</text>
          <text class="info-value">{{detail.createTimeText}}</text>
        </view>
        <view wx:if="{{detail.cancelTimeText}}" class="info-row">
          <text class="info-label">撤销时间</text>
          <text class="info-value">{{detail.cancelTimeText}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">更新时间</text>
          <text class="info-value">{{detail.updateTimeText}}</text>
        </view>
      </view>
    </view>
  </block>

  <view wx:else class="empty-wrap">
    <text>加载失败</text>
  </view>
</view>
