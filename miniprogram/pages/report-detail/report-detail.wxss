@import "../../styles/wdd-polish.wxss";

page {
  background: #f5f7fa;
}

.detail-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #f7f9fc 0%, #f5f7fa 42%, #f7f9fc 100%);
}

.loading-wrap,
.empty-wrap {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7e879b;
  font-size: 28rpx;
}

.section-card {
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 22rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(17, 24, 39, 0.04);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 34rpx rgba(31, 45, 61, 0.06);
}

.primary-card {
  padding-bottom: 26rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.card-title {
  display: block;
  color: #111827;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.35;
}

.status-pill {
  flex-shrink: 0;
  min-width: 104rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.2;
}

.status-pending {
  color: #1677d2;
  background: #eef5ff;
}

.status-cancelled {
  color: #6b7280;
  background: #f1f3f6;
}

.status-resolved {
  color: #15803d;
  background: #eaf8ef;
}

.info-line {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-top: 28rpx;
}

.info-line:first-of-type {
  margin-top: 0;
}

.info-label {
  width: 128rpx;
  flex-shrink: 0;
  color: #465066;
  font-size: 28rpx;
  line-height: 44rpx;
  white-space: nowrap;
}

.info-value {
  min-width: 0;
  flex: 1;
  color: #111827;
  font-size: 28rpx;
  line-height: 44rpx;
  word-break: break-word;
}

.type-pill,
.role-pill {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #1677d2;
  background: #eef5ff;
  font-size: 26rpx;
  line-height: 44rpx;
  box-sizing: border-box;
}

.desc-line {
  margin-top: 26rpx;
}

.desc-text {
  line-height: 46rpx;
}

.evidence-block {
  margin-top: 36rpx;
}

.evidence-title {
  display: block;
  margin-bottom: 18rpx;
  color: #465066;
  font-size: 28rpx;
  line-height: 1.4;
}

.evidence-grid {
  display: flex;
  gap: 16rpx;
}

.evidence-thumb {
  width: calc((100% - 32rpx) / 3);
  height: 156rpx;
  flex-shrink: 0;
  border-radius: 14rpx;
  background: #eef2f6;
}

.evidence-empty {
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  color: #9aa5b1;
  background: #f4f6f9;
  font-size: 26rpx;
}

.evidence-count {
  display: block;
  margin-top: 14rpx;
  color: #7e879b;
  font-size: 26rpx;
  line-height: 1.3;
}

.link-card {
  padding-top: 28rpx;
}

.card-hover {
  background: #f9fbff;
}

.task-row,
.target-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 22rpx;
}

.task-icon {
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
}

.task-main,
.target-main {
  min-width: 0;
  flex: 1;
}

.task-title {
  display: block;
  overflow: hidden;
  color: #111827;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 42rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 14rpx;
  min-width: 0;
}

.task-location {
  min-width: 0;
  overflow: hidden;
  color: #7e879b;
  font-size: 26rpx;
  line-height: 36rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-reward {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  flex-shrink: 0;
}

.reward-label {
  color: #7e879b;
  font-size: 24rpx;
}

.reward-value {
  color: #fa541c;
  font-size: 30rpx;
  font-weight: 500;
}

.target-avatar {
  width: 76rpx;
  height: 76rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #eef2f6;
}

.target-name-line {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.target-name {
  max-width: 320rpx;
  overflow: hidden;
  color: #111827;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 40rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.credit-text {
  display: block;
  margin-top: 8rpx;
  color: #7e879b;
  font-size: 26rpx;
  line-height: 34rpx;
}

.time-card {
  margin-bottom: 0;
}

.time-list {
  margin-top: 24rpx;
}

.time-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 10rpx 0;
}

.time-label {
  flex-shrink: 0;
  color: #465066;
  font-size: 28rpx;
  line-height: 40rpx;
}

.time-value {
  min-width: 0;
  color: #334155;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: right;
  word-break: break-word;
}

.time-state {
  color: #1677d2;
}

.notice-box {
  margin-top: 28rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid #d8e8ff;
  border-radius: 14rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #f3f8ff 100%);
}

.notice-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.notice-title {
  color: #1677d2;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 36rpx;
}

.notice-text {
  display: block;
  color: #334155;
  font-size: 26rpx;
  line-height: 40rpx;
}
