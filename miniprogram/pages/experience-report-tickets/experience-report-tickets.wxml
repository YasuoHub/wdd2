<view class="experience-page admin-ticket-page">
  <view class="tab-bar">
    <view class="tab-item {{status === 'pending' ? 'active' : ''}}" data-status="pending" bindtap="switchStatus">
      <text>待处理</text>
    </view>
    <view class="tab-item {{status === 'resolved' ? 'active' : ''}}" data-status="resolved" bindtap="switchStatus">
      <text>已处理</text>
    </view>
  </view>

  <view wx:if="{{list.length === 0 && !loading}}" class="empty-state">暂无举报工单</view>
  <view class="ticket-list">
    <view wx:for="{{list}}" wx:key="_id" class="ticket-card {{item.status === 'resolved' ? 'resolved' : ''}}" data-id="{{item.experience_id}}" bindtap="goDetail">
      <view class="card-left left-report"></view>
      <view class="card-body">
        <view class="card-title-row">
          <wdd-icon name="flag" color="#d64545" size="28"></wdd-icon>
          <text class="card-title">{{item.title_snapshot}}</text>
          <view class="status-tag {{item.status === 'resolved' ? 'status-resolved' : 'status-pending'}}">{{item.status === 'resolved' ? '已处理' : '待处理'}}</view>
        </view>
        <view class="card-info-row">
          <text class="info-label">累计举报</text>
          <text class="info-value">{{item.total_count || 0}}</text>
        </view>
        <view class="card-info-row">
          <text class="info-label">本轮待处理</text>
          <text class="info-value">{{item.pending_count || 0}}</text>
        </view>
        <view class="card-footer">
          <view class="footer-time">
            <wdd-icon name="clock-3" color="#9AA5B1" size="22"></wdd-icon>
            <text>{{item.status === 'resolved' ? '已完成处理' : '等待客服处理'}}</text>
          </view>
          <text class="supplement-tag">{{item.status === 'resolved' ? (item.result === 'down' ? '下架' : '不予处理') : '待核查'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
