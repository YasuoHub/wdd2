<page-meta page-style="{{showPreview ? 'overflow: hidden;' : ''}}" />
<view class="experience-page experience-edit-page">
  <view wx:if="{{loading}}" class="empty-state">正在根据任务内容整理经验草稿...</view>
  <block wx:else>
    <view wx:if="{{status === 'pending_confirmation'}}" class="status-note">
      已提交帮助者确认。在帮助者处理前，你仍可修改并提交最新内容；48小时截止时间不会改变。
    </view>
    <view wx:elif="{{!editable}}" class="status-note">该经验已处理，当前内容不能再修改。</view>

    <view class="task-context-panel">
      <view class="task-type-pill">
        <wdd-icon name="{{task.typeIcon}}" color="var(--brand-primary)" size="26"></wdd-icon>
        <text>{{task.typeName}}</text>
      </view>
      <view class="task-context-desc">{{task.description || '暂无任务描述'}}</view>
      <view class="task-context-location">
        <wdd-icon name="map-pin" color="#667085" size="24"></wdd-icon>
        <text>{{task.locationName || '任务地点'}}</text>
      </view>
    </view>

    <view class="form-section edit-form-section">
      <view class="field-group compact-group">
        <view class="label-row">
          <view class="field-label required-label"><text>公开标题</text><text class="required-star">*</text></view>
        </view>
        <input class="field-input edit-input" disabled="{{!editable}}" maxlength="50" value="{{form.title}}" data-field="title" bindinput="onFieldInput" />
      </view>

      <view class="field-group compact-group">
        <view class="label-row">
          <view class="field-label required-label"><text>公开地点</text><text class="required-star">*</text></view>
        </view>
        <view class="location-editor">
          <input class="field-input edit-input location-input" disabled="{{!editable}}" maxlength="80" value="{{form.publicLocation}}" data-field="publicLocation" bindinput="onFieldInput" />
          <button class="location-pick-btn" disabled="{{!editable}}" bindtap="choosePublicLocation">
            <wdd-icon name="map-pinned" color="var(--brand-primary)" size="26"></wdd-icon>
            <text>选择</text>
          </button>
        </view>
      </view>

      <view class="field-group compact-group">
        <view class="label-row">
          <view class="field-label required-label"><text>公开描述</text><text class="required-star">*</text></view>
        </view>
        <textarea class="field-textarea edit-textarea compact-textarea" disabled="{{!editable}}" maxlength="300" value="{{form.question}}" data-field="question" bindinput="onFieldInput" />
      </view>

      <view class="field-group compact-group">
        <view class="label-row">
          <view class="field-label required-label"><text>任务结果</text><text class="required-star">*</text></view>
        </view>
        <textarea class="field-textarea edit-textarea compact-textarea" disabled="{{!editable}}" maxlength="1000" value="{{form.result}}" data-field="result" bindinput="onFieldInput" />
      </view>

      <view class="field-group compact-group">
        <view class="label-row">
          <view class="field-label required-label"><text>信息有效期</text><text class="required-star">*</text></view>
        </view>
        <picker disabled="{{!editable}}" mode="selector" range="{{freshnessOptions}}" value="{{freshnessIndex}}" bindchange="onFreshnessChange">
          <view class="picker-field {{form.freshness ? '' : 'placeholder'}}">
            <text>{{form.freshness || '请选择有效期'}}</text>
            <wdd-icon name="chevron-down" color="#667085" size="24"></wdd-icon>
          </view>
        </picker>
      </view>

      <view class="field-group compact-group last-group">
        <view class="label-row">
          <text class="field-label">注意事项</text>
        </view>
        <textarea class="field-textarea edit-textarea compact-textarea" disabled="{{!editable}}" maxlength="500" value="{{form.tips}}" data-field="tips" bindinput="onFieldInput" />
      </view>
    </view>

    <view wx:if="{{availableImages.length > 0}}" class="form-section edit-form-section">
      <text class="section-title">选择允许公开的图片</text>
      <view class="image-grid">
        <view wx:for="{{availableImages}}" wx:key="url" class="selectable-image {{item.selected ? 'selected' : ''}}" data-url="{{item.url}}" bindtap="toggleImage">
          <image src="{{item.url}}" mode="aspectFill" />
          <view wx:if="{{item.selected}}" class="select-mark">✓</view>
        </view>
      </view>
    </view>

    <view class="fixed-actions" wx:if="{{editable}}">
      <button wx:if="{{submittedOnce}}" class="danger-button" bindtap="cancelShare">取消分享</button>
      <button class="primary-button" loading="{{saving}}" bindtap="submit">提交</button>
    </view>
  </block>
</view>
<view wx:if="{{showPreview}}" class="report-mask" bindtap="closePreview"></view>
<view wx:if="{{showPreview}}" class="report-dialog">
  <text class="section-title">发布前预览</text>
  <view class="preview-block">
    <text class="experience-title">{{form.title}}</text>
    <view class="experience-location">地点：{{form.publicLocation}}</view>
    <view class="experience-meta">类型：{{task.typeName}} · {{form.freshness}}</view>
  </view>
  <view class="preview-block">
    <text class="field-label">公开描述</text>
    <text class="detail-value">{{form.question}}</text>
  </view>
  <view class="preview-block">
    <text class="field-label">任务结果</text>
    <text class="detail-value">{{form.result}}</text>
  </view>
  <view wx:if="{{form.tips}}" class="preview-block">
    <text class="field-label">注意事项</text>
    <text class="detail-value">{{form.tips}}</text>
  </view>
  <view wx:if="{{selectedImages.length > 0}}" class="preview-block">
    <text class="field-label">公开图片</text>
    <view class="detail-image-grid">
      <view wx:for="{{selectedImages}}" wx:key="*this" class="detail-image-wrap">
        <image class="detail-image" src="{{item}}" mode="aspectFill" />
      </view>
    </view>
  </view>
  <view class="report-actions">
    <button class="secondary-button" bindtap="closePreview">再改改</button>
    <button class="primary-button" loading="{{saving}}" bindtap="confirmSubmit">确认提交</button>
  </view>
</view>
