@import "../../styles/experience.wxss";

.experience-edit-page {
  padding-top: 22rpx;
}

.task-context-panel,
.edit-form-section {
  margin-bottom: 42rpx;
  border: 1rpx solid #e1e8f0;
  border-radius: 14rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.task-context-panel {
  padding: 24rpx 26rpx;
}

.task-type-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  max-width: 100%;
  min-height: 50rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: var(--brand-primary);
  background: var(--brand-primary-08);
  font-size: 25rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.task-context-desc {
  margin-top: 18rpx;
  color: #111827;
  font-size: 30rpx;
  line-height: 1.5;
  font-weight: 600;
}

.task-context-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 14rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.4;
}

.task-context-location text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.edit-form-section {
  padding: 26rpx;
}

.compact-group {
  margin-bottom: 24rpx;
}

.last-group {
  margin-bottom: 0;
}

.label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 12rpx;
}

.label-row .field-label {
  margin-bottom: 0;
}

.required-label {
  display: inline-flex;
  align-items: baseline;
  gap: 4rpx;
}

.required-star {
  color: #e5484d;
  font-size: 28rpx;
  line-height: 1;
}

.edit-input,
.picker-field {
  height: 72rpx;
  border-radius: 10rpx;
  background: #f9fbfd;
}

.edit-input {
  min-height: 72rpx;
  padding: 0 20rpx;
  line-height: 72rpx;
  box-sizing: border-box;
}

.location-editor {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.location-input {
  flex: 1;
  min-width: 0;
}

.location-pick-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 136rpx;
  gap: 6rpx;
  width: 136rpx;
  height: 72rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(22, 119, 210, 0.24);
  border-radius: 10rpx;
  color: var(--brand-primary);
  background: #ffffff;
  font-size: 26rpx;
  line-height: 72rpx;
  box-sizing: border-box;
}

.location-pick-btn::after {
  border: 0;
}

.location-pick-btn[disabled] {
  color: #98a2b3;
  border-color: #e1e8f0;
  background: #f5f7fa;
}

.edit-textarea {
  min-height: 118rpx;
  padding: 14rpx 20rpx;
  border-radius: 10rpx;
  background: #f9fbfd;
  line-height: 1.45;
  box-sizing: border-box;
}

.compact-textarea {
  height: 124rpx;
}

.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  border: 1rpx solid #d8e1eb;
  color: #111827;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-field.placeholder {
  color: #98a2b3;
}

@media screen and (max-width: 350px) {
  .edit-form-section,
  .task-context-panel {
    padding-right: 22rpx;
    padding-left: 22rpx;
  }

  .location-editor {
    gap: 10rpx;
  }

  .location-pick-btn {
    flex-basis: 118rpx;
    width: 118rpx;
    font-size: 24rpx;
  }
}
