<page-meta page-style="{{showReport ? 'overflow: hidden;' : ''}}" />
<view class="experience-page">
  <view wx:if="{{loading}}" class="empty-state">加载中...</view>
  <block wx:elif="{{experience}}">
    <view class="detail-section">
      <text class="experience-title">{{experience.title}}</text>
      <view class="experience-location">地点：{{experience.publicLocation}}</view>
      <view class="experience-meta">有用 {{experience.usefulCount}} · {{experience.freshness || '时效请自行判断'}}</view>
    </view>
    <view class="detail-section">
      <text class="section-title">当时的问题</text>
      <text class="detail-value">{{experience.question}}</text>
    </view>
    <view class="detail-section">
      <text class="section-title">实际结果</text>
      <text class="detail-value">{{experience.result}}</text>
    </view>
    <view wx:if="{{experience.applicableTime || experience.tips}}" class="detail-section">
      <block wx:if="{{experience.applicableTime}}">
        <text class="section-title">适用时间</text>
        <text class="detail-value">{{experience.applicableTime}}</text>
      </block>
      <block wx:if="{{experience.tips}}">
        <text class="section-title" style="margin-top: 24rpx;">注意事项</text>
        <text class="detail-value">{{experience.tips}}</text>
      </block>
    </view>
    <view wx:if="{{experience.images.length > 0}}" class="detail-section">
      <text class="section-title">现场图片</text>
      <view class="detail-image-grid">
        <view wx:for="{{experience.images}}" wx:key="*this" class="detail-image-wrap">
          <image class="detail-image" src="{{item}}" mode="aspectFill" data-url="{{item}}" bindtap="previewImage" />
        </view>
      </view>
    </view>

    <view class="card-actions">
      <view wx:if="{{experience.canReport}}" class="inline-action danger" bindtap="openReport">举报</view>
      <view wx:if="{{!experience.isParticipant}}" class="inline-action" bindtap="toggleLike">{{experience.isLiked ? '取消有用' : '有用'}} {{experience.usefulCount}}</view>
    </view>
  </block>
</view>

<view wx:if="{{showReport}}" class="report-mask" bindtap="closeReport"></view>
<view wx:if="{{showReport}}" class="report-dialog">
  <text class="section-title">举报经验</text>
  <textarea class="field-textarea" maxlength="300" value="{{reportDescription}}" placeholder="可选：补充举报说明" bindinput="onReportInput" />
  <view class="report-actions">
    <button class="secondary-button" bindtap="closeReport">取消</button>
    <button class="primary-button" loading="{{reporting}}" bindtap="submitReport">提交举报</button>
  </view>
</view>
