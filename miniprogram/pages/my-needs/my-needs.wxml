<!-- 我的求助列表页面 -->
<view class="container">
  <!-- 状态筛选标签 -->
  <view class="filter-tabs">
    <view
      class="tab {{currentFilter === 'all' ? 'active' : ''}}"
      bindtap="switchFilter"
      data-filter="all"
    >
      全部
    </view>
    <view
      class="tab {{currentFilter === 'ongoing' ? 'active' : ''}}"
      bindtap="switchFilter"
      data-filter="ongoing"
    >
      进行中
    </view>
    <view
      class="tab {{currentFilter === 'completed' ? 'active' : ''}}"
      bindtap="switchFilter"
      data-filter="completed"
    >
      已完成
    </view>
    <view
      class="tab {{currentFilter === 'cancelled' ? 'active' : ''}}"
      bindtap="switchFilter"
      data-filter="cancelled"
    >
      已取消
    </view>
  </view>

  <!-- 任务列表 -->
  <scroll-view class="task-list" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="loadMore">
    <empty wx:if="{{needs.length === 0}}" type="normal" icon="📝" title="暂无{{filterText}}任务" desc="去发布页发布你的第一个求助吧" showBtn="true" btnText="去发布" btnType="primary" bind:btnTap="goToPublish"></empty>

    <view wx:else class="need-list">
      <view
        wx:for="{{needs}}"
        wx:key="_id"
        class="need-card"
        bindtap="goToDetail"
        data-id="{{item._id}}"
      >
        <!-- 卡片头部 -->
        <view class="card-header">
          <view class="type-tag" style="background: {{item.bgColor}}; color: {{item.color}};">
            <text class="type-icon">{{item.typeIcon}}</text>
            <text>{{item.typeName}}</text>
          </view>
          <view class="status-badge {{item.status}}">{{item.statusText}}</view>
        </view>

        <!-- 任务内容 -->
        <view class="card-content">
          <text class="description">{{item.description}}</text>
        </view>

        <!-- 位置信息 -->
        <view class="location-info">
          <text class="location-icon">📍</text>
          <text class="location-name">{{item.locationName}}</text>
        </view>

        <!-- 卡片底部 -->
        <view class="card-footer">
          <view class="meta-left">
            <view class="points-tag">{{item.points}}积分</view>
            <!-- 只有待匹配状态才显示剩余时间 -->
            <view wx:if="{{item.status === 'pending'}}" class="countdown">
              剩余{{item.remainTime}}
            </view>
          </view>
          <view class="time-text">{{item.createTime}}</view>
        </view>

        <!-- 操作按钮 -->
        <view wx:if="{{item.status === 'ongoing' || item.status === 'pending'}}" class="card-actions">
          <view wx:if="{{item.status === 'ongoing'}}" class="action-btn primary" catchtap="goToChat" data-id="{{item._id}}">
            进入聊天
          </view>
          <view wx:if="{{item.status === 'ongoing'}}" class="action-btn success" catchtap="completeNeed" data-id="{{item._id}}">
            完成任务
          </view>
          <!-- 只有待匹配状态才能取消 -->
          <view wx:if="{{item.status === 'pending'}}" class="action-btn danger" catchtap="cancelNeed" data-id="{{item._id}}" data-status="{{item.status}}">
            取消任务
          </view>
        </view>

        <!-- 已完成任务按钮 -->
        <view wx:if="{{item.status === 'completed'}}" class="card-actions">
          <view class="action-btn primary" catchtap="goToChat" data-id="{{item._id}}">
            查看聊天
          </view>
          <!-- 未评价显示去评价，已评价显示查看评价 -->
          <view wx:if="{{!item.hasRated}}" class="action-btn success" catchtap="goToRate" data-id="{{item._id}}">
            去评价
          </view>
          <view wx:else class="action-btn" catchtap="viewRating" data-id="{{item._id}}">
            查看评价
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{hasMore}}" class="load-more">
        <text>加载更多...</text>
      </view>
    </view>
  </scroll-view>
</view>
