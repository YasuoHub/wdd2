<!-- 我的求助列表页：求助人视角 -->
<wxs src="../../utils/money.wxs" module="money" />
<view class="container">
  <view class="filter-tabs">
    <view class="tab {{currentFilter === 'all' ? 'active' : ''}}" bindtap="switchFilter" data-filter="all">全部</view>
    <view class="tab {{currentFilter === 'ongoing' ? 'active' : ''}}" bindtap="switchFilter" data-filter="ongoing">进行中</view>
    <view class="tab {{currentFilter === 'completed' ? 'active' : ''}}" bindtap="switchFilter" data-filter="completed">已完成</view>
    <view class="tab {{currentFilter === 'breaking' ? 'active' : ''}}" bindtap="switchFilter" data-filter="breaking">审核中</view>
    <view class="tab {{currentFilter === 'cancelled' ? 'active' : ''}}" bindtap="switchFilter" data-filter="cancelled">已取消</view>
  </view>

  <scroll-view class="task-scroll" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="loadMore">
    <empty
      wx:if="{{needs.length === 0}}"
      type="normal"
      icon="notebook-pen"
      title="暂无{{filterText}}任务"
      desc="去发布页发布你的第一个求助吧"
      showBtn="true"
      btnText="去发布"
      btnType="primary"
      bind:btnTap="goToPublish"
    ></empty>

    <view wx:else class="card-list">
      <view
        wx:for="{{needs}}"
        wx:key="_id"
        class="record-card status-{{item.status}}"
        bindtap="goToDetail"
        data-id="{{item._id}}"
      >
        <view class="amount"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(item.displayAmount)}}</text></view>

        <view class="card-main">
          <view class="status-row">
            <view class="status-badge {{item.status}}">{{item.statusText}}</view>
          </view>

          <view class="title">{{item.description}}</view>

          <view class="type-row">
            <view class="type-tag">{{item.typeName}}</view>
            <text class="publish-time">发布时间</text>
            <text class="publish-time">{{item.publishTime}}</text>
          </view>

          <view class="info-row">
            <wdd-icon name="map-pin" color="#5F6975" size="24"></wdd-icon>
            <text class="info-text">{{item.locationName}}</text>
          </view>

          <view wx:if="{{item.status === 'ongoing'}}" class="info-row">
            <wdd-icon name="user-round" color="#5F6975" size="24"></wdd-icon>
            <text class="info-text">帮助者：{{item.takerNickname || '当地帮助者'}} · 接单 {{item.takerTimeText}}</text>
          </view>

          <view wx:elif="{{item.status === 'pending'}}" class="info-row">
            <wdd-icon name="clock-3" color="#5F6975" size="24"></wdd-icon>
            <text class="info-text">剩余 {{item.remainTime || '等待匹配'}}</text>
          </view>

          <view wx:elif="{{item.status === 'completed'}}" class="info-row success-row">
            <wdd-icon name="circle-check" color="#25A94F" size="24"></wdd-icon>
            <text class="info-text">已完成 · 完成时间 {{item.endTimeText}}</text>
          </view>

          <view wx:elif="{{item.status === 'cancelled'}}" class="info-row">
            <wdd-icon name="clock-3" color="#5F6975" size="24"></wdd-icon>
            <text class="info-text">已取消 · 取消时间 {{item.endTimeText}}</text>
          </view>

          <view wx:if="{{item.status === 'breaking'}}" class="notice warning">
            <wdd-icon name="circle-alert" color="#F27600" size="24"></wdd-icon>
            <text>审核中，暂不可操作</text>
          </view>
        </view>

        <view wx:if="{{item.status === 'ongoing'}}" class="card-actions">
          <view class="action-btn outline" catchtap="goToChat" data-id="{{item._id}}">进入聊天</view>
          <view class="action-btn primary" catchtap="completeNeed" data-id="{{item._id}}">确认完成</view>
        </view>

        <view wx:elif="{{item.status === 'pending'}}" class="card-actions right">
          <view class="action-btn outline" catchtap="cancelNeed" data-id="{{item._id}}" data-status="{{item.status}}">取消任务</view>
        </view>

        <view wx:elif="{{item.status === 'completed'}}" class="card-actions right">
          <view wx:if="{{item.showAppealBtn}}" class="action-btn outline" catchtap="goToAppeal" data-id="{{item._id}}">申诉</view>
          <view wx:if="{{!item.hasRated}}" class="action-btn outline" catchtap="goToRate" data-id="{{item._id}}">去评价</view>
          <view wx:else class="action-btn outline" catchtap="viewRating" data-id="{{item._id}}">查看评价</view>
        </view>

        <view wx:elif="{{item.status === 'cancelled' && item.showAppealBtn}}" class="card-actions right">
          <view class="action-btn outline" catchtap="goToAppeal" data-id="{{item._id}}">申诉</view>
        </view>
      </view>

      <view wx:if="{{hasMore}}" class="load-more">加载更多...</view>
    </view>
  </scroll-view>
</view>
