/* ============================================
   问当地 - 我的求助 - 天蓝色青春活力风格
   ============================================ */

page {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
}

.container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F8FF 0%, #E6F3FF 30%, #EDF7FF 70%, #F5FAFF 100%);
  box-sizing: border-box;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  padding: 28rpx 24rpx;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.9);
  position: sticky;
  top: 0;
  z-index: 10;
  backdrop-filter: blur(20rpx);
  border-bottom: 2rpx solid rgba(93, 184, 230, 0.06);
  box-sizing: border-box;
}

.tab {
  flex: 1;
  min-width: 0;
  text-align: center;
  padding: 16rpx 8rpx;
  font-size: 26rpx;
  color: #6B8BA4;
  background: rgba(240, 248, 255, 0.8);
  border-radius: 9999rpx;
  transition: all 0.3s;
  font-weight: 500;
  border: 2rpx solid rgba(93, 184, 230, 0.1);
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tab.active {
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  color: white;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.3);
}

/* 任务列表 */
.task-list {
  width: 100%;
  height: calc(100vh - 116rpx);
  box-sizing: border-box;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, #E6F3FF 0%, #D4EDF7 50%, #C4E5F5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 88rpx;
  box-shadow: 0 6rpx 30rpx rgba(93, 184, 230, 0.15);
  flex-shrink: 0;
}

.empty-text {
  font-size: 34rpx;
  color: #2C3E50;
  margin-bottom: 12rpx;
  font-weight: 700;
  text-align: center;
  word-break: break-all;
}

.empty-hint {
  font-size: 26rpx;
  color: #8FA8B8;
  margin-bottom: 40rpx;
  text-align: center;
  word-break: break-all;
}

.empty-btn {
  padding: 28rpx 72rpx;
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  color: white;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 9999rpx;
  box-shadow: 0 6rpx 24rpx rgba(93, 184, 230, 0.35);
  transition: all 0.3s;
  flex-shrink: 0;
}

.empty-btn:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(93, 184, 230, 0.25);
}

/* 任务卡片列表 */
.need-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.need-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 36rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
  position: relative;
  overflow: hidden;
  transition: all 0.3s;
  box-sizing: border-box;
}

.need-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 28rpx rgba(93, 184, 230, 0.15);
}

/* 左侧天蓝色装饰 */
.need-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  width: 6rpx;
  height: 60%;
  background: linear-gradient(180deg, #5DB8E6 0%, #7EC8E8 100%);
  border-radius: 0 4rpx 4rpx 0;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 16rpx;
  min-width: 0;
}

.type-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 600;
  background: rgba(93, 184, 230, 0.1);
  color: #5DB8E6;
  flex-shrink: 0;
  max-width: 60%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.type-icon {
  font-size: 26rpx;
  flex-shrink: 0;
}

.status-badge {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 9999rpx;
  font-weight: 500;
  flex-shrink: 0;
  white-space: nowrap;
  box-sizing: border-box;
}

.status-badge.pending {
  background: rgba(255, 209, 102, 0.15);
  color: #E6A23C;
}

.status-badge.ongoing {
  background: rgba(93, 184, 230, 0.12);
  color: #3A9AD2;
}

.status-badge.completed {
  background: rgba(109, 213, 176, 0.12);
  color: #4DB895;
}

.status-badge.cancelled {
  background: rgba(255, 140, 105, 0.1);
  color: #E86A4A;
}

/* 卡片内容 */
.card-content {
  margin-bottom: 16rpx;
  width: 100%;
  min-width: 0;
}

.description {
  font-size: 28rpx;
  color: #2C3E50;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
  word-wrap: break-word;
}

/* 位置信息 */
.location-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding: 12rpx 16rpx;
  background: rgba(240, 248, 255, 0.6);
  border-radius: 16rpx;
  width: 100%;
  box-sizing: border-box;
  min-width: 0;
}

.location-icon {
  font-size: 24rpx;
  color: #5DB8E6;
  flex-shrink: 0;
}

.location-name {
  font-size: 26rpx;
  color: #6B8BA4;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(93, 184, 230, 0.06);
  gap: 16rpx;
  min-width: 0;
}

.meta-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  flex: 1;
  overflow: hidden;
}

.points-tag {
  background: linear-gradient(135deg, #FF8C69 0%, #FF9A8B 100%);
  color: white;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 18rpx;
  border-radius: 9999rpx;
  box-shadow: 0 2rpx 10rpx rgba(255, 140, 105, 0.25);
  flex-shrink: 0;
  white-space: nowrap;
  box-sizing: border-box;
}

.countdown {
  font-size: 22rpx;
  color: #FF8C69;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
}

.time-text {
  font-size: 22rpx;
  color: #A8C4D4;
  flex-shrink: 0;
  white-space: nowrap;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.action-btn {
  flex: 1;
  min-width: 0;
  text-align: center;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.3s;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.action-btn.primary {
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.3);
}

.action-btn.primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(93, 184, 230, 0.2);
}

.action-btn.danger {
  background: rgba(255, 140, 105, 0.1);
  color: #E86A4A;
}

.action-btn.danger:active {
  background: rgba(255, 140, 105, 0.15);
}

.action-btn.success {
  background: linear-gradient(135deg, #6DD5B0 0%, #88D8A3 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(109, 213, 176, 0.3);
}

.action-btn.success:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(109, 213, 176, 0.2);
}

/* 查看评价按钮 - 灰色默认样式 */
.action-btn:not(.primary):not(.danger):not(.success) {
  background: rgba(168, 196, 212, 0.15);
  color: #6B8BA4;
}

.action-btn:not(.primary):not(.danger):not(.success):active {
  background: rgba(168, 196, 212, 0.25);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: #A8C4D4;
  width: 100%;
  box-sizing: border-box;
}
