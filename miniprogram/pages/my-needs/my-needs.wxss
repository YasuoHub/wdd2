/* ============================================
   问当地 - 我的求助 - 城市服务清爽可信风格
   ============================================ */

page {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
}

.container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 30%, var(--bg-tertiary) 70%, #F5FAFF 100%);
  box-sizing: border-box;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  padding: 28rpx 24rpx;
  gap: 12rpx;
  background: var(--bg-card);
  position: sticky;
  top: 0;
  z-index: 10;
  backdrop-filter: blur(20rpx);
  border-bottom: 2rpx solid rgba(22, 119, 210, 0.06);
  box-sizing: border-box;
}

.tab {
  flex: 1;
  min-width: 0;
  text-align: center;
  padding: 16rpx 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: rgba(240, 248, 255, 0.8);
  border-radius: var(--radius-full);
  transition: all 0.3s;
  font-weight: 500;
  border: 2rpx solid rgba(22, 119, 210, 0.1);
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tab.active {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  color: white;
  font-weight: 600;
  box-shadow: var(--shadow-sky);
}

/* 任务列表 */
.task-list {
  width: 100%;
  height: calc(100vh - 116rpx);
  box-sizing: border-box;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, var(--bg-secondary) 0%, #EEF7FD 50%, #C4E5F5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 88rpx;
  box-shadow: 0 6rpx 30rpx rgba(22, 119, 210, 0.15);
  flex-shrink: 0;
}

.empty-text {
  font-size: 34rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  font-weight: 700;
  text-align: center;
  word-break: break-all;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 40rpx;
  text-align: center;
  word-break: break-all;
}

.empty-btn {
  padding: 28rpx 72rpx;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  color: white;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  box-shadow: 0 6rpx 24rpx rgba(22, 119, 210, 0.35);
  transition: all 0.3s;
  flex-shrink: 0;
}

.empty-btn:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(22, 119, 210, 0.25);
}

/* 任务卡片列表 */
.need-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.need-card {
  width: 100%;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid rgba(22, 119, 210, 0.08);
  position: relative;
  overflow: hidden;
  transition: all 0.3s;
  box-sizing: border-box;
}

.need-card:active {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-md);
}

/* 左侧天蓝色装饰 */
.need-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  width: 6rpx;
  height: 60%;
  background: linear-gradient(180deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  border-radius: 0 4rpx 4rpx 0;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 16rpx;
  min-width: 0;
}

.type-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 600;
  background: rgba(22, 119, 210, 0.1);
  color: var(--sky-primary);
  flex-shrink: 0;
  max-width: 60%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.type-icon {
  font-size: 26rpx;
  flex-shrink: 0;
}

.status-badge {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
  flex-shrink: 0;
  white-space: nowrap;
  box-sizing: border-box;
}

.status-badge.pending {
  background: rgba(255, 209, 102, 0.15);
  color: #E6A23C;
}

.status-badge.ongoing {
  background: rgba(22, 119, 210, 0.12);
  color: #0F66BD;
}

.status-badge.completed {
  background: rgba(31, 143, 122, 0.12);
  color: #4DB895;
}

.status-badge.cancelled {
  background: rgba(217, 106, 34, 0.1);
  color: #E86A4A;
}

.status-badge.breaking {
  background: rgba(255, 193, 7, 0.12);
  color: #C7910B;
}

/* 卡片内容 */
.card-content {
  margin-bottom: 16rpx;
  width: 100%;
  min-width: 0;
}

.description {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
  word-wrap: break-word;
}

/* 位置信息 */
.location-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding: 12rpx 16rpx;
  background: var(--bg-glass);
  border-radius: var(--radius-sm);
  width: 100%;
  box-sizing: border-box;
  min-width: 0;
}

.location-icon {
  font-size: 24rpx;
  color: var(--sky-primary);
  flex-shrink: 0;
}

.location-name {
  font-size: 26rpx;
  color: var(--text-tertiary);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--border-light);
  gap: 16rpx;
  min-width: 0;
}

.meta-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  flex: 1;
  overflow: hidden;
}

.points-tag {
  background: linear-gradient(135deg, var(--vitality-orange) 0%, var(--vitality-coral) 100%);
  color: white;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 18rpx;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-orange);
  flex-shrink: 0;
  white-space: nowrap;
  box-sizing: border-box;
}

.countdown {
  font-size: 22rpx;
  color: var(--vitality-orange);
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
}

.time-text {
  font-size: 22rpx;
  color: var(--text-light);
  flex-shrink: 0;
  white-space: nowrap;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.action-btn {
  flex: 1;
  min-width: 0;
  text-align: center;
  padding: 20rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.3s;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  color: white;
  box-shadow: var(--shadow-sky);
}

.action-btn.primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(22, 119, 210, 0.2);
}

.action-btn.danger {
  background: rgba(217, 106, 34, 0.1);
  color: var(--danger-color);
}

.action-btn.danger:active {
  background: rgba(217, 106, 34, 0.15);
}

.action-btn.success {
  background: linear-gradient(135deg, var(--fresh-mint) 0%, var(--fresh-green) 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(31, 143, 122, 0.3);
}

.action-btn.success:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(31, 143, 122, 0.2);
}

/* 查看评价按钮 - 灰色默认样式 */
.action-btn:not(.primary):not(.danger):not(.success) {
  background: rgba(168, 196, 212, 0.15);
  color: var(--text-tertiary);
}

.action-btn:not(.primary):not(.danger):not(.success):active {
  background: rgba(168, 196, 212, 0.25);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: var(--text-light);
  width: 100%;
  box-sizing: border-box;
}
/* ============================================
   城市服务风格视觉覆盖：清爽可信、交易清楚、低装饰
   ============================================ */
.container,
.chat-container {
  background: #f5f7fa;
}

.header,
.footer,
.input-area,
.popup-content,
.modal-content,
.rules-modal-content {
  background: #ffffff;
  border-color: var(--border-light);
  box-shadow: var(--shadow-card);
}

.section-card,
.task-card,
.user-card,
.menu-list,
.quick-panel,
.need-feed,
.login-tip-card,
.balance-section,
.record-card,
.ticket-card,
.report-card,
.appeal-card,
.profile-card,
.rating-card,
.info-card,
.form-card,
.stat-card,
.card {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.location-bar,
.filter-item,
.sort-section,
.distance-section,
.type-badge,
.card-location,
.distance-tag,
.quick-tag,
.type-item,
.time-option,
.quick-point,
.quick-amount,
.payment-option,
.amount-detail,
.rules-tip,
.points-tip-wrapper,
.input-wrapper,
.toolbar-toggle-btn,
.more-btn,
.system-message-text,
.time-divider text {
  background: #f8fafc;
  border-color: var(--border-light);
  box-shadow: none;
}

.filter-item.active,
.type-item.active,
.quick-tag.active,
.time-option.active,
.payment-option.active {
  background: rgba(22, 119, 210, 0.08);
  border-color: rgba(22, 119, 210, 0.34);
  box-shadow: none;
}

.filter-item.active .filter-name,
.quick-tag.active,
.time-option.active,
.payment-option.active .payment-name {
  color: var(--sky-deep);
  font-weight: 600;
}

.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.amount-badge,
.quick-amount.active,
.quick-point.active,
.time-recommend,
.btn-vitality {
  background: var(--vitality-orange);
  box-shadow: var(--shadow-orange);
}

.balance-value.points,
.balance-value.available,
.points-number,
.publish-points,
.publish-amount {
  color: var(--text-primary);
  background: none;
  -webkit-text-fill-color: currentColor;
}

.wdd-amount,
.need-amount,
.amount-current,
.amount-symbol,
.detail-value.fee,
.warning-text,
.balance-value.insufficient,
.task-points-mini {
  color: var(--vitality-orange);
}

.detail-value.income,
.tag-mint,
.status-success,
.success-text {
  color: var(--fresh-mint);
}

.message-item.other .message-bubble.text {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-sm);
}

.message-item.self .message-bubble.text {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.popup-overlay,
.modal-mask,
.rules-modal {
  background: rgba(15, 23, 42, 0.46);
}

.helper-profile-tip,
.balance-insufficient,
.task-ended-bar.breaking-bar {
  background: #fff8e6;
  border-color: rgba(233, 185, 73, 0.34);
}

image,
button,
view {
  letter-spacing: 0;
}
/* 城市服务按钮对比修正 */
.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  color: #ffffff;
}

.publish-btn.disabled,
.send-btn[disabled],
.disabled {
  color: var(--text-muted);
}