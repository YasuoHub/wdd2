@import "../../styles/wdd-polish.wxss";

page {
  width: 100%;
  min-height: 100vh;
  background: #f5f7fa;
}

.container {
  min-height: 100vh;
  background: #f5f7fa;
  box-sizing: border-box;
}

.filter-tabs {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  gap: 18rpx;
  padding: 24rpx 30rpx 18rpx;
  background: rgba(255, 255, 255, 0.96);
  border-bottom: 1rpx solid #edf1f5;
  box-sizing: border-box;
}

.tab {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  line-height: 58rpx;
  text-align: center;
  border: 1rpx solid #dce4ed;
  border-radius: 10rpx;
  background: #ffffff;
  color: #1f2933;
  font-size: 26rpx;
  font-weight: 400;
  box-sizing: border-box;
  white-space: nowrap;
}

.tab.active {
  border-color: #6eacff;
  background: #f0f7ff;
  color: #096bd8;
  font-weight: 600;
  box-shadow: none;
}

.task-scroll {
  height: calc(100vh - 104rpx);
  box-sizing: border-box;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 22rpx 30rpx 34rpx;
  box-sizing: border-box;
}

.record-card {
  position: relative;
  overflow: hidden;
  width: 100%;
  padding: 26rpx 26rpx 24rpx;
  border: 1rpx solid #e5ebf2;
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(22, 34, 51, 0.08);
  box-sizing: border-box;
}

.record-card:active {
  transform: scale(0.992);
  box-shadow: 0 6rpx 18rpx rgba(22, 34, 51, 0.06);
}

.amount {
  position: absolute;
  top: 28rpx;
  right: 30rpx;
  max-width: 150rpx;
  color: #f06a00;
  font-size: 38rpx;
  line-height: 1.1;
  font-weight: 400;
  text-align: right;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
  z-index: 1;
}

.card-main {
  box-sizing: border-box;
}

.tag-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 16rpx;
  min-width: 0;
}

.status-badge,
.type-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 600;
  box-sizing: border-box;
  white-space: nowrap;
}

.status-badge.pending,
.status-badge.ongoing {
  background: #eaf3ff;
  color: #096bd8;
}

.status-badge.completed {
  background: #e8f8ec;
  color: #24a148;
}

.status-badge.breaking {
  background: #fff1df;
  color: #ec6a00;
}

.status-badge.cancelled {
  background: #eef1f4;
  color: #58616d;
}

.type-tag {
  background: #eaf3ff;
  color: #096bd8;
  max-width: 210rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.title {
  margin-bottom: 16rpx;
  color: #05070a;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  margin-top: 12rpx;
  color: #4f5b68;
}

.info-text {
  flex: 1;
  min-width: 0;
  color: #4f5b68;
  font-size: 26rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.success-row .info-text {
  color: #4f5b68;
}

.notice {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.35;
  box-sizing: border-box;
}

.notice.warning {
  color: #d95c00;
}

.notice.muted {
  color: #5f6975;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 18rpx;
  margin-top: 22rpx;
}

.card-actions.right {
  justify-content: flex-end;
}

.action-btn {
  min-width: 148rpx;
  height: 58rpx;
  line-height: 56rpx;
  padding: 0 28rpx;
  border-radius: 8rpx;
  border: 1rpx solid #0f73df;
  color: #096bd8;
  background: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.action-btn.primary {
  background: #096bd8;
  color: #ffffff;
  border-color: #096bd8;
  box-shadow: none;
}

.action-btn.outline {
  background: #ffffff;
}

.action-btn:active {
  opacity: 0.82;
}

.load-more,
.no-more {
  padding: 24rpx 0 8rpx;
  color: #8a96a3;
  font-size: 25rpx;
  text-align: center;
}

.no-more {
  color: #a6b0ba;
}
