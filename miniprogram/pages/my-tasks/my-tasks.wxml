<!-- 我的接单列表页面 -->
<view class="container">
  <!-- 状态筛选标签 -->
  <view class="filter-tabs">
    <view
      class="tab {{currentFilter === 'all' ? 'active' : ''}}"
      bindtap="switchFilter"
      data-filter="all"
    >
      全部
    </view>
    <view
      class="tab {{currentFilter === 'ongoing' ? 'active' : ''}}"
      bindtap="switchFilter"
      data-filter="ongoing"
    >
      进行中
    </view>
    <view
      class="tab {{currentFilter === 'completed' ? 'active' : ''}}"
      bindtap="switchFilter"
      data-filter="completed"
    >
      已完成
    </view>
    <view
      class="tab {{currentFilter === 'breaking' ? 'active' : ''}}"
      bindtap="switchFilter"
      data-filter="breaking"
    >
      审核中
    </view>
    <view
      class="tab {{currentFilter === 'cancelled' ? 'active' : ''}}"
      bindtap="switchFilter"
      data-filter="cancelled"
    >
      已取消
    </view>
  </view>

  <!-- 任务列表 -->
  <scroll-view class="task-scroll" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="loadMore">
    <empty wx:if="{{tasks.length === 0}}" type="normal" icon="🤗" title="暂无{{filterText}}任务" desc="去任务大厅接单赚取积分吧" showBtn="true" btnText="去大厅" btnType="primary" bind:btnTap="goToHall"></empty>

    <view wx:else class="task-list">
      <view
        wx:for="{{tasks}}"
        wx:key="_id"
        class="task-card"
        bindtap="goToDetail"
        data-id="{{item.need_id}}"
      >
        <!-- 卡片头部 -->
        <view class="card-header">
          <view class="type-tag" style="background: {{item.bgColor}}; color: {{item.color}};">
            <text class="type-icon">{{item.typeIcon}}</text>
            <text>{{item.typeName}}</text>
          </view>
          <view class="status-badge {{item.status}}">{{item.statusText}}</view>
        </view>

        <!-- 求助者信息 -->
        <view class="seeker-info">
          <text class="seeker-label">求助者：</text>
          <text class="seeker-name">{{item.seekerNickname}}</text>
        </view>

        <!-- 任务内容 -->
        <view class="card-content">
          <text class="description">{{item.description}}</text>
        </view>

        <!-- 位置信息 -->
        <view class="location-info">
          <text class="location-icon">📍</text>
          <text class="location-name">{{item.locationName}}</text>
        </view>

        <!-- 卡片底部 -->
        <view class="card-footer">
          <view class="meta-left">
            <view class="points-tag" wx:if="{{item.rewardAmount > 0}}">+¥{{item.rewardAmount}}</view>
            <view class="points-tag" wx:elif="{{item.points > 0}}">+{{item.points}}积分</view>
          </view>
          <view class="time-text">{{item.createTime}}</view>
        </view>

        <!-- 进行中按钮 -->
        <view wx:if="{{item.status === 'ongoing'}}" class="card-actions">
          <view class="action-btn primary" catchtap="goToChat" data-id="{{item.need_id}}">
            进入聊天
          </view>
        </view>

        <!-- 已完成任务按钮 -->
        <view wx:if="{{item.status === 'completed'}}" class="card-actions">
          <view wx:if="{{item.showAppealBtn}}" class="action-btn warning" catchtap="goToAppeal" data-id="{{item.need_id}}">
            申诉
          </view>
          <view class="action-btn primary full-width" catchtap="goToChat" data-id="{{item.need_id}}">
            查看聊天
          </view>
        </view>

        <!-- 已取消任务按钮（客服裁决取消可申诉） -->
        <view wx:if="{{item.status === 'cancelled' && item.showAppealBtn}}" class="card-actions">
          <view class="action-btn warning" catchtap="goToAppeal" data-id="{{item.need_id}}">
            申诉
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{hasMore}}" class="load-more">
        <text>加载更多...</text>
      </view>
    </view>
  </scroll-view>
</view>
