@import "../../styles/wdd-polish.wxss";

page {
  width: 100%;
  min-height: 100vh;
  background: #f5f7fa;
}

.container {
  min-height: 100vh;
  background: #f5f7fa;
  box-sizing: border-box;
}

.filter-tabs {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  gap: 18rpx;
  padding: 24rpx 30rpx 18rpx;
  background: rgba(255, 255, 255, 0.96);
  border-bottom: 1rpx solid #edf1f5;
  box-sizing: border-box;
}

.tab {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  line-height: 58rpx;
  text-align: center;
  border: 1rpx solid #dce4ed;
  border-radius: 10rpx;
  background: #ffffff;
  color: #1f2933;
  font-size: 26rpx;
  font-weight: 400;
  box-sizing: border-box;
  white-space: nowrap;
}

.tab.active {
  border-color: #6eacff;
  background: #f0f7ff;
  color: #096bd8;
  font-weight: 600;
  box-shadow: none;
}

.task-scroll {
  height: calc(100vh - 104rpx);
  box-sizing: border-box;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 26rpx 30rpx 36rpx;
  box-sizing: border-box;
}

.record-card {
  position: relative;
  overflow: hidden;
  width: 100%;
  padding: 30rpx 30rpx 28rpx;
  border: 1rpx solid #e1e8f0;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.045);
  box-sizing: border-box;
}

.record-card:active {
  transform: scale(0.994);
  box-shadow: 0 5rpx 16rpx rgba(15, 23, 42, 0.045);
}

.amount {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  max-width: 156rpx;
  color: var(--money-gold);
  font-size: 36rpx;
  line-height: 1.1;
  font-weight: 700;
  text-align: right;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
  z-index: 1;
}

.card-main {
  padding-right: 162rpx;
  box-sizing: border-box;
}

.tag-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  min-width: 0;
  margin-bottom: 28rpx;
}

.status-badge,
.type-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 38rpx;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  border: 1rpx solid transparent;
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 500;
  box-sizing: border-box;
  white-space: nowrap;
}

.status-badge.pending,
.status-badge.ongoing {
  background: var(--brand-primary-08);
  border-color: var(--brand-primary-16);
  color: var(--sky-deep);
}

.status-badge.completed {
  background: var(--fresh-mint-08);
  border-color: var(--fresh-mint-18);
  color: var(--fresh-mint);
}

.status-badge.breaking {
  background: #fff8e6;
  border-color: var(--vitality-yellow-26);
  color: #946b00;
}

.status-badge.cancelled {
  background: #eef2f6;
  border-color: #d9e2ec;
  color: var(--text-secondary);
}

.type-tag {
  max-width: 210rpx;
  overflow: hidden;
  color: var(--sky-deep);
  text-overflow: ellipsis;
  background: var(--brand-primary-08);
  border-color: #d9ecfb;
}

.title {
  margin-bottom: 24rpx;
  color: #111827;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  margin-top: 14rpx;
  color: var(--text-secondary);
}

.info-text {
  flex: 1;
  min-width: 0;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.divider {
  display: none;
}

.meta-grid {
  display: block;
}

.meta-grid .info-row {
  margin-top: 14rpx;
}

.time-cell {
  justify-content: flex-start;
}

.notice {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  color: var(--text-secondary);
  font-size: 25rpx;
  line-height: 1.4;
  box-sizing: border-box;
}

.notice.warning {
  color: #946b00;
}

.notice.muted {
  color: var(--text-secondary);
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 26rpx;
}

.card-actions.right {
  justify-content: flex-end;
}

.action-btn {
  min-width: 144rpx;
  height: 60rpx;
  line-height: 58rpx;
  padding: 0 26rpx;
  border-radius: 8rpx;
  border: 1rpx solid #c9d7e4;
  color: var(--sky-deep);
  background: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.action-btn.primary {
  background: var(--brand-primary);
  color: #ffffff;
  border-color: var(--brand-primary);
  box-shadow: 0 4rpx 12rpx var(--brand-primary-16);
}

.action-btn.outline {
  background: #ffffff;
}

.action-btn:active {
  opacity: 0.86;
}

.load-more,
.no-more {
  padding: 24rpx 0 8rpx;
  color: #8a96a3;
  font-size: 25rpx;
  text-align: center;
}

.no-more {
  color: #a6b0ba;
}
