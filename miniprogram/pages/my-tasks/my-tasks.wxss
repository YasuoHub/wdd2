/* ============================================
   问当地 - 我的接单 - 天蓝色青春活力风格
   ============================================ */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F8FF 0%, #E6F3FF 30%, #EDF7FF 70%, #F5FAFF 100%);
  box-sizing: border-box;
  width: 100%;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  padding: 28rpx 32rpx;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-bottom: 2rpx solid rgba(93, 184, 230, 0.06);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #6B8BA4;
  background: rgba(240, 248, 255, 0.8);
  border-radius: 9999rpx;
  transition: all 0.3s;
  font-weight: 500;
  border: 2rpx solid rgba(93, 184, 230, 0.1);
}

.tab.active {
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  color: white;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.3);
}

/* 统计信息 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
  margin: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #2C3E50;
}

.stat-label {
  font-size: 24rpx;
  color: #6B8BA4;
}

/* 任务列表 */
.task-list {
  height: calc(100vh - 300rpx);
  padding: 0 32rpx 32rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 40rpx;
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, #E6F3FF 0%, #D4EDF7 50%, #C4E5F5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 88rpx;
  box-shadow: 0 6rpx 30rpx rgba(93, 184, 230, 0.15);
}

.empty-text {
  font-size: 34rpx;
  color: #2C3E50;
  margin-bottom: 12rpx;
  font-weight: 700;
}

.empty-hint {
  font-size: 26rpx;
  color: #8FA8B8;
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 28rpx 72rpx;
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  color: white;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 9999rpx;
  box-shadow: 0 6rpx 24rpx rgba(93, 184, 230, 0.35);
  transition: all 0.3s;
}

.empty-btn:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(93, 184, 230, 0.25);
}

/* 任务卡片 */
.task-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 36rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
  position: relative;
  overflow: hidden;
  transition: all 0.3s;
}

.task-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 28rpx rgba(93, 184, 230, 0.15);
}

/* 左侧天蓝色装饰 */
.task-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  width: 6rpx;
  height: 60%;
  background: linear-gradient(180deg, #5DB8E6 0%, #7EC8E8 100%);
  border-radius: 0 4rpx 4rpx 0;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.type-tag {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 600;
  background: rgba(93, 184, 230, 0.1);
  color: #5DB8E6;
}

.type-icon {
  font-size: 28rpx;
}

.status-badge {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 9999rpx;
  font-weight: 500;
}

.status-badge.ongoing {
  background: rgba(93, 184, 230, 0.12);
  color: #3A9AD2;
}

.status-badge.completed {
  background: rgba(109, 213, 176, 0.12);
  color: #4DB895;
}

/* 求助者信息 */
.seeker-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(240, 248, 255, 0.6);
  border-radius: 16rpx;
}

.seeker-label {
  font-size: 24rpx;
  color: #8FA8B8;
}

.seeker-name {
  font-size: 28rpx;
  color: #5DB8E6;
  font-weight: 600;
}

/* 卡片内容 */
.card-content {
  margin-bottom: 20rpx;
}

.description {
  font-size: 30rpx;
  color: #2C3E50;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 位置信息 */
.location-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 14rpx 18rpx;
  background: rgba(240, 248, 255, 0.6);
  border-radius: 16rpx;
}

.location-icon {
  font-size: 24rpx;
  color: #5DB8E6;
}

.location-name {
  font-size: 26rpx;
  color: #6B8BA4;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(93, 184, 230, 0.06);
}

.meta-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.points-tag {
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  color: white;
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx 24rpx;
  border-radius: 9999rpx;
  box-shadow: 0 2rpx 10rpx rgba(93, 184, 230, 0.25);
}

.countdown {
  font-size: 24rpx;
  color: #FF8C69;
  font-weight: 600;
}

.time-text {
  font-size: 24rpx;
  color: #A8C4D4;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 24rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.action-btn.primary {
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(93, 184, 230, 0.3);
}

.action-btn.primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(93, 184, 230, 0.2);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: #A8C4D4;
}
