/* ============================================
   问当地 - 我的接单 - 天蓝色青春活力风格
   ============================================ */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 30%, var(--bg-tertiary) 70%, var(--bg-primary) 100%);
  box-sizing: border-box;
  width: 100%;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  padding: 28rpx 32rpx;
  gap: 16rpx;
  background: var(--bg-card);
  backdrop-filter: blur(20rpx);
  border-bottom: 2rpx solid var(--border-light);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: var(--text-tertiary);
  background: var(--bg-glass);
  border-radius: var(--radius-full);
  transition: all 0.3s;
  font-weight: 500;
  border: 2rpx solid var(--border-light);
}

.tab.active {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  color: white;
  font-weight: 600;
  box-shadow: var(--shadow-sky);
}

/* 任务列表容器 */
.task-scroll {
  height: calc(100vh - 120rpx);
  padding: 0 32rpx 32rpx;
  box-sizing: border-box;
}

/* 任务列表 */
.task-list {
  padding-top: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 40rpx;
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 50%, var(--sky-soft) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 88rpx;
  box-shadow: var(--shadow-md);
}

.empty-text {
  font-size: 34rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  font-weight: 700;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 28rpx 72rpx;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  color: white;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  box-shadow: 0 6rpx 24rpx rgba(93, 184, 230, 0.35);
  transition: all 0.3s;
}

.empty-btn:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 12rpx rgba(93, 184, 230, 0.25);
}

/* 任务卡片 */
.task-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
  position: relative;
  overflow: hidden;
  transition: all 0.3s;
}

.task-card:active {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-md);
}

/* 左侧天蓝色装饰 */
.task-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  width: 6rpx;
  height: 60%;
  background: linear-gradient(180deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  border-radius: 0 4rpx 4rpx 0;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.type-tag {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 600;
  background: var(--bg-glass);
  color: var(--sky-primary);
  border: 2rpx solid var(--border-light);
}

.type-icon {
  font-size: 28rpx;
}

.status-badge {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}

.status-badge.ongoing {
  background: rgba(93, 184, 230, 0.12);
  color: var(--sky-primary);
}

.status-badge.completed {
  background: rgba(109, 213, 176, 0.12);
  color: var(--fresh-green);
}

/* 求助者信息 */
.seeker-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
  padding: 16rpx 20rpx;
  background: var(--bg-glass);
  border-radius: var(--radius-sm);
  border: 2rpx solid var(--border-light);
}

.seeker-label {
  font-size: 24rpx;
  color: var(--text-light);
}

.seeker-name {
  font-size: 28rpx;
  color: var(--sky-primary);
  font-weight: 600;
}

/* 卡片内容 */
.card-content {
  margin-bottom: 20rpx;
}

.description {
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 位置信息 */
.location-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 14rpx 18rpx;
  background: var(--bg-glass);
  border-radius: var(--radius-sm);
  border: 2rpx solid var(--border-light);
}

.location-icon {
  font-size: 24rpx;
  color: var(--sky-primary);
}

.location-name {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid var(--border-light);
}

.meta-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.points-tag {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  color: white;
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-sky);
}

.countdown {
  font-size: 24rpx;
  color: var(--vitality-orange);
  font-weight: 600;
}

.time-text {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 24rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  color: white;
  box-shadow: var(--shadow-sky);
}

.action-btn.primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(93, 184, 230, 0.2);
}

/* 全宽按钮 */
.action-btn.full-width {
  flex: 1;
  width: 100%;
}

/* 成功按钮 - 去评价 */
.action-btn.success {
  background: linear-gradient(135deg, var(--fresh-mint) 0%, var(--fresh-green) 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(109, 213, 176, 0.3);
}

.action-btn.success:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(109, 213, 176, 0.2);
}

/* 查看评价按钮 - 灰色默认样式 */
.action-btn:not(.primary):not(.success) {
  background: rgba(168, 196, 212, 0.15);
  color: var(--text-tertiary);
}

.action-btn:not(.primary):not(.success):active {
  background: rgba(168, 196, 212, 0.25);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: var(--text-light);
}
