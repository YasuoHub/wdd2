/* 我的接单列表页面样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FDF8F3 0%, #F8F4EF 100%);
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.8);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #636E72;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 9999rpx;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #A8E6CF 0%, #88D8C0 100%);
  color: white;
  font-weight: 600;
}

/* 统计信息 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
  margin: 0 32rpx 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(45, 52, 54, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #2D3436;
}

.stat-label {
  font-size: 24rpx;
  color: #636E72;
}

/* 任务列表 */
.task-list {
  height: calc(100vh - 280rpx);
  padding: 0 32rpx 32rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #636E72;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #B2BEC3;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, #A8E6CF 0%, #88D8C0 100%);
  color: white;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 9999rpx;
  box-shadow: 0 4rpx 16rpx rgba(168, 230, 207, 0.4);
}

/* 任务卡片 */
.task-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(45, 52, 54, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.type-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.type-icon {
  font-size: 28rpx;
}

.status-badge {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  font-weight: 500;
}

.status-badge.ongoing {
  background: rgba(168, 230, 207, 0.3);
  color: #2D9C6F;
}

.status-badge.completed {
  background: rgba(189, 195, 199, 0.2);
  color: #636E72;
}

/* 求助者信息 */
.seeker-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  background: rgba(248, 244, 239, 0.6);
  border-radius: 12rpx;
}

.seeker-label {
  font-size: 24rpx;
  color: #B2BEC3;
}

.seeker-name {
  font-size: 26rpx;
  color: #636E72;
  font-weight: 500;
}

/* 卡片内容 */
.card-content {
  margin-bottom: 16rpx;
}

.description {
  font-size: 30rpx;
  color: #2D3436;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 位置信息 */
.location-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.location-icon {
  font-size: 24rpx;
  color: #B2BEC3;
}

.location-name {
  font-size: 26rpx;
  color: #636E72;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(189, 195, 199, 0.1);
}

.meta-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.points-tag {
  background: linear-gradient(135deg, #A8E6CF 0%, #88D8C0 100%);
  color: white;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
}

.countdown {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.time-text {
  font-size: 24rpx;
  color: #B2BEC3;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 20rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: linear-gradient(135deg, #A8E6CF 0%, #88D8C0 100%);
  color: white;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: #B2BEC3;
}
