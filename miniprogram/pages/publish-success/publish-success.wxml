<!-- 发布成功页面 -->
<wxs src="../../utils/money.wxs" module="money" />
<view class="container wdd-page {{showAnimation ? 'show' : ''}}">
  <view class="success-section">
    <view class="success-icon">
      <wdd-icon name="check" color="var(--brand-primary)" size="74"></wdd-icon>
    </view>
    <text class="success-title">发布成功</text>
    <text class="success-subtitle">您的求助已进入任务大厅，等待附近帮助者响应</text>
  </view>

  <view class="task-info-card content-card">
    <view class="card-title">任务摘要</view>
    <view class="info-row">
      <text class="info-label">求助类型</text>
      <text class="info-value">{{typeName}}</text>
    </view>
    <view class="info-divider"></view>
    <view class="info-row">
      <text class="info-label">悬赏金额</text>
      <view class="info-value amount"><wdd-icon name="coins" color="var(--money-gold)" size="26"></wdd-icon><text class="money-text">{{money.format(amount)}}</text></view>
    </view>
    <view class="info-divider"></view>
    <view class="info-row">
      <text class="info-label">任务地点</text>
      <text class="info-value location">{{taskLocation}}</text>
    </view>
  </view>

  <view class="tips-section content-card">
    <view class="tip-item">
      <view class="tip-icon">
        <wdd-icon name="clipboard-list" color="#8A9AAF" size="34"></wdd-icon>
      </view>
      <text class="tip-text">任务有效期内，附近帮助者可在任务大厅响应求助</text>
    </view>
    <view class="tip-divider"></view>
    <view class="tip-item">
      <view class="tip-icon">
        <wdd-icon name="bell" color="#8A9AAF" size="34"></wdd-icon>
      </view>
      <text class="tip-text">有帮助者响应后，您会收到通知，可立即开始沟通</text>
    </view>
  </view>

  <view class="refund-tip">
    <wdd-icon name="info" color="#5E7187" size="30"></wdd-icon>
    <text>退款提示：任务取消后，悬赏金额将原路退回至您的账户</text>
  </view>

  <view class="footer">
    <button class="btn-primary" bindtap="goToTaskDetail">
      查看任务详情
    </button>
    <button class="btn-secondary" bindtap="goToHome">
      返回首页
    </button>
  </view>
</view>
