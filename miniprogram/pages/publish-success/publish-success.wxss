/* 发布成功页面 */
.container {
  min-height: 100vh;
  background: linear-gradient(
    180deg,
    #f0f8ff 0%,
    #e6f3ff 30%,
    #edf7ff 70%,
    #f5faff 100%
  );
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 40rpx;
  box-sizing: border-box;
  opacity: 0;
  transform: translateY(30rpx);
  transition: all 0.6s ease;
}

.container.show {
  opacity: 1;
  transform: translateY(0);
}

/* 成功动画区域 */
.success-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.success-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  animation: bounceIn 0.6s ease;
}

@keyframes bounceIn {
  0% {
    transform: scale(0);
    opacity: 0;
  }
  50% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.success-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.success-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.5;
}

/* 任务信息卡片 */
.task-info-card {
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(93, 184, 230, 0.15);
  border: 2rpx solid rgba(93, 184, 230, 0.1);
  margin-bottom: 48rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.info-value.amount {
  color: var(--vitality-orange);
  font-size: 36rpx;
}

.info-value.income {
  color: var(--fresh-mint);
}

.info-divider {
  height: 2rpx;
  background: rgba(93, 184, 230, 0.12);
}

/* 提示信息 */
.tips-section {
  width: 100%;
  max-width: 600rpx;
  margin-bottom: 48rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 0;
}

.tip-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 底部按钮 */
.footer {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: auto;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(
    135deg,
    var(--sky-primary) 0%,
    var(--sky-light) 100%
  );
  border-radius: 48rpx;
  color: white;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(93, 184, 230, 0.4);
}

.btn-secondary {
  width: 100%;
  height: 96rpx;
  background: transparent;
  border: 2rpx solid rgba(93, 184, 230, 0.3);
  border-radius: 48rpx;
  color: var(--sky-primary);
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}
