@import "../../styles/wdd-polish.wxss";

/* 发布成功页面 */
.container {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #f6faff 0%, #ffffff 48%, #f8fbff 100%);
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding: 62rpx 40rpx 46rpx;
  box-sizing: border-box;
  opacity: 0;
  transform: translateY(24rpx);
  transition: opacity 0.45s ease, transform 0.45s ease;
}

.container.show {
  opacity: 1;
  transform: translateY(0);
}

.success-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 42rpx;
}

.success-icon {
  width: 108rpx;
  height: 108rpx;
  border: 8rpx solid var(--brand-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 34rpx;
  animation: successPop 0.5s ease;
}

@keyframes successPop {
  0% {
    transform: scale(0.72);
    opacity: 0;
  }
  70% {
    transform: scale(1.06);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.success-title {
  font-size: 44rpx;
  font-weight: 400;
  color: #1f2933;
  line-height: 1.25;
  margin-bottom: 22rpx;
}

.success-subtitle {
  max-width: 620rpx;
  font-size: 28rpx;
  color: #52616f;
  text-align: center;
  line-height: 1.55;
}

.content-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid #dfe7ef;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 22rpx rgba(15, 23, 42, 0.05);
  box-sizing: border-box;
}

.task-info-card {
  padding: 28rpx 32rpx 22rpx;
  margin-bottom: 28rpx;
}

.tips-section {
  padding: 30rpx 32rpx 32rpx;
  margin-bottom: 56rpx;
}

.card-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1.3;
  margin-bottom: 24rpx;
}

.info-row {
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 28rpx;
}

.info-label {
  color: #52616f;
  font-size: 28rpx;
  line-height: 1.4;
  flex-shrink: 0;
}

.info-value {
  min-width: 0;
  color: #111827;
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.4;
  text-align: right;
}

.info-value.amount {
  color: #f26a1b;
  font-size: 34rpx;
  font-weight: 400;
  font-variant-numeric: tabular-nums;
}

.info-value.location {
  max-width: 430rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-divider,
.tip-divider {
  height: 1rpx;
  background: #e4ebf2;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 20rpx 0;
}

.tip-item:first-of-type {
  padding-top: 0;
}

.tip-icon {
  width: 40rpx;
  min-width: 40rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tip-text {
  flex: 1;
  color: #1f2933;
  font-size: 28rpx;
  line-height: 1.55;
}

.refund-tip {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 76rpx;
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  background: #f3f6fa;
  border-radius: 12rpx;
  color: #5e7187;
  font-size: 25rpx;
  line-height: 1.45;
}

.refund-tip text {
  flex: 1;
}

.footer {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: auto;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.btn-primary,
.btn-secondary {
  width: 100%;
  height: 88rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1;
}

.btn-primary {
  background: #1677f2;
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(22, 119, 242, 0.22);
}

.btn-secondary {
  background: #ffffff;
  color: #1677f2;
  border: 2rpx solid #1677f2;
  box-shadow: none;
}

.btn-primary:active,
.btn-secondary:active {
  transform: scale(0.98);
}
