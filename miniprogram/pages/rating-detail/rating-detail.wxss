/* 评价详情页面样式 */

page {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F8FF 0%, #E6F3FF 30%, #EDF7FF 70%, #F5FAFF 100%);
  box-sizing: border-box;
}

.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 加载中 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-icon {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(93, 184, 230, 0.2);
  border-top-color: #5DB8E6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #6B8BA4;
}

/* 评价对象卡片 */
.target-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
}

.target-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: white;
  font-weight: 600;
  flex-shrink: 0;
}

.target-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.target-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.target-label {
  font-size: 24rpx;
  color: #8FA8B8;
}

.target-name {
  font-size: 34rpx;
  color: #2C3E50;
  font-weight: 700;
}

/* 任务卡片 */
.task-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.task-type {
  font-size: 28rpx;
  color: #5DB8E6;
  font-weight: 600;
  background: rgba(93, 184, 230, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
}

.task-points {
  font-size: 26rpx;
  color: #FF8C69;
  font-weight: 600;
}

.task-desc {
  font-size: 28rpx;
  color: #2C3E50;
  line-height: 1.6;
}

/* 评分区域 */
.rating-section {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
  text-align: center;
}

.section-title {
  font-size: 28rpx;
  color: #6B8BA4;
  margin-bottom: 24rpx;
  display: block;
}

.stars-wrapper {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.star {
  font-size: 56rpx;
  color: #E0E0E0;
  transition: all 0.3s;
}

.star.active {
  color: #FFD166;
}

.star-icon {
  line-height: 1;
}

.rating-score {
  font-size: 40rpx;
  color: #2C3E50;
  font-weight: 700;
}

/* 标签区域 */
.tags-section {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
}

.tags-wrapper {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  background: rgba(93, 184, 230, 0.1);
  color: #5DB8E6;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
  font-weight: 500;
}

/* 评价内容区域 */
.comment-section {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
}

.comment-box {
  background: rgba(240, 248, 255, 0.6);
  border-radius: 20rpx;
  padding: 24rpx;
}

.comment-text {
  font-size: 28rpx;
  color: #2C3E50;
  line-height: 1.8;
}

/* 时间区域 */
.time-section {
  text-align: center;
  margin-bottom: 32rpx;
}

.time-text {
  font-size: 24rpx;
  color: #A8C4D4;
}

/* 提示区域 */
.tips-section {
  text-align: center;
  padding: 24rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #8FA8B8;
}
