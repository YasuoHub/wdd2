/* ============================================
   问当地 - 评价详情 - 城市服务清爽可信风格
   ============================================ */

page {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 30%, var(--bg-tertiary) 70%, var(--bg-primary) 100%);
  box-sizing: border-box;
}

.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 加载中 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-icon {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-light);
  border-top-color: var(--sky-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 评价对象卡片 */
.target-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--border-light);
}

.target-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: white;
  font-weight: 400;
  flex-shrink: 0;
}

.target-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.target-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.target-label {
  font-size: 24rpx;
  color: var(--text-light);
}

.target-name {
  font-size: 34rpx;
  color: var(--text-primary);
  font-weight: 400;
}

/* 任务卡片 */
.task-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--border-light);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.task-type {
  font-size: 28rpx;
  color: var(--sky-primary);
  font-weight: 400;
  background: var(--bg-glass);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
}

.task-points {
  font-size: 26rpx;
  color: var(--vitality-orange);
  font-weight: 400;
}

.task-desc {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

/* 评分区域 */
.rating-section {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--border-light);
  text-align: center;
}

.section-title {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-bottom: 24rpx;
  display: block;
}

.stars-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.star {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.star-symbol {
  color: #d4dbe5;
  font-size: 62rpx;
  font-weight: 400;
  line-height: 1;
  text-align: center;
}

.star.active .star-symbol {
  color: var(--money-gold);
}

.rating-score {
  font-size: 40rpx;
  color: var(--text-primary);
  font-weight: 400;
}

/* 标签区域 */
.tags-section {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--border-light);
}

.tags-wrapper {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 20rpx 14rpx;
}

.tag {
  min-width: 0;
  height: 66rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 2rpx solid #d7dde6;
  border-radius: 999rpx;
  color: #7b8794;
  font-size: 26rpx;
  font-weight: 400;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tag text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 评价内容区域 */
.comment-section {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--border-light);
}

.comment-box {
  background: var(--bg-glass);
  border-radius: var(--radius-md);
  padding: 24rpx;
  border: 2rpx solid var(--border-light);
}

.comment-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
}

/* 时间区域 */
.time-section {
  text-align: center;
  margin-bottom: 32rpx;
}

.time-text {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 提示区域 */
.tips-section {
  text-align: center;
  padding: 24rpx;
  background: var(--bg-glass);
  border-radius: var(--radius-lg);
  margin-top: 16rpx;
  border: 2rpx solid var(--border-light);
}

.tips-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
@import "../../styles/wdd-polish.wxss";
