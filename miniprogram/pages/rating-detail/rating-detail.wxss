/* ============================================
   问当地 - 评价详情 - 城市服务清爽可信风格
   ============================================ */

page {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 30%, var(--bg-tertiary) 70%, var(--bg-primary) 100%);
  box-sizing: border-box;
}

.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 加载中 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-icon {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-light);
  border-top-color: var(--sky-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 评价对象卡片 */
.target-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--border-light);
}

.target-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: white;
  font-weight: 600;
  flex-shrink: 0;
}

.target-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.target-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.target-label {
  font-size: 24rpx;
  color: var(--text-light);
}

.target-name {
  font-size: 34rpx;
  color: var(--text-primary);
  font-weight: 700;
}

/* 任务卡片 */
.task-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--border-light);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.task-type {
  font-size: 28rpx;
  color: var(--sky-primary);
  font-weight: 600;
  background: var(--bg-glass);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
}

.task-points {
  font-size: 26rpx;
  color: var(--vitality-orange);
  font-weight: 600;
}

.task-desc {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

/* 评分区域 */
.rating-section {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--border-light);
  text-align: center;
}

.section-title {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-bottom: 24rpx;
  display: block;
}

.stars-wrapper {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.star {
  font-size: 56rpx;
  color: var(--border-color);
  transition: all 0.3s;
}

.star.active {
  color: var(--vitality-yellow);
}

.star-icon {
  line-height: 1;
}

.rating-score {
  font-size: 40rpx;
  color: var(--text-primary);
  font-weight: 700;
}

/* 标签区域 */
.tags-section {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--border-light);
}

.tags-wrapper {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  background: var(--bg-glass);
  color: var(--sky-primary);
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  font-weight: 500;
}

/* 评价内容区域 */
.comment-section {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--border-light);
}

.comment-box {
  background: var(--bg-glass);
  border-radius: var(--radius-md);
  padding: 24rpx;
  border: 2rpx solid var(--border-light);
}

.comment-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
}

/* 时间区域 */
.time-section {
  text-align: center;
  margin-bottom: 32rpx;
}

.time-text {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 提示区域 */
.tips-section {
  text-align: center;
  padding: 24rpx;
  background: var(--bg-glass);
  border-radius: var(--radius-lg);
  margin-top: 16rpx;
  border: 2rpx solid var(--border-light);
}

.tips-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
/* ============================================
   城市服务风格视觉覆盖：清爽可信、交易清楚、低装饰
   ============================================ */
.container,
.chat-container {
  background: #f5f7fa;
}

.header,
.footer,
.input-area,
.popup-content,
.modal-content,
.rules-modal-content {
  background: #ffffff;
  border-color: var(--border-light);
  box-shadow: var(--shadow-card);
}

.section-card,
.task-card,
.user-card,
.menu-list,
.quick-panel,
.need-feed,
.login-tip-card,
.balance-section,
.record-card,
.ticket-card,
.report-card,
.appeal-card,
.profile-card,
.rating-card,
.info-card,
.form-card,
.stat-card,
.card {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.location-bar,
.filter-item,
.sort-section,
.distance-section,
.type-badge,
.card-location,
.distance-tag,
.quick-tag,
.type-item,
.time-option,
.quick-point,
.quick-amount,
.payment-option,
.amount-detail,
.rules-tip,
.points-tip-wrapper,
.input-wrapper,
.toolbar-toggle-btn,
.more-btn,
.system-message-text,
.time-divider text {
  background: #f8fafc;
  border-color: var(--border-light);
  box-shadow: none;
}

.filter-item.active,
.type-item.active,
.quick-tag.active,
.time-option.active,
.payment-option.active {
  background: rgba(22, 119, 210, 0.08);
  border-color: rgba(22, 119, 210, 0.34);
  box-shadow: none;
}

.filter-item.active .filter-name,
.quick-tag.active,
.time-option.active,
.payment-option.active .payment-name {
  color: var(--sky-deep);
  font-weight: 600;
}

.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.amount-badge,
.quick-amount.active,
.quick-point.active,
.time-recommend,
.btn-vitality {
  background: var(--vitality-orange);
  box-shadow: var(--shadow-orange);
}

.balance-value.points,
.balance-value.available,
.points-number,
.publish-points,
.publish-amount {
  color: var(--text-primary);
  background: none;
  -webkit-text-fill-color: currentColor;
}

.wdd-amount,
.need-amount,
.amount-current,
.amount-symbol,
.detail-value.fee,
.warning-text,
.balance-value.insufficient,
.task-points-mini {
  color: var(--vitality-orange);
}

.detail-value.income,
.tag-mint,
.status-success,
.success-text {
  color: var(--fresh-mint);
}

.message-item.other .message-bubble.text {
  background: #ffffff;
  border: 1rpx solid var(--border-light);
  box-shadow: var(--shadow-sm);
}

.message-item.self .message-bubble.text {
  background: var(--sky-primary);
  box-shadow: var(--shadow-sky);
}

.popup-overlay,
.modal-mask,
.rules-modal {
  background: rgba(15, 23, 42, 0.46);
}

.helper-profile-tip,
.balance-insufficient,
.task-ended-bar.breaking-bar {
  background: #fff8e6;
  border-color: rgba(233, 185, 73, 0.34);
}

image,
button,
view {
  letter-spacing: 0;
}
/* 城市服务按钮对比修正 */
.primary-action,
.hero-login-btn,
.publish-btn,
.send-btn,
.take-btn,
.sign-in-btn,
.invite-btn,
.rules-modal-btn,
.empty-btn.primary,
.modal-btn.confirm,
.logout-section.login-btn,
.picker-icon-wrapper,
.tool-icon {
  color: #ffffff;
}

.publish-btn.disabled,
.send-btn[disabled],
.disabled {
  color: var(--text-muted);
}