<!-- 个人中心页面 -->
<wxs src="../../utils/money.wxs" module="money" />
<view class="container wdd-page">
  <view class="wdd-page-bg"></view>
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-header">
      <view class="avatar-wrapper">
        <image wx:if="{{userInfo.avatar}}" class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"/>
        <view wx:else class="avatar-default">
          <text wx:if="{{userInfo.nickname}}">{{userInfo.nickname[0]}}</text>
          <wdd-icon wx:else name="circle-user" color="#FFFFFF" size="58"></wdd-icon>
        </view>
      </view>
      <view class="user-info">
        <text class="nickname">{{userInfo.nickname || '微信用户'}}</text>
        <text class="user-id">ID: {{userInfo.displayId || '未知'}}</text>
      </view>
    </view>

    <!-- 余额展示 -->
    <view class="balance-section" bindtap="goToWallet">
      <view class="balance-item">
        <text class="balance-value">¥{{money.format(userInfo.balance)}}</text>
        <text class="balance-label">余额</text>
      </view>
      <view class="balance-divider"></view>
      <view class="balance-item">
        <text class="balance-value points">{{userInfo.total_points || 0}}</text>
        <text class="balance-label">积分</text>
      </view>
    </view>

    <!-- 签到按钮 -->
    <view wx:if="{{!hasSignedToday}}" class="sign-in-btn" bindtap="handleSignIn">
      <wdd-icon name="calendar-check" color="#FFFFFF" size="34"></wdd-icon>
      <text>每日签到 +{{signPoints}}积分</text>
    </view>
    <view wx:else class="sign-in-btn signed">
      <wdd-icon name="circle-check-big" color="#6DD5B0" size="34"></wdd-icon>
      <text>今日已签到</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-title">我的任务</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToMyNeeds">
        <view class="menu-icon-wrapper">
          <wdd-icon name="send" color="var(--brand-primary)" size="36"></wdd-icon>
        </view>
        <view class="menu-content">
          <text class="menu-text">我的求助</text>
          <text class="menu-desc">{{myNeedsCount}}个进行中</text>
        </view>
        <wdd-icon class="menu-arrow" name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>
      <view class="menu-item" bindtap="goToMyTasks">
        <view class="menu-icon-wrapper">
          <wdd-icon name="handshake" color="#119B72" size="38"></wdd-icon>
        </view>
        <view class="menu-content">
          <text class="menu-text">我的帮助</text>
          <text class="menu-desc">{{myTasksCount}}个进行中</text>
        </view>
        <wdd-icon class="menu-arrow" name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">帮助者设置</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToHelperProfile">
        <view class="menu-icon-wrapper">
          <wdd-icon name="user-round-cog" color="#119B72" size="38"></wdd-icon>
        </view>
        <view class="menu-content">
          <text class="menu-text">帮助者资料</text>
          <text class="menu-desc">{{userInfo.help_willingness ? '已完善' : '未设置，点击完善'}}</text>
        </view>
        <wdd-icon class="menu-arrow" name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">资产管理</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToWallet">
        <view class="menu-icon-wrapper">
          <wdd-icon name="wallet" color="var(--vitality-orange)" size="38"></wdd-icon>
        </view>
        <view class="menu-content">
          <text class="menu-text">我的钱包</text>
          <text class="menu-desc">余额 ¥{{money.format(userInfo.balance)}}</text>
        </view>
        <wdd-icon class="menu-arrow" name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>
      <view class="menu-item" bindtap="goToPointRecords">
        <view class="menu-icon-wrapper">
          <wdd-icon name="star" color="#C9941E" size="38"></wdd-icon>
        </view>
        <view class="menu-content">
          <text class="menu-text">我的积分</text>
          <text class="menu-desc">可兑换免单券、提现免手续费券等权益</text>
        </view>
        <wdd-icon class="menu-arrow" name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>
      <view class="menu-item" bindtap="showInviteModal">
        <view class="menu-icon-wrapper">
          <wdd-icon name="gift" color="#7B61D1" size="38"></wdd-icon>
        </view>
        <view class="menu-content">
          <text class="menu-text">邀请好友</text>
          <text class="menu-desc">邀请得积分</text>
        </view>
        <wdd-icon class="menu-arrow" name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>
    </view>
  </view>

  <!-- 服务记录 -->
  <view class="menu-section">
    <view class="menu-title">服务记录</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToMyReports">
        <view class="menu-icon-wrapper">
          <wdd-icon name="shield-alert" color="#FF6B6B" size="38"></wdd-icon>
        </view>
        <view class="menu-content">
          <text class="menu-text">我的举报</text>
        </view>
        <wdd-icon class="menu-arrow" name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>
      <view class="menu-item" bindtap="goToMyAppeals">
        <view class="menu-icon-wrapper">
          <wdd-icon name="notebook-pen" color="var(--vitality-orange)" size="38"></wdd-icon>
        </view>
        <view class="menu-content">
          <text class="menu-text">我的申诉</text>
        </view>
        <wdd-icon class="menu-arrow" name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>
    </view>
  </view>

  <!-- 客服入口（仅客服可见）-->
  <view wx:if="{{isCustomerService}}" class="menu-section">
    <view class="menu-title">客服系统</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToTicketList">
        <view class="menu-icon-wrapper">
          <wdd-icon name="headphones" color="#FF6B6B" size="38"></wdd-icon>
        </view>
        <view class="menu-content">
          <text class="menu-text">客服工单处理</text>
          <text class="menu-desc">处理举报和申诉工单</text>
        </view>
        <wdd-icon class="menu-arrow" name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>
    </view>
  </view>

  <!-- 超管入口（仅超管可见）-->
  <view wx:if="{{isSuperAdmin}}" class="menu-section">
    <view class="menu-title">超级管理员</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToOpsAnalytics">
        <view class="menu-icon-wrapper">
          <wdd-icon name="chart-column" color="#119B72" size="38"></wdd-icon>
        </view>
        <view class="menu-content">
          <text class="menu-text">运营分析</text>
          <text class="menu-desc">查看平台运营数据</text>
        </view>
        <wdd-icon class="menu-arrow" name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>
      <view class="menu-item" bindtap="goToFundApproval">
        <view class="menu-icon-wrapper">
          <wdd-icon name="banknote" color="var(--brand-primary)" size="38"></wdd-icon>
        </view>
        <view class="menu-content">
          <text class="menu-text">资金审批</text>
          <text class="menu-desc">处理用户提现申请</text>
        </view>
        <wdd-icon class="menu-arrow" name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">其他</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="showAbout">
        <view class="menu-icon-wrapper">
          <wdd-icon name="info" color="#FF6B9D" size="38"></wdd-icon>
        </view>
        <view class="menu-content">
          <text class="menu-text">关于我们</text>
        </view>
        <wdd-icon class="menu-arrow" name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>
      <view class="menu-item" bindtap="showRules">
        <view class="menu-icon-wrapper">
          <wdd-icon name="clipboard-list" color="#5E7187" size="38"></wdd-icon>
        </view>
        <view class="menu-content">
          <text class="menu-text">积分规则</text>
        </view>
        <wdd-icon class="menu-arrow" name="chevron-right" color="#9AA5B1" size="28"></wdd-icon>
      </view>
    </view>
  </view>

  <!-- 退出登录 / 一键登录 -->
  <view class="logout-section {{isLoggedIn ? '' : 'login-btn'}}" bindtap="{{isLoggedIn ? 'handleLogout' : 'handleLogin'}}">
    <text class="logout-text">{{isLoggedIn ? '退出登录' : '一键登录'}}</text>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text>问当地 v1.0.0</text>
    <text style="margin-top: 8rpx; font-size: 22rpx;">成都起步，互帮互助</text>
  </view>
</view>

<!-- 邀请好友弹窗 -->
<view class="modal {{showInviteModal ? 'show' : ''}}" wx:if="{{showInviteModal}}">
  <view class="modal-mask" bindtap="hideInviteModal"></view>
  <view class="modal-content">
    <view class="modal-close" bindtap="hideInviteModal">
      <wdd-icon name="x" color="#7B8794" size="28"></wdd-icon>
    </view>
    <view class="modal-title">邀请好友</view>
    <view class="invite-content">
      <view class="invite-icon">
        <wdd-icon name="gift" color="#FFFFFF" size="60"></wdd-icon>
      </view>
      <view class="invite-text">邀请好友注册，双方各得50积分！</view>
      <view class="invite-tip">好友通过你的分享注册后，积分自动到账</view>
    </view>
    <button class="invite-btn" open-type="share">分享给好友</button>
  </view>
</view>

<!-- 关于我们弹窗 -->
<view class="modal {{showAboutModal ? 'show' : ''}}" wx:if="{{showAboutModal}}">
  <view class="modal-mask" bindtap="hideAboutModal"></view>
  <view class="modal-content">
    <view class="modal-title">关于问当地</view>
    <view class="modal-body">
      <text class="body-text">问当地是一款基于地理位置的即时互帮互助小程序。</text>
      <text class="body-text">无论你是想了解异地的实时天气、路况，还是确认某家店是否营业，都可以找当地的用户帮你确认。</text>
      <text class="body-text brand">成都起步，互帮互助。</text>
    </view>
    <view class="modal-footer">
      <button class="modal-btn confirm" bindtap="hideAboutModal">我知道了</button>
    </view>
  </view>
</view>

<!-- 积分规则弹窗 -->
<view class="modal {{showRulesModal ? 'show' : ''}}" wx:if="{{showRulesModal}}">
  <view class="modal-mask" bindtap="hideRulesModal"></view>
  <view class="modal-content">
    <view class="modal-title">积分规则</view>
    <view class="modal-body">
      <view class="rule-section">
        <text class="section-title">获取方式</text>
        <text class="section-text">1. 新用户注册：+100积分</text>
        <text class="section-text">2. 每日签到：+5~30积分（连续签到递增）</text>
        <text class="section-text">3. 邀请好友：双方各+50积分</text>
      </view>
      <view class="rule-section">
        <text class="section-title">积分用途</text>
        <text class="section-text">积分可兑换平台内免单券、提现免手续费券等权益（功能开发中，敬请期待）。</text>
      </view>
      <view class="rule-section">
        <text class="section-title">重要说明</text>
        <text class="section-text">积分仅用于平台内权益兑换，不可提现、不可转让、无现金价值。</text>
        <text class="section-text">平台保留调整积分发放规则、有效期、可兑换权益种类与比例的权利。</text>
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn confirm" bindtap="hideRulesModal">我知道了</button>
    </view>
  </view>
</view>
