/* ============================================
   问当地 - 个人中心 - 城市服务清爽可信风格
   ============================================ */

/* 页面容器 - 浅灰服务背景 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #fafbfc 45%, #f3f8fc 100%);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  width: 100%;
}

.container::before {
  display: none;
}

.container::after {
  display: none;
}

/* ============================================
   用户信息卡片 - 毛玻璃效果
   ============================================ */
.user-card {
  margin: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 42rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--brand-primary-12);
  position: relative;
  z-index: 1;
  overflow: hidden;
}

/* 顶部装饰条 */
.user-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  /* background: linear-gradient(90deg, var(--brand-primary) 0%, var(--brand-primary-light) 50%, #D9ECFB 100%); */
}

.user-header {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 36rpx;
}

/* 头像包装器 - 可信头像样式 */
.avatar-wrapper {
  width: 130rpx;
  height: 130rpx;
  border-radius: var(--radius-full);
  overflow: hidden;
  border: 4rpx solid white;
  box-shadow: 0 6rpx 24rpx var(--brand-primary-35);
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 50%, var(--sky-soft) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.avatar-wrapper.has-avatar {
  background: transparent;
  border-radius: 50%;
}

.avatar-wrapper::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  right: -10rpx;
  bottom: -10rpx;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  border-radius: var(--radius-full);
  z-index: -1;
  opacity: 0.35;
  filter: blur(16rpx);
}

.avatar-wrapper.has-avatar::before {
  display: none;
}

.avatar {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 50%;
  overflow: hidden;
  background: transparent;
}

.avatar-default {
  font-size: 52rpx;
  color: white;
  font-weight: 400;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.nickname {
  font-size: 42rpx;
  font-weight: 400;
  color: var(--text-primary);
}

.user-id {
  font-size: 24rpx;
  color: var(--text-light);
  font-weight: 400;
}

/* ============================================
   余额展示 - 精致卡片
   ============================================ */
.balance-section {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 0;
  background: rgba(240, 248, 255, 0.7);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--brand-primary-12);
  position: relative;
  overflow: hidden;
}

.balance-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(135deg, var(--brand-primary-05) 0%, rgba(217, 236, 251, 0.03) 100%);
}

.balance-item {
  flex: 1;
  align-self: stretch;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 32rpx 0;
  position: relative;
  z-index: 1;
}

.balance-item-active {
  background: var(--brand-primary-08);
}

.balance-value {
  font-size: 48rpx;
  font-weight: 400;
  color: var(--text-primary);
}

.balance-value.points {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.balance-value.points .points-text {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-dark) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.balance-value.credit {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.credit-score-text {
  color: #119B72;
  font-weight: 500;
}

.balance-value.available {
  background: linear-gradient(135deg, var(--fresh-mint) 0%, var(--fresh-green) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.balance-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 400;
}

.balance-divider {
  width: 2rpx;
  height: 70rpx;
  background: linear-gradient(180deg, transparent 0%, var(--brand-primary-30) 50%, transparent 100%);
}

/* ============================================
   签到按钮 - 克制主色发光
   ============================================ */
.sign-in-btn {
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 50%, var(--sky-soft) 100%);
  border-radius: var(--radius-md);
  color: white;
  font-size: 32rpx;
  font-weight: 400;
  box-shadow: 0 8rpx 32rpx var(--brand-primary-35);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.sign-in-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.sign-in-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s;
}

.sign-in-btn:active::after {
  left: 100%;
}

.sign-in-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx var(--brand-primary-30);
}

.sign-in-btn.signed {
  background: var(--bg-glass);
  color: var(--text-tertiary);
  box-shadow: inset 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid var(--border-light);
}

.sign-in-icon {
  font-size: 36rpx;
  position: relative;
  z-index: 1;
}

/* ============================================
   菜单区域
   ============================================ */
.menu-section {
  margin: 0 32rpx 28rpx;
  position: relative;
  z-index: 1;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--text-tertiary);
  margin-bottom: 18rpx;
  margin-left: 10rpx;
  letter-spacing: 2rpx;
}

.menu-list {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--brand-primary-10);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid var(--border-light);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.menu-item:active {
  background: var(--brand-primary-05);
}

.menu-item:last-child {
  border-bottom: none;
}

/* 菜单图标 - 仅保留线形图标 */
.menu-icon-wrapper {
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  align-self: center;
  position: relative;
  overflow: hidden;
  background: transparent;
  box-shadow: none;
  line-height: 0;
  transform: translateY(2rpx);
}

.menu-icon-wrapper::before {
  display: none;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
  min-height: 76rpx;
  min-width: 0;
}

.menu-text {
  font-size: 32rpx;
  line-height: 40rpx;
  color: var(--text-primary);
  font-weight: 400;
}

.menu-desc {
  font-size: 24rpx;
  line-height: 32rpx;
  color: var(--text-light);
}

.menu-item.no-desc .menu-content {
  flex-direction: row;
  align-items: center;
  justify-content: left;
  gap: 0;
}

.menu-item.no-desc .menu-text {
  line-height: 40rpx;
}

.menu-arrow {
  font-size: 38rpx;
  color: var(--text-light);
  margin-left: 8rpx;
  align-self: center;
  transition: transform 0.3s ease;
}

.menu-item:active .menu-arrow {
  transform: translateX(6rpx);
}

/* ============================================
   退出登录
   ============================================ */
.logout-section {
  margin: 20rpx 32rpx;
  padding: 28rpx 0;
  background: var(--danger-color);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 14rpx rgba(214, 69, 69, 0.18);
}

.logout-section:active {
  background: #c63d3d;
  transform: scale(0.98);
}

/* 一键登录按钮样式 */
.logout-section.login-btn {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  box-shadow: var(--shadow-sky);
}

.logout-section.login-btn:active {
  background: linear-gradient(135deg, var(--sky-light) 0%, var(--sky-primary) 100%);
  transform: scale(0.98);
}

.logout-text {
  font-size: 30rpx;
  color: var(--text-white);
  font-weight: 400;
}

.logout-section.login-btn .logout-text {
  color: var(--text-white);
  font-weight: 400;
}

.delete-account-section {
  margin: 20rpx 32rpx;
  padding: 24rpx 0;
  background: transparent;
  border: 2rpx solid rgba(214, 69, 69, 0.35);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.delete-account-section:active {
  background: rgba(214, 69, 69, 0.08);
  transform: scale(0.98);
}

.delete-account-text {
  font-size: 28rpx;
  color: var(--danger-color);
  font-weight: 400;
}

/* ============================================
   底部信息
   ============================================ */
.container .footer {
  text-align: center;
  padding: 48rpx 32rpx;
  font-size: 24rpx;
  color: var(--text-light);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  position: relative;
  z-index: 1;
  background: transparent;
  border-color: transparent;
  box-shadow: none;
}

/* ============================================
   弹窗 - 毛玻璃效果
   ============================================ */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 80, 0.5);
  backdrop-filter: blur(8rpx);
}

.modal-content {
  position: relative;
  width: 620rpx;
  background: rgba(255, 255, 255, 0.98);
  border-radius: var(--radius-xl);
  overflow: hidden;
  padding: 52rpx;
  box-shadow: var(--shadow-lg);
  border: 2rpx solid var(--brand-primary-10);
  transform: translateY(20rpx) scale(0.95);
  transition: all 0.3s ease;
}

.modal.show .modal-content {
  transform: translateY(0) scale(1);
}

.modal-close {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: var(--text-light);
  background: var(--brand-primary-10);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.modal-close:active {
  background: var(--brand-primary-20);
  transform: scale(0.9);
}

.modal-title {
  font-size: 40rpx;
  font-weight: 400;
  text-align: center;
  margin-bottom: 36rpx;
  color: var(--text-primary);
}

.asset-forfeit-content {
  padding: 44rpx 42rpx 36rpx;
}

.asset-forfeit-title {
  margin-bottom: 22rpx;
}

.asset-forfeit-desc {
  padding: 24rpx 26rpx;
  margin-bottom: 24rpx;
  border-radius: var(--radius-md);
  background: rgba(214, 69, 69, 0.07);
  border: 1rpx solid rgba(214, 69, 69, 0.16);
  color: var(--text-secondary);
  font-size: 27rpx;
  line-height: 42rpx;
}

.asset-forfeit-input {
  height: 88rpx;
  padding: 0 24rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
  border-radius: var(--radius-sm);
  background: rgba(248, 251, 253, 0.96);
  border: 2rpx solid var(--border-light);
  color: var(--text-primary);
  font-size: 30rpx;
}

.asset-forfeit-placeholder {
  color: var(--text-light);
  font-size: 28rpx;
}

.asset-forfeit-actions {
  display: flex;
  gap: 18rpx;
}

.asset-forfeit-btn {
  flex: 1;
  height: 82rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 400;
}

.asset-forfeit-btn.secondary {
  background: rgba(248, 251, 253, 0.98);
  color: var(--text-secondary);
  border: 1rpx solid var(--border-light);
}

.asset-forfeit-btn.danger {
  background: var(--danger-color);
  color: var(--text-white);
  box-shadow: 0 4rpx 14rpx rgba(214, 69, 69, 0.18);
}

.asset-forfeit-btn:active {
  transform: scale(0.98);
}

.invite-content {
  text-align: center;
  padding: 24rpx 0 44rpx;
}

.invite-icon {
  width: 130rpx;
  height: 130rpx;
  margin: 0 auto 28rpx;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 50%, var(--sky-soft) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx var(--brand-primary-35);
  position: relative;
  overflow: hidden;
  animation: float 3s ease-in-out infinite;
}

.invite-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.invite-text {
  font-size: 34rpx;
  color: var(--text-primary);
  font-weight: 400;
  margin-bottom: 14rpx;
}

.invite-tip {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.invite-btn {
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 50%, var(--sky-soft) 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 400;
  padding: 32rpx;
  border-radius: var(--radius-md);
  border: none;
  box-shadow: 0 8rpx 32rpx var(--brand-primary-35);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.about-sheet-body {
  padding: 8rpx 0 16rpx;
}

.about-hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 30rpx;
  margin-bottom: 26rpx;
  background: linear-gradient(135deg, var(--brand-primary-08) 0%, rgba(255, 255, 255, 0.94) 52%, var(--fresh-mint-08) 100%);
  border: 1rpx solid var(--brand-primary-12);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.about-logo {
  width: 92rpx;
  height: 92rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: linear-gradient(135deg, var(--sky-primary) 0%, var(--sky-light) 100%);
  box-shadow: 0 10rpx 28rpx var(--brand-primary-30);
}

.about-hero-content {
  flex: 1;
  min-width: 0;
}

.about-name {
  display: block;
  margin-bottom: 8rpx;
  font-size: 34rpx;
  line-height: 42rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.about-summary {
  display: block;
  font-size: 26rpx;
  line-height: 40rpx;
  font-weight: 400;
  color: var(--text-secondary);
}

.about-scenarios {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.about-scenario {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(248, 251, 253, 0.96);
  border: 1rpx solid rgba(216, 226, 235, 0.78);
  border-radius: var(--radius-md);
}

.scenario-icon {
  width: 62rpx;
  height: 62rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
}

.scenario-icon.weather {
  background: var(--brand-primary-08);
}

.scenario-icon.traffic {
  background: var(--vitality-orange-10);
}

.scenario-icon.shop {
  background: var(--fresh-mint-10);
}

.scenario-copy {
  flex: 1;
  min-width: 0;
}

.scenario-title {
  display: block;
  margin-bottom: 6rpx;
  font-size: 28rpx;
  line-height: 36rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.scenario-desc {
  display: block;
  font-size: 25rpx;
  line-height: 36rpx;
  color: var(--text-tertiary);
}

.about-trust-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--brand-primary-08);
  border: 1rpx solid var(--brand-primary-12);
  color: var(--text-secondary);
  font-size: 25rpx;
  line-height: 38rpx;
  font-weight: 400;
}

.credit-rules-body {
  padding: 8rpx 0 18rpx;
}

.credit-rule-card {
  padding: 30rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, var(--fresh-mint-10) 0%, rgba(255, 255, 255, 0.96) 54%, var(--brand-primary-08) 100%);
  border: 1rpx solid var(--fresh-mint-10);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.credit-rule-main {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.credit-rule-score {
  font-size: 58rpx;
  line-height: 68rpx;
  font-weight: 500;
  color: #119B72;
}

.credit-rule-unit {
  margin-left: 6rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.credit-rule-summary {
  display: block;
  font-size: 26rpx;
  line-height: 40rpx;
  color: var(--text-secondary);
}

.credit-rule-list {
  overflow: hidden;
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.96);
}

.credit-rule-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 26rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.credit-rule-row:last-child {
  border-bottom: none;
}

.credit-rule-title {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  line-height: 38rpx;
  color: var(--text-primary);
}

.credit-rule-value {
  flex-shrink: 0;
  font-size: 26rpx;
  line-height: 34rpx;
  font-weight: 500;
}

.credit-rule-value.positive {
  color: #119B72;
}

.credit-rule-value.negative {
  color: var(--danger-color);
}

.credit-rule-value.neutral {
  color: var(--text-tertiary);
}

.credit-rule-tip {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--brand-primary-08);
  border: 1rpx solid var(--brand-primary-12);
  color: var(--text-secondary);
  font-size: 25rpx;
  line-height: 38rpx;
}

.invite-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.invite-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s;
}

.invite-btn:active::after {
  left: 100%;
}

.invite-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx var(--brand-primary-30);
}

.invite-btn::after {
  border: none;
}

/* ============================================
   动画
   ============================================ */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}
@import "../../styles/wdd-polish.wxss";
