/* ============================================
   问当地 - 个人中心 - 梦幻渐变风格
   风格：柔和粉彩 / 毛玻璃 / 精致优雅
   ============================================ */

/* CSS变量 - 设计令牌 */
:root {
  /* 主色调 - 梦幻渐变 */
  --gradient-dream: linear-gradient(135deg, #FFE6FA 0%, #E6F4FF 50%, #F0FFFA 100%);
  --gradient-primary: linear-gradient(135deg, #8093F1 0%, #B388EB 100%);
  --gradient-accent: linear-gradient(135deg, #FF9A9E 0%, #FAD0C4 100%);
  --gradient-success: linear-gradient(135deg, #A1C4FD 0%, #C2E9FB 100%);

  /* 文字颜色 */
  --text-primary: #2A2D43;
  --text-secondary: #6C6F8B;
  --text-tertiary: #A0A3BD;
  --text-light: #FFFFFF;

  /* 阴影 */
  --shadow-soft: 0 4rpx 20rpx rgba(42, 45, 67, 0.08);
  --shadow-medium: 0 8rpx 32rpx rgba(42, 45, 67, 0.12);
  --shadow-glow: 0 0 40rpx rgba(179, 136, 235, 0.3);

  /* 圆角 */
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  --radius-full: 9999rpx;

  /* 间距 */
  --space-xs: 12rpx;
  --space-sm: 20rpx;
  --space-md: 32rpx;
  --space-lg: 48rpx;
}

/* 页面容器 - 梦幻渐变背景 */
.container {
  min-height: 100vh;
  background: var(--gradient-dream);
  padding-bottom: 40rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰元素 */
.container::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -150rpx;
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, rgba(179, 136, 235, 0.1) 0%, rgba(128, 147, 241, 0.1) 100%);
  border-radius: 50%;
  z-index: 0;
}

.container::after {
  content: '';
  position: absolute;
  bottom: 300rpx;
  left: -200rpx;
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, rgba(255, 154, 158, 0.08) 0%, rgba(250, 208, 196, 0.08) 100%);
  border-radius: 50%;
  z-index: 0;
}

/* 用户信息卡片 - 毛玻璃效果 */
.user-card {
  margin: 32rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(40rpx);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-soft);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  position: relative;
  z-index: 1;
  overflow: hidden;
}

.user-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #8093F1 0%, #B388EB 50%, #FF9A9E 100%);
}

.user-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

/* 头像包装器 - 发光效果 */
.avatar-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-full);
  overflow: hidden;
  border: 4rpx solid white;
  box-shadow: 0 4rpx 20rpx rgba(128, 147, 241, 0.3);
  background: var(--gradient-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.avatar-wrapper::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  background: var(--gradient-primary);
  border-radius: var(--radius-full);
  z-index: -1;
  opacity: 0.4;
  filter: blur(12rpx);
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-default {
  font-size: 48rpx;
  color: white;
  font-weight: 700;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nickname {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.user-id {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

/* 积分展示 - 精致卡片 */
.points-section {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 28rpx 0;
  background: rgba(248, 249, 255, 0.6);
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  position: relative;
  overflow: hidden;
}

.points-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(135deg, rgba(128, 147, 241, 0.03) 0%, rgba(179, 136, 235, 0.03) 100%);
}

.points-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  position: relative;
  z-index: 1;
}

.points-value {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

.points-value.available {
  background: linear-gradient(135deg, #8093F1 0%, #B388EB 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.points-value.frozen {
  background: linear-gradient(135deg, #FF9A9E 0%, #FAD0C4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.points-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.points-divider {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(128, 147, 241, 0.3) 50%, transparent 100%);
}

/* 签到按钮 - 渐变发光 */
.sign-in-btn {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx;
  background: var(--gradient-primary);
  border-radius: var(--radius-md);
  color: white;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 32rpx rgba(128, 147, 241, 0.4);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.sign-in-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.sign-in-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s;
}

.sign-in-btn:active::after {
  left: 100%;
}

.sign-in-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(128, 147, 241, 0.3);
}

.sign-in-btn.signed {
  background: linear-gradient(135deg, #A0A3BD 0%, #C5C7D9 100%);
  color: white;
  box-shadow: 0 2rpx 12rpx rgba(160, 163, 189, 0.3);
}

.sign-in-icon {
  font-size: 32rpx;
  position: relative;
  z-index: 1;
}

/* 菜单区域 */
.menu-section {
  margin: 0 32rpx 24rpx;
  position: relative;
  z-index: 1;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  margin-left: 8rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.menu-list {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-soft);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid rgba(128, 147, 241, 0.08);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.menu-item:active {
  background: rgba(128, 147, 241, 0.05);
}

.menu-item:last-child {
  border-bottom: none;
}

/* 菜单图标 - 多彩渐变 */
.menu-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.menu-icon-wrapper::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

/* 不同菜单项的图标颜色 */
.menu-item:nth-child(1) .menu-icon-wrapper {
  background: linear-gradient(135deg, #8093F1 0%, #B388EB 100%);
}

.menu-item:nth-child(2) .menu-icon-wrapper {
  background: linear-gradient(135deg, #FF9A9E 0%, #FAD0C4 100%);
}

.menu-item:nth-child(3) .menu-icon-wrapper {
  background: linear-gradient(135deg, #A1C4FD 0%, #C2E9FB 100%);
}

.menu-item:nth-child(4) .menu-icon-wrapper {
  background: linear-gradient(135deg, #FDCB6E 0%, #E17055 100%);
}

.menu-icon {
  font-size: 36rpx;
  color: white;
  position: relative;
  z-index: 1;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.menu-text {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.menu-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.menu-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  margin-left: 8rpx;
  transition: transform 0.3s ease;
}

.menu-item:active .menu-arrow {
  transform: translateX(4rpx);
}

/* 底部信息 */
.footer {
  text-align: center;
  padding: 48rpx 32rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  position: relative;
  z-index: 1;
}

/* 弹窗 - 毛玻璃效果 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(42, 45, 67, 0.6);
  backdrop-filter: blur(8rpx);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(40rpx);
  border-radius: var(--radius-xl);
  overflow: hidden;
  padding: 48rpx;
  box-shadow: var(--shadow-medium);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transform: translateY(20rpx) scale(0.95);
  transition: all 0.3s ease;
}

.modal.show .modal-content {
  transform: translateY(0) scale(1);
}

.modal-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-tertiary);
  background: rgba(128, 147, 241, 0.1);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.modal-close:active {
  background: rgba(128, 147, 241, 0.2);
  transform: scale(0.9);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
  margin-bottom: 32rpx;
  color: var(--text-primary);
  background: linear-gradient(135deg, #2A2D43 0%, #6C6F8B 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.invite-content {
  text-align: center;
  padding: 20rpx 0 40rpx;
}

.invite-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  background: var(--gradient-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  box-shadow: 0 8rpx 32rpx rgba(128, 147, 241, 0.3);
  position: relative;
  overflow: hidden;
}

.invite-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.invite-text {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 700;
  margin-bottom: 12rpx;
}

.invite-tip {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.invite-btn {
  background: var(--gradient-primary);
  color: white;
  font-size: 30rpx;
  font-weight: 700;
  padding: 28rpx;
  border-radius: var(--radius-md);
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(128, 147, 241, 0.4);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.invite-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.invite-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s;
}

.invite-btn:active::after {
  left: 100%;
}

.invite-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(128, 147, 241, 0.3);
}

.invite-btn::after {
  border: none;
}
