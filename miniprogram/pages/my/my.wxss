/* ============================================
   问当地 - 个人中心 - 天蓝色青春活力风格
   ============================================ */

/* 页面容器 - 天蓝渐变背景 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F8FF 0%, #E6F3FF 30%, #EDF7FF 70%, #F5FAFF 100%);
  padding-bottom: 40rpx;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  width: 100%;
}

/* 背景装饰元素 - 气泡效果 */
.container::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(93, 184, 230, 0.12) 0%, transparent 70%);
  border-radius: 50%;
  z-index: 0;
}

.container::after {
  content: '';
  position: absolute;
  bottom: 200rpx;
  left: -150rpx;
  width: 350rpx;
  height: 350rpx;
  background: radial-gradient(circle, rgba(255, 140, 105, 0.08) 0%, transparent 70%);
  border-radius: 50%;
  z-index: 0;
}

/* ============================================
   用户信息卡片 - 毛玻璃效果
   ============================================ */
.user-card {
  margin: 32rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(40rpx);
  border-radius: 44rpx;
  padding: 44rpx;
  box-shadow: 0 6rpx 32rpx rgba(93, 184, 230, 0.12);
  border: 2rpx solid rgba(93, 184, 230, 0.1);
  position: relative;
  z-index: 1;
  overflow: hidden;
}

/* 顶部装饰条 */
.user-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #5DB8E6 0%, #7EC8E8 50%, #A8D8F0 100%);
}

.user-header {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 36rpx;
}

/* 头像包装器 - 天蓝色发光效果 */
.avatar-wrapper {
  width: 130rpx;
  height: 130rpx;
  border-radius: 9999rpx;
  overflow: hidden;
  border: 4rpx solid white;
  box-shadow: 0 6rpx 24rpx rgba(93, 184, 230, 0.35);
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 50%, #A8D8F0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.avatar-wrapper::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  right: -10rpx;
  bottom: -10rpx;
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
  border-radius: 9999rpx;
  z-index: -1;
  opacity: 0.35;
  filter: blur(16rpx);
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-default {
  font-size: 52rpx;
  color: white;
  font-weight: 700;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.nickname {
  font-size: 42rpx;
  font-weight: 800;
  color: #2C3E50;
}

.user-id {
  font-size: 24rpx;
  color: #8FA8B8;
  font-weight: 500;
}

/* ============================================
   积分展示 - 精致卡片
   ============================================ */
.points-section {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 32rpx 0;
  background: rgba(240, 248, 255, 0.7);
  border-radius: 32rpx;
  border: 2rpx solid rgba(93, 184, 230, 0.12);
  position: relative;
  overflow: hidden;
}

.points-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(135deg, rgba(93, 184, 230, 0.05) 0%, rgba(168, 216, 240, 0.03) 100%);
}

.points-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  position: relative;
  z-index: 1;
}

.points-value {
  font-size: 52rpx;
  font-weight: 800;
  color: #2C3E50;
}

.points-value.available {
  background: linear-gradient(135deg, #5DB8E6 0%, #3A9AD2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.points-value.frozen {
  background: linear-gradient(135deg, #FF8C69 0%, #E86A4A 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.points-label {
  font-size: 24rpx;
  color: #6B8BA4;
  font-weight: 500;
}

.points-divider {
  width: 2rpx;
  height: 70rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(93, 184, 230, 0.3) 50%, transparent 100%);
}

/* ============================================
   签到按钮 - 天蓝色渐变发光
   ============================================ */
.sign-in-btn {
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 50%, #A8D8F0 100%);
  border-radius: 32rpx;
  color: white;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 32rpx rgba(93, 184, 230, 0.4);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.sign-in-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.sign-in-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s;
}

.sign-in-btn:active::after {
  left: 100%;
}

.sign-in-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(93, 184, 230, 0.3);
}

.sign-in-btn.signed {
  background: linear-gradient(135deg, #D4EDF7 0%, #E8F4F8 100%);
  color: #6B8BA4;
  box-shadow: inset 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.sign-in-icon {
  font-size: 36rpx;
  position: relative;
  z-index: 1;
}

/* ============================================
   菜单区域
   ============================================ */
.menu-section {
  margin: 0 32rpx 28rpx;
  position: relative;
  z-index: 1;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #6B8BA4;
  margin-bottom: 18rpx;
  margin-left: 10rpx;
  letter-spacing: 2rpx;
}

.menu-list {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(93, 184, 230, 0.1);
  border: 2rpx solid rgba(93, 184, 230, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid rgba(93, 184, 230, 0.06);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.menu-item:active {
  background: rgba(93, 184, 230, 0.05);
}

.menu-item:last-child {
  border-bottom: none;
}

/* 菜单图标 - 多彩渐变 */
.menu-icon-wrapper {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.menu-icon-wrapper::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

/* 不同菜单项的图标颜色 - 青春活力配色 */
.menu-item:nth-child(1) .menu-icon-wrapper {
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 100%);
}

.menu-item:nth-child(2) .menu-icon-wrapper {
  background: linear-gradient(135deg, #FF8C69 0%, #FF9A8B 100%);
}

.menu-item:nth-child(3) .menu-icon-wrapper {
  background: linear-gradient(135deg, #6DD5B0 0%, #88D8A3 100%);
}

.menu-item:nth-child(4) .menu-icon-wrapper {
  background: linear-gradient(135deg, #FFD166 0%, #FFE08C 100%);
}

.menu-icon {
  font-size: 38rpx;
  color: white;
  position: relative;
  z-index: 1;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.menu-text {
  font-size: 32rpx;
  color: #2C3E50;
  font-weight: 600;
}

.menu-desc {
  font-size: 24rpx;
  color: #8FA8B8;
}

.menu-arrow {
  font-size: 38rpx;
  color: #A8C4D4;
  margin-left: 8rpx;
  transition: transform 0.3s ease;
}

.menu-item:active .menu-arrow {
  transform: translateX(6rpx);
}

/* ============================================
   退出登录
   ============================================ */
.logout-section {
  margin: 20rpx 32rpx;
  padding: 28rpx 0;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.logout-section:active {
  background: rgba(255, 77, 79, 0.08);
  transform: scale(0.98);
}

.logout-text {
  font-size: 30rpx;
  color: #ff4d4f;
  font-weight: 500;
}

/* ============================================
   底部信息
   ============================================ */
.footer {
  text-align: center;
  padding: 48rpx 32rpx;
  font-size: 24rpx;
  color: #8FA8B8;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  position: relative;
  z-index: 1;
}

/* ============================================
   弹窗 - 毛玻璃效果
   ============================================ */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 62, 80, 0.5);
  backdrop-filter: blur(8rpx);
}

.modal-content {
  position: relative;
  width: 620rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(40rpx);
  border-radius: 44rpx;
  overflow: hidden;
  padding: 52rpx;
  box-shadow: 0 8rpx 40rpx rgba(93, 184, 230, 0.2);
  border: 2rpx solid rgba(93, 184, 230, 0.1);
  transform: translateY(20rpx) scale(0.95);
  transition: all 0.3s ease;
}

.modal.show .modal-content {
  transform: translateY(0) scale(1);
}

.modal-close {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #A8C4D4;
  background: rgba(93, 184, 230, 0.1);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.modal-close:active {
  background: rgba(93, 184, 230, 0.2);
  transform: scale(0.9);
}

.modal-title {
  font-size: 40rpx;
  font-weight: 800;
  text-align: center;
  margin-bottom: 36rpx;
  color: #2C3E50;
}

.invite-content {
  text-align: center;
  padding: 24rpx 0 44rpx;
}

.invite-icon {
  width: 130rpx;
  height: 130rpx;
  margin: 0 auto 28rpx;
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 50%, #A8D8F0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  box-shadow: 0 8rpx 32rpx rgba(93, 184, 230, 0.35);
  position: relative;
  overflow: hidden;
  animation: float 3s ease-in-out infinite;
}

.invite-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.invite-text {
  font-size: 34rpx;
  color: #2C3E50;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.invite-tip {
  font-size: 26rpx;
  color: #6B8BA4;
}

.invite-btn {
  background: linear-gradient(135deg, #5DB8E6 0%, #7EC8E8 50%, #A8D8F0 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 700;
  padding: 32rpx;
  border-radius: 32rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(93, 184, 230, 0.4);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.invite-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
}

.invite-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s;
}

.invite-btn:active::after {
  left: 100%;
}

.invite-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(93, 184, 230, 0.3);
}

.invite-btn::after {
  border: none;
}

/* ============================================
   动画
   ============================================ */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}
