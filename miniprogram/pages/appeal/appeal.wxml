<view class="container">
  <!-- 补充材料模式：显示任务摘要 -->
  <block wx:if="{{mode === 'supplement' && taskSummary}}">
    <view class="opponent-card">
      <view class="opponent-title">任务摘要</view>
      <view class="opponent-row">
        <text class="opponent-label">任务类型</text>
        <text class="opponent-value">{{taskSummary.typeName || taskSummary.type || '未知'}}</text>
      </view>
      <view class="opponent-row">
        <text class="opponent-label">任务悬赏</text>
        <text class="opponent-value">¥{{taskSummary.rewardAmount || 0}}</text>
      </view>
      <button class="detail-btn" bindtap="goToTaskDetail">查看任务详情 ›</button>
      <view class="countdown-wrap">
        <text class="countdown-label">剩余时间：</text>
        <text class="countdown-value {{!canSupplement ? 'timeout' : ''}}">{{supplementCountdown}}</text>
      </view>
    </view>
  </block>

  <!-- 表单视图 -->
  <block wx:if="{{!isSubmitted}}">
    <!-- 申诉类型（仅发起模式可见） -->
    <block wx:if="{{mode !== 'supplement'}}">
    <view class="form-group">
      <text class="form-label">申诉类型<text class="required">*</text></text>
      <picker bindchange="onTypeChange" range="{{appealTypes}}">
        <view class="picker-wrap">
          <text class="picker-text {{selectedTypeValue ? '' : 'placeholder'}}">{{selectedTypeLabel || '请选择申诉类型'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
    </block>

    <!-- 申诉理由 / 情况说明 -->
    <view class="form-group">
      <text class="form-label">{{mode === 'supplement' ? '情况说明' : '申诉理由'}}<text class="required">*</text></text>
      <view class="textarea-wrap">
        <textarea
          placeholder="{{mode === 'supplement' ? '请详细说明情况，5~300字' : '请详细描述申诉理由，5~300字'}}"
          maxlength="300"
          bindinput="onReasonInput"
          value="{{reason}}"
        />
      </view>
      <view class="word-count {{wordCount > 300 ? 'error' : ''}}">{{wordCount}}/300</view>
    </view>

    <!-- 证据截图 -->
    <view class="form-group">
      <text class="form-label">证据截图<text class="required">*</text></text>
      <view class="image-upload">
        <view wx:for="{{images}}" wx:key="index" class="image-item">
          <image src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
          <view class="remove-btn" catchtap="removeImage" data-index="{{index}}">×</view>
        </view>
        <view wx:if="{{images.length < 3}}" class="upload-btn" bindtap="chooseImage">
          <text class="upload-icon">+</text>
          <text class="upload-text">上传图片</text>
        </view>
      </view>
      <text class="upload-tip">最多上传3张，至少上传1张</text>
    </view>

    <!-- 提交按钮 -->
    <button class="submit-btn {{isSubmitting || (mode === 'supplement' && !canSupplement) ? 'disabled' : ''}}" bindtap="showConfirm" disabled="{{isSubmitting || (mode === 'supplement' && !canSupplement)}}">
      {{isSubmitting ? '提交中...' : (mode === 'supplement' ? '提交补充材料' : '提交申诉')}}
    </button>
  </block>

  <!-- 提交成功视图 -->
  <block wx:else>
    <view class="success-wrap">
      <view class="success-icon">✓</view>
      <view class="success-title">申诉提交成功</view>
      <view class="success-desc">平台将依据您提交的证据进行仲裁处理，请耐心等待</view>

      <button wx:if="{{canCancel}}" class="cancel-btn" bindtap="cancelAppeal">撤销申诉</button>
      <button class="back-btn" bindtap="goBack">返回</button>
    </view>
  </block>

  <!-- 确认弹窗 -->
  <view class="modal {{showConfirmModal ? 'show' : ''}}" wx:if="{{showConfirmModal}}">
    <view class="modal-mask" bindtap="hideConfirm"></view>
    <view class="modal-content">
      <view class="modal-title">确认提交申诉</view>
      <view class="modal-body">
        提交申诉后，任务将进入客服评审状态，将关闭双方聊天通道，平台将依据证据进行仲裁处理，请如实填写理由并上传证据。您可在客服处理前随时撤销本次申诉，撤销后恢复正常任务流程。
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="hideConfirm">取消</button>
        <button class="modal-btn confirm" bindtap="submitAppeal">确认提交</button>
      </view>
    </view>
  </view>
</view>
